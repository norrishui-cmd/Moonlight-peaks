---
import type { TopicItem } from '../data/topic';

interface Props { item: TopicItem; base: string; }
const { item, base } = Astro.props;
---
<a class="thub-card" href={`${base}/${item.slug}`}>
  {item.image && <img class="thub-img" src={item.image} alt={`${item.title} — Moonlight Peaks`} width="1200" height="630" loading="lazy" />}
  <div class="thub-body">
    <span class="thub-tag">{item.tag}{item.status && item.status !== 'confirmed' ? ` · ${item.status}` : ''}</span>
    <h2 class="thub-title">{item.title}</h2>
    <p class="thub-dek">{item.dek}</p>
    <span class="thub-more">Explore →</span>
  </div>
</a>

<style>
  .thub-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
    border: 1px solid var(--line);
    border-radius: 16px;
    overflow: hidden;
    background: var(--surface);
    color: inherit;
    text-decoration: none;
    transition: border-color .15s ease, transform .15s ease;
  }
  .thub-card:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); transform: translateY(-2px); }
  .thub-img { width: 100%; height: auto; max-width: 100%; display: block; border-bottom: 1px solid var(--line); }
  .thub-body { padding: 14px 16px 16px; min-width: 0; }
  .thub-tag { font-family: var(--mono); font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--candle); }
  .thub-title { font-family: var(--display); font-weight: 600; font-size: 1.22rem; margin: 6px 0 4px; overflow-wrap: break-word; }
  .thub-dek { color: #ded3e6; font-size: 0.92rem; margin: 0 0 10px; overflow-wrap: break-word; }
  .thub-more { font-family: var(--mono); font-size: 0.74rem; color: var(--candle); }
</style>

