---
import type { Locale } from '../i18n/nav';
import { charTranslations } from '../i18n/characters-data';

interface Props { lang: Locale; path: string; }
const { lang, path } = Astro.props;

const labels: Record<Locale, string> = { en: 'English', es: 'Español', ja: '日本語', zh: '中文' };
const shortLabels: Record<Locale, string> = { en: 'EN', es: 'ES', ja: 'JA', zh: 'ZH' };
// Only pages in this set exist in translated form so far. Falls back to the English
// version of the current page for any locale/page combo not yet translated.
const translatedPaths = new Set<string>(['/', '/beginner-guide', '/release-date', '/faq', '/characters', '/farming', '/magic', '/platforms', '/romance', '/environment', '/items', '/demo', '/cheats', '/character-creator', '/shapeshifting', '/languages']);
const translatedCharSlugs = new Set<string>(Object.keys(charTranslations.es)); // same slugs across es/ja/zh
const bare = path.replace(/^\/(es|ja|zh)(\/|$)/, '/');
const charMatch = bare.match(/^\/characters\/([a-z0-9-]+)$/);
const isTranslated = translatedPaths.has(bare) || (charMatch !== null && translatedCharSlugs.has(charMatch[1]));

const hrefFor = (target: Locale): string => {
  if (!isTranslated) return target === 'en' ? bare : `/${target}`; // send untranslated pages to that language's homepage instead of a 404
  if (target === 'en') return bare;
  return bare === '/' ? `/${target}` : `/${target}${bare}`;
};
const locales: Locale[] = ['en', 'es', 'ja', 'zh'];
---
<details class="nav-dd lang-dd">
  <summary aria-label="Change language">
    <span class="lang-globe" aria-hidden="true">🌐</span>
    <span class="lang-current">{shortLabels[lang]}</span>
  </summary>
  <div class="nav-dd-menu lang-dd-menu">
    {locales.map((code) => (
      <a href={hrefFor(code)} aria-current={code === lang ? 'page' : undefined}>{labels[code]}</a>
    ))}
  </div>
</details>

<style>
  .lang-dd > summary { display: inline-flex; align-items: center; gap: 5px; }
  .lang-globe { font-size: 0.95rem; line-height: 1; }
  .lang-current { font-family: var(--mono); font-size: 0.72rem; }
</style>
