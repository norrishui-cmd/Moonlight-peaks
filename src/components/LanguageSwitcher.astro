---
import type { Locale } from '../i18n/nav';
import { isPathTranslated } from '../i18n/translated-paths';

interface Props { lang: Locale; path: string; }
const { lang, path } = Astro.props;

const labels: Record<Locale, string> = { en: 'English', es: 'Español', ja: '日本語', zh: '简体中文', 'zh-hant': '繁體中文', de: 'Deutsch' };
const shortLabels: Record<Locale, string> = { en: 'EN', es: 'ES', ja: 'JA', zh: 'ZH', 'zh-hant': 'ZH-TW', de: 'DE' };
const bare = path.replace(/^\/(es|ja|zh-hant|zh|de)(\/|$)/, '/');

const hrefFor = (target: Locale): string => {
  if (target === 'en') return bare; // English (source) always exists for a translated page's bare path.
  if (!isPathTranslated(target, bare)) return `/${target}`; // no translation for this page — go to that locale's homepage instead of a broken link.
  return bare === '/' ? `/${target}` : `/${target}${bare}`;
};
const locales: Locale[] = ['en', 'es', 'ja', 'zh', 'zh-hant', 'de'];
---
<details class="nav-dd lang-dd">
  <summary aria-label="Change language">
    <span class="lang-globe" aria-hidden="true">🌐</span>
    <span class="lang-current">{shortLabels[lang]}</span>
  </summary>
  <div class="nav-dd-menu lang-dd-menu">
    {locales.map((code) => (
      <a href={hrefFor(code)} aria-current={code === lang ? 'page' : undefined}>{labels[code]}</a>
    ))}
  </div>
</details>

<style>
  .lang-dd > summary { display: inline-flex; align-items: center; gap: 5px; }
  .lang-globe { font-size: 0.95rem; line-height: 1; }
  .lang-current { font-family: var(--mono); font-size: 0.72rem; }
</style>
