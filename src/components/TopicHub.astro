---
import Base from '../layouts/Base.astro';
import { SITE } from '../consts';
import News from './News.astro';
import ThubCard from './ThubCard.astro';
import type { TopicSection, TopicItem } from '../data/topic';
import type { NewsCategory } from '../data/news';

interface Props {
  section: TopicSection; items: TopicItem[]; newsCategory?: NewsCategory; newsTopic?: string; newsHeading?: string;
  faqLinks?: { label: string; href: string }[];
}
const { section, items, newsCategory, newsTopic, newsHeading, faqLinks } = Astro.props;

// Group items by their `tag` field when the section opts in, preserving first-seen tag order
// so the grouping reads naturally rather than alphabetically.
const groups: [string, TopicItem[]][] = [];
if (section.groupByTag) {
  const byTag = new Map<string, TopicItem[]>();
  for (const it of items) {
    if (!byTag.has(it.tag)) byTag.set(it.tag, []);
    byTag.get(it.tag)!.push(it);
  }
  groups.push(...byTag.entries());
}

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: section.label, item: new URL(section.base, SITE.url).href },
  ] },
  // Each list entry is typed as the section's actual schema type (e.g. Place for locations,
  // Thing for a generic fallback) rather than a bare untyped reference, and carries an image
  // when the item has one — both give Google more to work with for list-style rich results.
  { '@context': 'https://schema.org', '@type': 'ItemList', itemListElement: items.map((it, i) => ({
    '@type': 'ListItem', position: i + 1,
    item: {
      '@type': section.schemaType || 'Thing',
      name: it.title,
      url: new URL(`${section.base}/${it.slug}`, SITE.url).href,
      ...(it.image ? { image: new URL(it.image, SITE.url).href } : {}),
      description: it.dek,
    },
  })) },
  ...(section.faq && section.faq.length > 0 ? [{
    '@context': 'https://schema.org', '@type': 'FAQPage',
    mainEntity: section.faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  }] : []),
];
---
<Base
  title={section.title}
  description={section.description}
  path={section.base}
  jsonLd={jsonLd}
  crumbs={[{ label: section.label }]}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Hub · {section.eyebrow}</p>
      <h1 set:html={section.heading}></h1>
      <p class="intro">{section.intro}</p>

      {section.groupByTag && groups.length > 0 && (
        <nav class="thub-jump" aria-label={`${section.label} groups`}>
          {groups.map(([tag]) => <a href={`#group-${tag.toLowerCase().replace(/\s+/g, '-')}`}>{tag}</a>)}
        </nav>
      )}

      {section.groupByTag && groups.length > 0 ? (
        groups.map(([tag, groupItems]) => (
          <section class="thub-group" id={`group-${tag.toLowerCase().replace(/\s+/g, '-')}`}>
            <h2 class="thub-group-title">{tag} <span class="thub-group-count">({groupItems.length})</span></h2>
            <div class="thub-grid">{groupItems.map((it) => <ThubCard item={it} base={section.base} />)}</div>
          </section>
        ))
      ) : (
        <div class="thub-grid">{items.map((it) => <ThubCard item={it} base={section.base} />)}</div>
      )}

      {section.faq && section.faq.length > 0 && (
        <>
          <h2>FAQ</h2>
          <div class="faq">
            {section.faq.map((f) => (
              <details>
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))}
          </div>
        </>
      )}

      {(newsCategory || newsTopic) && (
        <>
          <h2>{newsHeading ?? 'Latest updates'}</h2>
          <News category={newsCategory} topic={newsTopic} limit={5} />
        </>
      )}

      {faqLinks && faqLinks.length > 0 && (
        <div class="callout">
          <strong>Related FAQ:</strong>{' '}
          {faqLinks.map((l, i) => (
            <>{i > 0 ? ' · ' : ''}<a href={l.href}>{l.label}</a></>
          ))}
          {' · '}<a href="/faq">full FAQ hub</a>.
        </div>
      )}
    </div>
  </article>

  <style>
    .thub-jump { display: flex; flex-wrap: wrap; gap: 8px; margin: 18px 0 8px; }
    .thub-jump a { border: 1px solid var(--line); border-radius: 999px; color: var(--mist); background: var(--surface); padding: 7px 14px; text-decoration: none; font-family: var(--mono); font-size: 0.76rem; }
    .thub-jump a:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); color: var(--candle); }
    .thub-group { margin-top: 30px; scroll-margin-top: 90px; }
    .thub-group-title { margin: 0 0 12px; }
    .thub-group-count { color: var(--faint); font-weight: 400; font-size: 0.85em; }
    .thub-grid { display: grid; grid-template-columns: 1fr; gap: 16px; }
    @media (min-width: 640px) { .thub-grid { grid-template-columns: 1fr 1fr; } }
  </style>
</Base>
