---
import Base from '../layouts/Base.astro';
import { GAME, SITE } from '../consts';
import type { SeoPage } from '../data/seoGraph';

interface Props {
  page: SeoPage;
}

const { page } = Astro.props;
const canonical = new URL(page.path, SITE.url).href;
const structuredDataDate = '2026-07-04';
const structuredDataAuthor = {
  '@type': 'Organization',
  name: SITE.brand,
  url: SITE.url,
};
const crumbs = [
  { label: page.hub.replace(' Hub', ''), href: page.hubPath },
  { label: page.h1.replace(/^Moonlight Peaks /, '') },
];

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: page.hub.replace(' Hub', ''), item: new URL(page.hubPath, SITE.url).href },
    { '@type': 'ListItem', position: 3, name: page.h1, item: canonical },
  ],
};

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: page.faqs.map((faq, index) => ({
    '@type': 'Question',
    name: faq.q,
    author: structuredDataAuthor,
    datePublished: structuredDataDate,
    answerCount: 1,
    url: `${canonical}#faq-${index + 1}`,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.a,
      author: structuredDataAuthor,
      datePublished: structuredDataDate,
      upvoteCount: 0,
      url: `${canonical}#answer-${index + 1}`,
    },
  })),
};

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: page.h1,
  description: page.description,
  url: canonical,
  dateModified: '2026-06-30',
  publisher: { '@type': 'Organization', name: SITE.brand },
  about: { '@type': 'VideoGame', name: GAME.title, datePublished: GAME.releaseISO, gamePlatform: GAME.platforms },
  ...(page.sources && page.sources.length > 0 ? { citation: page.sources.map((source) => new URL(source.href, SITE.url).href) } : {}),
};

const howToLd = page.kind === 'guide'
  ? {
      '@context': 'https://schema.org',
      '@type': 'HowTo',
      name: page.h1,
      description: page.description,
      step: page.sections.map((section, index) => ({
        '@type': 'HowToStep',
        position: index + 1,
        name: section.title,
        text: section.body,
      })),
    }
  : null;

const itemListLd = page.kind === 'hub' || page.kind === 'list'
  ? {
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      itemListElement: page.related.map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.label,
        url: new URL(item.href, SITE.url).href,
      })),
    }
  : null;

const jsonLd = [breadcrumbLd, faqLd, articleLd, howToLd, itemListLd].filter(Boolean);
---
<Base title={page.title} description={page.description} path={page.path} jsonLd={jsonLd} crumbs={crumbs}>
  <article class="page seo-page">
    <div class="wrap">
      <p class="eyebrow">{page.hub} / {page.kind}</p>
      <h1>{page.h1}</h1>
      <p class="intro">{page.intro}</p>

      {page.sections.map((section) => (
        <section class="seo-section">
          <h2>{section.title}</h2>
          <p>{section.body}</p>
        </section>
      ))}

      <section class="seo-section">
        <h2>Related guides</h2>
        <div class="seo-links">
          {page.related.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </div>
      </section>

      <section class="seo-section">
        <h2>FAQ</h2>
        {page.faqs.map((faq, index) => (
          <div class="seo-faq" id={`faq-${index + 1}`}>
            <h3>{faq.q}</h3>
            <p id={`answer-${index + 1}`}>{faq.a}</p>
          </div>
        ))}
      </section>

      {page.sources && page.sources.length > 0 && (
        <section class="seo-section">
          <h2>Sources &amp; update policy</h2>
          <p>
            This generated page is based on official or neutral public sources plus verified site data.
            Unconfirmed launch details are marked for later verification instead of being guessed.
          </p>
          <ul class="seo-sources">
            {page.sources.map((source) => (
              <li>
                <a href={source.href} target={source.href.startsWith('http') ? '_blank' : undefined} rel={source.href.startsWith('http') ? 'noopener noreferrer nofollow' : undefined}>{source.label}</a>
                <span>{source.note}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section class="seo-section">
        <h2>Latest news</h2>
        <p>
          Check the <a href="/#latest-news">latest news</a>, <a href="/previews">previews</a>,
          <a href="/release-date">release date</a>, and <a href="/demo">demo guide</a> pages for new
          Moonlight Peaks details as launch coverage expands.
        </p>
      </section>
    </div>
  </article>

  <style>
    .seo-page h2 { margin-top: 24px; }
    .seo-section { margin: 0 0 18px; }
    .seo-links {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
      margin-top: 10px;
    }
    @media (min-width: 640px) {
      .seo-links { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    .seo-links a {
      border: 1px solid var(--line);
      border-radius: 8px;
      color: var(--mist);
      padding: 10px 12px;
      text-decoration: none;
    }
    .seo-links a:hover { border-color: color-mix(in srgb, var(--candle) 55%, var(--line)); }
    .seo-faq {
      border-left: 2px solid var(--candle-dim);
      margin: 12px 0;
      padding-left: 14px;
    }
    .seo-faq h3 {
      color: var(--mist);
      font-family: var(--display);
      font-size: 1.04rem;
      font-weight: 600;
      margin: 0 0 4px;
    }
    .seo-faq p { margin: 0; }
    .seo-sources {
      list-style: none;
      padding: 0;
      margin: 10px 0 0;
      display: grid;
      gap: 10px;
    }
    .seo-sources li {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      padding: 10px 12px;
    }
    .seo-sources a {
      display: block;
      color: var(--candle);
      font-weight: 700;
      text-decoration: none;
    }
    .seo-sources span {
      display: block;
      color: var(--muted);
      font-size: 0.84rem;
      margin-top: 3px;
    }
  </style>
</Base>
