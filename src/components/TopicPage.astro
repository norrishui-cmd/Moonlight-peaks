---
import Base from '../layouts/Base.astro';
import { SITE } from '../consts';
import { isPathTranslated } from '../i18n/translated-paths';
import { relatedLabelsDe, relatedLabelsJa } from '../i18n/related-labels';
import type { TopicSection, TopicItem } from '../data/topic';

interface Props { section: TopicSection; item: TopicItem; prev: TopicItem; next: TopicItem; lang?: 'en' | 'ja' | 'de' | 'es' | 'fr' | 'ko' | 'zh' | 'zh-hant'; basePath?: string; }
const { section, item, prev, next, lang = 'en', basePath } = Astro.props;
const base = basePath ?? section.base;
// Related links in the underlying data are always bare English paths and labels (shared across
// every locale). Localize both here rather than at the data layer, falling back to English when
// no translation exists yet, so we never link to a 404 or show an unexpectedly blank label.
const localizeRelatedHref = (href: string): string => {
  if (lang === 'en' || !href.startsWith('/')) return href;
  return isPathTranslated(lang, href) ? `/${lang}${href}` : href;
};
const relatedLabels = lang === 'de' ? relatedLabelsDe : lang === 'ja' ? relatedLabelsJa : {};
const localizeRelatedLabel = (label: string): string => relatedLabels[label] ?? label;

const ui = {
  en: {
    whatWeKnow: 'What we know', status: 'Status:', related: 'Related:', faq: 'FAQ',
    prev: 'Prev:', next: 'Next:', all: (l: string) => `All ${l.toLowerCase()}`,
    statusLabels: {
      confirmed: 'Developer-confirmed',
      expected: 'Expected - not yet confirmed',
      datamined: 'Datamined - from pre-launch game files, cross-referenced against pre-launch references; verify at launch',
      reported: 'Reported - verify at launch',
    },
    statusNote: 'We keep developer-confirmed facts separate from reported or expected details and never invent data — this page is updated as real post-launch information is verified.',
  },
  ja: {
    whatWeKnow: '判明している情報', status: 'ステータス:', related: '関連ページ:', faq: 'FAQ',
    prev: '前へ:', next: '次へ:', all: (l: string) => `${l}一覧`,
    statusLabels: {
      confirmed: '開発元確認済み',
      expected: '予想 - まだ未確認',
      datamined: 'データマイニング - 発売前のゲームファイルから、発売前資料と照合済み;発売時に検証予定',
      reported: '報告済み - 発売時に検証予定',
    },
    statusNote: '開発元確認済みの事実と、報告済み・予想情報を明確に分けて掲載し、データを創作することはありません——実機での情報が確認され次第、このページを更新します。',
  },
  de: {
    whatWeKnow: 'Was wir wissen', status: 'Status:', related: 'Verwandt:', faq: 'FAQ',
    prev: 'Zurück:', next: 'Weiter:', all: (l: string) => `Alle ${l}`,
    statusLabels: {
      confirmed: 'Vom Entwickler bestätigt',
      expected: 'Erwartet - noch nicht bestätigt',
      datamined: 'Datamined - aus vorab durchgesickerten Spieldateien, mit Vorab-Referenzen abgeglichen; Verifizierung beim Release',
      reported: 'Gemeldet - Verifizierung beim Release',
    },
    statusNote: 'Wir halten vom Entwickler bestätigte Fakten getrennt von gemeldeten oder erwarteten Details und erfinden niemals Daten — diese Seite wird aktualisiert, sobald echte Post-Release-Informationen verifiziert sind.',
  },
  es: {
    whatWeKnow: 'Lo que sabemos', status: 'Estado:', related: 'Relacionado:', faq: 'FAQ',
    prev: 'Anterior:', next: 'Siguiente:', all: (l: string) => `Todo: ${l.toLowerCase()}`,
    statusLabels: {
      confirmed: 'Confirmado por el desarrollador',
      expected: 'Esperado - aún no confirmado',
      datamined: 'Extraído de datos - de archivos del juego previos al lanzamiento, verificado contra referencias previas; confirmar al lanzamiento',
      reported: 'Reportado - confirmar al lanzamiento',
    },
    statusNote: 'Mantenemos los hechos confirmados por el desarrollador separados de los detalles reportados o esperados, y nunca inventamos datos — esta página se actualiza conforme se verifica información real posterior al lanzamiento.',
  },
  fr: {
    whatWeKnow: 'Ce que nous savons', status: 'Statut :', related: 'Lié :', faq: 'FAQ',
    prev: 'Précédent :', next: 'Suivant :', all: (l: string) => `Tout : ${l.toLowerCase()}`,
    statusLabels: {
      confirmed: 'Confirmé par les développeurs',
      expected: 'Attendu - pas encore confirmé',
      datamined: 'Datamining - fichiers de jeu antérieurs à la sortie, recoupés avec des références préalables ; à vérifier à la sortie',
      reported: 'Rapporté - à vérifier à la sortie',
    },
    statusNote: "Nous séparons toujours les faits confirmés par les développeurs des détails rapportés ou attendus, et n'inventons jamais de données — cette page est mise à jour à mesure que de vraies informations post-sortie sont vérifiées.",
  },
  ko: {
    whatWeKnow: '확인된 내용', status: '상태:', related: '관련:', faq: 'FAQ',
    prev: '이전:', next: '다음:', all: (l: string) => `전체 ${l}`,
    statusLabels: {
      confirmed: '개발자 확인됨',
      expected: '예상됨 - 아직 미확인',
      datamined: '데이터마이닝 - 출시 전 게임 파일에서, 사전 자료와 교차 확인됨; 출시 시 검증 예정',
      reported: '제보됨 - 출시 시 검증 예정',
    },
    statusNote: '개발자가 확인한 사실과 제보되거나 예상되는 세부 사항을 항상 구분하며, 데이터를 지어내지 않습니다 — 실제 출시 후 정보가 확인되는 대로 이 페이지를 업데이트합니다.',
  },
  zh: {
    whatWeKnow: '目前已知的信息', status: '状态:', related: '相关:', faq: '常见问题',
    prev: '上一个:', next: '下一个:', all: (l: string) => `全部${l}`,
    statusLabels: {
      confirmed: '开发者已确认',
      expected: '预期 - 尚未确认',
      datamined: '数据挖掘 - 来自发售前的游戏文件,已与发售前资料交叉核对;发售后待验证',
      reported: '据报道 - 发售后待验证',
    },
    statusNote: '我们始终把开发者确认的事实与据报道或预期的细节区分开,绝不编造数据——这个页面会随着真实的发售后信息得到验证而持续更新。',
  },
  'zh-hant': {
    whatWeKnow: '目前已知的資訊', status: '狀態:', related: '相關:', faq: '常見問題',
    prev: '上一個:', next: '下一個:', all: (l: string) => `全部${l}`,
    statusLabels: {
      confirmed: '開發者已確認',
      expected: '預期 - 尚未確認',
      datamined: '資料探勘 - 來自發售前的遊戲檔案,已與發售前資料交叉核對;發售後待驗證',
      reported: '據報導 - 發售後待驗證',
    },
    statusNote: '我們始終把開發者確認的事實與據報導或預期的細節區分開,絕不編造資料——這個頁面會隨著真實的發售後資訊得到驗證而持續更新。',
  },
}[lang];

const url = new URL(`${base}/${item.slug}`, SITE.url).href;
const statusLabel = ui.statusLabels[item.status as keyof typeof ui.statusLabels] ?? ui.statusLabels.reported;

const ld: object[] = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: lang === 'ja' ? 'ホーム' : lang === 'de' ? 'Startseite' : lang === 'fr' ? 'Accueil' : lang === 'ko' ? '홈' : lang === 'es' ? 'Inicio' : lang === 'zh' ? '首页' : lang === 'zh-hant' ? '首頁' : 'Home', item: lang === 'en' ? SITE.url : `${SITE.url}/${lang}` },
    { '@type': 'ListItem', position: 2, name: section.label, item: new URL(base, SITE.url).href },
    { '@type': 'ListItem', position: 3, name: item.title, item: url },
  ] },
  { '@context': 'https://schema.org', '@type': section.schemaType, name: item.title, description: item.dek,
    ...(item.image ? { image: new URL(item.image, SITE.url).href } : {}) },
];
if (item.faq && item.faq.length > 0) {
  ld.push({ '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: item.faq.map((f) => ({
    '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a },
  })) });
}
---
<Base
  title={item.seoTitle ?? (item.title.includes('Moonlight Peaks') ? `${item.title} - ${section.label}` : `${item.title} - Moonlight Peaks ${section.label}`)}
  description={item.seoDescription ?? item.dek}
  path={`${base}/${item.slug}`}
  jsonLd={ld}
  ogImage={item.image}
  crumbs={[{ label: section.label, href: base }, { label: item.title }]}
  lang={lang}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">{section.eyebrow} - {item.tag}</p>
      {item.image && <img class="tp-hero" src={item.image} alt={`${item.title} - Moonlight Peaks`} width="1200" height="630" />}
      <h1>{item.title}</h1>
      <p class="intro">{item.dek}</p>

      {item.sections && item.sections.length > 0 ? (
        item.sections.map((s) => (
          <>
            <h2>{s.title}</h2>
            <p>{s.body}</p>
          </>
        ))
      ) : (
        <>
          <h2>{ui.whatWeKnow}</h2>
          {item.body.map((p) => (<p>{p}</p>))}
        </>
      )}

      <div class="callout">
        <strong>{ui.status}</strong> {statusLabel}. {ui.statusNote}
      </div>

      {item.faq && item.faq.length > 0 && (
        <>
          <h2>{ui.faq}</h2>
          {item.faq.map((f) => (<div class="tp-faq"><p class="tp-q">{f.q}</p><p class="tp-a">{f.a}</p></div>))}
        </>
      )}

      {item.related && item.related.length > 0 && (
        <div class="callout">
          <strong>{ui.related}</strong>{' '}
          {item.related.map((r, i) => (<>{i > 0 ? ' - ' : ''}<a href={localizeRelatedHref(r.href)}>{localizeRelatedLabel(r.label)}</a></>))}
        </div>
      )}

      <nav class="prevnext" aria-label={`${section.label} navigation`}>
        <a href={`${base}/${prev.slug}`}>{ui.prev} {prev.title}</a>
        <a href={base}>{ui.all(section.label)}</a>
        <a href={`${base}/${next.slug}`}>{ui.next} {next.title}</a>
      </nav>
    </div>
  </article>

  <style>
    .tp-hero { width: 100%; height: auto; display: block; border: 1px solid var(--line); border-radius: 14px; margin: 4px 0 14px; }
    .tp-faq { border-left: 2px solid var(--candle-dim); padding: 2px 0 2px 14px; margin: 0 0 12px; }
    .tp-q { font-family: var(--display); font-weight: 600; color: var(--mist); margin: 0 0 4px; }
    .tp-a { color: #ded3e6; margin: 0; }
    .prevnext { display: flex; justify-content: space-between; gap: 10px; margin: 18px 0 0; font-family: var(--mono); font-size: 0.8rem; }
    .prevnext a { color: var(--candle); }
  </style>
</Base>


