---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const settingsRows = [
  ['PC', '확인된 접근성/그래픽 옵션: VSync 스위치, 컨트롤러 진동 스위치, 화면 상호작용 라벨, 텍스트 애니메이션 스위치, 키 재배정, 프레임레이트 제한, 렌더 스케일링. 커뮤니티 제보: 오전 6시라는 엄격한 일출 마감 시간을 고려하면 생각보다 중요한 12시간/24시간 표시 선택도 가능합니다. 실제 제보된 특이점: 그래픽 설정(해상도 포함)이 클라우드 저장에 저장되므로 Steam Deck과 데스크톱 모니터를 오갈 때마다 다시 조정해야 합니다.'],
  ['Mac', 'Windows와 동일한 Steam 빌드로 실행됩니다. 특정 Mac 하드웨어에 대한 현재 Steam 시스템 요구 사항을 확인하세요.'],
  ['Steam Deck', 'ProtonDB에서 Gold 등급으로 Steam Deck 확인됨. 한 심층 리뷰는 무제한 TDP에서 60FPS 유지가 어려울 수 있다고 보고했으며, 더 부드럽고 배터리 친화적인 경험을 위해 새로고침 빈도를 50Hz로 제한할 것을 권장합니다.'],
  ['Nintendo Switch / Switch 2', '처음부터 완전한 컨트롤러 지원. 리뷰어들은 Switch 2 버전이 휴대 모드에서 매우 잘 작동한다고 평가했습니다. 에디션별 차이는 저희 Switch 가이드를 참고하세요.'],
  ['카메라 & UI 편의성(모든 플랫폼)', '플레이어가 제보한 실제 특이점: 기본 카메라가 상당히 가깝게/확대되어 있어, 큰 모니터를 사용하는 일부 PC 플레이어는 이를 불편하게(멀미와 유사하게) 느꼈습니다. 같은 확대 수준이 작은 화면에서는 자연스럽게 보이는 Steam Deck이나 Switch와는 대조적입니다.'],
];

const testingSteps = [
  '먼저 접근성 필요 사항을 확인하세요: 확인된 옵션은 진동, 상호작용 라벨, 텍스트 애니메이션, 키 재배정입니다 — 색맹 모드는 확인되지 않았습니다.',
  '무제한 TDP에서 프레임레이트 저하가 보인다면 Steam Deck에서 새로고침 빈도를 50Hz로 제한해 보세요.',
  'PC 모니터로 플레이하는데 기본 카메라 확대가 너무 가깝게 느껴진다면, 여러 플레이어가 더 편하다고 느낀 창모드를 시도해 보세요.',
  '기기를 바꾼 후에는 그래픽 설정을 다시 조정해야 할 수 있습니다 — 기기별이 아니라 클라우드 저장에 저장됩니다.',
  '컨트롤러와 키보드+마우스를 초반에 테스트해 보세요: 여러 플레이어가 이 게임이 컨트롤러 중심이며, 기본 키보드 방식에서는 마우스 사용이 평균 이하라고 제보했습니다.',
];

const faq = [
  { q: 'Moonlight Peaks의 최적 설정은 무엇인가요?', a: 'Steam Deck에서 프레임레이트 저하가 보인다면 50Hz로 고정된 새로고침 빈도를 시도해 보세요. PC 모니터에서는 기본 카메라 확대가 너무 가깝게 느껴진다면 창모드가 도움이 될 수 있습니다. 그래픽 설정은 클라우드 저장에 저장되므로 기기를 바꾼 후 재조정이 필요할 수 있습니다.' },
  { q: 'Moonlight Peaks의 최적 Steam Deck 설정은 무엇인가요?', a: '확인됨: 이 게임은 ProtonDB에서 Gold 등급으로 Steam Deck 확인되었으며 처음부터 완전한 컨트롤러 지원을 제공합니다. 한 심층 리뷰는 무제한 TDP에서 60FPS 도달이 어려울 수 있다고 판단했으며, 더 부드럽고 배터리 친화적인 플레이를 위해 50Hz로 고정된 새로고침 빈도를 권장합니다.' },
  { q: '컨트롤러와 키보드 중 무엇을 사용해야 하나요?', a: '컨트롤러가 더 자연스럽습니다 — 여러 플레이어가 기본 키보드+마우스 방식에서는 마우스가 거의 사용되지 않아 키보드를 잡은 손이 대부분의 작업을 처리해야 한다고 제보했습니다. 완전한 컨트롤러 지원은 PC, Steam Deck, Switch에서 모두 잘 작동합니다.' },
  { q: 'Moonlight Peaks에 접근성 설정이 있나요?', a: '몇 가지 있습니다: 확인된 옵션은 VSync, 컨트롤러 진동, 화면 상호작용 라벨, 텍스트 애니메이션, 키 재배정, 프레임레이트 제한, 렌더 스케일링입니다. 확인되지 않음: 색맹 모드나 난독증 친화적 텍스트 옵션은 제보되지 않았습니다.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '최적 설정', item: new URL('/ko/best-settings', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({
    '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a },
  })) },
];
---
<Base
  title="Moonlight Peaks 최적 설정 - PC, Steam Deck, Switch, Mac"
  description="PC, Mac, Steam Deck, Switch, Switch 2를 위한 Moonlight Peaks 최적 설정, 컨트롤러 편의성, 가독성, 데모 테스트, 출시 업데이트."
  path="/ko/best-settings"
  jsonLd={jsonLd}
  crumbs={[{ label: '최적 설정' }]}
  lang="ko"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">출시 / 최적 설정</p>
      <h1>Moonlight Peaks <em>최적 설정</em></h1>
      <p class="intro">
        PC, Mac, Steam Deck, Switch/Switch 2용 {GAME.title}의 실제 확인된 설정과 접근성
        옵션, 그리고 출시 이후 플레이어들이 제보한 플랫폼별 특이점 몇 가지입니다.
      </p>

      <div class="callout">
        <strong>지어낸 벤치마크 없음:</strong> 정확한 FPS, 그래픽 사전 설정, 배터리 수명,
        플랫폼 성능 노트는 출시 후 테스트나 신뢰할 수 있는 출처 확인 후에만 추가됩니다.
      </div>

      <h2>플랫폼 체크리스트</h2>
      <table class="facts">
        {settingsRows.map((row) => (<tr><th>{row[0]}</th><td>{row[1]}</td></tr>))}
      </table>

      <h2>먼저 테스트해야 할 것</h2>
      <ol>
        {testingSteps.map((step) => (<li>{step}</li>))}
      </ol>

      <h2>관련 페이지</h2>
      <div class="link-grid">
        <a href="/ko/demo">데모 가이드</a>
        <a href="/ko/system-requirements">시스템 요구 사항</a>
        <a href="/known-issues">알려진 문제</a>
        <a href="/ko/platforms">플랫폼</a>
        <a href="/launch-day">출시일 허브</a>
      </div>

      <h2>자주 묻는 질문</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </article>

  <style>
    .link-grid { display: grid; grid-template-columns: 1fr; gap: 10px; margin-top: 10px; }
    @media (min-width: 640px) { .link-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    .link-grid a { border: 1px solid var(--line); border-radius: 10px; background: var(--surface); color: var(--mist); padding: 12px 14px; text-decoration: none; }
    .link-grid a:hover { border-color: color-mix(in srgb, var(--candle) 55%, var(--line)); }
  </style>
</Base>
