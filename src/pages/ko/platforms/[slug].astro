---
import TopicPage from '../../../components/TopicPage.astro';
import { platformsSection, platforms } from '../../../data/platforms';
import { platformsKo } from '../../../i18n/platforms-ko';

export function getStaticPaths() {
  return platforms.filter((it) => platformsKo[it.slug]).map((it, i, arr) => {
    const tr = platformsKo[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...arr[(i - 1 + arr.length) % arr.length], ...platformsKo[arr[(i - 1 + arr.length) % arr.length].slug] },
        next: { ...arr[(i + 1) % arr.length], ...platformsKo[arr[(i + 1) % arr.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const koSection = { ...platformsSection, base: '/ko/platforms', label: '플랫폼', eyebrow: '플랫폼' };
---
<TopicPage section={koSection} item={item} prev={prev} next={next} lang="ko" basePath="/ko/platforms" />
