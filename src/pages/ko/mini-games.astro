---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';
import GuideImage from '../../components/GuideImage.astro';

const minigames = [
  { name: '주문 시전', how: '지팡이를 장착한 상태로 D패드 힌트를 따라 원과 점 패턴을 그립니다.', where: '마법이 해금되면 어디서나' },
  { name: '데이트 미니게임', how: '데이트마다 다릅니다 — 원하는 색으로 꽃다발 묶기나 선호하는 정도로 마시멜로 굽기 등이 예시입니다.', where: '하트 레벨 4 이상 주민과의 데이트에서' },
  { name: '낚시', how: '물속 그림자를 향해 던진 다음, 타이밍 기반 미니게임으로 릴을 감습니다.', where: '낚싯대가 해금되면 물가 구역에서' },
  { name: 'Noel과의 낚시 대회', how: '250골드 내기를 걸고 Noel보다 먼저 서로 다른 물고기 3마리를 잡아 낚싯대를 얻습니다.', where: '초반, Noel과 연결됨' },
];

const faq = [
  { q: 'Moonlight Peaks에는 어떤 미니게임이 있나요?', a: '지금까지 확인됨: 주문 시전(원과 점 패턴), 꽃다발 묶기와 마시멜로 굽기 같은 데이트 활동, 타이밍 기반 낚시 미니게임 — 그리고 낚싯대를 해금해주는 Noel의 낚시 대회.' },
  { q: 'Moonlight Peaks에서 낚시는 어렵나요?', a: '리뷰어들은 이를 실력을 요구하는 도전이라기보다 애니멀 크로싱 스타일의 여유로운 던지고 감기에 가까운, 의도적으로 스트레스 없는 방식으로 설명합니다.' },
  { q: '미니게임이 관계에 영향을 미치나요?', a: '네, 특히 데이트에서 — 늦게 도착하거나 데이트 미니게임을 망치면 즉시 모든 것이 끝나는 대신 관계 포인트를 잃는 것으로 확인됩니다.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '미니게임', item: new URL('/ko/mini-games', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks 미니게임 — 데이트, 낚시 & 주문 시전"
  description="Moonlight Peaks의 모든 확인된 미니게임: 꽃다발 묶기 같은 데이트 활동, 던지고 감는 낚시 시스템, 주문 시전 작동 방식."
  path="/ko/mini-games"
  jsonLd={jsonLd}
  crumbs={[{ label: '미니게임' }]}
  lang="ko"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">항목 · 미니게임</p>
      <h1>Moonlight Peaks <em>미니게임</em></h1>
      <p class="intro">
        {GAME.title}는 여러 미니게임을 별도의 아케이드 모드가 아니라 시스템에 통합했습니다.
        지금까지 확인된 내용은 다음과 같습니다. 업데이트: {SITE.updated}.
      </p>

      <GuideImage imageId="minigame" priority />

      <table class="facts">
        <tr><th>미니게임</th><th>작동 방식</th><th>등장 위치</th></tr>
        {minigames.map((m) => (
          <tr>
            <td>{m.name}</td>
            <td>{m.how}</td>
            <td>{m.where}</td>
          </tr>
        ))}
      </table>

      <div class="callout">
        다른 미니게임(Nokturna, 요리, 물약 제조)은 자체 전용 메커니즘이 있을 수 있습니다 —
        여기서 중복하지 않고 아래 연결된 가이드를 참고하세요.
      </div>

      <h2>자주 묻는 질문</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        관련: <a href="/ko/fishing">낚시</a>, <a href="/ko/magic">마법</a>, <a href="/ko/romance">로맨스</a>,
        <a href="/ko/nokturna">Nokturna</a>.
      </div>
    </div>
  </article>
</Base>
