---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const rows = [
  ['먼저 읽어야 할 것', '초보자 가이드, 데모, 출시일, 지원 플랫폼.'],
  ['핵심 시스템', '농사, 낚시, 마법, 활동, 아이템, 지도, Nokturna.'],
  ['인간관계', '캐릭터, 가문, 로맨스, 선물, 결혼, 우정 루트.'],
  ['컬렉션', '물고기, 곤충, 레시피, 물약, 유물, 장식품, 재료.'],
  ['구매 전 체크리스트', 'Steam Deck, Switch, Android, 가격, 데모, 비교 페이지.'],
];

const links = [
  { href: '/ko/beginner-guide', label: '초보자 가이드' },
  { href: '/ko/release-date', label: '출시일' },
  { href: '/ko/demo', label: '데모' },
  { href: '/ko/platforms', label: '플랫폼' },
  { href: '/ko/characters', label: '캐릭터' },
  { href: '/ko/romance', label: '로맨스' },
  { href: '/ko/farming', label: '농사' },
  { href: '/ko/magic', label: '마법' },
  { href: '/ko/items', label: '아이템' },
  { href: '/ko/tools', label: '도구' },
];

const faq = [
  { q: '문라이트 피크스 가이드는 무엇부터 읽어야 하나요?', a: '먼저 초보자 가이드를 읽고, 목표에 따라 데모, 출시일, 플랫폼, 캐릭터, 로맨스 페이지를 참고하세요.' },
  { q: '이 페이지의 모든 정보가 확인된 것인가요?', a: '전부는 아닙니다. 확인된 사실, 실제 플레이어 후기, 아직 검증이 필요한 내용을 명확히 구분합니다 — 추측을 사실처럼 보여주지 않습니다.' },
  { q: '선물, 물고기, 작물 표는 어디서 볼 수 있나요?', a: '신뢰할 수 있는 데이터가 확인되는 대로 로맨스, 캐릭터, 아이템, 농사, 활동 각 페이지에 추가됩니다.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '가이드', item: new URL('/ko/guides', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
];
---
<Base
  title="문라이트 피크스 가이드 - 초보자, 농사, 로맨스"
  description="문라이트 피크스 한국어 가이드 모음. 초보자, 데모, 출시일, 플랫폼, 농사, 마법, 캐릭터, 로맨스, 아이템까지 한눈에."
  path="/ko/guides"
  jsonLd={jsonLd}
  crumbs={[{ label: '가이드' }]}
  lang="ko"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">허브 / 가이드</p>
      <h1>문라이트 피크스 <em>가이드</em></h1>
      <p class="intro">
        {GAME.title}을 시작하기 전에 읽어야 할 페이지들을 모은 가이드 허브입니다. 출시 후 확인된
        상세 데이터는 각 주제별 페이지에 계속 추가됩니다.
      </p>

      <h2>가이드 개요</h2>
      <table class="facts">
        {rows.map((row) => (<tr><th>{row[0]}</th><td>{row[1]}</td></tr>))}
      </table>

      <h2>주요 페이지</h2>
      <div class="link-grid">
        {links.map((link) => <a href={link.href}>{link.label}</a>)}
      </div>

      <h2>추천 읽기 순서</h2>
      <ol class="steps">
        <li>출시일, 데모, 플랫폼을 확인하세요.</li>
        <li>첫날 밤을 맞이하기 전에 초보자 가이드를 읽으세요.</li>
        <li>첫 번째 목표를 정하세요: 농사, 마법, 로맨스, 수집, 탐험 중 하나.</li>
        <li>정확한 답을 원한다면 각 전용 페이지를 활용하세요.</li>
      </ol>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => <details><summary>{f.q}</summary><p>{f.a}</p></details>)}
      </div>
    </div>
  </article>

  <style>
    .link-grid { display: grid; grid-template-columns: 1fr; gap: 10px; margin: 12px 0 24px; }
    @media (min-width: 720px) { .link-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    .link-grid a { border: 1px solid var(--line); border-radius: 10px; background: var(--surface); color: var(--mist); padding: 12px 14px; text-decoration: none; }
  </style>
</Base>
