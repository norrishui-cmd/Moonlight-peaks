---
import Base from '../../../../layouts/Base.astro';
import { SITE, GAME } from '../../../../consts';
import { storyQuests, storyQuestBySlug } from '../../../../data/quests-story';
import { storyQuestsKo, storyChaptersKo } from '../../../../i18n/quests-story-ko';

export function getStaticPaths() {
  return storyQuests.filter((q) => storyQuestsKo[q.slug]).map((q) => ({ params: { slug: q.slug }, props: { q } }));
}

const { q } = Astro.props as { q: (typeof storyQuests)[number] };
const tr = storyQuestsKo[q.slug];
const chapter = storyChaptersKo.find((c) => c.number === q.chapter)!;
const prev = storyQuests[storyQuests.indexOf(q) - 1];
const next = q.leadsTo ? storyQuestBySlug.get(q.leadsTo) : undefined;
const statusLabel = q.status === 'confirmed' ? '확인됨' : '제보됨';

const faq = [
  { q: `Moonlight Peaks에서 "${tr.title}"는 어떻게 해금하나요?`, a: tr.unlock || '이 퀘스트는 이전 스토리 지점에서 바로 이어집니다 — 아래 전제 퀘스트 링크를 참고하세요.' },
  { q: `"${tr.title}"는 무엇을 보상하나요?`, a: tr.reward || '이 퀘스트에 대해 확인된 직접적인 아이템 보상은 아직 문서화되지 않았습니다.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '퀘스트 가이드', item: `${SITE.url}/ko/quests` },
    { '@type': 'ListItem', position: 3, name: '메인 스토리', item: `${SITE.url}/ko/quests/story` },
    { '@type': 'ListItem', position: 4, name: tr.title, item: `${SITE.url}/ko/quests/story/${q.slug}` },
  ] },
];
---
<Base
  title={`${tr.title} — Moonlight Peaks 퀘스트 가이드`}
  description={`${GAME.title} "${tr.title}" 퀘스트: ${tr.summary.slice(0, 130)}`}
  path={`/ko/quests/story/${q.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: '퀘스트 가이드', href: '/ko/quests' }, { label: '메인 스토리', href: '/ko/quests/story' }, { label: tr.title }]}
  lang="ko"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">메인 스토리 · 챕터 {q.chapter}: {chapter.title} · <span class="tag-community">{statusLabel}</span></p>
      <h1>{tr.title}</h1>

      {tr.unlock && (
        <div class="callout">
          <strong>해금 조건:</strong> {tr.unlock}
        </div>
      )}

      <h2>무슨 일이 일어나나요</h2>
      <p>{tr.summary}</p>

      {tr.reward && (
        <>
          <h2>보상</h2>
          <p>{tr.reward}</p>
        </>
      )}

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <nav class="prevnext" aria-label="퀘스트 탐색">
        {prev && storyQuestsKo[prev.slug] ? <a href={`/ko/quests/story/${prev.slug}`}>← {storyQuestsKo[prev.slug].title}</a> : <span />}
        <a href="/ko/quests/story">모든 챕터</a>
        {next && storyQuestsKo[next.slug] ? <a href={`/ko/quests/story/${next.slug}`}>{storyQuestsKo[next.slug].title} →</a> : <span />}
      </nav>

      <div class="callout wip">
        관련: <a href="/ko/quests">퀘스트 허브</a>, <a href="/ko/quests/side">사이드 퀘스트</a>,
        <a href="/ko/beginner-guide">초보자 가이드</a>.
      </div>
    </div>
  </article>

  <style>
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 7px;
      vertical-align: middle;
    }
    .prevnext { display: flex; justify-content: space-between; gap: 10px; margin: 22px 0; font-family: var(--mono); font-size: 0.82rem; }
    .prevnext a { color: var(--candle); }
  </style>
</Base>
