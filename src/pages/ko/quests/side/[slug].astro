---
import Base from '../../../../layouts/Base.astro';
import { SITE, GAME } from '../../../../consts';
import { sideQuests } from '../../../../data/quests-side';
import { sideQuestsKo } from '../../../../i18n/quests-side-ko';

export function getStaticPaths() {
  const translated = sideQuests.filter((q) => sideQuestsKo[q.slug]);
  return translated.map((q, i) => ({
    params: { slug: q.slug },
    props: { q, prev: translated[(i - 1 + translated.length) % translated.length], next: translated[(i + 1) % translated.length] },
  }));
}

const { q, prev, next } = Astro.props as { q: (typeof sideQuests)[number]; prev: (typeof sideQuests)[number]; next: (typeof sideQuests)[number] };
const tr = sideQuestsKo[q.slug];
const statusLabel = q.status === 'confirmed' ? '확인됨' : '제보됨';
const troubleshooting = tr.troubleshooting || [];
const allFaq = [...troubleshooting, { q: `Moonlight Peaks에서 "${tr.title}"는 무엇인가요?`, a: tr.summary }];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: allFaq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '퀘스트 가이드', item: `${SITE.url}/ko/quests` },
    { '@type': 'ListItem', position: 3, name: '사이드 퀘스트', item: `${SITE.url}/ko/quests/side` },
    { '@type': 'ListItem', position: 4, name: tr.title, item: `${SITE.url}/ko/quests/side/${q.slug}` },
  ] },
];
---
<Base
  title={`${tr.title} — Moonlight Peaks 해결법`}
  description={`${GAME.title} "${tr.title}": ${(troubleshooting[0]?.q || tr.summary).slice(0, 100)}`}
  path={`/ko/quests/side/${q.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: '퀘스트 가이드', href: '/ko/quests' }, { label: '사이드 퀘스트', href: '/ko/quests/side' }, { label: tr.title }]}
  lang="ko"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">사이드 퀘스트 · <span class="tag-community">{statusLabel}</span></p>
      <h1>{tr.title}</h1>
      <p class="intro">{tr.summary}</p>

      {tr.reward && (
        <div class="callout">
          <strong>보상:</strong> {tr.reward}
        </div>
      )}

      {troubleshooting.length > 0 && (
        <>
          <h2>막혔나요? 이것부터 확인하세요</h2>
          <div class="faq">
            {troubleshooting.map((f) => (
              <details open>
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))}
          </div>
        </>
      )}

      <nav class="prevnext" aria-label="사이드 퀘스트 탐색">
        <a href={`/ko/quests/side/${prev.slug}`}>← {sideQuestsKo[prev.slug].title}</a>
        <a href="/ko/quests/side">모든 사이드 퀘스트</a>
        <a href={`/ko/quests/side/${next.slug}`}>{sideQuestsKo[next.slug].title} →</a>
      </nav>
    </div>
  </article>

  <style>
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 7px;
      vertical-align: middle;
    }
    .prevnext { display: flex; justify-content: space-between; gap: 10px; margin: 22px 0; font-family: var(--mono); font-size: 0.82rem; }
    .prevnext a { color: var(--candle); }
  </style>
</Base>
