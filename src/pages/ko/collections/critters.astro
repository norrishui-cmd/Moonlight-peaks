---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { critterDetailPages } from '../../../data/collectionDetailPages';

const faq = [
  { q: 'Moonlight Peaks에서 작은 생물로 무엇을 할 수 있나요?', a: '확인됨: 잡은 작은 생물(또는 물고기)은 모두 집에 장식품으로 전시할 수 있습니다 — 팔기보다 희귀하거나 귀여운 것을 남겨둘 가치가 있습니다.' },
  { q: 'Moonlight Peaks의 작은 생물은 계절에 따라 바뀌나요?', a: '네, 확인됨: 낚시와 마찬가지로 계절과 날씨에 따라 다른 곤충과 작은 생물이 나타납니다.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '컬렉션', item: `${SITE.url}/ko/collections` },
    { '@type': 'ListItem', position: 3, name: '작은 생물', item: `${SITE.url}/ko/collections/critters` },
  ] },
];
---
<Base
  title="Moonlight Peaks 작은 생물 — 잡기, 계절 & 집 장식"
  description="확인됨: Moonlight Peaks의 작은 생물과 곤충은 계절과 날씨에 따라 바뀌며, 잡은 것은 모두 집에 장식품으로 전시할 수 있습니다."
  path="/ko/collections/critters"
  jsonLd={jsonLd}
  crumbs={[{ label: '컬렉션', href: '/ko/collections' }, { label: '작은 생물' }]}
  lang="ko"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">컬렉션 · 작은 생물</p>
      <h1>Moonlight Peaks <em>작은 생물</em></h1>
      <p class="intro">
        출시 첫 주 가이드로 확인됨: 잡는 곤충과 작은 생물은 판매나 요리용으로만 쓰이지 않습니다 —
        잡은 것은 모두 집에 장식품으로 전시할 수 있습니다.
      </p>

      <h2>작은 생물 잡기</h2>
      <p>
        확인됨: 곤충 잡기는 배우기 쉽지만 실수하기도 쉬운데, 작은 생물이 빠르게 움직이고 놓친
        공격은 에너지를 소모하기 때문입니다. 낚시와 마찬가지로 계절과 날씨에 따라 다른 곤충이
        나타나므로, 어떤 밤에 찾지 못한 작은 생물도 알맞은 조건을 기다리고 있는 것일 수 있습니다.
      </p>

      <h2>장식품으로 전시하기</h2>
      <p>
        확인됨: 잡은 생물 — 물고기든 곤충이든 — 모두 집 안에 장식품으로 배치할 수 있으므로, 팔기
        보다 희귀하거나 귀여운 것을 남겨둘 가치가 있습니다. 장식에 대해 더 알고 싶다면
        <a href="/ko/farm/house">우리 집</a>을 참고하세요.
      </p>

      <h2>생물 목록</h2>
      <p>항목을 클릭하면 계절, 장소, 종류, 판매 가격이 담긴 상세 페이지로 이동합니다. "-" 로 표시된 항목은 아직 확인되지 않았습니다.</p>
      <ul class="fish-link-list">
        {critterDetailPages.map((c) => (
          <li><a href={`/ko/collections/critters/${c.slug}`}>{c.name}</a></li>
        ))}
      </ul>

      <h2>아직 확인 중</h2>
      <ul>
        <li>상세 페이지가 아직 "-"로 표시하는 장소, 계절, 날씨.</li>
        <li>전시 외에 작은 생물을 선물하거나 판매할 수 있는지 여부.</li>
      </ul>

      <h2>자주 묻는 질문</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        관련 페이지: <a href="/ko/collections">컬렉션 허브</a>, <a href="/environment">환경</a>,
        <a href="/map">지도</a>, <a href="/ko/activities">활동</a>.
      </div>
    </div>
  </article>

  <style>
    .fish-link-list {
      list-style: none; padding: 0; margin: 12px 0 24px;
      display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 8px;
    }
    .fish-link-list a {
      display: block; border: 1px solid var(--line); border-radius: 10px; padding: 8px 12px;
      background: var(--surface); color: var(--candle); text-decoration: none; font-size: 0.88rem;
    }
    .fish-link-list a:hover { border-color: color-mix(in srgb, var(--candle) 54%, var(--line)); }
  </style>
</Base>
