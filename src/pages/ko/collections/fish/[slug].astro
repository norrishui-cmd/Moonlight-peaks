---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';
import { fishDetailPages } from '../../../../data/collectionDetailPages';

export function getStaticPaths() {
  return fishDetailPages.map((entry, index) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      previous: fishDetailPages[index - 1],
      next: fishDetailPages[index + 1],
    },
  }));
}

const { entry, previous, next } = Astro.props;
const labelKo: Record<string, string> = {
  'Location': '장소', 'Rarity': '희귀도', 'Spawns during': '출현 시기',
  'Size': '크기', 'Consumption value': '섭취 에너지', 'Sell price': '판매 가격',
};
const fact = (label: string) => entry.facts.find((item: any) => item.label === label)?.value || '-';
const hasIcon = entry.icon.startsWith('/images/');
const pagePath = `/ko/collections/fish/${entry.slug}`;
const title = `${entry.name} — Moonlight Peaks 물고기 가이드`;
const description = `Moonlight Peaks ${entry.name}: 장소, 희귀도, 출현 시기, 크기, 판매 가격을 한눈에.`;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
      { '@type': 'ListItem', position: 2, name: '컬렉션', item: `${SITE.url}/ko/collections` },
      { '@type': 'ListItem', position: 3, name: '물고기', item: `${SITE.url}/ko/collections/fish` },
      { '@type': 'ListItem', position: 4, name: entry.name, item: `${SITE.url}${pagePath}` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: `Moonlight Peaks에서 ${entry.name}는 어디서 잡나요?`,
        acceptedAnswer: { '@type': 'Answer', text: `현재 확인된 데이터에는 장소가 ${fact('Location')}로 기재되어 있습니다. "-"로 표시된 항목은 아직 실제 게임에서 확인되지 않았습니다.` },
      },
      {
        '@type': 'Question',
        name: `${entry.name}의 가치는 얼마인가요?`,
        acceptedAnswer: { '@type': 'Answer', text: `현재 확인된 데이터에는 판매 가격이 ${fact('Sell price')}, 섭취 에너지가 ${fact('Consumption value')}로 기재되어 있습니다.` },
      },
    ],
  },
];
---
<Base
  title={title}
  description={description}
  path={pagePath}
  jsonLd={jsonLd}
  crumbs={[{ label: '컬렉션', href: '/ko/collections' }, { label: '물고기', href: '/ko/collections/fish' }, { label: entry.name }]}
  lang="ko"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">컬렉션 · 물고기</p>
      <section class="detail-hero">
        <div>
          <h1>{entry.name} <em>(물고기)</em></h1>
          <p class="intro">
            컬렉션 표에서 확인된 데이터를 바탕으로 만든 Moonlight Peaks 물고기 상세 페이지입니다.
            아직 알려지지 않은 값은 실제 게임에서 확인될 때까지 <strong>-</strong>로 표시됩니다.
          </p>
        </div>
        <div class="detail-icon" aria-hidden={!hasIcon}>
          {hasIcon ? <img src={entry.icon} alt={`${entry.name} 아이콘`} loading="eager" /> : <span>아직 아이콘 없음</span>}
        </div>
      </section>

      <section class="fact-grid" aria-label={`${entry.name} 정보`}>
        {entry.facts.map((item: any) => (
          <div class="fact-card">
            <span>{labelKo[item.label] ?? item.label}</span>
            <strong>{item.value}</strong>
          </div>
        ))}
      </section>

      <h2>{entry.name} — 참고</h2>
      <p>
        {entry.name}는 현재 Moonlight Peaks 물고기 컬렉션 데이터에 등재되어 있습니다. 이
        페이지는 전체 표를 뒤지지 않고도 장소, 희귀도, 출현 시기, 크기, 에너지 값, 판매 가격을
        빠르게 확인할 수 있도록 핵심 정보를 한곳에 모았습니다.
      </p>
      <p>
        용도 참고: <strong>{entry.use}</strong>. 항목이 아직 <strong>-</strong>로 표시된다면,
        제공된 원본 스크린샷에 확인된 값이 아직 나타나지 않았다는 의미입니다.
      </p>
      <p class="source-note">
        출처 참고: 이 페이지는 확인된 Moonlight Peaks 물고기 데이터를 바탕으로 만든 현재의
        컬렉션 표를 사용하며, 새로운 공식 또는 실제 게임 값이 확인될 때만 확장됩니다.
      </p>

      <h2>관련 페이지</h2>
      <div class="related-grid">
        <a href="/ko/collections/fish">모든 물고기</a>
        <a href="/ko/collections">컬렉션 허브</a>
      </div>

      <nav class="detail-nav" aria-label="물고기 상세 탐색">
        {previous ? <a href={`/ko/collections/fish/${previous.slug}`}>← {previous.name}</a> : <span />}
        {next ? <a href={`/ko/collections/fish/${next.slug}`}>{next.name} →</a> : <span />}
      </nav>
    </div>
  </article>
  <style>
    .detail-hero {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 20px;
      align-items: start;
    }
    .detail-icon {
      width: 140px;
      height: 140px;
      border-radius: 16px;
      border: 1px solid var(--line);
      background: var(--surface);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .detail-icon img { width: 100%; height: 100%; object-fit: contain; }
    .detail-icon span { color: var(--faint); font-size: 0.7rem; text-transform: uppercase; }
    .fact-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
      margin: 18px 0 28px;
    }
    .fact-card {
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--surface);
      padding: 14px;
    }
    .fact-card span {
      display: block;
      color: var(--candle);
      font-family: var(--mono);
      font-size: 0.68rem;
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    .fact-card strong { color: var(--text); font-size: 1rem; }
    .related-grid, .detail-nav {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 10px;
      margin-top: 12px;
    }
    .source-note { border-left: 3px solid var(--candle); padding-left: 14px; color: var(--muted); }
    .related-grid a, .detail-nav a {
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 12px 14px;
      background: var(--surface);
      color: var(--candle);
      font-family: var(--mono);
      text-decoration: none;
    }
    @media (max-width: 640px) {
      .detail-hero { grid-template-columns: 1fr; }
      .detail-icon { width: 112px; height: 112px; }
    }
  </style>
</Base>
