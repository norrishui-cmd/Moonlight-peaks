---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';

const entries = [
  { group: '낚시', title: '물고기', desc: '약 22종의 물고기, Noel에게서 첫 낚싯대를 얻는 방법, 그리고 어떤 물고기가 잡힐지에 영향을 주는 요소.', href: '/ko/collections/fish' },
  { group: '경제', title: '알베르투스의 일거리', desc: '알베르투스의 일거리 게시판 — 골드, 아이템, 관계 포인트를 보상하는 짧은 의뢰.', href: '/ko/collections/albertus-jobs' },
  { group: '생물', title: '작은 생물', desc: '계절과 날씨에 따라 달라지는 잡을 수 있는 곤충, 집 장식으로도 사용 가능.', href: '/ko/collections/critters' },
  { group: '생물', title: '뱀스터', desc: '확인된 100마리의 뱀스터, 찾는 방법, 그리고 집으로 데려다주는 방법.', href: '/ko/collections/vampsters' },
  { group: '생물', title: '소울 블롭', desc: '100개의 소울 블롭과 전부 모으면 얻는 골동품 시계 보상.', href: '/ko/collections/soul-blobs' },
];

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '컬렉션', item: `${SITE.url}/ko/collections` },
  ],
};
---
<Base
  title="Moonlight Peaks 컬렉션 — 물고기, 일거리, 작은 생물, 뱀스터 & 소울 블롭"
  description="한국어로 보는 Moonlight Peaks 컬렉션 허브: 물고기, 알베르투스의 일거리, 작은 생물, 뱀스터, 소울 블롭 — 공식 위키와 출시 주간 커버리지를 교차 확인했습니다."
  path="/ko/collections"
  jsonLd={jsonLd}
  crumbs={[{ label: '컬렉션' }]}
  lang="ko"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">허브 · 컬렉션</p>
      <h1>{GAME.title} <em>컬렉션</em></h1>
      <p class="intro">
        게임의 수집 및 채집 시스템에 관한 모든 것 — 무엇을 잡고, 무엇을 제출하고, 그 가치는
        얼마인지. 아래 내용 대부분은 공식 Moonlight Peaks 위키에서 직접 가져왔습니다.
      </p>

      <div class="itg">
        {entries.map((e) => (
          <a class="itcard" href={e.href}>
            <span class="itgroup">{e.group}</span>
            <h3>{e.title}</h3>
            <p>{e.desc}</p>
          </a>
        ))}
      </div>

      <div class="callout wip">
        관련 페이지: <a href="/ko/farm">농장</a>, <a href="/ko/items">아이템</a>,
        <a href="/ko/activities">활동</a>, <a href="/achievements">업적</a>.
      </div>
    </div>
  </article>

  <style>
    .itg { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 6px 0 18px; }
    @media (min-width: 640px) { .itg { grid-template-columns: 1fr 1fr; } }
    @media (min-width: 980px) { .itg { grid-template-columns: 1fr 1fr 1fr; } }
    .itcard {
      display: block; border: 1px solid var(--line); border-radius: 14px;
      background: var(--surface); padding: 14px; color: inherit; text-decoration: none;
      transition: border-color .15s ease, transform .15s ease;
    }
    .itcard:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); transform: translateY(-2px); }
    .itgroup { font-family: var(--mono); color: var(--faint); text-transform: uppercase; letter-spacing: 0.04em; font-size: 0.62rem; }
    .itcard h3 { font-family: var(--display); font-weight: 600; font-size: 1rem; margin: 4px 0 6px; }
    .itcard p { color: #ded3e6; font-size: 0.84rem; margin: 0 0 10px; }
  </style>
</Base>
