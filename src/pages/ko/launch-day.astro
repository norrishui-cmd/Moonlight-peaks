---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const rows = [
  ['여기서 시작하세요', '설치 전 출시 시기, 데모 이용 가능 여부, 플랫폼 선택, 시스템 요구 사항, 지원 언어를 확인하세요.'],
  ['첫 플레이 세션', '뱀파이어를 생성하고, 조작을 테스트하고, 가독성을 확인하고, 밤낮 주기를 익히며, 확인되지 않은 자금이나 선물 루트를 서두르지 마세요.'],
  ['확인해야 할 데이터', '작물, 물고기, 선물, 일정, 상점 가격, 퀘스트, 저장, 성능, 그리고 출시 관련 버그.'],
  ['안전한 업데이트 정책', '실제 게임, 공식 노트, 스토어 페이지, 또는 신뢰할 수 있는 중립적 보도에서 확인된 후에만 수치를 추가합니다.'],
];

const checklist = [
  { label: '출시일', href: '/ko/release-date', note: '출시 시기, 가격, 플랫폼, 데모 상태.' },
  { label: '데모 가이드', href: '/ko/demo', note: '구매나 재시작 전에 테스트할 것.' },
  { label: '시스템 요구 사항', href: '/ko/system-requirements', note: 'PC, Mac, Steam Deck 확인 사항.' },
  { label: '언어', href: '/ko/languages', note: '일본어, 중국어, 한국어, 독일어, 영어 지원.' },
  { label: '알려진 문제', href: '/known-issues', note: '출시 버그 추적 및 검증 노트.' },
  { label: '최적 설정', href: '/ko/best-settings', note: 'PC, Steam Deck, Switch, Mac 설정 체크리스트.' },
  { label: '초보자 가이드', href: '/ko/beginner-guide', note: '첫날 밤 우선순위와 안전한 초반 목표.' },
  { label: '캐릭터', href: '/ko/characters', note: '주민, 로맨스 상태, 출시 검증.' },
];

const faq = [
  { q: 'Moonlight Peaks 출시일에 가장 먼저 확인해야 할 것은 무엇인가요?', a: '상세한 아이템이나 선물 표를 쫓기 전에 출시 시기, 플랫폼, 시스템 요구 사항, 언어 지원, 알려진 문제, 초보자 가이드부터 확인하세요.' },
  { q: '출시일 데이터가 바로 완전할까요?', a: '아니요. 작물, 선물, 일정, 상점 가격, 퀘스트, 성능 노트 같은 정확한 수치는 실제 게임에서 확인된 후에만 추가됩니다.' },
  { q: '출시 후에도 데모를 플레이해야 하나요?', a: '네, 자신의 기기에서 조작, 톤, 가독성, 성능이 확실하지 않다면요. 데모는 빠른 편의성 확인 수단으로 계속 유용합니다.' },
  { q: '버그와 성능 노트는 어디에 정리되나요?', a: '크래시, 저장 문제, 컨트롤러 문제, Steam Deck 노트, Switch 성능, 기타 출시 주간 문제는 알려진 문제 페이지를 이용하세요.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '출시일', item: new URL('/ko/launch-day', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({
    '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a },
  })) },
];
---
<Base
  title="Moonlight Peaks 출시일 가이드 - 가장 먼저 확인할 것"
  description="출시 시기, 데모, 시스템 요구 사항, 언어, 알려진 문제, 최적 설정, 초보자 팁, 안전한 데이터 업데이트를 위한 Moonlight Peaks 출시일 허브."
  path="/ko/launch-day"
  jsonLd={jsonLd}
  crumbs={[{ label: '출시일' }]}
  lang="ko"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">출시 / 첫날</p>
      <h1>Moonlight Peaks <em>출시일</em> 가이드</h1>
      <p class="intro">
        {GAME.title}를 위한 첫날 허브: 설치 전 확인해야 할 것, 검증된 데이터가 정리될 곳,
        그리고 부실하거나 추측성인 출시 정보를 피하는 방법.
      </p>

      <div class="callout">
        <strong>출시 시기:</strong> {GAME.releaseNote}
      </div>

      <h2>출시일 개요</h2>
      <table class="facts">
        {rows.map((row) => (<tr><th>{row[0]}</th><td>{row[1]}</td></tr>))}
      </table>

      <h2>이것부터 확인하세요</h2>
      <div class="link-grid">
        {checklist.map((item) => (
          <a href={item.href}>
            <strong>{item.label}</strong>
            <span>{item.note}</span>
          </a>
        ))}
      </div>

      <h2>추측하지 말아야 할 것</h2>
      <p>
        정확한 최고 선물, 아이템 가격, 퀘스트 결과, 작물 수익, 낚시 장소, Steam Deck 등급,
        저장 경로는 실제 게임이나 공식 자료에서 확인되기 전까지 게시하지 마세요. 출시 검색
        트래픽은 가치가 있지만, 추측한 표는 플레이어에게 나쁘고 SEO에도 위험합니다.
      </p>

      <h2>자주 묻는 질문</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </article>

  <style>
    .link-grid { display: grid; grid-template-columns: 1fr; gap: 10px; margin-top: 10px; }
    @media (min-width: 680px) { .link-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    .link-grid a { display: flex; flex-direction: column; gap: 3px; border: 1px solid var(--line); border-radius: 10px; background: var(--surface); padding: 12px 14px; text-decoration: none; }
    .link-grid strong { color: var(--mist); font-family: var(--display); }
    .link-grid span { color: var(--muted); font-size: 0.84rem; }
    .link-grid a:hover { border-color: color-mix(in srgb, var(--candle) 55%, var(--line)); }
  </style>
</Base>
