---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';
import { characters } from '../../../data/characters';

const known = characters.filter((c) => c.status !== 'unconfirmed');

const jsonLd = [
  {
    '@context': 'https://schema.org', '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
      { '@type': 'ListItem', position: 2, name: '도구', item: new URL('/ko/tools', SITE.url).href },
      { '@type': 'ListItem', position: 3, name: '선물 기록기', item: new URL('/ko/tools/gift-tracker', SITE.url).href },
    ],
  },
  {
    '@context': 'https://schema.org', '@type': 'WebApplication',
    name: 'Moonlight Peaks 선물 기록기', applicationCategory: 'GameApplication', operatingSystem: 'Web',
    url: new URL('/ko/tools/gift-tracker', SITE.url).href,
    description: '실제 게임에서 선물을 테스트하며 각 주민의 반응을 기록하는, 브라우저에 저장되는 개인 선물 기록장.',
  },
];
---
<Base
  title="Moonlight Peaks 선물 기록기 — 나만의 테스트를 기록하세요"
  description="대부분 주민의 완전한 선물 목록은 아직 확인되지 않았습니다 — 브라우저에 저장되는 이 개인 기록기로 각 주민이 어떤 선물을 좋아하는지 직접 기록해 보세요."
  path="/ko/tools/gift-tracker"
  jsonLd={jsonLd}
  crumbs={[{ label: '도구', href: '/ko/tools' }, { label: '선물 기록기' }]}
  lang="ko"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">도구 / 선물 기록기</p>
      <h1>Moonlight Peaks — <em>선물 기록기</em></h1>
      <p class="intro">
        대부분 주민의 완전한 애정/호감/비호감 선물 목록은 아직 확인되지 않았습니다 — 그래서 재미있는
        부분이 남아있죠. 주민을 선택하고, 게임 안에서 선물을 준 뒤, 아래에 반응을 기록하세요.
        모든 데이터는 브라우저에만 비공개로 저장됩니다. 이미 확인된 내용은
        <a href="/tools/romance-gift-finder">선물 검색기</a>에서 확인하세요.
      </p>

      <section class="gt-shell" data-gift-tracker>
        <aside class="gt-panel">
          <label>
            <span>주민</span>
            <select data-resident>
              {known.map((c) => <option value={c.id}>{c.name}{c.family && c.family !== 'Unknown' ? ` (${c.family})` : ''}</option>)}
            </select>
          </label>
          <label>
            <span>선물</span>
            <input data-item type="text" placeholder="예: Blood Grapes" />
          </label>
          <label>
            <span>반응</span>
            <select data-reaction>
              <option value="loved">아주 좋아함</option>
              <option value="liked">좋아함</option>
              <option value="neutral">보통</option>
              <option value="disliked">싫어함</option>
              <option value="hated">매우 싫어함</option>
            </select>
          </label>
          <label>
            <span>메모 (선택 사항)</span>
            <input data-notes type="text" placeholder="예: 생일 보너스?" />
          </label>
          <button type="button" class="btn btn-gold" data-add>이 선물 기록하기</button>
          <button type="button" class="btn btn-ghost" data-export>텍스트로 내보내기</button>
          <button type="button" class="btn btn-ghost" data-reset>전체 기록 지우기</button>
        </aside>

        <div class="gt-log" data-log aria-live="polite">
          <p class="empty" data-empty>아직 기록된 선물이 없습니다 — 왼쪽에서 첫 테스트를 추가하세요.</p>
        </div>
      </section>

      <div class="callout">
        이 도구는 여러분의 브라우저에만 기록을 저장합니다 — 사이트로 전송되는 데이터는 없습니다.
        공유할 만한 발견을 하셨나요? <a href="/tools/submit-data">데이터 제출 도구</a>로 모두에게
        도움이 되는 검증에 참여해 보세요.
      </div>
    </div>
  </article>

  <script define:vars={{ known: known.map((c) => ({ id: c.id, name: c.name })) }}>
    const root = document.querySelector('[data-gift-tracker]');
    if (root) {
      const key = 'moonlight-gift-tracker-v1';
      const residentSel = root.querySelector('[data-resident]');
      const itemInput = root.querySelector('[data-item]');
      const reactionSel = root.querySelector('[data-reaction]');
      const notesInput = root.querySelector('[data-notes]');
      const addBtn = root.querySelector('[data-add]');
      const exportBtn = root.querySelector('[data-export]');
      const resetBtn = root.querySelector('[data-reset]');
      const log = root.querySelector('[data-log]');
      const emptyMsg = root.querySelector('[data-empty]');
      const nameOf = Object.fromEntries(known.map((c) => [c.id, c.name]));

      let entries = JSON.parse(localStorage.getItem(key) || '[]');
      const save = () => localStorage.setItem(key, JSON.stringify(entries));

      const reactionLabel = { loved: '아주 좋아함 💜', liked: '좋아함', neutral: '보통', disliked: '싫어함', hated: '매우 싫어함' };

      const render = () => {
        if (!entries.length) {
          emptyMsg.style.display = '';
          log.querySelectorAll('.gt-row').forEach((r) => r.remove());
          return;
        }
        emptyMsg.style.display = 'none';
        log.querySelectorAll('.gt-row').forEach((r) => r.remove());
        [...entries].reverse().forEach((entry, revIndex) => {
          const index = entries.length - 1 - revIndex;
          const row = document.createElement('div');
          row.className = 'gt-row';
          row.innerHTML = `
            <span class="gt-resident">${nameOf[entry.residentId] || entry.residentId}</span>
            <span class="gt-item">${entry.item}</span>
            <span class="gt-reaction gt-reaction-${entry.reaction}">${reactionLabel[entry.reaction] || entry.reaction}</span>
            <span class="gt-notes">${entry.notes || ''}</span>
            <button type="button" class="gt-remove" data-remove="${index}" aria-label="기록 삭제">✕</button>
          `;
          log.appendChild(row);
        });
      };

      addBtn.addEventListener('click', () => {
        const item = itemInput.value.trim();
        if (!item) { itemInput.focus(); return; }
        entries.push({
          residentId: residentSel.value,
          item,
          reaction: reactionSel.value,
          notes: notesInput.value.trim(),
        });
        save();
        itemInput.value = '';
        notesInput.value = '';
        render();
      });

      log.addEventListener('click', (event) => {
        const btn = event.target.closest('[data-remove]');
        if (!btn) return;
        entries.splice(Number(btn.dataset.remove), 1);
        save();
        render();
      });

      exportBtn.addEventListener('click', () => {
        if (!entries.length) return;
        const text = entries.map((e) => `${nameOf[e.residentId] || e.residentId} — ${e.item}: ${reactionLabel[e.reaction] || e.reaction}${e.notes ? ' (' + e.notes + ')' : ''}`).join('\n');
        navigator.clipboard?.writeText(text).catch(() => {});
        alert('선물 기록을 클립보드에 복사했습니다!');
      });

      resetBtn.addEventListener('click', () => {
        if (!confirm('모든 선물 기록을 지우시겠습니까? 이 작업은 되돌릴 수 없습니다.')) return;
        entries = [];
        save();
        render();
      });

      render();
    }
  </script>

  <style>
    .gt-shell { display: grid; grid-template-columns: 280px minmax(0, 1fr); gap: 18px; margin: 28px 0; }
    @media (max-width: 820px) { .gt-shell { grid-template-columns: 1fr; } }
    .gt-panel { border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); padding: 16px; display: grid; gap: 12px; align-self: start; }
    .gt-panel label span { display: block; margin-bottom: 6px; color: var(--mist); font-weight: 600; }
    .gt-panel select, .gt-panel input[type="text"] {
      width: 100%; min-height: 44px; border: 1px solid var(--line); border-radius: 10px;
      background: var(--ink); color: var(--mist); padding: 0 12px; font: inherit;
    }
    .gt-log { display: grid; gap: 8px; align-content: start; }
    .gt-row {
      display: grid; grid-template-columns: 1fr 1fr 100px 1fr 28px; gap: 10px; align-items: center;
      border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface);
      padding: 10px 12px;
    }
    @media (max-width: 700px) { .gt-row { grid-template-columns: 1fr; } }
    .gt-resident { color: var(--mist); font-weight: 600; }
    .gt-item { color: var(--muted); }
    .gt-reaction { font-family: var(--mono); font-size: 0.7rem; text-transform: uppercase; padding: 3px 8px; border-radius: 999px; text-align: center; }
    .gt-reaction-loved { background: rgba(200,80,140,0.2); color: #e08ac0; }
    .gt-reaction-liked { background: rgba(120,180,120,0.2); color: #9ad09a; }
    .gt-reaction-neutral { background: rgba(150,150,150,0.2); color: var(--muted); }
    .gt-reaction-disliked, .gt-reaction-hated { background: rgba(200,90,90,0.2); color: #e08a8a; }
    .gt-notes { color: var(--muted); font-size: 0.85rem; }
    .gt-remove { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 1rem; }
    .gt-remove:hover { color: var(--candle); }
    .empty { border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); padding: 16px; color: var(--muted); }
  </style>
</Base>
