---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
      { '@type': 'ListItem', position: 2, name: '도구', item: `${SITE.url}/ko/tools` },
      { '@type': 'ListItem', position: 3, name: '농업 수익 계산기', item: new URL('/ko/tools/farming-profit-planner', SITE.url).href },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Moonlight Peaks 농업 수익 계산기',
    applicationCategory: 'GameApplication',
    operatingSystem: 'Web',
    url: new URL('/ko/tools/farming-profit-planner', SITE.url).href,
    description: '씨앗 가격, 판매 가격, 성장 일수, 반복 수확, 비료 계획을 위한 Moonlight Peaks 작물 수익 계산기.',
  },
];
---
<Base
  title="Moonlight Peaks 농업 수익 계산기 - 계산기와 최고의 작물"
  description="바로 사용할 수 있는 농업 계산기로 Moonlight Peaks 작물 수익을 계획하세요. 씨앗 가격, 판매 가격, 성장 일수, 수확 횟수, 비료 가정을 비교해 보세요."
  path="/ko/tools/farming-profit-planner"
  jsonLd={jsonLd}
  crumbs={[{ label: '도구', href: '/ko/tools' }, { label: '수익 계산기' }]}
  lang="ko"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">도구 / 농업 계산기</p>
      <h1>Moonlight Peaks — <em>농업 수익 계산기</em></h1>
      <p class="intro">
        {GAME.title}의 실제 가격이 확인되면 밤당 수익으로 작물을 비교할 수 있습니다. 출시 데이터가
        검증되기 전까지는 아래 수동 입력란을 사용해 시나리오를 테스트하세요 — 미확인 작물 수치를
        확정된 값처럼 제시하지 않습니다.
      </p>

      <section class="profit-tool" data-profit-tool>
        <form class="profit-form">
          <label><span>작물 이름</span><input data-crop value="확인 필요한 작물" /></label>
          <label><span>씨앗 가격</span><input data-seed type="number" min="0" value="0" /></label>
          <label><span>수확당 판매 가격</span><input data-sell type="number" min="0" value="0" /></label>
          <label><span>성장 일수</span><input data-days type="number" min="1" value="1" /></label>
          <label><span>수확 횟수</span><input data-harvests type="number" min="1" value="1" /></label>
          <label><span>추가 비용</span><input data-extra type="number" min="0" value="0" /></label>
          <button type="button" class="btn btn-primary" data-add>비교에 추가</button>
        </form>

        <aside class="profit-result">
          <span class="result-kicker">현재 추정치</span>
          <h2 data-profit>0</h2>
          <p data-profit-copy>출시 후 가격을 입력하면 총 수익과 일일 수익을 계산할 수 있습니다.</p>
        </aside>
      </section>

      <h2>작물 비교</h2>
      <div class="profit-table-wrap">
        <table class="profit-table">
          <thead>
            <tr>
              <th>작물</th>
              <th>씨앗</th>
              <th>판매</th>
              <th>일수</th>
              <th>수확</th>
              <th>총 수익</th>
              <th>일일 수익</th>
            </tr>
          </thead>
          <tbody data-rows>
            <tr><td colspan="7">출시 데이터가 확인되면 작물을 추가하세요.</td></tr>
          </tbody>
        </table>
      </div>

      <div class="callout">
        안전한 데이터 원칙: 작물 이름, 씨앗 가격, 판매 가치, 성장 시간, 비료 효과, 재생 규칙은
        가이드 콘텐츠로 다루기 전에 실제 게임이나 공식 자료로 검증되어야 합니다.
      </div>
    </div>
  </article>

  <script>
    const root = document.querySelector('[data-profit-tool]');
    const rowsEl = document.querySelector('[data-rows]');
    if (root && rowsEl) {
      const els = {
        crop: root.querySelector('[data-crop]'),
        seed: root.querySelector('[data-seed]'),
        sell: root.querySelector('[data-sell]'),
        days: root.querySelector('[data-days]'),
        harvests: root.querySelector('[data-harvests]'),
        extra: root.querySelector('[data-extra]'),
        add: root.querySelector('[data-add]'),
        profit: root.querySelector('[data-profit]'),
        copy: root.querySelector('[data-profit-copy]'),
      };
      const key = 'moonlight-farming-planner-v1';
      let rows = JSON.parse(localStorage.getItem(key) || '[]');
      const num = (el) => Math.max(0, Number(el.value || 0));
      const calc = () => {
        const seed = num(els.seed);
        const sell = num(els.sell);
        const days = Math.max(1, num(els.days));
        const harvests = Math.max(1, num(els.harvests));
        const extra = num(els.extra);
        const totalRevenue = sell * harvests;
        const totalProfit = totalRevenue - seed - extra;
        const perDay = totalProfit / days;
        els.profit.textContent = Math.round(totalProfit).toString();
        els.copy.textContent = `${days}일 동안 일일 수익 ${perDay.toFixed(2)}.`;
        return { crop: els.crop.value || '확인 필요한 작물', seed, sell, days, harvests, totalProfit, perDay };
      };
      const renderRows = () => {
        rowsEl.innerHTML = rows.length ? rows.map((r) => `
          <tr>
            <td>${r.crop}</td>
            <td>${r.seed}</td>
            <td>${r.sell}</td>
            <td>${r.days}</td>
            <td>${r.harvests}</td>
            <td>${Math.round(r.totalProfit)}</td>
            <td>${Number(r.perDay).toFixed(2)}</td>
          </tr>
        `).join('') : '<tr><td colspan="7">출시 데이터가 확인되면 작물을 추가하세요.</td></tr>';
      };
      const save = () => localStorage.setItem(key, JSON.stringify(rows.slice(-12)));
      root.addEventListener('input', calc);
      els.add.addEventListener('click', () => {
        rows.push(calc());
        save();
        renderRows();
      });
      calc();
      renderRows();
    }
  </script>

  <style>
    .profit-tool { display: grid; grid-template-columns: minmax(0, 1fr) 300px; gap: 18px; margin: 28px 0; }
    @media (max-width: 820px) { .profit-tool { grid-template-columns: 1fr; } }
    .profit-form, .profit-result {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--surface);
      padding: 18px;
    }
    .profit-form { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
    @media (max-width: 640px) { .profit-form { grid-template-columns: 1fr; } }
    .profit-form label span { display: block; margin-bottom: 6px; color: var(--mist); font-weight: 600; }
    .profit-form input {
      width: 100%;
      min-height: 44px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--ink);
      color: var(--mist);
      padding: 0 12px;
      font: inherit;
    }
    .profit-form button { grid-column: 1 / -1; justify-content: center; }
    .result-kicker { font-family: var(--mono); color: var(--candle); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; }
    .profit-result h2 { font-size: 3rem; margin: 8px 0; }
    .profit-result p { color: var(--muted); }
    .profit-table-wrap { overflow-x: auto; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); }
    .profit-table { width: 100%; min-width: 720px; border-collapse: collapse; }
    .profit-table th, .profit-table td { border-bottom: 1px solid var(--line); padding: 10px 12px; text-align: left; }
    .profit-table th { color: var(--candle); font-family: var(--mono); font-size: 0.68rem; text-transform: uppercase; }
    .profit-table tr:last-child td { border-bottom: 0; }
  </style>
</Base>
