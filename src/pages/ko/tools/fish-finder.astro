---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { fishDetailPages } from '../../../data/collectionDetailPages';

const fact = (facts: { label: string; value: string }[], label: string) => facts.find((f) => f.label === label)?.value || '-';

const locations = [...new Set(fishDetailPages.map((f) => fact(f.facts, 'Location')).filter((v) => v !== '-'))].sort();
const rarities = [...new Set(fishDetailPages.map((f) => fact(f.facts, 'Rarity')).filter((v) => v !== '-'))].sort();

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '도구', item: `${SITE.url}/ko/tools` },
    { '@type': 'ListItem', position: 3, name: '물고기 검색기', item: new URL('/ko/tools/fish-finder', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'Moonlight Peaks 물고기 검색기',
    applicationCategory: 'GameApplication', operatingSystem: 'Web',
    url: new URL('/ko/tools/fish-finder', SITE.url).href,
    description: 'Moonlight Peaks의 확인된 물고기 22종을 위치와 희귀도로 필터링해 정확히 어디서 낚을 수 있는지 알아보세요.' },
];
---
<Base
  title="Moonlight Peaks 물고기 검색기 — 위치와 희귀도로 필터링"
  description="Moonlight Peaks의 확인된 물고기 22종을 위치와 희귀도로 검색하고 필터링하세요. 각 종의 전체 상세 페이지 링크도 제공합니다."
  path="/ko/tools/fish-finder"
  jsonLd={jsonLd}
  crumbs={[{ label: '도구', href: '/ko/tools' }, { label: '물고기 검색기' }]}
  lang="ko"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">도구 / 물고기 검색기</p>
      <h1>Moonlight Peaks — <em>물고기 검색기</em></h1>
      <p class="intro">
        확인된 {fishDetailPages.length}종의 물고기를 검색 가능한 목록으로 정리했습니다 — 위치나
        희귀도로 필터링해 원하는 물고기를 찾은 후, 상세 페이지에서 시즌, 크기, 판매 가격까지
        확인하세요. 데이터는 <a href="/collections/fish">물고기 컬렉션</a>에서 직접 가져옵니다.
      </p>

      <div class="ff-controls">
        <input class="ff-search" id="ff-search" type="search" placeholder="물고기 이름으로 검색…" aria-label="물고기 검색" />
        <div class="ff-selects">
          <select id="ff-location" aria-label="위치로 필터링">
            <option value="all">모든 위치</option>
            {locations.map((l) => <option value={l}>{l}</option>)}
          </select>
          <select id="ff-rarity" aria-label="희귀도로 필터링">
            <option value="all">모든 희귀도</option>
            {rarities.map((r) => <option value={r}>{r}</option>)}
          </select>
        </div>
      </div>

      <p class="ff-count" id="ff-count">{fishDetailPages.length}종의 물고기</p>
      <div class="ff-grid" id="ff-grid">
        {fishDetailPages.map((f) => (
          <a class="ff-card" href={`/collections/fish/${f.slug}`}
             data-name={f.name.toLowerCase()}
             data-location={fact(f.facts, 'Location')}
             data-rarity={fact(f.facts, 'Rarity')}>
            <strong>{f.name}</strong>
            <span class="ff-meta">{fact(f.facts, 'Location')} · {fact(f.facts, 'Rarity')}</span>
          </a>
        ))}
      </div>
      <p class="ff-noresult" id="ff-noresult" hidden>필터 조건에 맞는 물고기가 없습니다 — 필터를 하나 제거해 보세요.</p>

      <div class="callout wip">
        관련: <a href="/collections/fish">전체 물고기 컬렉션</a>, <a href="/collections/critters">작은 생물들</a>,
        <a href="/ko/beginner-guide">초보자 가이드</a>, <a href="/characters/noel">노엘 (첫 낚싯대)</a>.
      </div>
    </div>
  </article>

  <script>
    const search = document.getElementById('ff-search') as HTMLInputElement | null;
    const locationSel = document.getElementById('ff-location') as HTMLSelectElement | null;
    const raritySel = document.getElementById('ff-rarity') as HTMLSelectElement | null;
    const grid = document.getElementById('ff-grid');
    const count = document.getElementById('ff-count');
    const noresult = document.getElementById('ff-noresult');
    if (search && grid && locationSel && raritySel) {
      const cards = Array.from(grid.querySelectorAll<HTMLElement>('.ff-card'));
      const apply = () => {
        const q = (search.value || '').trim().toLowerCase();
        const loc = locationSel.value;
        const rar = raritySel.value;
        let shown = 0;
        cards.forEach((el) => {
          const name = el.getAttribute('data-name') || '';
          const cardLoc = el.getAttribute('data-location') || '';
          const cardRar = el.getAttribute('data-rarity') || '';
          const matchText = !q || name.includes(q);
          const matchLoc = loc === 'all' || cardLoc === loc;
          const matchRar = rar === 'all' || cardRar === rar;
          const show = matchText && matchLoc && matchRar;
          el.style.display = show ? '' : 'none';
          if (show) shown++;
        });
        if (count) count.textContent = shown + '종의 물고기';
        if (noresult) (noresult as HTMLElement).hidden = shown !== 0;
      };
      search.addEventListener('input', apply);
      locationSel.addEventListener('change', apply);
      raritySel.addEventListener('change', apply);
    }
  </script>

  <style>
    .ff-controls { display: flex; flex-direction: column; gap: 10px; margin: 16px 0 8px; }
    .ff-search {
      width: 100%; padding: 12px 14px; border-radius: 10px; border: 1px solid var(--line);
      background: var(--surface); color: var(--mist); font-size: 0.95rem; font-family: var(--body);
    }
    .ff-search:focus { outline: 2px solid var(--candle); outline-offset: 1px; }
    .ff-selects { display: flex; gap: 10px; flex-wrap: wrap; }
    .ff-selects select {
      flex: 1 1 160px; min-height: 42px; border: 1px solid var(--line); border-radius: 10px;
      background: var(--ink); color: var(--mist); padding: 0 10px; font: inherit;
    }
    .ff-count { font-family: var(--mono); font-size: 0.74rem; color: var(--faint); letter-spacing: 0.06em; text-transform: uppercase; margin: 14px 0 12px; }
    .ff-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 10px; }
    .ff-card {
      display: flex; flex-direction: column; gap: 4px; border: 1px solid var(--line); border-radius: 12px;
      background: var(--surface); padding: 12px 14px; text-decoration: none; color: inherit;
      transition: border-color .15s ease;
    }
    .ff-card:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); }
    .ff-card strong { font-family: var(--display); font-weight: 600; color: var(--mist); }
    .ff-meta { color: var(--faint); font-size: 0.78rem; font-family: var(--mono); }
    .ff-noresult { color: var(--faint); font-size: 0.9rem; margin-top: 16px; }
  </style>
</Base>
