---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const facts = [
  ['출시일', GAME.releaseLabel],
  ['가격', `${GAME.price} (Nintendo Switch 2 에디션: 39.99달러)`],
  ['플랫폼', GAME.platforms.join(', ')],
  ['무료 데모', GAME.demo],
  ['시스템 요구 사항', 'PC/Mac 공식 요구 사항은 Steam에서 확인하세요; 실제 테스트는 데모를 이용하세요'],
  ['지원 언어', GAME.languages.join(', ')],
  ['PS5 / Xbox / iOS', '발표되지 않음'],
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '플랫폼', item: `${SITE.url}/ko/platforms` },
  ] },
];
---
<Base
  title="문라이트 피크스 — 플랫폼: Switch, Switch 2, Steam, 가격"
  description="문라이트 피크스를 플레이할 수 있는 곳: Switch, Switch 2, Steam(PC/Mac), Steam Deck, Android — 가격, 무료 데모, PS5/Xbox/iOS 지원 여부."
  path="/ko/platforms"
  jsonLd={jsonLd}
  crumbs={[{ label: '플랫폼' }]}
  lang="ko"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">입문 · 플랫폼</p>
      <h1>문라이트 피크스 — <em>플랫폼</em>과 가격</h1>
      <p class="intro">
        문라이트 피크스는 {GAME.releaseLabel}에 출시되어 이미 플레이할 수 있습니다. 어디서
        플레이할 수 있는지, 가격은 얼마인지, 무료 데모는 어떻게 작동하는지 정리했습니다.
      </p>

      <h2>한눈에 보기</h2>
      <table class="facts">
        {facts.map((f) => (<tr><th>{f[0]}</th><td>{f[1]}</td></tr>))}
      </table>

      <h2>어디서 플레이할 수 있나요</h2>
      <p>
        문라이트 피크스는 Steam(PC와 Mac), Steam Deck, Nintendo Switch, Nintendo Switch 2, 그리고
        Google Play를 통한 Android에서 확인되었습니다. 각 플랫폼마다 성능, 조작, 가격에 관한
        상세 가이드가 있습니다 — 현재는 영어로만 제공됩니다.
      </p>

      <h2>문라이트 피크스는 PlayStation, Xbox, iOS에서도 할 수 있나요?</h2>
      <p>
        PlayStation, Xbox, iOS 버전은 발표되지 않았습니다. 확인된 플랫폼은 Steam(PC와 Mac),
        Steam Deck, Nintendo Switch, Nintendo Switch 2, 그리고 Google Play를 통한 Android입니다.
        변경 사항이 있으면 이 페이지를 업데이트하겠습니다.
      </p>

      <div class="callout wip">
        관련: <a href="/release-date">출시일</a>, <a href="/demo">데모</a>,
        <a href="/system-requirements">시스템 요구 사항</a>, <a href="/languages">지원 언어</a>,
        <a href="/compare">다른 코지 심과 비교</a>, <a href="/faq">전체 FAQ</a>(영어).
      </div>
    </div>
  </article>
</Base>
