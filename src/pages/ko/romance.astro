---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';
import { characters, typeLabels } from '../../data/characters';

const familyNameKo: Record<string, string> = {
  'Vampire (Ambrosia)': '뱀파이어 · Ambrosia 가문',
  'Vampire (Dracula)': '뱀파이어 · Dracula 가문',
  'Witch (Webb)': '마녀 · Webb 가문',
  'Werewolf (Logan)': '늑대인간 · Logan 가문',
  'Mermaid (Hosu)': '인어 · Hosu 가문',
  'Seer (Khazan)': '예언자 · Khazan 가문',
  'Human (Henderson)': '인간 · Henderson 가문',
  'Unknown': '가문 없음',
};
const typeKo: Record<string, string> = {
  vampire: '뱀파이어', werewolf: '늑대인간', witch: '마녀', mermaid: '인어',
  seer: '예언자', ghost: '유령', human: '인간', other: '기타',
};
const statusKo: Record<string, string> = { confirmed: '확인됨', reported: '보고됨', datamined: '데이터마이닝', unconfirmed: '미확인' };

const romanceable = characters.filter((c) => c.romanceable === true);
const groups = new Map<string, typeof romanceable>();
for (const c of romanceable) {
  const key = c.family || 'Unknown';
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(c);
}
const familyGroups = [...groups.entries()].sort((a, b) => b[1].length - a[1].length);

const faq = [
  { q: '문라이트 피크스에는 로맨스 대상이 몇 명인가요?', a: '출시 시점에 확인됨: 공식 로맨스 소개 자료에 따르면 23명 — 이전에는 약 15명으로 언급된 적도 있습니다. 여섯 가문(Ambrosia, Webb, Logan, Hosu, Khazan, Henderson)에 속하며, 가문에 속하지 않는 Death와 사랑의 악마 Llemi까지 포함해서 로맨스 대상이 됩니다.' },
  { q: '데이트와 결혼에는 하트 레벨이 얼마나 필요한가요?', a: '확인됨: 데이트는 하트 레벨 4에서 해금됩니다. 청혼은 하트 레벨 8에서 가능합니다. 결혼은 청혼 후 일주일 이내에 이루어지며, 마을의 뱀파이어와 늑대인간들이 참석합니다.' },
  { q: '여러 명과 동시에 데이트할 수 있나요?', a: '네, 확인됨. 상대방들이 이를 눈치채고 언급하긴 하지만, 엄격한 라이벌 시스템이라기보다는 가벼운 질투 정도입니다. 결혼 자체는 엄격하게 일부일처제입니다.' },
  { q: '데이트를 너무 많이 거절하면 어떻게 되나요?', a: '확인됨: 상대방의 데이트 신청을 너무 자주 거절하면 이별로 이어집니다. 그러면 며칠 동안 상대방이 냉랭하게 대하다가 용서해줍니다.' },
  { q: '문라이트 피크스에서 결혼할 수 있나요? 아이도 가질 수 있나요?', a: '네, 결혼할 수 있습니다 — 배우자가 내 농장으로 이사 오고 새로운 하트 이벤트가 해금되며, 배우자를 뱀파이어로 만들 수도 있습니다. 아이는 없다고 여러 정보원을 통해 확인됐으며, 추가할 계획도 발표되지 않았습니다. 이미 자녀가 있는 Orlock 같은 연상 캐릭터와 결혼하면 보고에 따르면 계부모가 됩니다.' },
  { q: '로맨스는 성별에 제한이 있나요?', a: '아니요. 데이트는 완전히 성별 중립적으로 설계되어 있어서, 자신의 뱀파이어 캐릭터를 어떻게 만들든 로맨스 가능한 주민 누구와도 연애할 수 있습니다.' },
  { q: '뱀파이어가 늑대인간과 로맨스를 나눌 수 있나요?', a: '네. 마을의 뱀파이어와 늑대인간은 사이가 좋지 않고 자주 다투는 편이라, Saga 같은 늑대인간과 로맨스를 나누는 것은 그 벽을 넘는 일이기도 합니다 — 그것이 매력이기도 합니다.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '로맨스', item: `${SITE.url}/ko/romance` },
  ] },
];
---
<Base
  title="문라이트 피크스 로맨스 — 23명의 로맨스 대상과 결혼"
  description="문라이트 피크스 로맨스 가이드: 확인된 23명의 로맨스 대상, 성별 중립적 데이트, 데이트 해금 하트 레벨 4 / 청혼 하트 레벨 8, 그리고 일곱 가문."
  path="/ko/romance"
  jsonLd={jsonLd}
  crumbs={[{ label: '로맨스 & 가문' }]}
  lang="ko"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">입문 · 하트</p>
      <h1>문라이트 피크스 <em>로맨스</em>와 일곱 가문</h1>
      <p class="intro">
        로맨스는 {GAME.title}의 대표적인 특징입니다: 확인된 23명의 로맨스 대상, 성별 중립적
        데이트, 그리고 결혼(단, 자녀는 없음)까지. 이 페이지는 캐릭터 데이터베이스에서 직접
        생성됩니다. 최종 업데이트: {SITE.updated}.
      </p>

      <h2>로맨스 시스템은 실제로 어떻게 작동하나요</h2>
      <p>
        출시 시점에 확인됨: 주민에게 말을 걸고 선물을 줘서 관계를 발전시키며, 최근 선물 내역과
        상대방의 반응을 보여주는 메뉴에 기록됩니다. <strong>하트 레벨 4</strong>에서 데이트가
        해금되며 — 미니게임 형태로 진행됩니다(예: 데이트 상대가 원하는 색으로 꽃다발 만들기)
        — 단순한 감상용 장면이 아닙니다. <strong>하트 레벨 8</strong>에서는 청혼이 해금되며,
        결혼은 일주일 이내에 이루어지고 마을의 뱀파이어와 늑대인간들이 참석합니다.
      </p>
      <p>
        여러 명과 동시에 데이트할 수 있습니다 — 상대방들이 이를 눈치채고 언급하지만, 엄격한
        라이벌 시스템이라기보다는 가벼운 질투 정도입니다. 결혼 자체는 엄격하게 일부일처제이며,
        데이트를 너무 자주 거절하면 이별로 이어집니다(냉랭한 시기를 거침). 결혼 후 배우자는
        내 농장으로 이사 오며 뱀파이어로 변할 수도 있습니다. 관계를 쌓으면 제작 도안과 재료도
        해금됩니다.
      </p>

      <h2>여기서 시작하세요: 로맨스 루트 계획하기</h2>
      <p>23명의 후보 중에서, 아직 완전한 선물/이벤트 데이터베이스가 없는 상태이니 후보를 좁히는 것이 모두 시도하는 것보다 낫습니다:</p>
      <div class="rp-steps">
        <a class="rp-step" href="/tools/romance-match-quiz">
          <span class="rp-step-num">1</span>
          <strong>퀴즈 풀기</strong>
          <span>실제 단서를 기반으로 한 재미있는 매칭으로 선택지를 좁혀보세요.</span>
        </a>
        <a class="rp-step" href="/tools/families-explorer">
          <span class="rp-step-num">2</span>
          <strong>가문별로 탐색하기</strong>
          <span>23명의 로맨스 대상을 실제 가문별로 묶어서 확인하세요.</span>
        </a>
        <a class="rp-step" href="/tools/romance-planner">
          <span class="rp-step-num">3</span>
          <strong>후보 목록 만들기</strong>
          <span>선택과 메모를 브라우저에 비공개로 저장하세요.</span>
        </a>
        <a class="rp-step" href="/tools/gift-tracker">
          <span class="rp-step-num">4</span>
          <strong>선물 기록하기</strong>
          <span>완전한 가이드가 나올 때까지 직접 발견한 정보를 기록하세요.</span>
        </a>
      </div>

      <h2>핵심 요약</h2>
      <p>
        23명의 주민이 로맨스 가능하며, 여섯 가문으로 나뉩니다 — 뱀파이어(Ambrosia), 늑대인간
        (Logan), 마녀(Webb), 인어(Hosu), 예언자(Khazan), 인간(Henderson) — 그리고 가문에 속하지
        않는 Death와 사랑의 악마 Llemi까지 두 명이 더 있습니다.
      </p>

      <h2>23명의 로맨스 대상, 가문별로</h2>
      <p>캐릭터 데이터베이스에서 직접 가져온 데이터입니다 — 각 이름을 클릭하면 전체 프로필(현재는 영어)로 이동합니다.</p>
      {familyGroups.map(([family, members]) => (
        <div class="romance-family-group">
          <h3>{familyNameKo[family] || family} <span class="rf-count">({members.length})</span></h3>
          <table class="facts">
            <tr><th>캐릭터</th><th>유형</th><th>상태</th></tr>
            {members.map((c) => (
              <tr>
                <td><a href={`/characters/${c.id}`}>{c.name}</a></td>
                <td>{typeKo[c.type] || typeLabels[c.type] || c.type}</td>
                <td>{statusKo[c.status] || c.status}</td>
              </tr>
            ))}
          </table>
        </div>
      ))}

      <h2>선물 가이드</h2>
      <p>
        대부분의 선물 목록은 아직 공개되지 않았습니다 — <strong>Saga</strong>가 처음으로 확인된
        캐릭터입니다(화이트 와인을 아주 좋아함). <a href="/characters/saga">프로필</a>을 확인하고
        <a href="/tools/gift-tracker">선물 기록 도구</a>로 직접 발견한 내용을 기록해보세요.
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        출시 후 업데이트되는 페이지로, 캐릭터 데이터베이스에서 생성됩니다. 관련 페이지:
        <a href="/characters">전체 캐릭터</a>, <a href="/families">일곱 가문</a>,
        <a href="/ko/beginner-guide">초보자 가이드</a>(한국어).
      </div>
    </div>
  </article>
  <style>
    .romance-family-group { margin: 20px 0; }
    .romance-family-group h3 { margin: 0 0 8px; }
    .rf-count { color: var(--muted); font-weight: 400; font-size: 0.85rem; }
    .rp-steps { display: grid; grid-template-columns: 1fr; gap: 10px; margin: 14px 0 24px; }
    @media (min-width: 640px) { .rp-steps { grid-template-columns: 1fr 1fr; } }
    .rp-step {
      display: flex; flex-direction: column; gap: 4px; border: 1px solid var(--line); border-radius: 14px;
      background: var(--surface); padding: 14px 16px; text-decoration: none; position: relative;
      transition: border-color .15s ease;
    }
    .rp-step:hover { border-color: color-mix(in srgb, var(--candle) 45%, var(--line)); }
    .rp-step-num {
      position: absolute; top: 12px; right: 14px; font-family: var(--mono); font-size: 0.7rem; color: var(--candle);
      border: 1px solid color-mix(in srgb, var(--candle) 40%, var(--line)); border-radius: 999px; width: 20px; height: 20px;
      display: flex; align-items: center; justify-content: center;
    }
    .rp-step strong { font-family: var(--display); font-weight: 600; font-size: 0.94rem; color: var(--mist); padding-right: 26px; }
    .rp-step span:last-child { font-size: 0.8rem; color: var(--faint); line-height: 1.4; }
  </style>
</Base>
