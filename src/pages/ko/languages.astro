---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const rows = [
  ['영어', '지원 언어로 확인됨 — 인터페이스, 자막, 이 가이드의 기본 용어.'],
  ['독일어', '공식 Steam 스토어 정보에 따라 지원 언어로 확인됨 — 독일어로 문라이트 피크스를 플레이할 수 있습니다.'],
  ['일본어', '지원 언어로 확인됨, 일본의 Steam·Switch 플레이어에게 중요.'],
  ['한국어', '공식 Steam 스토어 정보에 따라 지원 언어로 확인됨.'],
  ['중국어 간체', '지원 언어로 확인됨, 중국어권 Steam 이용자에게 중요.'],
  ['중국어 번체', '지원 언어로 확인됨, 대만·홍콩과 지역 스토어에 관련.'],
];

const faq = [
  {
    q: '문라이트 피크스는 어떤 언어를 지원하나요?',
    a: `확인됨: ${GAME.languages.join(', ')}. 언어별로 인터페이스, 자막, 음성 지원 범위는 공식 스토어에서 확인할 수 있습니다.`,
  },
  {
    q: '문라이트 피크스를 한국어로 플레이할 수 있나요?',
    a: '네, 확인됨 — 한국어는 공식 Steam 스토어 정보에 따라 공식 지원 언어 중 하나입니다.',
  },
  {
    q: '문라이트 피크스는 일본어로도 이용 가능한가요?',
    a: '네, 확인됨 — 일본어는 공식 지원 언어 중 하나이며, 일본의 Switch·Steam 출시에 특히 중요합니다.',
  },
  {
    q: '언어 지원이 출시 후에도 바뀔 수 있나요?',
    a: '가능하지만, 공식 출시 후에는 일반적이지 않습니다. 스토어의 언어 메타데이터는 향후 업데이트로 바뀔 수 있으며, 확인되면 이 페이지를 업데이트하겠습니다.',
  },
];

const steamUrl = 'https://store.steampowered.com/app/2209900/Moonlight_Peaks/';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '지원 언어', item: new URL('/ko/languages', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({
    '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a },
  })) },
];
---
<Base
  title="문라이트 피크스 지원 언어 - 독일어, 일본어, 한국어 등"
  description="문라이트 피크스 확인된 지원 언어: 영어, 독일어, 일본어, 한국어, 중국어 간체·번체까지."
  path="/ko/languages"
  jsonLd={jsonLd}
  crumbs={[{ label: '지원 언어' }]}
  lang="ko"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">출시 / 지원 언어</p>
      <h1><em>문라이트 피크스</em>가 지원하는 언어</h1>
      <p class="intro">
        출시 시점에 확인됨: {GAME.title}은 {GAME.languages.length}개 언어를 지원하며, 그중 한국어가
        포함되어 있습니다. 일본어, 중국어, 독일어, 영어를 찾는 플레이어에게 중요한 내용을
        정리했습니다.
      </p>

      <div class="callout">
        <strong>확인됨:</strong> 한국어는 공식 Steam 스토어 정보에 따라 공식 지원 언어에
        포함되어 있습니다 — 인터페이스, 자막, 음성의 정확한 범위는 공식 스토어에서 확인하세요.
      </div>

      <h2>지원 언어</h2>
      <table class="facts">
        {rows.map((row) => (<tr><th>{row[0]}</th><td>{row[1]}</td></tr>))}
      </table>

      <h2>구매 전에 왜 중요한가</h2>
      <p>
        언어 지원은 중요한 구매 결정 요소입니다. 많은 플레이어들이 Steam, Switch, Switch 2,
        Android에서 플레이하기 전에 자신의 언어로 편안하게 즐길 수 있는지 미리 알고 싶어합니다.
      </p>

      <h2>확인할 체크리스트</h2>
      <ul>
        <li>Steam 언어 표에서 인터페이스, 자막, 음성 항목을 확인하세요.</li>
        <li>Nintendo eShop과 Google Play는 따로 확인하세요.</li>
        <li>출시 후에는 아이템, 캐릭터, UI 용어를 실제 게임 화면에 맞게 조정하세요.</li>
        <li>한국어 검색 수요가 늘어나면 우선적으로 업데이트하세요.</li>
      </ul>

      <h2>관련 페이지</h2>
      <div class="link-grid">
        <a href="/ko/release-date">출시일</a>
        <a href="/ko/platforms">플랫폼</a>
        <a href="/ko/demo">데모 가이드</a>
        <a href="/ko/beginner-guide">초보자 가이드</a>
      </div>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </article>

  <style>
    .link-grid { display: grid; grid-template-columns: 1fr; gap: 10px; margin-top: 10px; }
    @media (min-width: 640px) { .link-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    .link-grid a { border: 1px solid var(--line); border-radius: 10px; background: var(--surface); color: var(--mist); padding: 12px 14px; text-decoration: none; }
    .link-grid a:hover { border-color: color-mix(in srgb, var(--candle) 55%, var(--line)); }
  </style>
</Base>
