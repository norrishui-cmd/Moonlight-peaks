---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';

const issueRows = [
  ['시작 시 크래시 (Steam Deck)', '플레이어 제보 · 임시 해결책 있음', '여러 플레이어가 시작 시 크래시를 제보합니다. 제보된 해결책: 호환성 도구를 Proton 9.0-4로 변경.'],
  ['몇 초마다 미세 끊김', '플레이어 제보 · 확인된 해결책 없음', '고성능 PC에서도 발생합니다 — 단순한 하드웨어 문제로 보이지 않습니다.'],
  ['컨트롤러가 반응하지 않음', '플레이어 제보 · 임시 해결책 있음', '캐릭터 생성 중에는 컨트롤러가 작동하지만 이후 반응하지 않습니다. 임시 해결책: 컨트롤러 재연결 또는 키보드/마우스로 전환.'],
];

const faq = [
  { q: 'Moonlight Peaks가 Steam Deck에서 크래시가 나요 — 어떻게 하나요?', a: '플레이어 제보: Steam의 게임 속성에서 호환성 항목의 Proton 도구를 9.0-4로 변경하세요.' },
  { q: '컨트롤러가 작동하지 않아요 — 무엇을 할 수 있나요?', a: '플레이어 제보, 미해결: 컨트롤러를 재연결하거나 임시로 키보드/마우스로 전환하세요.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '알려진 문제', item: `${SITE.url}/ko/known-issues` },
  ] },
];
---
<Base
  title="Moonlight Peaks 알려진 문제 — 크래시 & 컨트롤러 (한국어)"
  description="한국어로 보는 Moonlight Peaks 알려진 문제: Steam Deck 크래시, 컨트롤러 문제, 확인된 임시 해결책 — 확인된 것과 커뮤니티 제보를 명확히 구분."
  path="/ko/known-issues"
  jsonLd={jsonLd}
  crumbs={[{ label: '알려진 문제' }]}
  lang="ko"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">항목 / 문제</p>
      <h1>Moonlight Peaks <em>알려진 문제</em></h1>
      <p class="intro">
        확인된 버그, 크래시, 컨트롤러 문제를 추적합니다 — 확인된 내용과 플레이어 제보를
        명확히 구분합니다.
      </p>

      <table class="facts">
        <tr><th>문제</th><th>상태</th><th>세부 사항</th></tr>
        {issueRows.map((r) => (<tr><td>{r[0]}</td><td>{r[1]}</td><td>{r[2]}</td></tr>))}
      </table>

      <h2>저장 파일 위치</h2>
      <p>
        확인됨: Windows에서 저장 파일은
        <code>%USERPROFILE%/AppData/LocalLow/Little Chicken Game Company/Moonlight Peaks/</code>에
        있습니다.
      </p>

      <h2>자주 묻는 질문</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        더 알아보기: <a href="/ko/platforms">플랫폼</a>,
        <a href="/known-issues">전체 가이드(영어)</a>.
      </div>
    </div>
  </article>
</Base>
