---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Moonlight Peaks는 PS5나 Xbox에서 플레이할 수 있나요?',
    acceptedAnswer: { '@type': 'Answer', text: '아니요 — PlayStation이나 Xbox 버전은 발표되지 않았습니다. 확인된 플랫폼은 Steam, Steam Deck, Nintendo Switch, Nintendo Switch 2, Android입니다.' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: `${SITE.url}/ko/faq` },
  ] },
];
---
<Base
  title="Moonlight Peaks는 PS5나 Xbox에서 플레이할 수 있나요?"
  description="아니요 — Moonlight Peaks는 PS5나 Xbox에서 이용할 수 없습니다. 확인된 플랫폼: Steam, Steam Deck, Switch, Switch 2, Android."
  path="/ko/faq/is-moonlight-peaks-on-ps5-or-xbox"
  jsonLd={jsonLd}
  crumbs={[{ label: 'FAQ', href: '/ko/faq' }, { label: 'PS5/Xbox' }]}
  lang="ko"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">FAQ</p>
      <h1>Moonlight Peaks는 <em>PS5나 Xbox</em>에서 플레이할 수 있나요?</h1>
      <p class="intro">
        결론부터 말하면: 아니요. PlayStation이나 Xbox 버전은 발표되지 않았습니다. 확인된
        플랫폼은 Steam, Steam Deck, Nintendo Switch, Nintendo Switch 2, Android입니다.
      </p>
      <p>추후 PS5나 Xbox 버전이 발표되면 이 페이지를 업데이트하겠습니다.</p>
      <div class="callout wip">
        더 알아보기: <a href="/ko/platforms">플랫폼</a>,
        <a href="/ko/release-date">출시일</a>.
      </div>
    </div>
  </article>
</Base>
