---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';
import { faqs } from '../../../data/faq';
import { faqKo } from '../../../i18n/faq-ko';

const catLabelKo: Record<string, string> = {
  platforms: '플랫폼, 가격 & 데모', romance: '로맨스 & 결혼', characters: '캐릭터',
  world: '세계 & 게임플레이', farming: '농사 & 경제', general: '일반',
};
const cats = ['platforms', 'romance', 'characters', 'world', 'farming', 'general'] as const;
const translated = faqs.filter((f) => faqKo[f.slug]);
const plain = (slug: string) => {
  const tr = faqKo[slug];
  return [tr.a, ...(tr.more || [])].join(' ');
};

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '자주 묻는 질문', item: `${SITE.url}/ko/faq` },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: translated.map((f) => ({
    '@type': 'Question', name: faqKo[f.slug].q, acceptedAnswer: { '@type': 'Answer', text: plain(f.slug) },
  })) },
];
---
<Base
  title="Moonlight Peaks FAQ — 출시, 로맨스, 데모 & 더 보기"
  description="Moonlight Peaks에 대해 가장 자주 묻는 질문들에 대한 답변: 출시일, 가격, 플랫폼, 멀티플레이어, 전투, 결혼, 로맨스 옵션, 데모, 게임플레이."
  path="/ko/faq"
  jsonLd={jsonLd}
  crumbs={[{ label: '자주 묻는 질문' }]}
  lang="ko"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">허브 · FAQ</p>
      <h1>{GAME.title} <em>FAQ</em></h1>
      <p class="intro">
        2026년 7월 7일 출시 이후 플레이어들이 {GAME.title}에 대해 가장 자주 묻는 질문에 대한
        빠르고 출처가 명확한 답변입니다. 모든 질문은 각자의 페이지를 가지고 있습니다. 확인되거나
        제보된 내용만 답하며, 아직 알려지지 않은 것은 추측하지 않고 표시합니다.
        최근 업데이트: {SITE.updated}.
      </p>

      <h2>이 FAQ 사용 방법</h2>
      <p>
        빠른 답변이 필요할 때 이 페이지를 이용한 다음, 더 자세한 내용을 위해 연결된 가이드를
        열어보세요. 플랫폼과 데모 관련 질문은 대개 출시 페이지로, 로맨스와 캐릭터 관련 질문은
        선물, 일정, 하트 이벤트, 가문 페이지로 이어집니다.
      </p>

      {cats.map((cat) => {
        const items = translated.filter((f) => f.cat === cat);
        if (items.length === 0) return null;
        return (
          <section class="grp">
            <div class="grp-head"><h2>{catLabelKo[cat]}</h2><span class="note">{items.length}개 질문</span></div>
            <ul class="q-list">
              {items.map((f) => (
                <li><a href={`/ko/faq/${f.slug}`}>{faqKo[f.slug].q}</a></li>
              ))}
            </ul>
          </section>
        );
      })}

      <div class="callout wip">
        현재 {translated.length}개의 FAQ 항목이 한국어로 번역되어 있습니다. 영어 버전은
        전체 {faqs.length}개 항목을 제공합니다 — <a href="/faq">영어 FAQ 페이지</a>.
      </div>
    </div>
  </article>

  <style>
    .grp { margin: 28px 0; }
    .grp-head { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; border-bottom: 1px solid var(--line); padding-bottom: 6px; margin-bottom: 10px; }
    .grp-head h2 { margin: 0; }
    .note { font-family: var(--mono); font-size: 0.72rem; color: var(--faint); white-space: nowrap; }
    .q-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; }
    .q-list a { display: block; padding: 8px 0; color: var(--mist); text-decoration: none; border-bottom: 1px dashed var(--line); }
    .q-list a:hover { color: var(--candle); }
  </style>
</Base>
