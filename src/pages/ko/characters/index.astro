---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';
import { characters, type CharType } from '../../../data/characters';
import { charTranslations } from '../../../i18n/characters-data';

const koTranslations = charTranslations.ko;
const translatedSlugs = new Set(Object.keys(koTranslations));

const typeLabelsKo: Record<CharType, string> = {
  vampire: '뱀파이어', werewolf: '늑대인간', witch: '마녀', mermaid: '인어',
  seer: '예언자', ghost: '유령', human: '인간', other: '기타',
};
const familyLabelKo = (family: string): string => {
  if (family.includes('Vampire')) return '뱀파이어 가문 (Ambrosia)';
  if (family.includes('Werewolf')) return '늑대인간 가문 (Logan)';
  if (family.includes('Witch')) return '마녀 가문 (Webb)';
  if (family.includes('Mermaid')) return '인어 가문 (Hosu)';
  if (family.includes('Seer')) return '예언자 가문 (Khazan)';
  if (family.includes('Human')) return '인간 가문 (Henderson)';
  return '가문 없음';
};

const isMainCast = (c: (typeof characters)[number]) => c.romanceable === true || c.id === 'count-dracula';
const translated = characters.filter((c) => translatedSlugs.has(c.id));
const untranslated = characters.filter((c) => !translatedSlugs.has(c.id));
const mainCast = translated.filter(isMainCast);
const npcs = translated.filter((c) => !isMainCast(c));

function displayName(c: (typeof characters)[number]): string {
  return translatedSlugs.has(c.id) ? koTranslations[c.id].name : c.name;
}

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '캐릭터', item: `${SITE.url}/ko/characters` },
  ],
};
---
<Base
  title="문라이트 피크스 캐릭터 (전체 주민) - 뱀파이어의 고딕 라이프"
  description="문라이트 피크스의 확인된 전체 주민 한국어 프로필: 23명의 로맨스 대상과 그 외 NPC까지."
  path="/ko/characters"
  jsonLd={jsonLd}
  crumbs={[{ label: '캐릭터' }]}
  lang="ko"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">입문 / 캐릭터</p>
      <h1>{GAME.title} <em>캐릭터</em> (전체 주민)</h1>
      <p class="intro">
        확인된 전체 주민을 로맨스 대상과 그 외 NPC로 나누어 정리했습니다. {translated.length}명의
        프로필이 한국어로 완전히 번역되어 있습니다.
      </p>

      <h2>로맨스 대상 & 주요 캐릭터 ({mainCast.length})</h2>
      <div class="cx-grid">
        {mainCast.map((c) => (
          <a class="cx-card" href={`/ko/characters/${c.id}`}>
            <span class="cx-thumb">
              {c.img ? <img src={c.img} alt="" loading="lazy" width="72" height="72" /> : <span class="cx-letter" style={`background: linear-gradient(135deg, ${c.c1}, ${c.c2})`}>{displayName(c).charAt(0)}</span>}
            </span>
            <span>
              <strong>{displayName(c)}</strong>
              <em>{familyLabelKo(c.family)} · {typeLabelsKo[c.type]}</em>
            </span>
          </a>
        ))}
      </div>

      <h2>그 외 NPC ({npcs.length})</h2>
      <div class="cx-grid">
        {npcs.map((c) => (
          <a class="cx-card" href={`/ko/characters/${c.id}`}>
            <span class="cx-thumb">
              {c.img ? <img src={c.img} alt="" loading="lazy" width="72" height="72" /> : <span class="cx-letter" style={`background: linear-gradient(135deg, ${c.c1}, ${c.c2})`}>{displayName(c).charAt(0)}</span>}
            </span>
            <span>
              <strong>{displayName(c)}</strong>
              <em>{familyLabelKo(c.family)} · {typeLabelsKo[c.type]}</em>
            </span>
          </a>
        ))}
      </div>

      {untranslated.length > 0 && (
        <div class="callout wip">
          {translated.length}명의 프로필이 한국어로 번역되어 있습니다. 나머지 {untranslated.length}명은
          <a href="/characters">영어 캐릭터 페이지</a>로 연결되며, 그곳에서 가장 상세한 확인된 정보를
          볼 수 있습니다(Kai, Celine처럼 아직 실제 내용이 없는 미확인 플레이스홀더 캐릭터 포함).
        </div>
      )}
    </div>
  </article>

  <style>
    .cx-grid { display: grid; grid-template-columns: 1fr; gap: 10px; margin: 8px 0 24px; }
    @media (min-width: 640px) { .cx-grid { grid-template-columns: 1fr 1fr; } }
    .cx-card { display: flex; align-items: center; gap: 12px; border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 12px; transition: border-color .15s ease; }
    .cx-card:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); }
    .cx-thumb { flex: 0 0 auto; width: 72px; height: 72px; border-radius: 10px; overflow: hidden; display: flex; align-items: center; justify-content: center; }
    .cx-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .cx-letter { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-family: var(--display); font-weight: 700; font-size: 1.6rem; color: rgba(255,255,255,0.9); }
    .cx-card span:not(.cx-thumb) { display: flex; flex-direction: column; }
    .cx-card strong { font-family: var(--display); font-weight: 600; font-size: 0.96rem; color: var(--mist); }
    .cx-card em { font-style: normal; font-size: 0.78rem; color: var(--faint); margin-top: 2px; }
  </style>
</Base>
