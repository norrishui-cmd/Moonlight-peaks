---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { characters } from '../../../data/characters';
import { charTranslations } from '../../../i18n/characters-data';

export function getStaticPaths() {
  return Object.keys(charTranslations.ko).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const base = characters.find((c) => c.id === slug)!;
const tr = charTranslations.ko[slug as keyof typeof charTranslations.ko];

const url = new URL(`/ko/characters/${slug}`, SITE.url).href;
const imgAbs = base.img ? new URL(base.img, SITE.url).href : undefined;
const statusLabel =
  base.status === 'confirmed' ? '확인됨'
  : base.status === 'reported' ? '보고됨'
  : base.status === 'datamined' ? '데이터마이닝'
  : '미확인';
const romanceText = base.romanceable === true ? tr.romanceYes : base.romanceable === false ? tr.romanceNo : tr.romanceTbc;

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '캐릭터', item: `${SITE.url}/ko/characters` },
    { '@type': 'ListItem', position: 3, name: tr.name, item: url },
  ] },
  { '@context': 'https://schema.org', '@type': 'Person', name: tr.name, description: tr.desc, ...(imgAbs ? { image: imgAbs } : {}) },
];
---
<Base
  title={`${tr.name} - 문라이트 피크스 캐릭터 가이드`}
  description={`문라이트 피크스 ${tr.name}: ${tr.desc} 가문, 로맨스 가능 여부, 현재까지 확인된 정보.`}
  path={`/ko/characters/${slug}`}
  jsonLd={jsonLd}
  ogImage={base.img}
  crumbs={[{ label: '캐릭터', href: '/ko/characters' }, { label: tr.name }]}
  lang="ko"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">캐릭터 · {tr.typeLabel}</p>

      <div class="chead">
        <div class="cavatar">
          {base.img ? (
            <img src={base.img} alt={`${tr.name} 초상화`} width="160" height="160" />
          ) : (
            <span class="fallback-avatar" style={`background: linear-gradient(135deg, ${base.c1}, ${base.c2})`}>{tr.name.charAt(0)}</span>
          )}
        </div>
        <div class="cmeta">
          <h1>{tr.name}</h1>
          <div class="ctags">
            <span class={`cbadge ${base.status === 'confirmed' ? 'is-conf' : base.status === 'reported' ? 'is-rep' : base.status === 'datamined' ? 'is-dm' : 'is-unc'}`}>{statusLabel}</span>
            <span class="ctag fam">{tr.familyLabel}</span>
            {base.romanceable === true && <span class="ctag heart">로맨스 대상</span>}
            {base.romanceable === false && <span class="ctag">로맨스 불가</span>}
            {base.romanceable === null && <span class="ctag">로맨스 여부 미확인</span>}
          </div>
          <p class="cdesc">{tr.desc}</p>
        </div>
      </div>

      <h2>확인된 정보</h2>
      <ul>{tr.knownInfo.map((k) => (<li>{k}</li>))}</ul>

      <h2>로맨스 정보</h2>
      <p>{romanceText}</p>

      {(base.lovedGifts?.length || base.likedGifts?.length || base.dislikedGifts?.length) && (
        <>
          <h2>선물 선호도</h2>
          {base.lovedGifts && base.lovedGifts.length > 0 && (
            <p><strong>최애:</strong> {base.lovedGifts.join(', ')}</p>
          )}
          {base.likedGifts && base.likedGifts.length > 0 && (
            <p><strong>선호:</strong> {base.likedGifts.join(', ')}</p>
          )}
          {base.dislikedGifts && base.dislikedGifts.length > 0 && (
            <p><strong>비선호:</strong> {base.dislikedGifts.join(', ')}</p>
          )}
          <p class="cnote">국제 언론(TheGamer, 2026년 7월 7일 게재)의 출시 주간 테스트를 기반으로 확인된 데이터입니다.</p>
        </>
      )}

      <div class="callout">
        관련 페이지: <a href="/ko/characters">캐릭터 개요</a>, <a href="/romance">로맨스 가이드</a>,
        <a href="/families">가문</a>, <a href="/characters">영어 상세 버전</a>.
      </div>
    </div>
  </article>
</Base>
