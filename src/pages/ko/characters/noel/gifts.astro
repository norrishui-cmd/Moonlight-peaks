---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Noel이 가장 좋아하는 선물은 무엇인가요?',
    acceptedAnswer: { '@type': 'Answer', text: 'Noel은 황금 달걀(Golden Egg)을 무엇보다 좋아합니다.' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '캐릭터', item: `${SITE.url}/ko/characters` },
    { '@type': 'ListItem', position: 3, name: 'Noel', item: `${SITE.url}/ko/characters/noel` },
  ] },
];
---
<Base
  title="Noel이 좋아하는 선물 | Moonlight Peaks 캐릭터 가이드"
  description="Moonlight Peaks에서 Noel의 확인된 선물 선호도 — 최고로 좋아하는 것, 좋아하는 것, 피해야 할 것."
  path="/ko/characters/noel/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: '캐릭터', href: '/ko/characters' }, { label: 'Noel', href: '/ko/characters/noel' }, { label: '선물' }]}
  lang="ko"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">캐릭터 · 선물</p>
      <h1>Noel이 좋아하는 <em>선물</em></h1>
      <p class="intro">출시 주간 테스트를 바탕으로 확인된 Noel의 선물 데이터입니다.</p>

      <h2>최고로 좋아함</h2>
      <p>Noel이 최고로 좋아하는 것으로 확인됨: 황금 달걀(Golden Egg). 관계를 빠르게 깊어지게 하는 가장 효과적인 선택입니다.</p>

      <h2>좋아함</h2>
      <p>최고 선호 선물 외에도 Noel은 다음을 좋아합니다: Blood Grape, Blood Grape 주스, 딸기 주스, Glibby 물고기.</p>

      <h2>싫어함</h2>
      <p>Noel에게 피해야 할 것: 보라색 튤립과 분홍색 아잘레아 — 대부분의 다른 캐릭터에게는 인기 있는 꽃이지만 그에게는 확인된 비선호 선물입니다.</p>

      <div class="callout wip">
        관련 페이지: <a href="/ko/characters/noel">Noel 프로필</a>,
        <a href="/ko/characters">모든 캐릭터</a>, <a href="/characters/noel/gifts">영어 전체 버전</a>.
      </div>
    </div>
  </article>
</Base>
