---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Fiona가 가장 좋아하는 선물은 무엇인가요?',
    acceptedAnswer: { '@type': 'Answer', text: 'Fiona는 딸기(Strawberries)를 무엇보다 좋아합니다.' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '캐릭터', item: `${SITE.url}/ko/characters` },
    { '@type': 'ListItem', position: 3, name: 'Fiona', item: `${SITE.url}/ko/characters/fiona` },
  ] },
];
---
<Base
  title="Fiona가 좋아하는 선물 | Moonlight Peaks 캐릭터 가이드"
  description="Moonlight Peaks에서 Fiona의 확인된 선물 선호도 — 최고로 좋아하는 것, 좋아하는 것, 피해야 할 것."
  path="/ko/characters/fiona/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: '캐릭터', href: '/ko/characters' }, { label: 'Fiona', href: '/ko/characters/fiona' }, { label: '선물' }]}
  lang="ko"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">캐릭터 · 선물</p>
      <h1>Fiona가 좋아하는 <em>선물</em></h1>
      <p class="intro">출시 주간 테스트를 바탕으로 확인된 Fiona의 선물 데이터입니다.</p>

      <h2>최고로 좋아함</h2>
      <p>Fiona가 최고로 좋아하는 것으로 확인됨: 딸기(Strawberries).</p>

      <h2>좋아함</h2>
      <p>최고 선호 선물 외에도 Fiona는 다음을 좋아합니다: 보라색 튤립, 보라색 아잘레아, 보라색 라벤더, 달걀, 문 주스(Moon Juice).</p>

      <h2>싫어함</h2>
      <p>Fiona에게 피해야 할 것: 양파 씨앗. 확인됨 — 호감도가 낮아집니다.</p>

      <div class="callout wip">
        관련 페이지: <a href="/ko/characters/fiona">Fiona 프로필</a>,
        <a href="/ko/characters">모든 캐릭터</a>, <a href="/characters/fiona/gifts">영어 전체 버전</a>.
      </div>
    </div>
  </article>
</Base>
