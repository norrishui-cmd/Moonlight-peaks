---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';
import { faqs, faqCatLabels, type FaqCat } from '../../data/faq';
import { faqKo } from '../../i18n/faq-ko';

const catLabelKo: Record<FaqCat, string> = {
  platforms: '플랫폼, 가격 & 데모',
  romance: '로맨스 & 결혼',
  characters: '캐릭터',
  world: '세계관 & 게임플레이',
  farming: '농사 & 경제',
  general: '일반',
  quests: '퀘스트 & 진행',
};

const cats: FaqCat[] = ['platforms', 'romance', 'characters', 'world', 'farming', 'quests', 'general'];
const translatedFaqs = faqs.filter((f) => faqKo[f.slug]);

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '자주 묻는 질문', item: new URL('/ko/faq', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: translatedFaqs.map((f) => ({
    '@type': 'Question', name: faqKo[f.slug].q,
    acceptedAnswer: { '@type': 'Answer', text: [faqKo[f.slug].a, ...(faqKo[f.slug].more || [])].join(' ') },
  })) },
];
---
<Base
  title="문라이트 피크스 — 자주 묻는 질문 전체 (FAQ)"
  description="문라이트 피크스 전체 FAQ 한국어판: 플랫폼, 로맨스, 캐릭터, 세계관, 농사, 퀘스트까지 카테고리별로 정리했습니다."
  path="/ko/faq"
  jsonLd={jsonLd}
  crumbs={[{ label: '자주 묻는 질문' }]}
  lang="ko"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">입문 · FAQ</p>
      <h1>문라이트 피크스 <em>전체 FAQ</em></h1>
      <p class="intro">
        {GAME.title}에 대한 {translatedFaqs.length}개의 질문과 답변을 카테고리별로 정리했습니다.
        추측이 아니라 확인된 사실을 기반으로 하며, 미확인 정보는 명확히 표시합니다. 최종 업데이트:
        {SITE.updated}.
      </p>

      <nav class="faq-jump" aria-label="FAQ 카테고리">
        {cats.map((cat) => {
          const count = translatedFaqs.filter((f) => f.cat === cat).length;
          return count > 0 ? <a href={`#${cat}`}>{catLabelKo[cat]} <span>{count}</span></a> : null;
        })}
      </nav>

      {cats.map((cat) => {
        const items = translatedFaqs.filter((f) => f.cat === cat);
        if (items.length === 0) return null;
        return (
          <section id={cat} class="faq-category">
            <h2>{catLabelKo[cat]}</h2>
            <div class="faq">
              {items.map((f) => (
                <details>
                  <summary>{faqKo[f.slug].q}</summary>
                  <p>{faqKo[f.slug].a}</p>
                  {faqKo[f.slug].more?.map((m) => <p>{m}</p>)}
                </details>
              ))}
            </div>
          </section>
        );
      })}

      <div class="callout wip">
        영문판과 동일한 {translatedFaqs.length}개 질문을 한국어로 번역했습니다. 각 질문의 상세 페이지는
        <a href="/faq">영문판 FAQ</a>에서도 확인할 수 있습니다.
        관련: <a href="/ko/beginner-guide">초보자 가이드</a>, <a href="/ko/romance">로맨스</a>.
      </div>
    </div>
  </article>

  <style>
    .faq-jump { display: flex; flex-wrap: wrap; gap: 8px; margin: 18px 0 28px; }
    .faq-jump a { border: 1px solid var(--line); border-radius: 999px; color: var(--mist); background: var(--surface); padding: 7px 12px; text-decoration: none; font-family: var(--mono); font-size: 0.76rem; }
    .faq-jump a:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); color: var(--candle); }
    .faq-jump span { color: var(--faint); margin-left: 4px; }
    .faq-category { margin: 28px 0; padding-top: 20px; border-top: 1px solid var(--line); }
    .faq-category:first-of-type { border-top: none; padding-top: 0; }
  </style>
</Base>
