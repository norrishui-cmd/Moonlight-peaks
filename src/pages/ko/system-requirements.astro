---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const checklist = [
  ['스토어 페이지', '구매나 가이드 업데이트 전 최종 확인 자료로 공식 Steam 페이지를 이용하세요.'],
  ['Windows / Mac', 'Moonlight Peaks는 PC와 Mac용 Steam에 등록되어 있습니다. OS, 프로세서, 메모리, 그래픽, DirectX, 저장 공간의 정확한 사항은 현재 Steam 사양 패널을 확인하세요.'],
  ['Steam Deck', 'Valve가 최종 호환성 등급을 표시할 때까지 Steam Deck 상태는 계속 확인해야 할 사항으로 간주하세요.'],
  ['컨트롤러', '구매 전 게임패드 편의성, 텍스트 가독성, UI 스케일링을 확인하는 데 데모가 유용합니다.'],
  ['저장 공간', '공식 스토어 페이지나 릴리스 노트에 나와 있지 않은 한 정확한 저장 공간 수치는 게시하지 않습니다.'],
];

const faq = [
  { q: 'Moonlight Peaks의 시스템 요구 사항은 무엇인가요?', a: '현재 Windows와 Mac 시스템 요구 사항은 공식 Steam 스토어 페이지를 확인하세요. 이 페이지는 하드웨어 수치를 지어내지 않고 확인해야 할 사항을 추적합니다.' },
  { q: 'Moonlight Peaks는 Mac에서 실행되나요?', a: 'Moonlight Peaks는 PC와 Mac용 Steam에 등록되어 있습니다. 정확한 Mac 버전 및 하드웨어 요구 사항은 현재 Steam 페이지에서 확인하세요.' },
  { q: 'Moonlight Peaks는 Steam Deck 인증을 받았나요?', a: 'Steam Deck 지원 여부는 직접 확인하세요. 게임은 Steam에 있지만 최종 Deck 호환성 등급은 Valve/스토어 신호입니다.' },
  { q: '성능 테스트를 위해 데모를 사용해야 하나요?', a: '네. 무료 데모는 구매 전 자신의 기기에서 조작감, 텍스트 크기, 카메라 편의성, 전반적인 성능을 테스트하는 가장 안전한 방법입니다.' },
];

const steamUrl = 'https://store.steampowered.com/app/2209900/Moonlight_Peaks/';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/ko` },
    { '@type': 'ListItem', position: 2, name: '시스템 요구 사항', item: new URL('/ko/system-requirements', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({
    '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a },
  })) },
];
---
<Base
  title="Moonlight Peaks 시스템 요구 사항 - PC, Mac, Steam Deck"
  description="Steam PC, Mac용 Moonlight Peaks 시스템 요구 사항, Steam Deck 확인 사항, 데모 테스트, 구매 전 확인해야 할 사항."
  path="/ko/system-requirements"
  jsonLd={jsonLd}
  crumbs={[{ label: '시스템 요구 사항' }]}
  lang="ko"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">출시 / 시스템 요구 사항</p>
      <h1>Moonlight Peaks <em>시스템 요구 사항</em></h1>
      <p class="intro">
        {GAME.title}가 PC, Mac, Steam Deck에서 실행되는지 확인하는 플레이어를 위한 믿을 수
        있는 요구 사항 페이지입니다. 스토어 메타데이터는 출시 직전에 바뀔 수 있으므로 정확한
        하드웨어 수치는 항상 공식 Steam 페이지로 확인하세요.
      </p>

      <h2>공식 자료를 먼저 확인하세요</h2>
      <p>
        현재 시스템 요구 사항, 지원 플랫폼, 데모 이용 가능 여부, 출시 시기는 공식 Steam
        페이지를 이용하세요. 이 페이지는 의도적으로 신중합니다: 무엇을 확인해야 하는지와 데모
        테스트 방법을 알려주지만, 공식 자료에서 확인되지 않은 CPU, GPU, RAM, 저장 공간, OS
        수치는 지어내지 않습니다.
      </p>
      <p><a href={steamUrl} target="_blank" rel="noopener noreferrer nofollow">공식 Steam 페이지 열기</a></p>

      <h2>구매 전 체크리스트</h2>
      <table class="facts">
        {checklist.map((row) => (<tr><th>{row[0]}</th><td>{row[1]}</td></tr>))}
      </table>

      <h2>데모로 테스트하는 방법</h2>
      <p>
        데모는 여러분의 실제 하드웨어에서 실행되므로 가장 유용한 실전 테스트입니다. 이동,
        메뉴, 텍스트 가독성, 컨트롤러 편의성, 낚시, 꽃꽂이, 자수, 캐릭터 생성을 테스트해
        보세요. 이동 중에 플레이하고 싶다면, 데스크톱 녹화만 보고 판단하기보다 정확히 그
        환경에서 데모를 테스트하세요.
      </p>
      <ul>
        <li><strong>PC:</strong> 해상도, 프레임 페이싱, 마우스/키보드 편의성, 로딩 시간을 확인하세요.</li>
        <li><strong>Mac:</strong> Steam에서 정확한 Mac 요구 사항을 확인한 후, 가능하다면 데모를 테스트하세요.</li>
        <li><strong>Steam Deck:</strong> 조작감, 텍스트 크기, 배터리 편의성, 그리고 출시 후 최종 Deck 등급을 확인하세요.</li>
      </ul>

      <h2>관련 출시 페이지</h2>
      <div class="link-grid">
        <a href="/ko/release-date">출시일</a>
        <a href="/ko/demo">데모 가이드</a>
        <a href="/ko/platforms">플랫폼</a>
        <a href="/ko/languages">언어</a>
        <a href="/ko/beginner-guide">초보자 가이드</a>
      </div>

      <h2>자주 묻는 질문</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </article>

  <style>
    .link-grid { display: grid; grid-template-columns: 1fr; gap: 10px; margin-top: 10px; }
    @media (min-width: 640px) { .link-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    .link-grid a { border: 1px solid var(--line); border-radius: 10px; background: var(--surface); color: var(--mist); padding: 12px 14px; text-decoration: none; }
    .link-grid a:hover { border-color: color-mix(in srgb, var(--candle) 55%, var(--line)); }
  </style>
</Base>
