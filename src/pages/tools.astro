---
import Base from '../layouts/Base.astro';
import { SITE } from '../consts';

const tools = [
  {
    href: '/tools/platform-picker',
    tag: 'Decision helper',
    title: 'Platform Picker',
    text: 'Answer a few practical questions and get a launch-safe platform recommendation for Steam, Steam Deck, Switch, Switch 2, or Android.',
    status: 'Live',
    icon: 'TV',
    accent: 'gold',
    points: ['Steam / Deck / Switch', 'Launch-safe picks'],
  },
  {
    href: '/tools/romance-gift-finder',
    tag: 'Relationship planner',
    title: 'Romance Gift Finder',
    text: 'Choose a resident and see romance status, family clues, verified-gift status, and what to check first when the full game launches.',
    status: 'Live',
    icon: 'Heart',
    accent: 'rose',
    points: ['Gift status', 'Resident filters'],
  },
  {
    href: '/tools/romance-match-quiz',
    tag: 'Just for fun',
    title: 'Romance Match Quiz',
    text: 'Six quick questions matched against sourced personality hints to find which resident fits your vibe before launch.',
    status: 'Live',
    icon: 'Quiz',
    accent: 'violet',
    points: ['Personality quiz', 'Sourced hints'],
  },
  {
    href: '/tools/romance-planner',
    tag: 'Relationship planner',
    title: 'Romance Planner',
    text: 'Shortlist your picks, add private notes, and check off launch-day prep saved locally in your browser.',
    status: 'Live',
    icon: 'Plan',
    accent: 'blue',
    points: ['Private notes', 'Local checklist'],
  },
  {
    href: '/tools/item-tracker',
    tag: 'Collection helper',
    title: 'Item Tracker',
    text: 'Track fish, critters, recipes, potions, artifacts, mineables, decorations, and other item categories locally.',
    status: 'Live',
    icon: 'List',
    accent: 'green',
    points: ['Collection progress', 'Local save'],
  },
  {
    href: '/tools/farming-profit-planner',
    tag: 'Farming calculator',
    title: 'Farming Profit Planner',
    text: 'Compare crop profit by seed price, sell price, growth days, harvest count, and extra costs once data is verified.',
    status: 'Live',
    icon: 'Calc',
    accent: 'amber',
    points: ['Profit/day', 'Crop comparison'],
  },
  {
    href: '/tools/submit-data',
    tag: 'Community workflow',
    title: 'Data Submitter',
    text: 'Save local launch-week drafts for fish, gifts, recipes, locations, bugs, shops, and other findings before manual review.',
    status: 'Live',
    icon: 'Data',
    accent: 'teal',
    points: ['Draft evidence', 'Manual review'],
  },
  {
    href: '/tools/families-explorer',
    tag: 'Reference tool',
    title: 'Seven Families Explorer',
    text: 'Browse every named resident grouped by the seven supernatural families — Ambrosia, Webb, Logan, Khazan, Horseus and more — filterable by type and romance status.',
    status: 'Live',
    icon: 'Tree',
    accent: 'green',
    points: ['Family groupings', 'Filter by type'],
  },
  {
    href: '/tools/gift-tracker',
    tag: 'Personal log',
    title: 'Gift Tracker',
    text: 'Confirmed gift lists aren\u2019t fully public yet — log your own gift-testing results per resident, saved privately in your browser.',
    status: 'Live',
    icon: 'Gift',
    accent: 'rose',
    points: ['Per-resident log', 'Local save'],
  },
  {
    href: '/tools/nokturna-tracker',
    tag: 'Personal log',
    title: 'Nokturna Collection Tracker',
    text: 'Over 67 confirmed Nokturna cards exist, but names aren\u2019t public yet — log your own collection as you win cards, saved privately in your browser.',
    status: 'Live',
    icon: 'Cards',
    accent: 'violet',
    points: ['Personal collection', 'Local save'],
  },
  {
    href: '/demo',
    tag: 'Demo prep',
    title: 'Demo Guide',
    text: 'Use the demo hub for download notes, what carries over, and the most useful things to test before launch.',
    status: 'Guide',
    icon: 'Demo',
    accent: 'silver',
    points: ['Download notes', 'Demo limits'],
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Tools', item: new URL('/tools', SITE.url).href },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Moonlight Peaks Tools',
    description: 'Interactive Moonlight Peaks tools for platform decisions, romance planning, gifts, item tracking, farming, and launch data collection.',
    url: new URL('/tools', SITE.url).href,
  },
];
---
<Base
  title="Moonlight Peaks Tools - Platform Picker, Romance Gifts & Player Helpers | Moonlight Peaks Wiki & Guide"
  description="Interactive Moonlight Peaks tools, including a platform picker, romance gift finder, item tracker, farming calculator, and launch data submitter."
  path="/tools"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Tools' }]}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Tools / Player helpers</p>
      <h1>Moonlight Peaks <em>tools</em></h1>
      <p class="intro">
        Practical helpers for players who want an answer, not another generic page. These tools are built to stay useful before and after launch:
        confirmed facts stay separate from data that still needs live-game verification.
      </p>

      <section class="tool-grid" aria-label="Moonlight Peaks tools">
        {tools.map((tool) => (
          <a class={`tool-card is-${tool.accent}`} href={tool.href}>
            <span class="tool-status">{tool.status}</span>
            <span class="tool-banner">
              <span class="tool-icon" aria-hidden="true">{tool.icon}</span>
              <span class="tool-tag">{tool.tag}</span>
            </span>
            <strong>{tool.title}</strong>
            <span class="tool-text">{tool.text}</span>
            <span class="tool-points">
              {tool.points.map((point) => <span>{point}</span>)}
            </span>
            <em>Open tool <span aria-hidden="true">-&gt;</span></em>
          </a>
        ))}
      </section>

      <h2>Why these tools are different</h2>
      <div class="tool-notes">
        <div>
          <h3>Built around decisions</h3>
          <p>Each tool answers a player question: where to buy, who to romance, what gift data is trustworthy, and what still needs checking.</p>
        </div>
        <div>
          <h3>No fake certainty</h3>
          <p>Pre-launch pages avoid inventing loved gifts or final performance claims. Unknown details are clearly marked so the pages can be updated cleanly.</p>
        </div>
        <div>
          <h3>Ready for launch updates</h3>
          <p>After July 7, 2026, the same URLs can be expanded with verified gift tables, platform performance, and checklist data.</p>
        </div>
      </div>

      <div class="callout">
        Related hubs: <a href="/platforms">platforms</a>, <a href="/romance">romance</a>, <a href="/characters">characters</a>, and <a href="/demo">demo guide</a>.
      </div>
    </div>
  </article>

  <style>
    .tool-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin: 30px 0 36px; }
    @media (max-width: 980px) { .tool-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 680px) { .tool-grid { grid-template-columns: 1fr; } }
    .tool-card {
      --accent: var(--candle);
      --accent-soft: rgba(244, 202, 104, 0.14);
      position: relative;
      min-height: 258px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 18px;
      border: 1px solid color-mix(in srgb, var(--accent) 34%, var(--line));
      border-radius: var(--radius);
      background:
        linear-gradient(135deg, var(--accent-soft), rgba(33, 24, 45, 0.44) 48%, rgba(14, 10, 19, 0.36)),
        linear-gradient(180deg, var(--surface), var(--ink-2));
      overflow: hidden;
      transition: transform .16s ease, border-color .16s ease, box-shadow .16s ease;
    }
    .tool-card::before {
      content: "";
      position: absolute;
      inset: 0 0 auto;
      height: 5px;
      background: linear-gradient(90deg, var(--accent), transparent);
    }
    .tool-card::after {
      content: "";
      position: absolute;
      right: -34px;
      top: -38px;
      width: 124px;
      height: 124px;
      border: 1px solid color-mix(in srgb, var(--accent) 38%, transparent);
      border-radius: 999px;
      background: color-mix(in srgb, var(--accent) 10%, transparent);
      pointer-events: none;
    }
    .tool-card:hover {
      transform: translateY(-4px);
      border-color: color-mix(in srgb, var(--accent) 72%, var(--line));
      box-shadow: 0 16px 32px rgba(0, 0, 0, 0.22);
    }
    .tool-card.is-gold { --accent: #f4ca68; --accent-soft: rgba(244, 202, 104, 0.18); }
    .tool-card.is-rose { --accent: #ff8fb3; --accent-soft: rgba(255, 143, 179, 0.16); }
    .tool-card.is-violet { --accent: #b69cff; --accent-soft: rgba(182, 156, 255, 0.16); }
    .tool-card.is-blue { --accent: #82b7ff; --accent-soft: rgba(130, 183, 255, 0.15); }
    .tool-card.is-green { --accent: #93e0a6; --accent-soft: rgba(147, 224, 166, 0.14); }
    .tool-card.is-amber { --accent: #ffa75e; --accent-soft: rgba(255, 167, 94, 0.15); }
    .tool-card.is-teal { --accent: #7bded4; --accent-soft: rgba(123, 222, 212, 0.14); }
    .tool-card.is-silver { --accent: #d4c9e8; --accent-soft: rgba(212, 201, 232, 0.13); }
    .tool-status {
      position: absolute;
      top: 16px;
      right: 16px;
      z-index: 1;
      font-family: var(--mono);
      font-size: 0.62rem;
      color: var(--accent);
      border: 1px solid color-mix(in srgb, var(--accent) 55%, var(--line));
      border-radius: 999px;
      padding: 4px 9px;
      text-transform: uppercase;
      background: rgba(14, 10, 19, 0.52);
    }
    .tool-banner { display: flex; align-items: center; gap: 12px; padding-right: 68px; }
    .tool-icon {
      width: 54px;
      height: 54px;
      flex: 0 0 54px;
      display: grid;
      place-items: center;
      border: 1px solid color-mix(in srgb, var(--accent) 55%, var(--line));
      border-radius: 14px;
      background: rgba(14, 10, 19, 0.42);
      color: var(--accent);
      font-family: var(--mono);
      font-size: 0.72rem;
      font-weight: 700;
    }
    .tool-tag {
      font-family: var(--mono);
      font-size: 0.68rem;
      color: color-mix(in srgb, var(--accent) 72%, var(--faint));
      text-transform: uppercase;
      letter-spacing: 0.12em;
      line-height: 1.35;
    }
    .tool-card strong { display: block; font-family: var(--display); font-size: 1.42rem; line-height: 1.08; color: var(--mist); }
    .tool-text { color: var(--muted); font-size: 0.92rem; line-height: 1.55; }
    .tool-points { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 2px; }
    .tool-points span {
      border: 1px solid color-mix(in srgb, var(--accent) 34%, var(--line));
      border-radius: 999px;
      padding: 5px 9px;
      color: #efe8f7;
      background: rgba(14, 10, 19, 0.28);
      font-family: var(--mono);
      font-size: 0.66rem;
    }
    .tool-card em {
      margin-top: auto;
      width: fit-content;
      font-style: normal;
      color: var(--ink);
      background: var(--accent);
      border-radius: 999px;
      padding: 8px 12px;
      font-family: var(--mono);
      font-size: 0.74rem;
      font-weight: 700;
    }
    .tool-notes { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
    @media (max-width: 820px) { .tool-notes { grid-template-columns: 1fr; } }
    .tool-notes > div { border: 1px solid var(--line); border-radius: 12px; padding: 16px; background: var(--surface); }
    .tool-notes h3 { margin-top: 0; }
    .tool-notes p { margin-bottom: 0; color: var(--muted); }
  </style>
</Base>
