---
import Base from '../layouts/Base.astro';
import { SITE } from '../consts';
import { cards } from '../data/nokturna';

const types = [...new Set(cards.map((c) => c.type).filter(Boolean))] as string[];

const faq = [
  { q: 'What is Nokturna in Moonlight Peaks?', a: "Nokturna is the town's favourite collectible card game. You collect cards and challenge the residents of Moonlight Peaks to matches, and it also doubles as a way to build friendships." },
  { q: 'How do you play Nokturna?', a: 'Confirmed: matches are best-of-three, with 3 cards played per round; a tie means both sides win that round. Cards use a "Persist" keyword mechanic, and decks lean into archetypes like Werewolf, Vampire, Plant, and Aquatic, or mixed builds.' },
  { q: 'Where do you get Nokturna cards?', a: 'Confirmed: winning a match against a resident adds a card to your collection — this is the main confirmed source. Community-reported: cards can also appear as dig-spot rewards once that feature is active. Collecting every card earns the "Nokturna Master" Steam achievement.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Nokturna', item: new URL('/nokturna', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Nokturna Guide: Decks, Cards & Common Problems"
  description="Nokturna card game guide for Moonlight Peaks: confirmed rules, 67+ cards, deck archetypes, and honest answers on deck-building questions that aren't documented yet."
  path="/nokturna"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Nokturna' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entry · Cards</p>
      <h1>Nokturna — the <em>Moonlight Peaks</em> card game</h1>
      <p class="intro">
        Nokturna is the town's favourite card game: collect cards and challenge residents to a match.
        Confirmed at launch: it's a best-of-three format with over 67 cards and multiple deck
        archetypes, invented in-universe by the seer Dragan. This is your searchable card database
        plus a how-to-win guide. Updated {SITE.updated}.
      </p>

      <h2>How to play</h2>
      <p>
        Confirmed at launch: Nokturna is a best-of-three card game — each round, both players play
        three cards, and points are tallied to see who wins that round (a tie counts as a win for
        both players). Win two of three rounds to win the match. Each card has a point value, and
        some carry effects or keywords — "Persist," for example, keeps a played card in play for the
        rest of the match. Cards you've won stay in your menu, and playing Nokturna with a resident
        is tracked in their friendship menu alongside conversations and gifts.
      </p>
      <p>
        The full card pool is confirmed at over 67 cards across multiple deck archetypes — confirmed
        so far: Werewolf, Vampire, Plant, and Aquatic decks, plus mixed decks.
      </p>

      <h2>How to get new cards</h2>
      <p>
        Confirmed: winning a match against a resident adds a card to your personal collection.
        <span class="tag-community">Community-reported</span> cards can also turn up as dig-spot
        rewards while digging around town, once that feature is active — so playing matches isn't
        the only source, though it remains the main one confirmed so far.
      </p>
      <p>
        Confirmed: collecting every Nokturna card earns the <strong>"Nokturna Master"</strong> Steam
        achievement — see our <a href="/achievements">achievements guide</a> for the rest of the list.
      </p>

      <h2>Why new Nokturna cards don't appear</h2>
      <p>
        This isn't independently documented in our current sources. If a card you've won in a
        match doesn't show up where you expect, the most likely confirmed fact that applies is
        this: cards you've won are tracked in your own menu, and playing with a resident is
        separately logged in their friendship menu — so check both places rather than assuming a
        card is lost. Beyond that, we don't have a confirmed explanation for cards not appearing,
        and we won't guess at one. If you're trying to keep track of your own collection in the
        meantime, the <a href="/tools/nokturna-tracker">Nokturna Tracker</a> lets you log cards
        privately in your browser.
      </p>

      <h2>How to create a new deck</h2>
      <p>
        Not yet documented in our current sources. We don't have confirmed or even
        community-reported specifics on a deck-creation menu, deck size, or deck-slot limits for
        Nokturna — rather than describe a deck-builder we can't verify, we're leaving this section
        honest about the gap. If you've found this in-game, the mechanic likely lives in the same
        menu where you review your card collection.
      </p>

      <h2>Can you edit the starter deck?</h2>
      <p>
        Not yet documented. We have no confirmed or community-reported information either way on
        whether an initial/starter deck is editable, or whether all matches use one shared,
        player-built deck instead. We'd rather leave this unanswered than invent a rule.
      </p>

      <h2>How to add collected cards</h2>
      <p>
        Not yet documented. Confirmed: winning a match adds a card to your personal collection,
        visible in your menu. How (or whether) you then have to manually add a won card into an
        active deck — versus decks drawing automatically from your full collection — isn't
        something we can confirm from current sources.
      </p>

      <h2>Common deck-building problems</h2>
      <ul>
        <li><strong>Can't tell if a match win actually added a card:</strong> check your card
          collection menu directly rather than assuming from the match-end screen alone.</li>
        <li><strong>Not sure which archetype to build toward:</strong> confirmed deck archetypes so
          far are Werewolf, Vampire, Plant, and Aquatic, plus mixed builds — Alpha Wolf (a
          Werewolf-archetype card) is the one card we can confirm the effect of, buffing other
          Werewolf cards, which suggests archetypes reward staying "on-color."</li>
        <li><strong>Something in the deck-building menu seems locked:</strong> not yet confirmed
          whether this ties to story progress, friendship level with the seer who invented
          Nokturna (Dragan), or something else — see <a href="/characters/dragan">Dragan's profile</a>.</li>
      </ul>

      <h2>Card database</h2>
      {cards.length === 0 ? (
        <div class="nok-empty">
          <p><strong>Confirmed: over 67 cards exist, in multiple deck archetypes.</strong> The
          individual card names and effects aren't public yet, so we haven't listed any — we won't
          invent cards. This becomes a fully searchable database of every Nokturna card, its effect,
          and how to get it as we verify them.</p>
        </div>
      ) : (
        <div class="nok-tool">
          <div class="nok-controls">
            <input class="nok-search" id="nok-search" type="search" placeholder="Search cards by name or effect…" aria-label="Search Nokturna cards" />
            <div class="nok-chips" id="nok-chips">
              <button class="nok-chip is-active" data-type="all" type="button">All</button>
              {types.map((t) => <button class="nok-chip" data-type={t.toLowerCase()} type="button">{t}</button>)}
            </div>
          </div>
          <p class="nok-count" id="nok-count">{cards.length} cards</p>
          <div class="nok-grid" id="nok-grid">
            {cards.map((c) => (
              <article class="nok-card" data-name={c.name.toLowerCase()} data-type={(c.type || '').toLowerCase()} data-effect={(c.effect || '').toLowerCase()}>
                <h3>{c.name}</h3>
                <div class="nok-meta">
                  {c.type && <span class="nok-badge">{c.type}</span>}
                  {c.rarity && <span class="nok-badge">{c.rarity}</span>}
                  {c.cost && <span class="nok-badge">Cost {c.cost}</span>}
                  {c.power && <span class="nok-badge">Power {c.power}</span>}
                </div>
                {c.effect && <p class="nok-effect">{c.effect}</p>}
                {c.howToGet && <p class="nok-get"><strong>How to get:</strong> {c.howToGet}</p>}
              </article>
            ))}
          </div>
          <p class="nok-noresult" id="nok-noresult" hidden>No cards match — try a different search.</p>
        </div>
      )}

      <h2>How to win & best decks</h2>
      <p>
        Once individual card names and effects are more fully documented, this section gets
        starter-friendly deck suggestions and answers to tougher opponents. Until then we're
        keeping it honest rather than guessing at a meta built on cards we can't verify.
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Related: <a href="/beginner-guide">beginner guide</a>,
        <a href="/romance">romance & families</a>, <a href="/tools/nokturna-tracker">Nokturna Tracker</a>,
        <a href="/characters/dragan">Dragan</a>, <a href="/release-date">release date</a>.
      </div>
    </div>
  </article>

  <style>
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 8px;
      margin-right: 6px; vertical-align: middle;
    }
    .nok-empty { border: 1px dashed var(--line); border-radius: 12px; background: var(--ink-2); padding: 18px; color: var(--muted); }
    .nok-controls { display: flex; flex-direction: column; gap: 12px; margin: 8px 0 14px; }
    .nok-search { width: 100%; padding: 12px 14px; border-radius: 10px; border: 1px solid var(--line); background: var(--surface); color: var(--mist); font-size: 0.95rem; font-family: var(--body); }
    .nok-search:focus { outline: 2px solid var(--candle); outline-offset: 1px; }
    .nok-chips { display: flex; gap: 8px; flex-wrap: wrap; }
    .nok-chip { font-size: 0.84rem; color: var(--muted); background: var(--ink); border: 1px solid var(--line); border-radius: 999px; padding: 6px 13px; cursor: pointer; transition: color .14s, border-color .14s; }
    .nok-chip:hover { color: var(--mist); }
    .nok-chip.is-active { color: #20160a; background: var(--candle); border-color: var(--candle); font-weight: 600; }
    .nok-count { font-family: var(--mono); font-size: 0.74rem; color: var(--faint); letter-spacing: 0.06em; text-transform: uppercase; margin: 0 0 12px; }
    .nok-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 14px; }
    .nok-card { border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 16px; }
    .nok-card h3 { font-family: var(--display); font-weight: 600; font-size: 1.1rem; margin: 0 0 8px; }
    .nok-meta { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 8px; }
    .nok-badge { font-family: var(--mono); font-size: 0.68rem; color: var(--candle); border: 1px solid var(--candle-dim); border-radius: 6px; padding: 2px 7px; }
    .nok-effect { color: #ded3e6; font-size: 0.9rem; margin: 0 0 8px; }
    .nok-get { color: var(--muted); font-size: 0.82rem; margin: 0; }
    .nok-noresult { color: var(--faint); font-size: 0.9rem; }
  </style>

  <script>
    const search = document.getElementById('nok-search');
    const grid = document.getElementById('nok-grid');
    const chips = document.getElementById('nok-chips');
    const count = document.getElementById('nok-count');
    const noresult = document.getElementById('nok-noresult');
    if (search && grid) {
      const items = Array.from(grid.querySelectorAll('.nok-card'));
      let activeType = 'all';
      const apply = () => {
        const q = (search.value || '').trim().toLowerCase();
        let shown = 0;
        items.forEach((el) => {
          const name = el.getAttribute('data-name') || '';
          const effect = el.getAttribute('data-effect') || '';
          const type = el.getAttribute('data-type') || '';
          const matchText = !q || name.includes(q) || effect.includes(q);
          const matchType = activeType === 'all' || type === activeType;
          const show = matchText && matchType;
          el.style.display = show ? '' : 'none';
          if (show) shown++;
        });
        if (count) count.textContent = shown + (shown === 1 ? ' card' : ' cards');
        if (noresult) noresult.hidden = shown !== 0;
      };
      search.addEventListener('input', apply);
      if (chips) {
        chips.addEventListener('click', (e) => {
          const btn = e.target.closest('.nok-chip');
          if (!btn) return;
          activeType = btn.getAttribute('data-type') || 'all';
          chips.querySelectorAll('.nok-chip').forEach((c) => c.classList.toggle('is-active', c === btn));
          apply();
        });
      }
    }
  </script>
</Base>
