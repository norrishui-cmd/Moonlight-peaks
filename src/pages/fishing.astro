---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';
import { fish, fishByValue } from '../data/fishing';
import GuideImage from '../components/GuideImage.astro';

const faq = [
  { q: 'Is fishing in Moonlight Peaks?', a: 'Yes — fishing is one of the activities available beyond the farm, alongside foraging and potion-crafting.' },
  { q: 'What fish can you catch?', a: 'The full fish list, locations, and prices will be added here at launch once verified in the live game.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Fishing', item: new URL('/fishing', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Fishing Guide — Fish List & Locations"
  description="Where and when to fish in Moonlight Peaks: fish list, locations, best times, and sell prices."
  path="/fishing"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Fishing' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entry · Fishing</p>
      <h1>Moonlight Peaks <em>fishing</em> guide</h1>
      <p class="intro">
        Beyond the farm, {GAME.title} lets you fish, forage, and craft potions. Updated {SITE.updated}.
      </p>

      <GuideImage imageId="pier-01" priority />

      <h2>Fish database</h2>
      {fish.length > 0 && fish[0].id !== 'example-fish' ? (
        <table class="facts compact">
          <tr><th>Fish</th><th>Location</th><th>Season</th><th>Time</th><th>Sell</th><th>Rarity</th><th>Status</th></tr>
          {fish.map((f) => (
            <tr>
              <td>{f.name}</td>
              <td>{f.location || '—'}</td>
              <td>{f.season.length ? f.season.join(', ') : '—'}</td>
              <td>{f.timeOfDay || '—'}</td>
              <td>{f.sellPrice ?? '—'}</td>
              <td>{f.rarity ?? '—'}</td>
              <td>{f.status}</td>
            </tr>
          ))}
        </table>
      ) : (
        <p>Fish data will be added as it is verified in the live game.</p>
      )}

      {fishByValue.length > 0 && (
        <>
          <h2>Most valuable fish</h2>
          <ol>{fishByValue.map((f) => (<li>{f.name} — {f.sellPrice}g</li>))}</ol>
        </>
      )}

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </article>
</Base>
