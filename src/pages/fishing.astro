---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';

const faq = [
  { q: 'Is there fishing in Moonlight Peaks?', a: 'Yes — fishing is one of the activities available beyond the farm, alongside foraging and potion-crafting.' },
  { q: 'How do you get a fishing rod?', a: 'Confirmed: the rod isn\u2019t available from the start \u2014 you unlock it by winning a bet against Noel (catch 3 different fish before he does).' },
  { q: 'Where\u2019s the full fish list, locations, and prices?', a: 'That full database now lives on our dedicated Collections page \u2014 22 confirmed species, each with its own detail page for location, rarity, season/time, size, and sell price.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Fishing', item: new URL('/fishing', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Fishing Guide — Fish List & Locations"
  description="Where and when to fish in Moonlight Peaks: how to get the fishing rod, and where to find the full 22-species fish database."
  path="/fishing"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Fishing' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entry · Fishing</p>
      <h1>Moonlight Peaks <em>fishing</em> guide</h1>
      <p class="intro">
        Beyond the farm, {GAME.title} lets you fish, forage, and craft potions. Updated {SITE.updated}.
      </p>

      <h2>Getting your first fishing rod</h2>
      <p>
        Confirmed: within your first few in-game nights, Noel challenges you to a fishing contest
        by the river — catch 3 different fish types before he does. It's untimed, so it's an easy
        win, and beating him rewards your first fishing rod plus a coin bonus.
      </p>

      <h2>The full fish database</h2>
      <p>
        The complete, confirmed fish list — 22 species, each with its own page covering location,
        rarity, season/weather/time window, size, and sell price — now lives on our
        <a href="/collections/fish">Collections: Fish</a> page rather than here. That's the page
        to bookmark for species-by-species detail.
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Related: <a href="/collections/fish">Fish collection</a>, <a href="/collections">Collections hub</a>,
        <a href="/characters/noel">Noel</a>, <a href="/beginner-guide">beginner guide</a>.
      </div>
    </div>
  </article>
</Base>
