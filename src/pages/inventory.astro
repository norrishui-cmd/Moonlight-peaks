---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';

const faq = [
  { q: 'How does inventory work in Moonlight Peaks?', a: 'Confirmed at launch: the game uses a universal house storage system — crafting stations (like the kitchen and cauldron) pull ingredients and materials directly from your house storage automatically, rather than requiring you to carry everything in a personal inventory.' },
  { q: 'Can you increase your inventory space?', a: 'Not yet confirmed. Given the universal-storage design, capacity upgrades (if any) more likely apply to house storage than a traditional carry-slot inventory.' },
  { q: 'How do you sell items?', a: 'Drop goods into Chester, the living storage chest gifted by Brook during Town Hall registration — items sell overnight while you sleep.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Inventory', item: new URL('/inventory', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Inventory — Universal Storage Explained"
  description="How inventory works in Moonlight Peaks: the universal house storage system that feeds your crafting stations automatically, and how selling works through Chester."
  path="/inventory"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Inventory' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entry · Inventory</p>
      <h1>Moonlight Peaks <em>inventory</em> & storage</h1>
      <p class="intro">
        {GAME.title} handles inventory differently from a typical carry-slot system. Here's what's
        confirmed. Updated {SITE.updated}.
      </p>

      <h2>Universal house storage</h2>
      <p>
        Confirmed at launch: rather than juggling a personal inventory for crafting, Moonlight Peaks
        uses universal house storage — drop materials into storage at home, and crafting stations
        (the kitchen, the cauldron, and others) pull what they need automatically. This is described
        by early players as one of the more convenient quality-of-life systems in the game.
      </p>

      <h2>Selling through Chester</h2>
      <p>
        Confirmed: you sell goods by dropping them into <a href="/characters/chester">Chester</a>,
        the living storage chest gifted by Brook during your Town Hall registration. Items sell
        overnight while you sleep, so there's no separate shop-visit step for basic sales.
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Related: <a href="/farming">farming</a>, <a href="/items">items</a>, <a href="/characters/chester">Chester</a>,
        <a href="/beginner-guide">beginner guide</a>.
      </div>
    </div>
  </article>
</Base>
