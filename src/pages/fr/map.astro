---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';
import { markers, categories, markersConfirmed } from '../../data/map-locations';
import GuideImage from '../../components/GuideImage.astro';

const colorOf = Object.fromEntries(categories.map((c) => [c.id, c.color]));
const labelOf = Object.fromEntries(categories.map((c) => [c.id, c.label]));

const faq = [
  { q: 'Y a-t-il une carte interactive pour Moonlight Peaks ?', a: "Oui — cette carte créée par des fans montre de vrais noms de lieux et de boutiques confirmés (Silverveil Lake, Cave of Echoes, mairie, Webb of Wonders, Howling Hammer). Les positions sont des approximations schématiques basées sur des indices descriptifs tirés de guides, pas mesurées à partir d'une image de carte officielle — le placement est donc plutôt indicatif qu'exact." },
  { q: 'Moonlight Peaks a-t-il une minimap ?', a: "Non, confirmé : il n'y a pas de système de minimap ou de marqueurs de quête, et la caméra est fixe plutôt que suiveuse libre. La carte en jeu est la principale aide à la navigation et marque les bâtiments d'un point d'exclamation ou d'une aura scintillante quand y entrer déclenche une cinématique." },
  { q: 'Où peut-on pêcher dans Moonlight Peaks ?', a: "Confirmé : Silverveil Lake supporte la pêche et abrite la famille de sirènes Hosu. Les espèces de poissons exactes et les emplacements de pêche spécifiques dans le lac ne sont pas encore sourcés — voir le guide de pêche pour l'état confirmé jusqu'à présent." },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'Carte', item: new URL('/fr/map', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Carte — Pêche, cueillette & boutiques"
  description="Une carte de ville interactive de Moonlight Peaks en français : filtrez les lieux de pêche, zones de cueillette, boutiques et maisons d'habitants. Remplie de lieux confirmés."
  path="/fr/map"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Carte' }]}
  lang="fr"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entrée · Carte</p>
      <h1>Moonlight Peaks <em>carte interactive</em></h1>
      <p class="intro">
        Filtrez la ville selon ce que vous cherchez, puis touchez un marqueur pour les détails.
        Mis à jour {SITE.updated}.
      </p>

      {!markersConfirmed && (
        <div class="callout wip">
          <strong>Positions schématiques.</strong> Les noms de marqueurs ci-dessous (Silverveil
          Lake, Cave of Echoes, mairie et plus) sont réels et confirmés — mais leur placement sur
          cette carte est une approximation basée sur des indices descriptifs tirés de guides, pas
          mesurée à partir d'une image de carte officielle. Nous passerons à des coordonnées
          précises dès que nous pourrons les obtenir du jeu en cours.
        </div>
      )}

      <GuideImage
        imageId="world-map-screenshot"
        contextAlt="Capture d'écran de la carte du monde en jeu montrant Moonlit Pines, la ville de Moonlight Peaks, Misty Shores et Silverveil Lake"
        caption="Une vraie capture d'écran de carte en jeu, en référence à côté de notre version schématique ci-dessous. Les régions nommées correspondent à ce que nous avons confirmé : Moonlit Pines, Moonlight Peaks (la ville), Misty Shores et Silverveil Lake."
      />

      <h2>Zones nommées confirmées</h2>
      <p>
        Les positions des marqueurs ci-dessous sont encore des espaces réservés, mais ces noms de
        quartiers sont confirmés via des rapports de la semaine de lancement : <strong>Misty
        Shores</strong> (le territoire de la famille Ambrosia, accessible via la quête "A Bridge
        Too Far", avec un cimetière où vous rencontrez Death), <strong>Moonlit Pines</strong>
        (siège du cercle de sorcières), le <strong>Pink Grove</strong> (maison du démon de
        l'amour Llemi, visité principalement pendant les festivals) et la <strong>mairie</strong>
        (où vous vous inscrivez auprès de la maire). Nous les placerons précisément dès que les
        coordonnées exactes seront vérifiées.
      </p>

      <div class="maplegend" id="maplegend">
        {categories.map((c) => (
          <button class="lg" data-cat={c.id} style={`--mk:${c.color}`} type="button" aria-pressed="true">
            <span class="lg-dot"></span>{c.label}
          </button>
        ))}
      </div>

      <div class="mapwrap">
        <svg viewBox="0 0 800 500" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Carte de ville stylisée">
          <rect width="800" height="500" rx="16" fill="#1b1526"/>
          <path d="M0 170 Q220 120 380 210 T800 240 L800 130 Q500 70 250 110 T0 90 Z" fill="#20283f" opacity="0.5"/>
          <path d="M120 470 Q260 360 480 380 T760 300" stroke="#3a567a" stroke-width="20" fill="none" opacity="0.7" stroke-linecap="round"/>
          <ellipse cx="190" cy="330" rx="70" ry="42" fill="#2c4666" opacity="0.85"/>
          <g fill="#33503e" opacity="0.9">
            <polygon points="600,360 628,310 656,360"/><polygon points="636,372 664,322 692,372"/>
            <polygon points="672,360 700,310 728,360"/><polygon points="300,410 324,368 348,410"/>
            <polygon points="336,420 360,378 384,420"/>
          </g>
          <g fill="#3a2f50" opacity="0.9">
            <rect x="150" y="120" width="60" height="44" rx="3"/><rect x="220" y="130" width="44" height="34" rx="3"/>
          </g>
          <g fill="#2f2440" stroke="#4a3a63" stroke-width="2">
            <rect x="372" y="232" width="40" height="34" rx="3"/><rect x="420" y="240" width="34" height="30" rx="3"/>
            <rect x="492" y="248" width="40" height="30" rx="3"/>
          </g>
          <text x="150" y="108" fill="#7c6e90" font-family="monospace" font-size="15">Votre ferme</text>
          <text x="150" y="392" fill="#7c6e90" font-family="monospace" font-size="15">Étang</text>
          <text x="600" y="300" fill="#7c6e90" font-family="monospace" font-size="15">Forêt</text>
          <text x="430" y="226" fill="#7c6e90" font-family="monospace" font-size="15">Place de la ville</text>
        </svg>
        {markers.map((m) => (
          <button
            class={`mk mk-${m.category}`}
            data-cat={m.category}
            data-name={m.name}
            data-note={m.note || ''}
            data-label={labelOf[m.category]}
            style={`left:${m.x}%;top:${m.y}%;--mk:${colorOf[m.category]}`}
            aria-label={m.name}
            type="button"
          ></button>
        ))}
      </div>

      <div class="mapinfo" id="mapinfo">
        <p class="mapinfo-empty">Touchez un marqueur pour voir ce qui s'y trouve.</p>
      </div>

      <h2>Navigation sans minimap</h2>
      <p>
        Confirmé via plusieurs sources : Moonlight Peaks n'a <strong>ni minimap ni marqueurs de
        quête</strong> et utilise une caméra fixe plutôt que suiveuse libre — la carte en jeu
        (ouverte via le menu pause) est votre principale aide à la navigation. Sur cette carte,
        des <strong>symboles de point d'exclamation</strong> marquent les bâtiments où entrer
        déclenche une cinématique, et une <strong>aura scintillante</strong> autour d'un bâtiment
        signifie qu'y entrer en déclenchera une — les deux valent la peine d'être vérifiés si vous
        cherchez un événement de cœur pas encore déclenché.
      </p>
      <p>
        Pour avancer rapidement : le <strong>cercle de sorcières</strong> offre une option de
        voyage rapide une fois débloqué, et la <a href="/shapeshifting">forme chauve-souris</a>
        couvre aussi rapidement du terrain. Deux objets à collectionner sont également liés à des
        zones souterraines spécifiques — les Vampsters sont portés jusqu'à un trou dans les
        <a href="/locations/crystal-cave">catacombes</a>, et les Soul Blobs sont attrapés au filet
        en ville une fois cette fonctionnalité débloquée.
      </p>

      <GuideImage
        imageId="moonlit-pines-vampster-map"
        contextAlt="Carte créée par la communauté montrant 14 emplacements numérotés de Vampsters à Moonlit Pines"
        caption="Une carte d'emplacements de Vampsters créée par la communauté pour la zone de Moonlit Pines, avec 14 emplacements recensés. Traitez la numérotation exacte comme un rapport communautaire plutôt que confirmé par le développeur, mais c'est un point de départ utile si vous cherchez des Vampsters spécifiquement dans cette région."
      />

      <h2>Encore en vérification</h2>
      <ul>
        <li>Chaque <strong>emplacement de pêche</strong> avec son poisson, sa saison et son heure.</li>
        <li><strong>Zones de cueillette</strong> et ce qui y apparaît.</li>
        <li><strong>Boutiques</strong> et ce que chacune vend.</li>
        <li><strong>Maisons d'habitants</strong>, liées aux pages de romance et de cadeaux.</li>
      </ul>

      <h2>Questions fréquentes</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout">
        Pages liées : <a href="/nokturna">jeu de cartes Nokturna</a>, <a href="/fr/romance">romance &amp; familles</a>,
        <a href="/fr/beginner-guide">guide du débutant</a>.
      </div>
    </div>
  </article>

  <style>
    .maplegend { display: flex; gap: 8px; flex-wrap: wrap; margin: 6px 0 14px; }
    .lg { display: inline-flex; align-items: center; gap: 7px; font-size: 0.84rem; color: var(--mist); background: var(--surface); border: 1px solid var(--line); border-radius: 999px; padding: 6px 13px; cursor: pointer; }
    .lg-dot { width: 11px; height: 11px; border-radius: 50%; background: var(--mk); }
    .lg[aria-pressed="false"] { opacity: 0.4; text-decoration: line-through; }
    .mapwrap { position: relative; width: 100%; border: 1px solid var(--line); border-radius: 14px; overflow: hidden; background: #15101d; }
    .mapwrap svg { display: block; width: 100%; height: auto; }
    .mk { position: absolute; transform: translate(-50%, -50%); width: 22px; height: 22px; border-radius: 50%; background: var(--mk); border: 2px solid #15101d; box-shadow: 0 0 0 2px var(--mk), 0 2px 6px rgba(0,0,0,0.4); cursor: pointer; padding: 0; transition: transform .12s ease; }
    .mk:hover, .mk.is-sel { transform: translate(-50%, -50%) scale(1.35); z-index: 3; }
    .mk.is-sel { box-shadow: 0 0 0 3px #fff, 0 2px 8px rgba(0,0,0,0.5); }
    .mk.hide { display: none; }
    @media (max-width: 520px) { .mk { width: 26px; height: 26px; } }
    .mapinfo { margin-top: 14px; border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 14px 16px; min-height: 64px; }
    .mapinfo-empty { color: var(--faint); margin: 0; }
    .mapinfo h3 { font-family: var(--display); font-weight: 600; font-size: 1.1rem; margin: 0 0 4px; }
    .mapinfo .cat { font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--candle); }
    .mapinfo p.note { color: #ded3e6; margin: 6px 0 0; font-size: 0.92rem; }
  </style>

  <script>
    const legend = document.getElementById('maplegend');
    const info = document.getElementById('mapinfo');
    const off = new Set();
    const markerEls = Array.from(document.querySelectorAll('.mk'));

    const refresh = () => {
      markerEls.forEach((m) => {
        const cat = m.getAttribute('data-cat') || '';
        m.classList.toggle('hide', off.has(cat));
      });
    };

    if (legend) {
      legend.addEventListener('click', (e) => {
        const btn = e.target.closest('.lg');
        if (!btn) return;
        const cat = btn.getAttribute('data-cat') || '';
        if (off.has(cat)) { off.delete(cat); btn.setAttribute('aria-pressed', 'true'); }
        else { off.add(cat); btn.setAttribute('aria-pressed', 'false'); }
        refresh();
      });
    }

    markerEls.forEach((m) => {
      m.addEventListener('click', () => {
        markerEls.forEach((x) => x.classList.remove('is-sel'));
        m.classList.add('is-sel');
        if (info) {
          const name = m.getAttribute('data-name') || '';
          const label = m.getAttribute('data-label') || '';
          const note = m.getAttribute('data-note') || '';
          info.innerHTML = '<span class="cat"></span><h3></h3>' + (note ? '<p class="note"></p>' : '');
          info.querySelector('.cat').textContent = label;
          info.querySelector('h3').textContent = name;
          if (note) info.querySelector('p.note').textContent = note;
        }
      });
    });
  </script>
</Base>
