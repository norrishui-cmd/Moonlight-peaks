---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';

const jsonLd = [
  {
    '@context': 'https://schema.org', '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
      { '@type': 'ListItem', position: 2, name: 'Outils', item: `${SITE.url}/fr/tools` },
      { '@type': 'ListItem', position: 3, name: 'Suivi de collection Nokturna', item: new URL('/fr/tools/nokturna-tracker', SITE.url).href },
    ],
  },
  {
    '@context': 'https://schema.org', '@type': 'WebApplication',
    name: 'Suivi de collection Nokturna Moonlight Peaks', applicationCategory: 'GameApplication', operatingSystem: 'Web',
    url: new URL('/fr/tools/nokturna-tracker', SITE.url).href,
    description: 'Un suivi de collection personnel, sauvegardé dans le navigateur, pour les cartes Nokturna dans Moonlight Peaks — enregistrez chaque carte au fur et à mesure que vous la trouvez, avant qu\u2019une base de données entièrement vérifiée n\u2019existe.',
  },
];
---
<Base
  title="Suivi de collection Nokturna Moonlight Peaks"
  description="Enregistrez votre propre collection de cartes Nokturna dans Moonlight Peaks — plus de 67 cartes confirmées existent dans plusieurs archétypes de deck. Suivez ce que vous avez trouvé, sauvegardé en privé dans votre navigateur."
  path="/fr/tools/nokturna-tracker"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Outils', href: '/fr/tools' }, { label: 'Suivi Nokturna' }]}
  lang="fr"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Outil / Suivi Nokturna</p>
      <h1>Moonlight Peaks — Suivi de collection <em>Nokturna</em></h1>
      <p class="intro">
        Confirmé au lancement : Nokturna compte plus de 67 cartes réparties dans plusieurs archétypes
        de deck, mais les noms de cartes individuelles ne sont pas encore publics — consultez le
        <a href="/nokturna">guide Nokturna</a> pour ce qui est confirmé jusqu'à présent. En attendant
        qu'une base de données complète existe, enregistrez ici votre propre collection au fur et à
        mesure que vous trouvez des cartes dans le jeu. Sauvegardé uniquement en privé dans votre navigateur.
      </p>

      <section class="nt-shell" data-nok-tracker>
        <aside class="nt-panel">
          <label>
            <span>Nom de la carte</span>
            <input data-name type="text" placeholder="ex. la carte que vous venez de gagner" />
          </label>
          <label>
            <span>Archétype / type (facultatif)</span>
            <input data-type type="text" placeholder="ex. vampire, sorcière, loup-garou…" />
          </label>
          <label>
            <span>Comment vous l'avez obtenue</span>
            <input data-source type="text" placeholder="ex. gagnée contre Orlock, récompense de pêche" />
          </label>
          <button type="button" class="btn btn-gold" data-add>Ajouter à la collection</button>
          <button type="button" class="btn btn-ghost" data-export>Exporter en texte</button>
          <button type="button" class="btn btn-ghost" data-reset>Effacer la collection</button>
          <div class="nt-stats"><strong data-count>0</strong><span>cartes enregistrées / 67+ confirmées existantes</span></div>
        </aside>

        <div class="nt-grid" data-grid aria-live="polite">
          <p class="empty" data-empty>Aucune carte enregistrée pour l'instant — ajoutez votre première victoire à gauche.</p>
        </div>
      </section>

      <div class="callout">
        Ceci est votre propre carnet personnel, pas une liste officielle de cartes — rien ici n'est
        envoyé au site. Si vous voulez aider à construire la base de données publique vérifiée,
        utilisez plutôt le <a href="/tools/submit-data">soumetteur de données</a>.
      </div>
    </div>
  </article>

  <script>
    const root = document.querySelector('[data-nok-tracker]');
    if (root) {
      const key = 'moonlight-nokturna-tracker-v1';
      const nameInput = root.querySelector('[data-name]');
      const typeInput = root.querySelector('[data-type]');
      const sourceInput = root.querySelector('[data-source]');
      const addBtn = root.querySelector('[data-add]');
      const exportBtn = root.querySelector('[data-export]');
      const resetBtn = root.querySelector('[data-reset]');
      const grid = root.querySelector('[data-grid]');
      const emptyMsg = root.querySelector('[data-empty]');
      const count = root.querySelector('[data-count]');

      let cards = JSON.parse(localStorage.getItem(key) || '[]');
      const save = () => localStorage.setItem(key, JSON.stringify(cards));

      const render = () => {
        count.textContent = cards.length;
        grid.querySelectorAll('.nt-card').forEach((c) => c.remove());
        if (!cards.length) { emptyMsg.style.display = ''; return; }
        emptyMsg.style.display = 'none';
        [...cards].reverse().forEach((card, revIndex) => {
          const index = cards.length - 1 - revIndex;
          const el = document.createElement('article');
          el.className = 'nt-card';
          el.innerHTML = `
            <button type="button" class="nt-remove" data-remove="${index}" aria-label="Supprimer la carte">✕</button>
            <h3>${card.name}</h3>
            ${card.type ? `<span class="nt-badge">${card.type}</span>` : ''}
            ${card.source ? `<p class="nt-source">${card.source}</p>` : ''}
          `;
          grid.appendChild(el);
        });
      };

      addBtn.addEventListener('click', () => {
        const name = nameInput.value.trim();
        if (!name) { nameInput.focus(); return; }
        cards.push({ name, type: typeInput.value.trim(), source: sourceInput.value.trim() });
        save();
        nameInput.value = '';
        typeInput.value = '';
        sourceInput.value = '';
        render();
      });

      grid.addEventListener('click', (event) => {
        const btn = event.target.closest('[data-remove]');
        if (!btn) return;
        cards.splice(Number(btn.dataset.remove), 1);
        save();
        render();
      });

      exportBtn.addEventListener('click', () => {
        if (!cards.length) return;
        const text = cards.map((c) => `${c.name}${c.type ? ' [' + c.type + ']' : ''}${c.source ? ' — ' + c.source : ''}`).join('\n');
        navigator.clipboard?.writeText(text).catch(() => {});
        alert('Votre collection Nokturna a été copiée dans le presse-papiers !');
      });

      resetBtn.addEventListener('click', () => {
        if (!confirm('Effacer toute votre collection Nokturna ? Cette action est irréversible.')) return;
        cards = [];
        save();
        render();
      });

      render();
    }
  </script>

  <style>
    .nt-shell { display: grid; grid-template-columns: 280px minmax(0, 1fr); gap: 18px; margin: 28px 0; }
    @media (max-width: 820px) { .nt-shell { grid-template-columns: 1fr; } }
    .nt-panel { border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); padding: 16px; display: grid; gap: 12px; align-self: start; }
    .nt-panel label span { display: block; margin-bottom: 6px; color: var(--mist); font-weight: 600; }
    .nt-panel input[type="text"] {
      width: 100%; min-height: 44px; border: 1px solid var(--line); border-radius: 10px;
      background: var(--ink); color: var(--mist); padding: 0 12px; font: inherit;
    }
    .nt-stats { border-top: 1px solid var(--line); padding-top: 12px; }
    .nt-stats strong { display: block; color: var(--candle); font-family: var(--display); font-size: 2rem; }
    .nt-stats span { color: var(--muted); font-size: 0.85rem; }
    .nt-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 12px; align-content: start; }
    .nt-card {
      position: relative; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface);
      padding: 14px; display: grid; gap: 6px;
    }
    .nt-card h3 { margin: 0; color: var(--mist); font-size: 1rem; padding-right: 20px; }
    .nt-badge { justify-self: start; font-family: var(--mono); font-size: 0.65rem; text-transform: uppercase; color: var(--candle); border: 1px solid var(--line); border-radius: 999px; padding: 2px 8px; }
    .nt-source { color: var(--muted); font-size: 0.82rem; margin: 0; }
    .nt-remove { position: absolute; top: 8px; right: 10px; background: none; border: none; color: var(--muted); cursor: pointer; }
    .nt-remove:hover { color: var(--candle); }
    .empty { border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); padding: 16px; color: var(--muted); }
  </style>
</Base>
