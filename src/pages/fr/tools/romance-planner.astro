---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { characters, typeLabels } from '../../../data/characters';

const typeLabelsFr: Record<string, string> = {
  vampire: 'Vampire', werewolf: 'Loup-garou', witch: 'Sorcière', mermaid: 'Sirène',
  seer: 'Voyante', ghost: 'Fantôme', human: 'Humain', other: 'Autre',
};
const statusLabelsFr: Record<string, string> = { confirmed: 'Confirmé', reported: 'Signalé', datamined: 'Dataminé', unconfirmed: 'Non confirmé' };

const candidates = characters
  .filter((c) => c.status !== 'unconfirmed' && c.romanceable !== false)
  .map((c) => ({
    id: c.id,
    name: c.name,
    family: c.family && c.family !== 'Unknown' ? c.family : null,
    type: typeLabelsFr[c.type] || typeLabels[c.type],
    status: statusLabelsFr[c.status] || c.status,
    href: `/characters/${c.id}`,
  }));

const prepTasks = [
  { id: 'read-profile', t: 'Lire le profil et les infos connues de votre candidat' },
  { id: 'check-home', t: 'Noter où votre candidat vit, si connu (voir « infos connues » du profil)' },
  { id: 'check-family', t: 'Confirmer à quelle famille ils appartiennent et les rivalités signalées' },
  { id: 'check-status', t: 'Vérifier leur niveau de confirmation actuel (confirmé/signalé/dataminé)' },
  { id: 'try-quiz', t: 'Faire le quiz de compatibilité romantique pour un second avis' },
  { id: 'plan-day-one', t: 'Décider à qui parler en premier le premier jour' },
  { id: 'bookmark-page', t: 'Mettre cette page en favori — votre liste et vos notes restent sur cet appareil' },
];

const faq = [
  { q: 'Cet outil utilise-t-il de vraies données de cadeaux ou de relation ?', a: 'Non. Les données de cadeaux, d\'affinité et d\'événements ne sont pas encore confirmées, donc rien de tout ça n\'est affiché ici. Cet outil suit uniquement votre propre liste de candidats, vos notes, et une check-list — tout est sauvegardé en privé dans votre navigateur, pas sur nos serveurs.' },
  { q: 'Ma liste de candidats sera-t-elle conservée après le lancement ?', a: 'Oui, tant que vous utilisez le même navigateur et appareil, et que vous n\'effacez pas les données de ce site. Une fois les vraies données de romance confirmées, nous étendrons cet outil pour les utiliser.' },
  { q: 'Mes données sont-elles envoyées quelque part ?', a: 'Non. Tout est stocké uniquement dans le stockage local de votre navigateur. Nous ne le voyons pas, ne le stockons sur aucun serveur, et ne l\'utilisons à aucune fin.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'Outils', item: `${SITE.url}/fr/tools` },
    { '@type': 'ListItem', position: 3, name: 'Planificateur de romance', item: new URL('/fr/tools/romance-planner', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'Planificateur de romance Moonlight Peaks',
    applicationCategory: 'GameApplication', operatingSystem: 'Web',
    url: new URL('/fr/tools/romance-planner', SITE.url).href,
    description: 'Un suivi de liste de candidats romantiques et de préparation avant le lancement de Moonlight Peaks, sauvegardé localement dans votre navigateur.' },
];
---
<Base
  title="Planificateur de romance Moonlight Peaks — Liste de candidats et suivi"
  description="Choisissez vos favoris parmi les 23 partenaires romantiques confirmés de Moonlight Peaks, ajoutez des notes personnelles, et suivez votre progression avec chacun — sauvegardé en privé dans votre navigateur, sans inventer de données de cadeaux."
  path="/fr/tools/romance-planner"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Outils', href: '/fr/tools' }, { label: 'Planificateur de romance' }]}
  lang="fr"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Outil · Romance</p>
      <h1>Planificateur de <em>romance</em></h1>
      <p class="intro">
        Choisissez parmi les 23 partenaires romantiques confirmés ceux que vous voulez explorer,
        écrivez vos propres notes, et suivez votre progression avec chacun. Tout ici reste privé dans
        votre navigateur — pas de compte, pas de serveur, et aucune donnée de cadeau ou d'affinité inventée.
      </p>

      <h2>Votre liste de candidats</h2>
      <p class="rp-sub">Cliquez sur un personnage pour l'ajouter ou le retirer de votre liste.</p>
      <div id="rp-candidates" class="rp-candidates">
        {candidates.map((c) => (
          <button type="button" class="rp-candidate" data-rp-id={c.id} data-rp-href={c.href} data-rp-name={c.name}>
            <span class="rp-star" aria-hidden="true">☆</span>
            <span class="rp-name">{c.name}</span>
            <span class="rp-meta">{c.family ? `${c.family} · ` : ''}{c.status}</span>
          </button>
        ))}
      </div>

      <h2>Vos notes</h2>
      <div id="rp-shortlist-empty" class="callout wip">Votre liste de candidats est vide — cliquez sur un personnage ci-dessus pour en ajouter un.</div>
      <div id="rp-notes-list" class="rp-notes-list"></div>

      <h2>Check-list de préparation au lancement</h2>
      <ul id="rp-prep-list" class="rp-prep-list">
        {prepTasks.map((task) => (
          <li>
            <label>
              <input type="checkbox" data-rp-task={task.id} />
              <span>{task.t}</span>
            </label>
          </li>
        ))}
      </ul>

      <div class="rp-actions">
        <button type="button" id="rp-clear" class="rq-btn">Effacer ma liste et mes notes</button>
      </div>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Voir aussi : <a href="/romance">Romance et mariage</a>, <a href="/tools/romance-match-quiz">Quiz de compatibilité</a>,
        <a href="/tools/romance-gift-finder">Chercheur de cadeaux romantiques</a>, <a href="/characters">Tous les personnages</a>.
      </div>
    </div>
  </article>

  <style>
    .rp-sub { color: var(--faint); font-size: 0.8rem; margin: -6px 0 12px; }
    .rp-candidates { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin: 0 0 24px; }
    @media (min-width: 640px) { .rp-candidates { grid-template-columns: repeat(3, 1fr); } }
    .rp-candidate {
      display: flex; flex-direction: column; align-items: flex-start; gap: 2px; text-align: left;
      border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 10px 12px;
      cursor: pointer; transition: border-color .15s ease;
    }
    .rp-candidate:hover { border-color: color-mix(in srgb, var(--candle) 45%, var(--line)); }
    .rp-candidate.is-picked { border-color: var(--candle); background: color-mix(in srgb, var(--candle) 10%, var(--surface)); }
    .rp-candidate .rp-star { font-size: 0.9rem; color: var(--faint); }
    .rp-candidate.is-picked .rp-star { color: var(--candle); }
    .rp-candidate .rp-name { font-family: var(--display); font-weight: 600; font-size: 0.88rem; color: var(--mist); }
    .rp-candidate .rp-meta { font-family: var(--mono); font-size: 0.66rem; color: var(--faint); }
    .rp-notes-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
    .rp-note-card { border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 12px 14px; }
    .rp-note-card .rp-note-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
    .rp-note-card strong { font-family: var(--display); font-size: 0.94rem; }
    .rp-note-card a { font-family: var(--mono); font-size: 0.7rem; color: var(--candle); }
    .rp-note-card textarea {
      width: 100%; min-height: 64px; background: var(--ink-2); border: 1px solid var(--line); border-radius: 8px;
      color: var(--mist); font-family: inherit; font-size: 0.84rem; padding: 8px 10px; resize: vertical;
    }
    .rp-prep-list { list-style: none; margin: 0 0 20px; padding: 0; display: flex; flex-direction: column; gap: 6px; }
    .rp-prep-list label { display: flex; align-items: center; gap: 10px; font-size: 0.86rem; color: var(--muted); cursor: pointer; }
    .rp-prep-list input { accent-color: var(--candle); }
    .rp-actions { margin: 0 0 24px; }
  </style>

  <script>
    (function () {
      var KEY_SHORTLIST = 'mp-romance-shortlist';
      var KEY_NOTES = 'mp-romance-notes';
      var KEY_PREP = 'mp-romance-prep';

      function readJSON(key, fallback) {
        try {
          var raw = localStorage.getItem(key);
          return raw ? JSON.parse(raw) : fallback;
        } catch (e) { return fallback; }
      }
      function writeJSON(key, val) {
        try { localStorage.setItem(key, JSON.stringify(val)); } catch (e) {}
      }

      var shortlist = readJSON(KEY_SHORTLIST, []);
      var notes = readJSON(KEY_NOTES, {});
      var prep = readJSON(KEY_PREP, {});

      var candidateEls = document.querySelectorAll('.rp-candidate');
      var notesList = document.getElementById('rp-notes-list');
      var emptyMsg = document.getElementById('rp-shortlist-empty');

      function renderCandidates() {
        candidateEls.forEach(function (el) {
          var id = el.getAttribute('data-rp-id');
          el.classList.toggle('is-picked', shortlist.indexOf(id) > -1);
          var star = el.querySelector('.rp-star');
          if (star) star.textContent = shortlist.indexOf(id) > -1 ? '★' : '☆';
        });
      }

      function renderNotes() {
        notesList.innerHTML = '';
        if (shortlist.length === 0) { emptyMsg.hidden = false; return; }
        emptyMsg.hidden = true;
        shortlist.forEach(function (id) {
          var el = document.querySelector('.rp-candidate[data-rp-id="' + id + '"]');
          if (!el) return;
          var name = el.getAttribute('data-rp-name');
          var href = el.getAttribute('data-rp-href');
          var card = document.createElement('div');
          card.className = 'rp-note-card';
          var head = document.createElement('div');
          head.className = 'rp-note-head';
          var strong = document.createElement('strong');
          strong.textContent = name;
          var link = document.createElement('a');
          link.href = href;
          link.textContent = 'Voir le profil';
          head.appendChild(strong);
          head.appendChild(link);
          var textarea = document.createElement('textarea');
          textarea.placeholder = 'Notes sur ' + name + '…';
          textarea.value = notes[id] || '';
          textarea.addEventListener('input', function () {
            notes[id] = textarea.value;
            writeJSON(KEY_NOTES, notes);
          });
          card.appendChild(head);
          card.appendChild(textarea);
          notesList.appendChild(card);
        });
      }

      candidateEls.forEach(function (el) {
        el.addEventListener('click', function () {
          var id = el.getAttribute('data-rp-id');
          var idx = shortlist.indexOf(id);
          if (idx > -1) { shortlist.splice(idx, 1); }
          else { shortlist.push(id); }
          writeJSON(KEY_SHORTLIST, shortlist);
          renderCandidates();
          renderNotes();
        });
      });

      document.querySelectorAll('[data-rp-task]').forEach(function (box) {
        var id = box.getAttribute('data-rp-task');
        box.checked = !!prep[id];
        box.addEventListener('change', function () {
          prep[id] = box.checked;
          writeJSON(KEY_PREP, prep);
        });
      });

      var clearBtn = document.getElementById('rp-clear');
      if (clearBtn) {
        clearBtn.addEventListener('click', function () {
          if (!window.confirm('Effacer votre liste, notes et check-list de préparation ? Action irréversible.')) return;
          shortlist = []; notes = {}; prep = {};
          writeJSON(KEY_SHORTLIST, shortlist);
          writeJSON(KEY_NOTES, notes);
          writeJSON(KEY_PREP, prep);
          renderCandidates();
          renderNotes();
          document.querySelectorAll('[data-rp-task]').forEach(function (box) { box.checked = false; });
        });
      }

      renderCandidates();
      renderNotes();
    })();
  </script>
</Base>
