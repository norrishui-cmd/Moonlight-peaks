---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const faq = [
  { q: "Combien coûte la grange dans Moonlight Peaks ?", a: "Confirmé via le wiki officiel : 4 000 pièces d'or chez Ridge au Howling Hammer, après que Luna vous a présenté les animaux de ferme." },
  { q: 'Quelle taille fait la grange dans Moonlight Peaks ?', a: 'Confirmé : la grange nécessite une surface de 10x6 et prend une nuit à construire. Elle accueille 4 animaux.' },
  { q: 'Peut-on construire plus d\'une grange dans Moonlight Peaks ?', a: "Oui, confirmé : vous pouvez construire plusieurs granges, chacune avec de la place pour 4 animaux, tant que vous avez la surface de 10x6 nécessaire pour chacune." },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'Ferme', item: `${SITE.url}/fr/farm` },
    { '@type': 'ListItem', position: 3, name: 'Grange', item: `${SITE.url}/fr/farm/barn` },
  ] },
];
---
<Base
  title="Moonlight Peaks Grange — Coût, taille & déblocage"
  description="Confirmé : la grange de Moonlight Peaks coûte 4 000 pièces d'or chez Ridge, nécessite une surface de 10x6, prend une nuit à construire et accueille 4 animaux."
  path="/fr/farm/barn"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Ferme', href: '/fr/farm' }, { label: 'Grange' }]}
  lang="fr"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Ferme · Grange</p>
      <h1>La <em>grange</em></h1>
      <p class="intro">
        Confirmé via le wiki officiel et recoupé avec la couverture de la semaine de lancement :
        la grange coûte <strong>4 000 pièces d'or</strong> au Howling Hammer, une fois que Luna
        vous a présenté les animaux de ferme.
      </p>

      <h2>Comment la débloquer</h2>
      <p>
        Confirmé : tôt au printemps de la première année, Ridge apparaît à votre porte et commente
        votre toit, tandis que vous recevez séparément une lettre de Luna concernant la quête
        "Farm Animals for Sale" — une visite chez Luna vous montre le premier animal disponible
        (un Cheeken). Une fois votre toit réparé, vous trouverez Ridge au Howling Hammer (ouvert
        de 18h à minuit) ; choisissez Boutique, puis le deuxième onglet, pour acheter la grange.
      </p>

      <h2>Taille, coût et capacité</h2>
      <table class="facts">
        <tr><th>Coût</th><td>4 000 pièces d'or</td></tr>
        <tr><th>Surface requise</th><td>10x6</td></tr>
        <tr><th>Temps de construction</th><td>1 nuit</td></tr>
        <tr><th>Capacité animale</th><td>4 par grange</td></tr>
        <tr><th>Plusieurs granges ?</th><td>Oui — construisez-en d'autres pour garder plus de 4 animaux</td></tr>
      </table>

      <h2>Ensuite</h2>
      <p>
        Confirmé : une fois la grange construite, retournez à la ferme de Luna pour adopter votre
        premier animal. Les animaux disponibles changent chaque jour dans un petit enclos près de
        sa maison, et vous devez nommer chacun vous-même — le jeu ne suggère pas de nom.
      </p>

      <h2>Questions fréquentes</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Issu du wiki officiel de Moonlight Peaks, recoupé avec les couvertures de Bonus Action et
        Prima Games. Pages liées : <a href="/fr/farm">hub de la ferme</a>,
        <a href="/fr/farm/animals">animaux</a>, <a href="/characters/ridge">Ridge</a>,
        <a href="/characters/luna">Luna</a>.
      </div>
    </div>
  </article>
</Base>
