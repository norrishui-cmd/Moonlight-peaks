---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';
import GuideImage from '../../components/GuideImage.astro';

const minigames = [
  { name: 'Lancer de sorts', how: "Dessinez un motif de cercle et de points avec la baguette équipée, en suivant l'indice du D-pad.", where: 'Partout, une fois la magie débloquée' },
  { name: 'Mini-jeux de rendez-vous', how: 'Varie selon le rendez-vous — par exemple lier un bouquet dans les couleurs voulues ou griller un marshmallow au degré de cuisson préféré.', where: 'Lors des rendez-vous avec un habitant à partir du niveau de cœur 4' },
  { name: 'Pêche', how: "Lancez en direction d'ombres dans l'eau, puis remontez avec un mini-jeu basé sur le timing.", where: 'Zones aquatiques, une fois la canne à pêche débloquée' },
  { name: 'Concours de pêche contre Noel', how: "Attrapez 3 poissons différents avant Noel, avec un pari de 250 pièces d'or pour gagner la canne.", where: 'Début de partie, lié à Noel' },
];

const faq = [
  { q: 'Quels mini-jeux existent dans Moonlight Peaks ?', a: "Confirmé jusqu'à présent : le lancer de sorts (un motif de cercle et de points), des activités de rendez-vous comme lier un bouquet et griller des marshmallows, et un mini-jeu de pêche basé sur le timing — plus le concours de pêche de Noel qui débloque votre canne." },
  { q: 'La pêche est-elle difficile dans Moonlight Peaks ?', a: "Les critiques la décrivent comme délibérément sans stress plutôt que frustrante, plus proche d'un lancer-et-remonter détendu façon Animal Crossing que d'un défi exigeant de l'habileté." },
  { q: 'Les mini-jeux affectent-ils les relations ?', a: "Oui, spécifiquement lors des rendez-vous — arriver en retard ou rater un mini-jeu de rendez-vous coûte confirmé des points de relation, plutôt que de tout arrêter immédiatement." },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'Mini-jeux', item: new URL('/fr/mini-games', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Mini-jeux — Rendez-vous, pêche & sorts"
  description="Chaque mini-jeu confirmé de Moonlight Peaks : activités de rendez-vous comme lier un bouquet, le système de pêche lancer-et-remonter, et comment fonctionne le lancer de sorts."
  path="/fr/mini-games"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Mini-jeux' }]}
  lang="fr"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entrée · Mini-jeux</p>
      <h1>Moonlight Peaks <em>mini-jeux</em></h1>
      <p class="intro">
        {GAME.title} intègre plusieurs mini-jeux dans ses systèmes, plutôt que de les traiter comme
        des modes arcade séparés. Voici ce qui est confirmé jusqu'à présent. Mis à jour {SITE.updated}.
      </p>

      <GuideImage imageId="minigame" priority />

      <table class="facts">
        <tr><th>Mini-jeu</th><th>Comment ça marche</th><th>Où ça se trouve</th></tr>
        {minigames.map((m) => (
          <tr>
            <td>{m.name}</td>
            <td>{m.how}</td>
            <td>{m.where}</td>
          </tr>
        ))}
      </table>

      <div class="callout">
        D'autres mini-jeux (Nokturna, cuisine, brassage de potions) ont peut-être leurs propres
        mécaniques dédiées — voir les guides liés ci-dessous plutôt que de les dupliquer ici.
      </div>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Lié : <a href="/fr/fishing">pêche</a>, <a href="/fr/magic">magie</a>, <a href="/fr/romance">romance</a>,
        <a href="/fr/nokturna">Nokturna</a>.
      </div>
    </div>
  </article>
</Base>
