---
import TopicPage from '../../../components/TopicPage.astro';
import { activitiesSection, activities } from '../../../data/activities';
import { activitiesFr } from '../../../i18n/activities-fr';

export function getStaticPaths() {
  const translated = activities.filter((it) => activitiesFr[it.slug]);
  return translated.map((it, i) => {
    const tr = activitiesFr[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...translated[(i - 1 + translated.length) % translated.length], ...activitiesFr[translated[(i - 1 + translated.length) % translated.length].slug] },
        next: { ...translated[(i + 1) % translated.length], ...activitiesFr[translated[(i + 1) % translated.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const frSection = { ...activitiesSection, base: '/fr/activities', label: 'Activités', eyebrow: 'Gameplay' };
---
<TopicPage section={frSection} item={item} prev={prev} next={next} lang="fr" basePath="/fr/activities" />
