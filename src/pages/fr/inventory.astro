---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const faq = [
  { q: "Comment fonctionne l'inventaire dans Moonlight Peaks ?", a: "Confirmé au lancement : le jeu utilise un système de stockage domestique universel — les stations d'artisanat (comme la cuisine et le chaudron) puisent automatiquement les ingrédients et matériaux directement dans votre stockage domestique, plutôt que de tout porter dans un inventaire personnel." },
  { q: "Peut-on augmenter l'espace d'inventaire ?", a: "Pas encore confirmé. Vu la conception de stockage universel, les améliorations de capacité (s'il y en a) concerneraient plutôt le stockage domestique qu'un inventaire à emplacements traditionnel." },
  { q: 'Comment vend-on des objets ?', a: "Jetez des marchandises dans Chester, le coffre de rangement vivant que Brook vous offre lors de l'inscription à la mairie — les objets se vendent pendant la nuit, pendant que vous dormez." },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'Inventaire', item: `${SITE.url}/fr/inventory` },
  ] },
];
---
<Base
  title="Moonlight Peaks Inventaire — Système de stockage universel expliqué"
  description="Comment fonctionne l'inventaire dans Moonlight Peaks : le système de stockage domestique universel qui alimente automatiquement vos stations d'artisanat, et comment fonctionne la vente via Chester."
  path="/fr/inventory"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Inventaire' }]}
  lang="fr"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entrée · Inventaire</p>
      <h1>Moonlight Peaks <em>Inventaire</em> & stockage</h1>
      <p class="intro">
        {GAME.title} gère l'inventaire différemment d'un système à emplacements typique. Voici ce
        qui est confirmé. Dernière mise à jour : {SITE.updated}.
      </p>

      <h2>Stockage domestique universel</h2>
      <p>
        Confirmé au lancement : plutôt que de jongler avec un inventaire personnel pour
        l'artisanat, Moonlight Peaks utilise un stockage domestique universel — jetez des
        matériaux dans le stockage de la maison, et les stations d'artisanat (la cuisine, le
        chaudron et d'autres) puisent automatiquement ce dont elles ont besoin. Les premiers
        joueurs décrivent cela comme l'un des systèmes de confort les plus appréciables du jeu.
      </p>

      <h2>Vendre via Chester</h2>
      <p>
        Confirmé : vous vendez des marchandises en les jetant dans <a href="/characters/chester">Chester</a>,
        le coffre de rangement vivant que Brook vous offre lors de votre inscription à la mairie.
        Les objets se vendent pendant la nuit, pendant que vous dormez, donc pas besoin d'une
        visite séparée en boutique pour les ventes simples.
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Lié : <a href="/fr/farming">agriculture</a>, <a href="/fr/items">objets</a>,
        <a href="/characters/chester">Chester</a>, <a href="/fr/beginner-guide">guide du débutant</a>.
      </div>
    </div>
  </article>
</Base>
