---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const coverage = [
  ['Sortie & plateformes', 'Date de sortie, démo, Steam, Steam Deck, Switch, Switch 2, Android, checklist avant achat.'],
  ['Guides joueurs', 'Débutant, agriculture, magie, activités, objets, carte, comparaisons, stratégies de début de partie.'],
  ['Personnages & romance', 'Résidents, familles, options de romance, cadeaux, mariage, données confirmées après la sortie.'],
  ['Outils & FAQ', 'Platform Picker, outils de romance, Item Tracker, calculateur agricole, FAQ, page de mises à jour.'],
];

const principles = [
  'Les faits confirmés, observations de démo, informations de preview et données non confirmées sont traités séparément.',
  'Les questions des joueurs priment sur l\u2019empilement de mots-clés.',
  'Les pages restent rapides, claires et lisibles sur mobile.',
  'Dès que des données fiables sont confirmées, la même URL est mise à jour.',
];

const faq = [
  { q: `${SITE.brand} est-il officiel ?`, a: `Non. ${SITE.brand} est un guide indépendant créé par des fans, sans lien officiel avec ${GAME.developer} ou ${GAME.publisher}.` },
  { q: 'Que couvre ce site ?', a: 'Date de sortie, démo, plateformes, personnages, familles, romance, cadeaux, agriculture, magie, objets, outils, FAQ et pages de comparaison.' },
  { q: 'Comment les informations non confirmées sont-elles traitées ?', a: 'Elles sont clairement indiquées comme non confirmées ou à vérifier. Les suppositions ne sont jamais présentées comme des données définitives.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'AboutPage', name: `À propos de ${SITE.brand}`, url: new URL('/fr/about', SITE.url).href },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'À propos', item: new URL('/fr/about', SITE.url).href },
  ] },
];
---
<Base
  title={`À propos de ${SITE.brand} - Guide indépendant Moonlight Peaks`}
  description={`${SITE.brand} est un guide indépendant sur Moonlight Peaks : date de sortie, démo, plateformes, romance, personnages, agriculture, magie, outils et FAQ.`}
  path="/fr/about"
  jsonLd={jsonLd}
  crumbs={[{ label: 'À propos' }]}
  lang="fr"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Guide indépendant créé par des fans</p>
      <h1>À propos de <em>{SITE.brand}</em></h1>
      <p class="intro">
        {SITE.brand} est un guide créé par des fans pour {GAME.title}. Nous facilitons l'accès
        rapide aux informations sur la date de sortie, la démo, les plateformes, la romance, les
        personnages, les cadeaux, l'agriculture, la magie, les outils et la préparation à la sortie.
      </p>

      <h2>Ce que nous couvrons</h2>
      <div class="info-grid">
        {coverage.map((item) => <section><h3>{item[0]}</h3><p>{item[1]}</p></section>)}
      </div>

      <h2>Principes éditoriaux</h2>
      <ul>
        {principles.map((item) => <li>{item}</li>)}
      </ul>

      <h2>À propos de notre indépendance</h2>
      <p>
        Ce site n'est pas un site officiel et n'est ni affilié, ni approuvé, ni associé à
        {GAME.developer} ou {GAME.publisher}. Les noms et matériaux de Moonlight Peaks
        appartiennent à leurs détenteurs respectifs.
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => <details><summary>{f.q}</summary><p>{f.a}</p></details>)}
      </div>
    </div>
  </article>

  <style>
    .info-grid { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 16px 0 24px; }
    @media (min-width: 760px) { .info-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    .info-grid section { border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 16px; }
    .info-grid h3 { margin-top: 0; }
  </style>
</Base>
