---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';

const tools = [
  { href: '/fr/tools/platform-picker', tag: 'Décision', title: 'Platform Picker', text: 'Choisis en toute sécurité entre Steam, Steam Deck, Switch, Switch 2 et Android.', status: 'Live' },
  { href: '/fr/tools/romance-gift-finder', tag: 'Romance', title: 'Romance Gift Finder', text: 'Résidents, statut de romance, indices familiaux et infos de cadeaux confirmées en un coup d\u2019œil.', status: 'Live' },
  { href: '/fr/tools/romance-match-quiz', tag: 'Quiz', title: 'Romance Match Quiz', text: 'Trouve des options de romance potentielles avec quelques questions simples.', status: 'Live' },
  { href: '/fr/tools/romance-planner', tag: 'Planificateur', title: 'Romance Planner', text: 'Sauvegarde tes favoris, notes et progression de romance dans ton navigateur.', status: 'Live' },
  { href: '/fr/tools/families-explorer', tag: 'Familles', title: 'Families Explorer', text: 'Parcours les 23 options de romance, regroupées par leur vraie famille.', status: 'Live' },
  { href: '/fr/tools/item-tracker', tag: 'Collection', title: 'Item Tracker', text: 'Suis ta progression de collection pour les poissons, insectes, recettes, potions et décorations.', status: 'Live' },
  { href: '/fr/tools/gift-tracker', tag: 'Journal personnel', title: 'Gift Tracker', text: 'Enregistre tes propres tests de cadeaux par résident, sauvegardés en privé dans ton navigateur.', status: 'Live' },
  { href: '/fr/tools/fish-finder', tag: 'Référence', title: 'Fish Finder', text: 'Filtre les 22 espèces de poissons confirmées par lieu ou rareté.', status: 'Live' },
  { href: '/fr/tools/farming-profit-planner', tag: 'Agriculture', title: 'Farming Profit Planner', text: 'Compare les profits des cultures une fois les prix et jours de croissance confirmés.', status: 'Live' },
  { href: '/fr/tools/nokturna-tracker', tag: 'Cartes', title: 'Nokturna Tracker', text: 'Enregistre ta propre collection de cartes Nokturna, au fur et à mesure des confirmations.', status: 'Live' },
  { href: '/fr/tools/submit-data', tag: 'Communauté', title: 'Data Submitter', text: 'Sauvegarde tes découvertes de la semaine de lancement comme brouillon local pour vérification ultérieure.', status: 'Live' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'Outils', item: new URL('/fr/tools', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'CollectionPage', name: 'Outils Moonlight Peaks', url: new URL('/fr/tools', SITE.url).href },
];
---
<Base
  title="Outils Moonlight Peaks - Plateforme, Romance, Collection"
  description="Hub d'outils français pour Moonlight Peaks. Choix de plateforme, romance, cadeaux, suivi d'objets, profit agricole et données communautaires."
  path="/fr/tools"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Outils' }]}
  lang="fr"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Outils / Aide au joueur</p>
      <h1>Outils <em>Moonlight Peaks</em></h1>
      <p class="intro">
        Des outils pratiques pour le choix de plateforme, la préparation de romance, la recherche
        de cadeaux, la collection d'objets et les calculs agricoles — tous utiles avant et après
        la sortie.
      </p>

      <section class="tool-grid" aria-label="Moonlight Peaks tools">
        {tools.map((tool) => (
          <a class="tool-card" href={tool.href}>
            <span class="tool-status">{tool.status}</span>
            <span class="tool-tag">{tool.tag}</span>
            <strong>{tool.title}</strong>
            <span>{tool.text}</span>
            <em>Ouvrir l'outil -&gt;</em>
          </a>
        ))}
      </section>

      <h2>Notre approche pour ces outils</h2>
      <p>
        Nous évitons de présenter des données non confirmées comme sûres. Les points non
        confirmés sont marqués comme ouverts, et dès que des informations fiables sont
        confirmées, nous mettons à jour la même URL.
      </p>
    </div>
  </article>

  <style>
    .tool-grid { display: grid; grid-template-columns: 1fr; gap: 14px; margin: 24px 0; }
    @media (min-width: 760px) { .tool-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @media (min-width: 1080px) { .tool-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    .tool-card { min-height: 190px; display: flex; flex-direction: column; gap: 10px; border: 1px solid var(--line); border-radius: 12px; background: linear-gradient(135deg, rgba(244,202,104,.12), var(--surface)); padding: 16px; text-decoration: none; }
    .tool-card strong { font-family: var(--display); font-size: 1.25rem; color: var(--mist); }
    .tool-card span { color: var(--muted); }
    .tool-status, .tool-tag, .tool-card em { font-family: var(--mono); color: var(--candle); font-style: normal; }
    .tool-card em { margin-top: auto; }
  </style>
</Base>
