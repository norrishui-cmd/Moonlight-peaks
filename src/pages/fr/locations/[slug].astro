---
import TopicPage from '../../../components/TopicPage.astro';
import { locationsSection, locations } from '../../../data/locations';
import { locationsFr } from '../../../i18n/locations-fr';

export function getStaticPaths() {
  return locations.filter((it) => locationsFr[it.slug]).map((it, i, arr) => {
    const tr = locationsFr[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...arr[(i - 1 + arr.length) % arr.length], ...locationsFr[arr[(i - 1 + arr.length) % arr.length].slug] },
        next: { ...arr[(i + 1) % arr.length], ...locationsFr[arr[(i + 1) % arr.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const frSection = { ...locationsSection, base: '/fr/locations', label: 'Lieux', eyebrow: 'Lieu' };
---
<TopicPage section={frSection} item={item} prev={prev} next={next} lang="fr" basePath="/fr/locations" />
