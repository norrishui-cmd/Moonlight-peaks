---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Quel est le cadeau préféré de Fiona ?',
    acceptedAnswer: { '@type': 'Answer', text: 'Fiona adore les Fraises (Strawberries) par-dessus tout.' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'Personnages', item: `${SITE.url}/fr/characters` },
    { '@type': 'ListItem', position: 3, name: 'Fiona', item: `${SITE.url}/fr/characters/fiona` },
  ] },
];
---
<Base
  title="Cadeaux préférés de Fiona | Guide des personnages Moonlight Peaks"
  description="Préférences de cadeaux confirmées pour Fiona dans Moonlight Peaks — ce qu'elle adore, ce qu'elle aime et ce qu'il faut éviter."
  path="/fr/characters/fiona/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Personnages', href: '/fr/characters' }, { label: 'Fiona', href: '/fr/characters/fiona' }, { label: 'Cadeaux' }]}
  lang="fr"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Personnages · Cadeaux</p>
      <h1>Cadeaux préférés de <em>Fiona</em></h1>
      <p class="intro">
        Données de cadeaux confirmées pour Fiona, basées sur des tests de la semaine de lancement.
      </p>

      <h2>Elle adore</h2>
      <p>Confirmé que Fiona adore : Fraises (Strawberries).</p>

      <h2>Elle aime</h2>
      <p>Au-delà de son favori, Fiona aime aussi : Tulipe Violette, Azalée Violette, Lavande Violette, Œuf et Jus de Lune.</p>

      <h2>Elle n'aime pas</h2>
      <p>Évitez avec Fiona : les Graines d'Oignon. Confirmé que cela réduit l'affection.</p>

      <div class="callout wip">
        Pages liées : <a href="/fr/characters/fiona">profil de Fiona</a>,
        <a href="/fr/characters">tous les personnages</a>, <a href="/characters/fiona/gifts">version complète en anglais</a>.
      </div>
    </div>
  </article>
</Base>
