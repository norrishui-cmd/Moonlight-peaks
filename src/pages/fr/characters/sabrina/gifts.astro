---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Quel est le cadeau préféré de Sabrina ?',
    acceptedAnswer: { '@type': 'Answer', text: 'Sabrina adore la Tulipe Violette et le Plumeria Violet.' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'Personnages', item: `${SITE.url}/fr/characters` },
    { '@type': 'ListItem', position: 3, name: 'Sabrina', item: `${SITE.url}/fr/characters/sabrina` },
  ] },
];
---
<Base
  title="Cadeaux préférés de Sabrina | Guide des personnages Moonlight Peaks"
  description="Préférences de cadeaux confirmées pour Sabrina dans Moonlight Peaks — ce qu'elle adore, ce qu'elle aime et ce qu'il faut éviter."
  path="/fr/characters/sabrina/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Personnages', href: '/fr/characters' }, { label: 'Sabrina', href: '/fr/characters/sabrina' }, { label: 'Cadeaux' }]}
  lang="fr"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Personnages · Cadeaux</p>
      <h1>Cadeaux préférés de <em>Sabrina</em></h1>
      <p class="intro">
        Données de cadeaux confirmées pour Sabrina, basées sur des tests de la semaine de lancement.
      </p>

      <h2>Elle adore</h2>
      <p>Confirmé que Sabrina adore : Tulipe Violette et Plumeria Violet.</p>

      <h2>Elle aime</h2>
      <p>Au-delà de ses favoris, Sabrina aime aussi : Blood Grape et Jus de Blood Grape.</p>

      <h2>Elle n'aime pas</h2>
      <p>Évitez avec Sabrina : les Graines d'Oignon et le Coquillage Rose. Confirmé que cela réduit l'affection.</p>

      <div class="callout wip">
        Pages liées : <a href="/fr/characters/sabrina">profil de Sabrina</a>,
        <a href="/fr/characters">tous les personnages</a>, <a href="/characters/sabrina/gifts">version complète en anglais</a>.
      </div>
    </div>
  </article>
</Base>
