---
import TopicPage from '../../../components/TopicPage.astro';
import { familiesSection, families } from '../../../data/families';
import { familiesFr } from '../../../i18n/families-fr';

export function getStaticPaths() {
  return families.filter((it) => familiesFr[it.slug]).map((it, i, arr) => {
    const tr = familiesFr[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...arr[(i - 1 + arr.length) % arr.length], ...familiesFr[arr[(i - 1 + arr.length) % arr.length].slug] },
        next: { ...arr[(i + 1) % arr.length], ...familiesFr[arr[(i + 1) % arr.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const frSection = { ...familiesSection, base: '/fr/families', label: 'Familles', eyebrow: 'Monde' };
---
<TopicPage section={frSection} item={item} prev={prev} next={next} lang="fr" basePath="/fr/families" />
