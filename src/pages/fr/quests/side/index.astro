---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';
import { sideQuests } from '../../../../data/quests-side';
import { sideQuestsFr } from '../../../../i18n/quests-side-fr';

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'Guide des quêtes', item: `${SITE.url}/fr/quests` },
    { '@type': 'ListItem', position: 3, name: 'Quêtes secondaires', item: `${SITE.url}/fr/quests/side` },
  ],
};
---
<Base
  title="Moonlight Peaks Quêtes secondaires — Chaque quête de PNJ & système secondaire"
  description="Chaque quête secondaire confirmée de Moonlight Peaks et demande spécifique de PNJ — concours de pêche, agrandissements de maison, le tableau des petits boulots, et les systèmes secondaires de collecte de créatures de la ville."
  path="/fr/quests/side"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Guide des quêtes', href: '/fr/quests' }, { label: 'Quêtes secondaires' }]}
  lang="fr"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Quêtes · Quêtes secondaires</p>
      <h1>Quêtes <em>secondaires</em></h1>
      <p class="intro">
        {sideQuests.length} quêtes secondaires confirmées et demandes spécifiques de PNJ, distinctes
        de la <a href="/fr/quests/story">chaîne d'histoire principale</a>. Elles vont de quêtes
        uniques avec un habitant précis à des systèmes secondaires continus comme le tableau des
        petits boulots.
      </p>

      <div class="sq-grid">
        {sideQuests.filter((q) => sideQuestsFr[q.slug]).map((q) => (
          <a class="sq-card" href={`/fr/quests/side/${q.slug}`}>
            <span class="sq-tag">{q.npc ? q.npc.charAt(0).toUpperCase() + q.npc.slice(1) : 'Système secondaire'}</span>
            <h3>{sideQuestsFr[q.slug].title}</h3>
            <p>{sideQuestsFr[q.slug].summary.length > 130 ? sideQuestsFr[q.slug].summary.slice(0, 127) + '…' : sideQuestsFr[q.slug].summary}</p>
          </a>
        ))}
      </div>

      <div class="callout wip">
        Lié : <a href="/fr/quests">hub des quêtes</a>, <a href="/fr/quests/story">histoire principale</a>,
        <a href="/fr/collections">collections</a>, <a href="/fr/characters">personnages</a>.
      </div>
    </div>
  </article>

  <style>
    .sq-grid { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 22px 0 30px; }
    @media (min-width: 640px) { .sq-grid { grid-template-columns: 1fr 1fr; } }
    .sq-card {
      display: block; border: 1px solid var(--line); border-radius: 14px; background: var(--surface);
      padding: 16px; text-decoration: none; color: inherit;
      transition: border-color .15s ease, transform .15s ease;
    }
    .sq-card:hover { border-color: color-mix(in srgb, var(--candle) 54%, var(--line)); transform: translateY(-2px); }
    .sq-tag { font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--candle); }
    .sq-card h3 { margin: 6px 0 6px; font-size: 1.05rem; }
    .sq-card p { margin: 0; color: #ded3e6; font-size: 0.86rem; }
  </style>
</Base>
