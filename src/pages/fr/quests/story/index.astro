---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';
import { storyQuests } from '../../../../data/quests-story';
import { storyQuestsFr, storyChaptersFr } from '../../../../i18n/quests-story-fr';

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'Guide des quêtes', item: `${SITE.url}/fr/quests` },
    { '@type': 'ListItem', position: 3, name: 'Histoire principale', item: `${SITE.url}/fr/quests/story` },
  ],
};
---
<Base
  title="Moonlight Peaks Quêtes d'histoire principale — Chapitre par chapitre"
  description="Chaque quête d'histoire principale confirmée de Moonlight Peaks, organisée en 5 chapitres de l'arrivée en ville à l'arc du mariage, recoupée via plusieurs sources de la semaine de lancement."
  path="/fr/quests/story"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Guide des quêtes', href: '/fr/quests' }, { label: 'Histoire principale' }]}
  lang="fr"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Quêtes · Histoire principale</p>
      <h1>Quêtes d'<em>histoire principale</em></h1>
      <p class="intro">
        {storyQuests.length} quêtes d'histoire principale, regroupées en {storyChaptersFr.length} chapitres.
        Choisissez le chapitre correspondant à votre progression — les quêtes de chaque chapitre
        sont listées dans l'ordre confirmé.
      </p>

      {storyChaptersFr.map((ch) => {
        const quests = storyQuests.filter((q) => q.chapter === ch.number && storyQuestsFr[q.slug]);
        return (
          <section class="chapter">
            <div class="chapter-head">
              <span class="chapter-num">Chapitre {ch.number}</span>
              <h2>{ch.title}</h2>
            </div>
            <p class="chapter-dek">{ch.dek}</p>
            <ol class="quest-list">
              {quests.map((q) => (
                <li>
                  <a href={`/fr/quests/story/${q.slug}`}>{storyQuestsFr[q.slug].title}</a>
                  {q.status === 'reported' && <span class="tag-community">Rapportée</span>}
                </li>
              ))}
            </ol>
          </section>
        );
      })}

      <div class="callout wip">
        Sourced from cross-verified launch-week walkthroughs (Neoseeker's quest log, Bonus Action,
        Output Lag, Into Indie Games). Le découpage en chapitres est notre propre organisation, pas
        des étiquettes officielles du jeu. Lié : <a href="/fr/quests">hub des quêtes</a>,
        <a href="/fr/quests/side">quêtes secondaires</a>, <a href="/quests/story/a-bridge-too-far">A Bridge Too Far (walkthrough complet, en anglais)</a>.
      </div>
    </div>
  </article>

  <style>
    .chapter { margin: 26px 0; padding-top: 18px; border-top: 1px solid var(--line); }
    .chapter:first-of-type { border-top: none; padding-top: 0; }
    .chapter-head { display: flex; align-items: baseline; gap: 10px; }
    .chapter-num { font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--candle); white-space: nowrap; }
    .chapter-head h2 { margin: 0; }
    .chapter-dek { color: var(--muted); font-size: 0.92rem; margin: 4px 0 12px; }
    .quest-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; counter-reset: qnum; }
    .quest-list li { counter-increment: qnum; padding: 8px 0; border-bottom: 1px dashed var(--line); display: flex; align-items: center; gap: 8px; }
    .quest-list li::before { content: counter(qnum) "."; color: var(--faint); font-family: var(--mono); font-size: 0.8rem; }
    .quest-list a { color: var(--mist); text-decoration: none; flex: 1; }
    .quest-list a:hover { color: var(--candle); }
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 7px;
    }
  </style>
</Base>
