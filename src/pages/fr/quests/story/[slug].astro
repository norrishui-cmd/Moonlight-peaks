---
import Base from '../../../../layouts/Base.astro';
import { SITE, GAME } from '../../../../consts';
import { storyQuests, storyQuestBySlug } from '../../../../data/quests-story';
import { storyQuestsFr, storyChaptersFr } from '../../../../i18n/quests-story-fr';

export function getStaticPaths() {
  return storyQuests.filter((q) => storyQuestsFr[q.slug]).map((q) => ({ params: { slug: q.slug }, props: { q } }));
}

const { q } = Astro.props as { q: (typeof storyQuests)[number] };
const tr = storyQuestsFr[q.slug];
const chapter = storyChaptersFr.find((c) => c.number === q.chapter)!;
const prev = storyQuests[storyQuests.indexOf(q) - 1];
const next = q.leadsTo ? storyQuestBySlug.get(q.leadsTo) : undefined;
const statusLabel = q.status === 'confirmed' ? 'Confirmée' : 'Rapportée';

const faq = [
  { q: `Comment débloquer "${tr.title}" dans Moonlight Peaks ?`, a: tr.unlock || "Cette quête découle directement du moment d'histoire précédent — voir le lien vers la quête prérequise ci-dessous." },
  { q: `Que récompense "${tr.title}" ?`, a: tr.reward || "Aucune récompense d'objet directe confirmée n'a encore été documentée pour cette quête." },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'Guide des quêtes', item: `${SITE.url}/fr/quests` },
    { '@type': 'ListItem', position: 3, name: 'Histoire principale', item: `${SITE.url}/fr/quests/story` },
    { '@type': 'ListItem', position: 4, name: tr.title, item: `${SITE.url}/fr/quests/story/${q.slug}` },
  ] },
];
---
<Base
  title={`${tr.title} — Guide des quêtes Moonlight Peaks`}
  description={`${GAME.title} quête "${tr.title}" : ${tr.summary.slice(0, 130)}`}
  path={`/fr/quests/story/${q.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: 'Guide des quêtes', href: '/fr/quests' }, { label: 'Histoire principale', href: '/fr/quests/story' }, { label: tr.title }]}
  lang="fr"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Histoire principale · Chapitre {q.chapter} : {chapter.title} · <span class="tag-community">{statusLabel}</span></p>
      <h1>{tr.title}</h1>

      {tr.unlock && (
        <div class="callout">
          <strong>Déblocage :</strong> {tr.unlock}
        </div>
      )}

      <h2>Ce qui se passe</h2>
      <p>{tr.summary}</p>

      {tr.reward && (
        <>
          <h2>Récompense</h2>
          <p>{tr.reward}</p>
        </>
      )}

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <nav class="prevnext" aria-label="Navigation des quêtes">
        {prev && storyQuestsFr[prev.slug] ? <a href={`/fr/quests/story/${prev.slug}`}>← {storyQuestsFr[prev.slug].title}</a> : <span />}
        <a href="/fr/quests/story">Tous les chapitres</a>
        {next && storyQuestsFr[next.slug] ? <a href={`/fr/quests/story/${next.slug}`}>{storyQuestsFr[next.slug].title} →</a> : <span />}
      </nav>

      <div class="callout wip">
        Lié : <a href="/fr/quests">hub des quêtes</a>, <a href="/fr/quests/side">quêtes secondaires</a>,
        <a href="/fr/beginner-guide">guide du débutant</a>.
      </div>
    </div>
  </article>

  <style>
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 7px;
      vertical-align: middle;
    }
    .prevnext { display: flex; justify-content: space-between; gap: 10px; margin: 22px 0; font-family: var(--mono); font-size: 0.82rem; }
    .prevnext a { color: var(--candle); }
  </style>
</Base>
