---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { itemCategories, getItemFramework } from '../../../data/items';
import { itemsFr } from '../../../i18n/items-fr';
import type { ItemCategory } from '../../../data/items';

export function getStaticPaths() {
  return itemCategories.filter((item) => itemsFr[item.slug]).map((item, index, arr) => ({
    params: { slug: item.slug },
    props: { item, prev: arr[(index - 1 + arr.length) % arr.length], next: arr[(index + 1) % arr.length] },
  }));
}

const { item } = Astro.props as { item: ItemCategory };
const tr = itemsFr[item.slug];
const url = new URL(`/fr/items/${item.slug}`, SITE.url).href;
const framework = getItemFramework(item.slug);
const hasRealData = item.slug === 'foraging' || item.slug === 'cooking';
const parseImageCell = (cell: string) => {
  const [src, alt = ''] = cell.slice('image:'.length).split('|');
  return { src, alt };
};

const statusLabelFr: Record<string, string> = {
  confirmed: 'Confirmé', datamined: 'Datamining', expected: 'Attendu',
};

const faq = [
  { q: `Qu'est-ce que ${tr.name} dans Moonlight Peaks ?`, a: `${tr.name} est une catégorie d'objets dans Moonlight Peaks. ${tr.summary}` },
  { q: `Les informations sur ${tr.name} sont-elles confirmées ?`, a: item.status === 'confirmed'
      ? `Le système pour ${tr.name} est confirmé, mais les noms d'objets individuels et leurs effets restent vérifiés dans le jeu en direct.`
      : `La catégorie ${tr.name} n'est pas encore confirmée indépendamment dans le jeu en direct. Nous ne devinons pas et mettrons à jour cette page dès que quelque chose sera confirmé.` },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'Objets', item: `${SITE.url}/fr/items` },
    { '@type': 'ListItem', position: 3, name: tr.name, item: url },
  ] },
];
---
<Base
  title={`${tr.name} | Guide des objets Moonlight Peaks`}
  description={tr.dek}
  path={`/fr/items/${item.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: 'Objets', href: '/fr/items' }, { label: tr.name }]}
  lang="fr"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Objets · {statusLabelFr[item.status] ?? item.status}</p>
      <h1><em>{tr.name}</em></h1>
      <p class="intro">{tr.dek}</p>

      <h2>Détails</h2>
      <p>{tr.summary}</p>

      <h2>Exemples</h2>
      <ul>{tr.examples.map((e) => (<li>{e}</li>))}</ul>

      {hasRealData && (
        <>
          <h2>Tableau de données complet</h2>
          <div class="fr-item-table-wrap">
            <table class="fr-item-table">
              <thead>
                <tr>{framework.columns.map((col) => <th>{col}</th>)}</tr>
              </thead>
              <tbody>
                {framework.rows.map((row) => (
                  <tr>
                    {row.map((cell) => {
                      const image = cell.startsWith('image:') ? parseImageCell(cell) : null;
                      return (
                        <td>
                          {image ? (
                            <img class="fr-item-table-icon" src={image.src} alt={image.alt} loading="lazy" decoding="async" />
                          ) : cell}
                        </td>
                      );
                    })}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="fr-source-note">{framework.sourceNote}</p>
        </>
      )}

      <h2>Questions fréquentes</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Lié : <a href="/fr/items">Tous les objets</a>, <a href={`/items/${item.slug}`}>version complète en anglais</a>.
      </div>
    </div>
  </article>

  <style>
    .fr-item-table-wrap { overflow-x: auto; border: 1px solid var(--line); border-radius: 14px; background: var(--surface); margin: 12px 0; }
    .fr-item-table { width: 100%; min-width: 700px; border-collapse: collapse; font-size: 0.84rem; }
    .fr-item-table th, .fr-item-table td { border-bottom: 1px solid var(--line); padding: 10px 12px; text-align: left; vertical-align: top; }
    .fr-item-table th { color: var(--candle); font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.05em; text-transform: uppercase; background: rgba(21, 16, 29, 0.58); white-space: nowrap; }
    .fr-item-table-icon { display: block; width: 68px; height: 68px; object-fit: contain; }
    .fr-item-table tr:last-child td { border-bottom: 0; }
    .fr-source-note { border-left: 3px solid var(--candle-dim); color: #ded3e6; padding-left: 12px; font-size: 0.88rem; }
  </style>
</Base>
