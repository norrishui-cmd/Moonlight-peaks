---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { fishDetailPages } from '../../../data/collectionDetailPages';

const faq = [
  { q: 'Comment obtenir sa première canne à pêche dans Moonlight Peaks ?', a: 'Confirmé : rencontrez Noel près d\'une rivière dans vos premières soirées de jeu. Il vous met au défi d\'attraper 3 espèces de poissons différentes avant lui — facile à gagner car sans limite de temps — et vous récompense avec votre première canne à pêche plus un bonus d\'or.' },
  { q: 'Combien de poissons y a-t-il dans Moonlight Peaks ?', a: 'Confirmé : 22 espèces de poissons, chacune avec sa propre valeur de vente et sa valeur énergétique de base, toutes deux augmentant en qualité 1 et 2 étoiles. La liste complète avec page détaillée par poisson se trouve ci-dessous.' },
  { q: 'Qu\'est-ce qui influence les poissons attrapés dans Moonlight Peaks ?', a: 'Confirmé : le lieu, la saison, la météo et l\'heure de la journée influencent tous les poissons disponibles à un moment donné.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'Collections', item: `${SITE.url}/fr/collections` },
    { '@type': 'ListItem', position: 3, name: 'Poissons', item: `${SITE.url}/fr/collections/fish` },
  ] },
];
---
<Base
  title="Moonlight Peaks Poissons — Les ~22 espèces & la première canne à pêche"
  description="Pêche confirmée dans Moonlight Peaks : comment obtenir sa première canne à pêche auprès de Noel, environ 22 espèces de poissons, niveaux de qualité, et ce qui influence les prises."
  path="/fr/collections/fish"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Collections', href: '/fr/collections' }, { label: 'Poissons' }]}
  lang="fr"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Collections · Poissons</p>
      <h1>Moonlight Peaks <em>poissons</em></h1>
      <p class="intro">
        Confirmé par deux sources indépendantes de la semaine de lancement : la pêche repose sur
        une véritable collection d'environ 22 espèces, chacune influencée par le lieu, le moment
        et la météo au moment du lancer.
      </p>

      <h2>Obtenir la première canne à pêche</h2>
      <p>
        Confirmé : vous rencontrez <a href="/characters/noel">Noel</a> près d'une rivière dans vos
        premières soirées de jeu. Il vous met au défi d'attraper 3 espèces de poissons différentes
        avant lui — facile à gagner car sans limite de temps — et vous récompense avec votre
        première canne à pêche plus un bonus d'or.
      </p>

      <h2>Combien de poissons, et ce qui change</h2>
      <p>
        Confirmé : la collection compte environ 22 espèces. Leur disponibilité dépend du lieu, de
        la saison, de la météo et de l'heure — un poisson introuvable un soir n'a peut-être besoin
        que des bonnes conditions plutôt que d'être totalement absent.
      </p>

      <h2>Niveaux de qualité</h2>
      <p>
        Confirmé : chaque poisson a une valeur de vente de base et une valeur énergétique de base
        à la consommation, toutes deux augmentant en qualité 1 et 2 étoiles — une prise de
        meilleure qualité de la même espèce vaut donc activement la peine d'être recherchée plutôt
        que de se contenter de la première touche.
      </p>

      <h2>Répertoire des poissons (les 22 espèces)</h2>
      <p>Cliquez sur un poisson pour sa page détaillée avec lieu, rareté, période d'apparition, taille et prix de vente.</p>
      <ul class="fish-link-list">
        {fishDetailPages.map((f) => (
          <li><a href={`/fr/collections/fish/${f.slug}`}>{f.name}</a></li>
        ))}
      </ul>

      <h2>Questions fréquentes</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Pages liées : <a href="/fr/collections">hub des collections</a>, <a href="/fr/activities">la pêche comme activité</a>,
        <a href="/characters/noel">Noel</a>, <a href="/fr/items">objets</a>.
      </div>
    </div>
  </article>

  <style>
    .fish-link-list {
      list-style: none; padding: 0; margin: 12px 0 24px;
      display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 8px;
    }
    .fish-link-list a {
      display: block; border: 1px solid var(--line); border-radius: 10px; padding: 8px 12px;
      background: var(--surface); color: var(--candle); text-decoration: none; font-size: 0.88rem;
    }
    .fish-link-list a:hover { border-color: color-mix(in srgb, var(--candle) 54%, var(--line)); }
  </style>
</Base>
