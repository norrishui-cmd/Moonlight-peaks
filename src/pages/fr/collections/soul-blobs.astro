---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const faq = [
  { q: 'Combien de Soul Blobs y a-t-il dans Moonlight Peaks ?', a: 'Confirmé au lancement : 100 Soul Blobs, répartis dans le monde du jeu.' },
  { q: 'Comment attraper les Soul Blobs dans Moonlight Peaks ?', a: "Confirmé : avec le filet, le même outil utilisé pour attraper les insectes — pas à la main." },
  { q: 'Que reçoit-on en collectant tous les Soul Blobs ?', a: "Confirmé : l'Horloge Antique, qui allonge la nuit de 15 minutes par défaut à 25 minutes." },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'Collections', item: `${SITE.url}/fr/collections` },
    { '@type': 'ListItem', position: 3, name: 'Soul Blobs', item: `${SITE.url}/fr/collections/soul-blobs` },
  ] },
];
---
<Base
  title="Moonlight Peaks Soul Blobs : les 100 & la récompense de l'Horloge Antique"
  description="Confirmé : 100 Soul Blobs sont répartis dans Moonlight Peaks, attrapés avec le filet. Les collecter tous récompense l'Horloge Antique, qui allonge la nuit à 25 minutes."
  path="/fr/collections/soul-blobs"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Collections', href: '/fr/collections' }, { label: 'Soul Blobs' }]}
  lang="fr"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Collections · Soul Blobs</p>
      <h1>Moonlight Peaks <em>Soul Blobs</em></h1>
      <p class="intro">
        Les Soul Blobs sont de petites âmes-crânes errantes, réparties dans le monde du jeu —
        confirmé au lancement : 100 au total, avec une récompense vraiment utile pour les
        complétionnistes.
      </p>

      <div class="callout">
        <strong>Réponse rapide :</strong> Death vous présente les Soul Blobs après votre deuxième
        rencontre en ville et vous demande de les attraper avec le filet. Il y en a 100 au total ;
        tous les collecter récompense l'Horloge Antique.
      </div>

      <h2>Comment les Soul Blobs sont introduits</h2>
      <p>
        Confirmé : <a href="/characters/death">Death</a> vous présente les Soul Blobs après votre
        deuxième rencontre en ville et vous demande de les attraper avec le filet — le même outil
        utilisé pour attraper les insectes, rien de séparé.
      </p>

      <h2>Ce qui les distingue des autres collections</h2>
      <p>
        Rapporté par la communauté : les Soul Blobs sont la plus narrative des deux collections de
        créatures du jeu (l'autre étant les
        <a href="/fr/collections/vampsters">Vampsters</a>). Quand vous attrapez un Soul Blob, le
        jeu vous raconte une courte vignette sur la façon dont cette âme est morte — une petite
        récompense narrative à chaque découverte plutôt qu'une simple case à cocher.
      </p>

      <h2>La récompense de complétion</h2>
      <p>
        Confirmé : collecter les 100 Soul Blobs récompense l'<strong>Horloge Antique</strong>, qui
        allonge la durée de la nuit de 15 minutes par défaut à 25 minutes — une véritable
        récompense de confort permanente plutôt que purement cosmétique.
      </p>

      <h2>Questions fréquentes</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Pages liées : <a href="/fr/collections">hub des collections</a>, <a href="/fr/collections/vampsters">Vampsters</a>,
        <a href="/characters/death">Death</a>, <a href="/fr/activities">pêche &amp; chasse aux insectes</a>.
      </div>
    </div>
  </article>
</Base>
