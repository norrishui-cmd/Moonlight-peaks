---
import TopicPage from '../../../components/TopicPage.astro';
import { platformsSection, platforms } from '../../../data/platforms';
import { platformsFr } from '../../../i18n/platforms-fr';

export function getStaticPaths() {
  return platforms.filter((it) => platformsFr[it.slug]).map((it, i, arr) => {
    const tr = platformsFr[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...arr[(i - 1 + arr.length) % arr.length], ...platformsFr[arr[(i - 1 + arr.length) % arr.length].slug] },
        next: { ...arr[(i + 1) % arr.length], ...platformsFr[arr[(i + 1) % arr.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const frSection = { ...platformsSection, base: '/fr/platforms', label: 'Plateformes', eyebrow: 'Plateforme' };
---
<TopicPage section={frSection} item={item} prev={prev} next={next} lang="fr" basePath="/fr/platforms" />
