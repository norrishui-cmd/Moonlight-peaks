---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';
import { faqs, faqCatLabels } from '../../../data/faq';
import { faqFr } from '../../../i18n/faq-fr';

export function getStaticPaths() {
  const translated = faqs.filter((f) => faqFr[f.slug]);
  return translated.map((f, i) => ({
    params: { slug: f.slug },
    props: { f, tr: faqFr[f.slug], prev: translated[(i - 1 + translated.length) % translated.length], next: translated[(i + 1) % translated.length] },
  }));
}

const { f, tr, prev, next } = Astro.props as {
  f: (typeof faqs)[number]; tr: { q: string; a: string; more?: string[] };
  prev: (typeof faqs)[number]; next: (typeof faqs)[number];
};
const url = new URL(`/fr/faq/${f.slug}`, SITE.url).href;
const plain = [tr.a, ...(tr.more || [])].join(' ');

const catLabelFr: Record<string, string> = {
  platforms: 'Plateformes, prix & démo', romance: 'Romance & mariage', characters: 'Personnages',
  world: 'Monde & gameplay', farming: 'Agriculture & économie', general: 'Général',
};

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'Questions fréquentes', item: `${SITE.url}/fr/faq` },
    { '@type': 'ListItem', position: 3, name: tr.q, item: url },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: tr.q, acceptedAnswer: { '@type': 'Answer', text: plain },
  }] },
];
---
<Base
  title={`${tr.q} · Moonlight Peaks`}
  description={plain.length > 155 ? plain.slice(0, 152) + '…' : plain}
  path={`/fr/faq/${f.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: 'Questions fréquentes', href: '/fr/faq' }, { label: tr.q }]}
  lang="fr"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">FAQ · {catLabelFr[f.cat] ?? faqCatLabels[f.cat]}</p>
      <h1>{tr.q}</h1>
      <p class="intro">{tr.a}</p>
      {tr.more && tr.more.map((m) => (<p>{m}</p>))}

      {f.related && f.related.length > 0 && (
        <div class="callout">
          <strong>Lié :</strong>{' '}
          {f.related.map((r, i) => (<>{i > 0 ? ' · ' : ''}<a href={r.href}>{r.label}</a></>))}
        </div>
      )}

      <p class="cnote">Nous ne répondons qu'à ce qui est confirmé ou rapporté sur {GAME.title} ; tout ce qui reste inconnu est marqué et mis à jour en continu.</p>

      <nav class="prevnext" aria-label="Navigation FAQ">
        <a href={`/fr/faq/${prev.slug}`}>← Précédent</a>
        <a href="/fr/faq">Toutes les FAQ</a>
        <a href={`/fr/faq/${next.slug}`}>Suivant →</a>
      </nav>
    </div>
  </article>

  <style>
    .cnote { font-size: 0.74rem; color: var(--faint); margin: 14px 0 0; }
    .prevnext { display: flex; justify-content: space-between; gap: 10px; margin: 18px 0 0; font-family: var(--mono); font-size: 0.8rem; }
    .prevnext a { color: var(--candle); }
  </style>
</Base>
