---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Moonlight Peaks est-il disponible sur PS5 ou Xbox ?',
    acceptedAnswer: { '@type': 'Answer', text: "Non — aucune version PlayStation ou Xbox n'a été annoncée. Les plateformes confirmées sont Steam, Steam Deck, Nintendo Switch, Nintendo Switch 2 et Android." },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: `${SITE.url}/fr/faq` },
  ] },
];
---
<Base
  title="Moonlight Peaks est-il disponible sur PS5 ou Xbox ?"
  description="Non — Moonlight Peaks n'est pas disponible sur PS5 ou Xbox. Plateformes confirmées : Steam, Steam Deck, Switch, Switch 2, Android."
  path="/fr/faq/is-moonlight-peaks-on-ps5-or-xbox"
  jsonLd={jsonLd}
  crumbs={[{ label: 'FAQ', href: '/fr/faq' }, { label: 'PS5/Xbox' }]}
  lang="fr"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">FAQ</p>
      <h1>Moonlight Peaks est-il disponible sur <em>PS5 ou Xbox</em> ?</h1>
      <p class="intro">
        En bref : non. Aucune version PlayStation ou Xbox n'a été annoncée. Les plateformes
        confirmées sont Steam, Steam Deck, Nintendo Switch, Nintendo Switch 2 et Android.
      </p>
      <p>Si une version PS5 ou Xbox est annoncée plus tard, nous mettrons à jour cette page.</p>
      <div class="callout wip">
        Aller plus loin : <a href="/fr/platforms">plateformes</a>,
        <a href="/fr/release-date">date de sortie</a>.
      </div>
    </div>
  </article>
</Base>
