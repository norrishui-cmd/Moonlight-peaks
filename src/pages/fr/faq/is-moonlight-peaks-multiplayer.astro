---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Moonlight Peaks est-il multijoueur ?',
    acceptedAnswer: { '@type': 'Answer', text: "Non — Moonlight Peaks est une expérience purement solo. Aucun mode multijoueur ou coopératif n'a été annoncé ; sur Steam, il est répertorié comme solo." },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/fr` },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: `${SITE.url}/fr/faq` },
  ] },
];
---
<Base
  title="Moonlight Peaks est-il multijoueur ?"
  description="Non — Moonlight Peaks est une expérience purement solo. Aucun mode multijoueur ou coopératif n'a été annoncé."
  path="/fr/faq/is-moonlight-peaks-multiplayer"
  jsonLd={jsonLd}
  crumbs={[{ label: 'FAQ', href: '/fr/faq' }, { label: 'Multijoueur ?' }]}
  lang="fr"
>
  <article class="page">
    <div class="wrap">
      <h1>Moonlight Peaks est-il <em>multijoueur</em> ?</h1>
      <p class="intro">
        Non — confirmé : Moonlight Peaks est une expérience purement solo. Aucun mode multijoueur
        ou coopératif n'a été annoncé, et sa fiche Steam le répertorie comme solo.
      </p>
      <div class="callout wip">
        Pages liées : <a href="/fr/faq">toutes les questions fréquentes</a>,
        <a href="/faq/is-moonlight-peaks-multiplayer">version complète en anglais</a>.
      </div>
    </div>
  </article>
</Base>
