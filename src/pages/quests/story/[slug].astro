---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';
import { storyQuests, storyChapters, storyQuestBySlug } from '../../../data/quests-story';

export function getStaticPaths() {
  return storyQuests.map((q) => ({ params: { slug: q.slug }, props: { q } }));
}

const { q } = Astro.props as { q: (typeof storyQuests)[number] };
const chapter = storyChapters.find((c) => c.number === q.chapter)!;
const prev = q.chapter > 1 || storyQuests.indexOf(q) > 0 ? storyQuests[storyQuests.indexOf(q) - 1] : undefined;
const next = q.leadsTo ? storyQuestBySlug.get(q.leadsTo) : undefined;
const statusLabel = q.status === 'confirmed' ? 'Confirmed' : 'Reported';

const baseFaq = [
  { q: `How do you unlock "${q.title}" in Moonlight Peaks?`, a: q.unlock || 'This quest follows on from the previous story beat — see the prerequisite link below.' },
  { q: `What does "${q.title}" reward?`, a: q.reward || 'No confirmed direct item reward has been documented for this quest yet.' },
];
const allFaq = [...baseFaq, ...(q.troubleshooting || [])];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: allFaq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Quests', item: new URL('/quests', SITE.url).href },
    { '@type': 'ListItem', position: 3, name: 'Main Story', item: new URL('/quests/story', SITE.url).href },
    { '@type': 'ListItem', position: 4, name: q.title, item: new URL(`/quests/story/${q.slug}`, SITE.url).href },
  ] },
];
---
<Base
  title={`${q.title} — Moonlight Peaks Quest Guide`}
  description={`${GAME.title} "${q.title}" quest: ${q.summary.slice(0, 140)}`}
  path={`/quests/story/${q.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: 'Quests', href: '/quests' }, { label: 'Main Story', href: '/quests/story' }, { label: q.title }]}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Main Story · Chapter {q.chapter}: {chapter.title} · <span class="tag-community">{statusLabel}</span></p>
      <h1>{q.title}</h1>

      <table class="qmeta">
        <tr><th>Giver</th><td>{q.giver}</td></tr>
        {q.unlock && <tr><th>Unlock</th><td>{q.unlock}</td></tr>}
        {q.reward && <tr><th>Leads to / Reward</th><td>{q.reward}</td></tr>}
      </table>

      <h2>What happens</h2>
      <p>{q.summary}</p>

      {q.related && q.related.length > 0 && (
        <div class="callout wip">
          <strong>Related:</strong>{' '}
          {q.related.map((r, i) => (
            <>{i > 0 ? ' · ' : ''}<a href={r.href}>{r.label}</a></>
          ))}
        </div>
      )}

      {q.troubleshooting && q.troubleshooting.length > 0 && (
        <>
          <h2>Stuck? Common problems with this quest</h2>
          <div class="faq">
            {q.troubleshooting.map((f) => (
              <details>
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))}
          </div>
        </>
      )}

      <h2>FAQ</h2>
      <div class="faq">
        {baseFaq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <nav class="prevnext" aria-label="Quest navigation">
        {prev ? <a href={`/quests/story/${prev.slug}`}>← {prev.title}</a> : <span />}
        <a href="/quests/story">All chapters</a>
        {next ? <a href={`/quests/story/${next.slug}`}>{next.title} →</a> : <span />}
      </nav>

      <div class="callout wip">
        Related: <a href="/quests">Quests hub</a>, <a href="/quests/side">side quests</a>,
        <a href="/beginner-guide">beginner guide</a>.
      </div>
    </div>
  </article>

  <style>
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 7px;
      vertical-align: middle;
    }
    .qmeta { width: 100%; border-collapse: collapse; margin: 16px 0 24px; }
    .qmeta th { text-align: left; color: var(--faint); font-family: var(--mono); font-size: 0.72rem; text-transform: uppercase; padding: 8px 14px 8px 0; vertical-align: top; white-space: nowrap; }
    .qmeta td { padding: 8px 0; border-bottom: 1px solid var(--line); color: var(--mist); }
    .prevnext { display: flex; justify-content: space-between; gap: 10px; margin: 22px 0; font-family: var(--mono); font-size: 0.82rem; }
    .prevnext a { color: var(--candle); }
  </style>
</Base>
