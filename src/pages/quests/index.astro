---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';
import { storyQuests, storyChapters } from '../../data/quests-story';
import { sideQuests } from '../../data/quests-side';

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Quests', item: new URL('/quests', SITE.url).href },
  ],
};
---
<Base
  title="Moonlight Peaks Quest Guide — Main Story & Side Quests, Step by Step"
  description="The complete Moonlight Peaks quest hub: the main story chain chapter by chapter, every confirmed side quest, and answers for when you're stuck — sourced from cross-verified launch-week walkthroughs."
  path="/quests"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Quests' }]}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Hub · Quests</p>
      <h1>{GAME.title} <em>quest guide</em></h1>
      <p class="intro">
        Whether you want to follow the main story in order or you're stuck on one specific quest,
        this is the hub for it. Everything here is cross-checked across multiple independent
        launch-week sources rather than a single walkthrough — quests are labeled <strong>confirmed</strong>
        when two or more sources agree on the same beats, and <strong>reported</strong> when only one
        source has documented it so far. Nothing here is invented to fill a gap.
      </p>

      <div class="q-split">
        <a class="q-card" href="/quests/story">
          <span class="q-tag">Main Story</span>
          <h2>Follow the story, chapter by chapter</h2>
          <p>{storyQuests.length} main-story quests, organized into {storyChapters.length} chapters from arriving in town to the wedding arc. Pick a chapter and go straight to where you are.</p>
          <strong>Browse chapters →</strong>
        </a>
        <a class="q-card" href="/quests/side">
          <span class="q-tag">Side Quests</span>
          <h2>NPC quests & side systems</h2>
          <p>{sideQuests.length} confirmed side quests and ongoing systems — fishing contests, house upgrades, the job board, and the town's two creature-collecting side hunts.</p>
          <strong>Browse side quests →</strong>
        </a>
      </div>

      <h2>Stuck on something specific?</h2>
      <p>
        If you're stuck on a particular story beat, <a href="/quests/a-bridge-too-far">A Bridge Too Far</a>
        is the most-searched early quest — see its dedicated page for the full Orlock/Fiona bridge
        walkthrough. For quest-related questions in general, see the
        <a href="/faq">FAQ</a>, which includes a dedicated quests section.
      </p>

      <div class="callout wip">
        Related: <a href="/beginner-guide">beginner guide</a>, <a href="/characters">characters</a>,
        <a href="/map">map</a>, <a href="/known-issues">known issues</a>.
      </div>
    </div>
  </article>

  <style>
    .q-split { display: grid; grid-template-columns: 1fr; gap: 14px; margin: 24px 0 30px; }
    @media (min-width: 720px) { .q-split { grid-template-columns: 1fr 1fr; } }
    .q-card {
      display: flex; flex-direction: column; gap: 8px;
      border: 1px solid var(--line); border-radius: 16px; background: var(--surface);
      padding: 20px; text-decoration: none; color: inherit;
      transition: border-color .15s ease, transform .15s ease;
    }
    .q-card:hover { border-color: color-mix(in srgb, var(--candle) 54%, var(--line)); transform: translateY(-2px); }
    .q-tag { font-family: var(--mono); font-size: 0.68rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--candle); }
    .q-card h2 { margin: 4px 0 6px; font-size: 1.2rem; }
    .q-card p { margin: 0 0 8px; color: #ded3e6; font-size: 0.9rem; }
    .q-card strong { font-family: var(--mono); font-size: 0.82rem; color: var(--candle); }
  </style>
</Base>
