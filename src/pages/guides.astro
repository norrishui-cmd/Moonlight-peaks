---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';
import PriorityLinks from '../components/PriorityLinks.astro';
import News from '../components/News.astro';
import {
  releasePriorityLinks,
  characterPriorityLinks,
  romancePriorityLinks,
  farmMagicPriorityLinks,
  databasePriorityLinks,
  systemsPriorityLinks,
  toolsHubPriorityLinks,
  launchStatusPriorityLinks,
  comparisonPriorityLinks,
  beginnerPriorityLinks,
} from '../data/priorityLinks';

const faq = [
  { q: 'What Moonlight Peaks guide should I read first?', a: 'Start with the beginner guide, then check platforms and release date if you haven\u2019t bought yet, or jump straight to farming, characters, and romance if you\u2019re already playing.' },
  { q: 'Are all guide details confirmed?', a: 'No — every page marks facts as confirmed, reported, or datamined. We update tables and FAQs as real launch-week data replaces earlier reports rather than guessing.' },
  { q: 'Where do I find data for crops, gifts, and cards?', a: 'Farming, characters, and Nokturna each have their own database sections. Where data isn\u2019t public yet, we point you to the matching tracker tool instead of inventing numbers.' },
  { q: 'Why are there so many guide URLs?', a: 'The site is organized as topic clusters so both players and search engines can land on the specific answer they need — like a single character\u2019s gifts, a platform question, or a known bug fix.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: new URL('/guides', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })) },
];
---
<Base
  title="Moonlight Peaks Guides — Beginner, Farming & Romance"
  description="Moonlight Peaks guides hub for beginners, farming, fishing, romance, tools, database, and launch-week updates — organized by what you're trying to do."
  path="/guides"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Guides' }]}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Hub / Guides</p>
      <h1>Moonlight Peaks <em>guides</em></h1>
      <p class="intro">
        Pick a cluster by what you're trying to do, not a generic link wall. {GAME.title} is out now
        on {GAME.platforms.join(', ')} — everything below is organized by intent and updated as we
        verify more. Updated {SITE.updated}.
      </p>

      <h2>Recommended reading order</h2>
      <ol class="steps">
        <li><strong>Check release and platform details.</strong> Confirm your platform, price, demo access, and whether your device is covered.</li>
        <li><strong>Read the beginner guide.</strong> Learn the night-farming loop, vampire powers, magic, townsfolk, and quest markers.</li>
        <li><strong>Pick your first goal.</strong> Farming, romance, Nokturna, and the item database each lead to different clusters below.</li>
        <li><strong>Use specific long-tail pages.</strong> When you need one answer, use pages like Saga's gifts, known issues, or a platform comparison.</li>
      </ol>

      <PriorityLinks title="Start here" note="release, demo, platforms" links={beginnerPriorityLinks} />

      <PriorityLinks title="Platforms & release" note="where to play" links={releasePriorityLinks} />

      <PriorityLinks title="Characters & relationships" note="residents, families, gifts" links={characterPriorityLinks} />

      <PriorityLinks title="Romance & marriage" note="dating, heart levels, weddings" links={romancePriorityLinks} />

      <PriorityLinks title="Farm & magic" note="crops, livestock, spells, shapeshifting" links={farmMagicPriorityLinks} />

      <PriorityLinks title="Database" note="items, locations, the map" links={databasePriorityLinks} />

      <PriorityLinks title="Systems" note="Nokturna and trackers" links={systemsPriorityLinks} />

      <PriorityLinks title="Tools" note="every planner & tracker" links={toolsHubPriorityLinks} />

      <PriorityLinks title="Launch status & safety" note="bugs, settings, cheats" links={launchStatusPriorityLinks} />

      <PriorityLinks title="Comparisons" note="vs. other cozy sims" links={comparisonPriorityLinks} />

      <h2>Latest guide updates</h2>
      <News category="guides" limit={5} />

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout">
        Related: <a href="/beginner-guide">beginner guide</a>, <a href="/demo">demo guide</a>,
        <a href="/platforms">platforms</a>, <a href="/characters">characters</a>, <a href="/romance">romance</a>.
        More FAQ: <a href="/faq/is-moonlight-peaks-worth-it">Is it worth it?</a>,
        <a href="/faq/how-long-is-moonlight-peaks">How long is it?</a>,
        <a href="/faq">full FAQ hub</a>.
      </div>
    </div>
  </article>
</Base>
