---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';
import { spellcastingSections, spellcastingSpells } from '../data/spellcasting';
import News from '../components/News.astro';

const iconCount = spellcastingSpells.filter((spell) => spell.icon).length;

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'World', item: new URL('/locations', SITE.url).href },
    { '@type': 'ListItem', position: 3, name: 'Spellcasting', item: new URL('/spellcasting', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'ItemList', name: 'Moonlight Peaks spellcasting catalog', itemListElement: spellcastingSpells.map((spell, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: spell.name,
    description: spell.description,
    ...(spell.icon ? { image: new URL(spell.icon, SITE.url).href } : {}),
  })) },
];
---

<Base
  title="Moonlight Peaks Spellcasting - Spells, Mana Costs & Buy Prices"
  description="Moonlight Peaks spellcasting catalog with cropped spell icons, mana costs, descriptions, and buy prices from the supplied screenshots."
  path="/spellcasting"
  jsonLd={jsonLd}
  crumbs={[{ label: 'World', href: '/locations' }, { label: 'Spellcasting' }]}
>
  <article class="page spellcasting-page">
    <div class="wrap">
      <p class="eyebrow">World / Spellcasting</p>
      <h1>Moonlight Peaks <em>spellcasting</em></h1>
      <p class="intro">
        Spellcasting data captured from the supplied screenshots for {GAME.title}. This page lists
        {spellcastingSpells.length} spells and {iconCount} cropped spell icons, with mana costs and buy prices where shown.
      </p>

      <nav class="spell-jump" aria-label="Spellcasting sections">
        {spellcastingSections.map((section) => (
          <a href={`#${section.slug}`}>{section.title} <span>{section.spells.length}</span></a>
        ))}
      </nav>

      {spellcastingSections.map((section) => (
        <section class="spell-section" id={section.slug} aria-labelledby={`${section.slug}-title`}>
          <h2 id={`${section.slug}-title`}>{section.title}</h2>
          <div class="spell-list">
            {section.spells.map((spell) => (
              <article class={`spell-card ${spell.icon ? '' : 'spell-card-no-icon'}`}>
                <div class="spell-icon" aria-hidden={!spell.icon}>
                  {spell.icon ? (
                    <img src={spell.icon} alt={`${spell.name} spell icon`} width="144" height="144" loading="lazy" />
                  ) : (
                    <span>-</span>
                  )}
                </div>
                <div class="spell-body">
                  <h3>{spell.name}</h3>
                  <p>{spell.description}</p>
                  <dl>
                    <div>
                      <dt>Mana</dt>
                      <dd>{spell.manaCost}</dd>
                    </div>
                    <div>
                      <dt>Buy Price</dt>
                      <dd>{spell.buyPrice}</dd>
                    </div>
                  </dl>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}

      <p class="spell-note">
        Missing values are kept as <code>-</code> when the screenshots showed a placeholder or no value.
        Maturio spell rows had text in the screenshots but no visible icon to crop.
      </p>

      <h2>Latest spellcasting updates</h2>
      <News topic="spellcasting" limit={5} />

      <div class="callout">
        Related: <a href="/magic">magic guide</a>, <a href="/farming">farming</a>,
        <a href="/items/tools">tools</a>, <a href="/items/cooking">cooking</a>, and <a href="/quests">quests</a>.
      </div>
    </div>
  </article>

  <style>
    .spell-jump {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 18px 0 24px;
    }

    .spell-jump a {
      border: 1px solid var(--line);
      border-radius: 999px;
      color: var(--mist);
      background: var(--surface);
      padding: 7px 12px;
      text-decoration: none;
      font-family: var(--mono);
      font-size: 0.76rem;
    }

    .spell-jump a:hover {
      border-color: color-mix(in srgb, #5ecfff 54%, var(--line));
      color: #84eaff;
    }

    .spell-jump span {
      color: var(--faint);
      margin-left: 4px;
    }

    .spell-section {
      margin-top: 24px;
    }

    .spell-list {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }

    @media (min-width: 760px) {
      .spell-list {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    .spell-card {
      display: grid;
      grid-template-columns: 104px minmax(0, 1fr);
      gap: 14px;
      align-items: center;
      min-height: 150px;
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: rgba(32, 18, 58, 0.74);
    }

    .spell-icon {
      width: 104px;
      height: 104px;
      display: grid;
      place-items: center;
      border-radius: 8px;
      border: 1px solid rgba(94, 207, 255, 0.16);
      background: rgba(15, 8, 36, 0.42);
    }

    .spell-icon img {
      width: 96px;
      height: 96px;
      object-fit: contain;
      display: block;
      filter: drop-shadow(0 0 13px rgba(49, 209, 255, 0.46));
    }

    .spell-icon span {
      color: var(--faint);
      font-family: var(--mono);
      font-size: 1.1rem;
    }

    .spell-body {
      min-width: 0;
    }

    .spell-body h3 {
      margin: 0 0 8px;
      color: #c8a8ee;
      font-family: var(--sans);
      font-size: 1.12rem;
      font-weight: 800;
      line-height: 1.2;
    }

    .spell-body p {
      margin: 0 0 10px;
      color: #eee7f3;
      font-size: 0.92rem;
      line-height: 1.45;
    }

    .spell-body dl {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 0;
    }

    .spell-body dl div {
      display: flex;
      align-items: center;
      gap: 6px;
      min-height: 28px;
      padding: 4px 8px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: rgba(20, 10, 44, 0.56);
    }

    .spell-body dt {
      margin: 0;
      color: var(--faint);
      font-family: var(--mono);
      font-size: 0.66rem;
      text-transform: uppercase;
    }

    .spell-body dd {
      margin: 0;
      color: var(--mist);
      font-weight: 700;
      font-size: 0.82rem;
    }

    .spell-note {
      color: var(--faint);
      font-size: 0.78rem;
      margin: 16px 0 18px;
    }

    .spell-note code {
      color: var(--mist);
    }

    @media (max-width: 520px) {
      .spell-card {
        grid-template-columns: 82px minmax(0, 1fr);
        gap: 10px;
        min-height: 126px;
        padding: 12px;
      }

      .spell-icon {
        width: 82px;
        height: 82px;
      }

      .spell-icon img {
        width: 76px;
        height: 76px;
      }

      .spell-body h3 {
        font-size: 1rem;
      }
    }
  </style>
</Base>
