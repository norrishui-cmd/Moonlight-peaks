---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';
import { collections } from '../../data/collections';
import News from '../../components/News.astro';

const faq = [
  { q: 'What are Moonlight Peaks collections?', a: 'Collections are trackable world lists such as fish, jobs, critters, Vampsters, and Soul Blobs. They belong under World because players usually search for locations, conditions, and completion progress rather than generic item stats.' },
  { q: 'Why move Critters out of Items?', a: 'Critters behave more like a catchable collection than a normal item category, so the Collection hub gives them better fields: spawn conditions, location, time, weather, use, and progress tracking.' },
  { q: 'Are these pages copied from the official wiki?', a: 'No. The official wiki is linked as a source. This site uses its own guide format, summaries, tables, and verification notes instead of copying full pages.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Collections', item: new URL('/collections', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'ItemList', name: 'Moonlight Peaks collections', itemListElement: collections.map((entry, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: entry.title,
    url: new URL(`/collections/${entry.slug}`, SITE.url).href,
  })) },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
];
---
<Base
  title="Moonlight Peaks Collections - Fish, Critters, Vampsters, Soul Blobs & Jobs"
  description="Moonlight Peaks collection hub for fish, Albertus' Jobs, critters, Vampsters, and Soul Blobs, with official source links and launch-safe tracking tables."
  path="/collections"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Collections' }]}
>
  <article class="page collections-page">
    <div class="wrap">
      <p class="eyebrow">World / Collections</p>
      <h1>Moonlight Peaks <em>collections</em></h1>
      <p class="intro">
        A dedicated World hub for trackable lists: fish, Albertus' Jobs, critters, Vampsters, and Soul Blobs.
        These pages use official wiki links as sources while presenting the information in a cleaner guide
        structure built for search, progress tracking, and post-launch updates.
      </p>

      <div class="collection-grid">
        {collections.map((entry) => (
          <a class="collection-card" href={`/collections/${entry.slug}`}>
            <img src={entry.image} alt={`${entry.title} - Moonlight Peaks collection`} loading="lazy" />
            <div class="collection-body">
              <span>{entry.tag}</span>
              <h2>{entry.title}</h2>
              <p>{entry.dek}</p>
              <strong>Open collection -&gt;</strong>
            </div>
          </a>
        ))}
      </div>

      <h2>Source and formatting policy</h2>
      <p>
        Official wiki pages are treated as source references, not as text to duplicate. Collection pages on this
        site are rewritten into task-oriented tables, checklists, and quick facts so players can scan them faster
        and Google does not see them as duplicate pages.
      </p>

      <h2>Latest collections updates</h2>
      <News topic="collections" limit={5} />

      <div class="callout">
        More FAQ: <a href="/faq/how-many-items-in-each-museum-collection">Museum collection counts</a>,
        <a href="/faq/does-farming-collection-need-perfect-quality">Farming Collection quality</a>,
        <a href="/faq">full FAQ hub</a>.
      </div>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </article>

  <style>
    .collection-grid { display: grid; grid-template-columns: 1fr; gap: 16px; margin: 24px 0 28px; }
    @media (min-width: 720px) { .collection-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    .collection-card {
      display: flex;
      flex-direction: column;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: var(--surface);
      color: inherit;
      text-decoration: none;
      transition: border-color .15s ease, transform .15s ease;
    }
    .collection-card:hover { border-color: color-mix(in srgb, var(--candle) 54%, var(--line)); transform: translateY(-2px); }
    .collection-card img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; border-bottom: 1px solid var(--line); }
    .collection-body { padding: 16px; }
    .collection-body span {
      color: var(--candle);
      font-family: var(--mono);
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .collection-body h2 { margin: 6px 0 6px; font-size: 1.38rem; }
    .collection-body p { margin: 0 0 12px; color: #ded3e6; font-size: 0.94rem; }
    .collection-body strong { color: var(--candle); font-family: var(--mono); font-size: 0.78rem; }
  </style>
</Base>
