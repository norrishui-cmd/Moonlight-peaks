---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';
import News from '../components/News.astro';
import PriorityLinks from '../components/PriorityLinks.astro';
import { previews } from '../data/previews';
import { homepagePriorityLinks } from '../data/priorityLinks';

const entries = [
  { ent: 'Entry / Launch', title: 'Where to play & price', desc: 'Steam, Switch, Switch 2, Android, demo access, launch discount, and platform notes.', href: '/release-date', live: true, img: '/card-release.webp' },
  { ent: 'Entry / Specs', title: 'System requirements', desc: 'PC, Mac, Steam Deck, and demo performance checks before buying.', href: '/system-requirements', live: true, img: '/card-guide.webp' },
  { ent: 'Entry / Languages', title: 'Languages', desc: 'Japanese, Chinese, Korean, German, and English support to verify at launch.', href: '/languages', live: true, img: '/card-guide.webp' },
  { ent: 'Entry · Guide', title: 'Beginner guide', desc: 'Everything known so far, shaping into your day-one head start.', href: '/beginner-guide', live: true, img: '/card-guide.webp' },
  { ent: 'Entry · Cards', title: 'Nokturna card game', desc: "The town's favorite game — how it works, cards, and how to win.", href: '/nokturna', live: true, img: '/card-nokturna.webp' },
  { ent: 'Entry · Hearts', title: 'Romance & families', desc: 'The seven families, who you can romance, and gift favorites.', href: '/romance', live: true, img: '/card-romance.webp' },
  { ent: 'Entry / Cheats', title: 'Cheats & console', desc: 'Console commands, money cheats, and what still needs launch-week verification.', href: '/cheats', live: true, img: '/card-cheats.webp' },
  { ent: 'Entry · Farm', title: 'Crops & seasons', desc: 'Mystical crops, magical livestock, and the night-farming loop.', href: '/farming', live: true, img: '/card-crops.webp' },
];

const explore = [
  { k: 'Characters', d: 'Residents, families & who you can romance', href: '/characters', img: '/count-dracula.webp' },
  { k: 'Locations', d: 'The town, your farm, the forest, the lake & more', href: '/locations', img: '/hero-loc-town.webp' },
  { k: 'Families', d: 'The seven supernatural families of the town', href: '/families', img: '/hero-fam-vampires.webp' },
  { k: 'Activities', d: 'Fishing, magic, crafts & cozy diversions', href: '/activities', img: '/hero-act-seasonal-events.webp' },
  { k: 'Items', d: 'Tools, potions, decorations & other categories', href: '/items', img: null, c1: '#3a4a2f', c2: '#8ab06a' },
  { k: 'FAQ', d: 'Quick answers to the most common questions', href: '/faq', img: '/card-faq.webp' },
  { k: 'Previews & guides', d: 'Demo impressions, press hands-on & how-tos', href: '/previews', img: '/hero-first-five-minutes.webp' },
  { k: 'Export to PDF', d: 'Pick any guides and export them together as one PDF', href: '/export', img: '/card-export-pdf.webp' },
];

const demoPosts = previews.filter((p) => p.category === 'preview').slice(0, 5);
const guidePosts = previews.filter((p) => p.category === 'guide').slice(0, 5);
const dailyPosts = previews
  .filter((p) => p.category === 'daily')
  .slice()
  .sort((a, b) => (a.date < b.date ? 1 : a.date > b.date ? -1 : 0))
  .slice(0, 6);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${SITE.url}/#website`,
    name: SITE.brand,
    alternateName: ['Moonlight Peaks Wiki', 'Moonlight Peaks Guide', 'Moonlight Peaks Fan Wiki'],
    url: SITE.url,
    inLanguage: 'en',
    description: 'Fan-made guide and wiki for Moonlight Peaks: release info, beginner guide, Nokturna, romance, and cheats.',
    publisher: { '@id': `${SITE.url}/#organization` },
    potentialAction: {
      '@type': 'SearchAction',
      target: { '@type': 'EntryPoint', urlTemplate: `${SITE.url}/search?q={search_term_string}` },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': `${SITE.url}/#organization`,
    name: SITE.brand,
    url: SITE.url,
    logo: `${SITE.url}/favicon.svg`,
    description: 'An independent, fan-made wiki and guide covering Moonlight Peaks — not affiliated with the game\u2019s developer or publisher.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'VideoGame',
    name: GAME.title,
    gamePlatform: GAME.platforms,
    publisher: { '@type': 'Organization', name: GAME.publisher },
    author: { '@type': 'Organization', name: GAME.developer },
    datePublished: GAME.releaseISO,
  },
];
---
<Base
  title="Moonlight Peaks Wiki & Guide - 11 Tools, 8 Languages"
  description="Moonlight Peaks launch hub in 8 languages: where to play, price, beginner guide, platform notes, romance, families, 11 interactive tools (gift finder, trackers, planners), known issues, and constantly updated launch news."
  path="/"
  jsonLd={jsonLd}
>
  <section class="hero hero-immersive">
    <div class="hero-art" aria-hidden="true">
      <img src="/hero-moonlit-peaks.webp" alt="Moonlight Peaks — a moonlit gothic village with cottages, lanterns, and a vampire farmer" fetchpriority="high" />
    </div>
    <div class="hero-mist" aria-hidden="true"></div>
    <div class="wrap">
      <div class="hero-copy">
      <p class="eyebrow">Launch hub for new vampires</p>
      <h1 class="title"><em>Moonlight Peaks</em> launch guide and wiki.</h1>
      <p class="lede">
        Start here after launch: where to play, what to check first, which guides are safe to trust,
        and the fastest routes into farming, romance, Nokturna, tools, items, and the town's
        supernatural families.
      </p>
      <div class="actions">
        <a class="btn btn-primary" href="/beginner-guide">Start guide <span class="arr">-&gt;</span></a>
        <a class="btn btn-ghost" href="/platforms">Pick platform</a>
        <a class="btn btn-ghost" href="/known-issues">Known issues</a>
      </div>

      <div class="launch-panel" aria-label="Moonlight Peaks launch status">
        <div class="launch-badge">
          <span>Launch hub live</span>
          <strong>{GAME.shortReleaseLabel}</strong>
        </div>
        <div class="launch-cards">
          <a href="/platforms">
            <span>Play on</span>
            <strong>Steam, Switch, Switch 2, Android</strong>
          </a>
          <a href="/release-date">
            <span>Price</span>
            <strong>{GAME.price} + launch discount</strong>
          </a>
          <a href="/tools">
            <span>Tools</span>
            <strong>Platform picker, gifts, item tracker</strong>
          </a>
        </div>
      </div>
      <div class="launch-strip" aria-label="Launch checklist">
        <a href="/launch-day">Launch checklist</a>
        <a href="/release-date">Price & date</a>
        <a href="/demo">Free demo</a>
        <a href="/known-issues">Known issues</a>
        <a href="/best-settings">Best settings</a>
        <a href="/system-requirements">System requirements</a>
        <a href="/languages">Languages</a>
        <a href="/platforms">Platforms</a>
      </div>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="sec-head">
        <h2>Almanac entries</h2>
        <span class="note">what players look up first</span>
      </div>
      <div class="entries">
        {entries.map((e) => (
          <a class={`entry${e.live ? '' : ' soon'}`} href={e.href}>
            {e.img && <img class="entry-img" src={e.img} alt={e.title} loading="lazy" />}
            <span class={`tag ${e.live ? 'live' : 'soon'}`}>{e.live ? 'Open' : 'Soon'}</span>
            <span class="ent">{e.ent}</span>
            <h3>{e.title}</h3>
            <p>{e.desc}</p>
            <span class="go">{e.live ? 'read entry ->' : 'at launch'}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="sec-head">
        <h2>Explore the world</h2>
        <span class="note">hubs &amp; guides</span>
      </div>
      <div class="explore">
        {explore.map((x) => (
          <a class="ex-card" href={x.href}>
            <span class="ex-thumb" style={!x.img ? `background: linear-gradient(135deg, ${x.c1}, ${x.c2})` : undefined}>
              {x.img ? <img src={x.img} alt="" loading="lazy" width="72" height="72" /> : <span class="ex-thumb-letter">{x.k[0]}</span>}
            </span>
            <span class="ex-body">
              <span class="ex-k">{x.k}</span>
              <span class="ex-d">{x.d}</span>
              <span class="ex-go">Open -&gt;</span>
            </span>
          </a>
        ))}
      </div>
      <PriorityLinks
        title="Most-searched Moonlight Peaks pages"
        note="SEO entry points"
        links={homepagePriorityLinks}
      />

      <div class="sec-head" style="margin-top: 28px;">
        <h2>Trending player problems</h2>
        <span class="note">what people are stuck on right now</span>
      </div>
      <ul class="trending-list">
        <li><a href="/quests/side/elviras-treasure-hunt">Elvira's Treasure Hunt Walkthrough</a></li>
        <li><a href="/shapeshifting">How to Unlock Mermaid Form</a></li>
        <li><a href="/locations/silverveil-museum">Museum Donations & How to Unlock It</a></li>
        <li><a href="/farm/farm-helpers">Firefly Sanctuary & Pollinator Guide</a></li>
        <li><a href="/magic">How to Fix the Wand (Mana Guide)</a></li>
        <li><a href="/items/mineables">Gold Ore & Mining Guide</a></li>
        <li><a href="/known-issues">Known Issues & Loading Problems</a></li>
        <li><a href="/quests/story/a-bridge-too-far">A Bridge Too Far Quest Guide</a></li>
      </ul>
    </div>
  </section>

  <style>
    .trending-list { list-style: none; margin: 12px 0 0; padding: 0; display: grid; grid-template-columns: 1fr; gap: 8px; }
    @media (min-width: 640px) { .trending-list { grid-template-columns: 1fr 1fr; } }
    .trending-list a {
      display: block; padding: 10px 14px; border: 1px solid var(--line); border-radius: 10px;
      color: var(--mist); text-decoration: none; font-size: 0.9rem; background: var(--surface);
      transition: border-color .15s ease;
    }
    .trending-list a:hover { border-color: color-mix(in srgb, var(--candle) 45%, var(--line)); color: var(--candle); }
  </style>

  {dailyPosts.length > 0 && (
    <section class="sec">
      <div class="wrap">
        <div class="sec-head">
          <h2>Daily updates</h2>
          <span class="note">freshest first</span>
        </div>
        <ul class="prev-list">
          {dailyPosts.map((p) => (
            <li>
              <a href={`/previews/${p.slug}`}>
                <img class="pl-thumb" src={p.image} alt={`${p.title} — Moonlight Peaks`} width="160" height="84" loading="lazy" />
                <span class="pl-body">
                  <span class="pl-tag">{p.tag}</span>
                  <span class="pl-title">{p.title}</span>
                  <span class="pl-dek">{p.dek}</span>
                  <span class="pl-meta">{p.readTime} · {p.date}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="sec">
    <div class="wrap">
      <div class="sec-head">
        <h2>Demo impressions</h2>
        <span class="note">what players & press say</span>
      </div>
      <ul class="prev-list">
        {demoPosts.map((p) => (
          <li>
            <a href={`/previews/${p.slug}`}>
              <img class="pl-thumb" src={p.image} alt={`${p.title} — Moonlight Peaks`} width="160" height="84" loading="lazy" />
              <span class="pl-body">
                <span class="pl-tag">{p.tag}</span>
                <span class="pl-title">{p.title}</span>
                <span class="pl-dek">{p.dek}</span>
                <span class="pl-meta">{p.readTime} · {p.date}</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
      <p class="prev-all"><a href="/previews">See all articles →</a></p>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="sec-head">
        <h2>Guides</h2>
        <span class="note">tips & reference</span>
      </div>
      <ul class="prev-list">
        {guidePosts.map((p) => (
          <li>
            <a href={`/previews/${p.slug}`}>
              <img class="pl-thumb" src={p.image} alt={`${p.title} — Moonlight Peaks`} width="160" height="84" loading="lazy" />
              <span class="pl-body">
                <span class="pl-tag">{p.tag}</span>
                <span class="pl-title">{p.title}</span>
                <span class="pl-dek">{p.dek}</span>
                <span class="pl-meta">{p.readTime} · {p.date}</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="sec-head">
        <h2>Latest news</h2>
        <span class="note">updates & announcements</span>
      </div>
      <News limit={5} />
    </div>
  </section>

  <style>
    .hero-immersive {
      min-height: min(760px, calc(100vh - 28px));
      display: flex;
      align-items: center;
      overflow: hidden;
      isolation: isolate;
      border-bottom: 1px solid color-mix(in srgb, var(--line) 72%, transparent);
    }
    .hero-immersive::before {
      z-index: -1;
      background:
        linear-gradient(90deg, rgba(21,16,29,0.92) 0%, rgba(21,16,29,0.76) 36%, rgba(21,16,29,0.28) 70%, rgba(21,16,29,0.22) 100%),
        linear-gradient(0deg, var(--ink) 0%, rgba(21,16,29,0.24) 34%, rgba(21,16,29,0.10) 74%);
    }
    .hero-art {
      position: absolute;
      inset: 0;
      z-index: -3;
      transform: scale(1.03);
      animation: heroDrift 18s ease-in-out infinite alternate;
    }
    .hero-art img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      object-position: 58% 50%;
      filter: saturate(1.04) contrast(1.03) brightness(0.78);
    }
    .hero-immersive::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -2;
      pointer-events: none;
      background:
        radial-gradient(circle at 78% 16%, rgba(246,237,211,0.28), transparent 10%),
        radial-gradient(680px 380px at 58% 72%, rgba(243,201,105,0.12), transparent 62%),
        radial-gradient(760px 420px at 18% 22%, rgba(192,67,106,0.13), transparent 62%);
      mix-blend-mode: screen;
      animation: moonPulse 7s ease-in-out infinite;
    }
    .hero-mist {
      position: absolute;
      inset: auto -10% 0 -10%;
      height: 44%;
      z-index: -1;
      pointer-events: none;
      background:
        linear-gradient(90deg, transparent, rgba(240,233,244,0.09), transparent),
        radial-gradient(60% 70% at 52% 78%, rgba(180,166,196,0.18), transparent 70%);
      filter: blur(18px);
      opacity: 0.74;
      animation: mistGlide 12s ease-in-out infinite alternate;
    }
    .hero-copy {
      max-width: 620px;
      padding: clamp(2rem, 6vw, 4.5rem) 0;
      text-shadow: 0 2px 22px rgba(0,0,0,0.46);
    }
    .hero-immersive .lede {
      color: color-mix(in srgb, var(--mist) 82%, var(--muted));
    }
    .hero-immersive .btn-ghost {
      background: rgba(36, 27, 49, 0.78);
      backdrop-filter: blur(8px);
    }
    .launch-panel {
      display: grid;
      grid-template-columns: minmax(150px, 0.7fr) minmax(0, 2.3fr);
      gap: 12px;
      max-width: 760px;
      margin-top: 30px;
    }
    .launch-badge,
    .launch-cards a {
      border: 1px solid rgba(255,255,255,0.18);
      background: rgba(21,16,29,0.58);
      backdrop-filter: blur(10px);
      box-shadow: 0 18px 44px rgba(0,0,0,0.2);
    }
    .launch-badge {
      display: flex;
      min-height: 124px;
      flex-direction: column;
      justify-content: center;
      gap: 8px;
      border-radius: 14px;
      padding: 18px;
    }
    .launch-badge span,
    .launch-cards span {
      color: var(--candle);
      font-family: var(--mono);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .launch-badge strong {
      color: var(--mist);
      font-family: var(--display);
      font-size: 1.45rem;
      line-height: 1.05;
    }
    .launch-cards {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }
    .launch-cards a {
      display: flex;
      min-height: 124px;
      flex-direction: column;
      justify-content: space-between;
      border-radius: 14px;
      padding: 16px;
      transition: transform .14s ease, border-color .14s ease, background .14s ease;
    }
    .launch-cards a:hover {
      transform: translateY(-2px);
      border-color: color-mix(in srgb, var(--candle) 60%, rgba(255,255,255,0.18));
      background: rgba(36,27,49,0.72);
    }
    .launch-cards strong {
      color: var(--mist);
      font-size: 0.92rem;
      line-height: 1.35;
    }
    .hero-immersive .cd-cell {
      background: linear-gradient(180deg, rgba(36,27,49,0.82), rgba(21,16,29,0.78));
      backdrop-filter: blur(8px);
    }
    @keyframes heroDrift {
      from { transform: scale(1.03) translate3d(0, 0, 0); }
      to { transform: scale(1.08) translate3d(-1.2%, -0.8%, 0); }
    }
    @keyframes moonPulse {
      0%, 100% { opacity: 0.72; }
      50% { opacity: 0.95; }
    }
    @keyframes mistGlide {
      from { transform: translate3d(-2%, 0, 0); opacity: 0.56; }
      to { transform: translate3d(4%, -5%, 0); opacity: 0.82; }
    }
    @media (max-width: 760px) {
      .hero-immersive {
        min-height: min(720px, calc(100vh - 22px));
        align-items: flex-end;
      }
      .hero-immersive::before {
        background:
          linear-gradient(180deg, rgba(21,16,29,0.22) 0%, rgba(21,16,29,0.52) 44%, rgba(21,16,29,0.94) 100%),
          linear-gradient(90deg, rgba(21,16,29,0.72), rgba(21,16,29,0.24));
      }
      .hero-art img {
        object-position: 58% 42%;
        filter: saturate(1.02) contrast(1.02) brightness(0.72);
      }
      .hero-copy {
        max-width: 100%;
        padding: 8rem 0 2rem;
      }
      .launch-panel {
        grid-template-columns: 1fr;
        margin-top: 24px;
      }
      .launch-badge {
        min-height: auto;
      }
      .launch-cards {
        grid-template-columns: 1fr;
      }
      .launch-cards a {
        min-height: 92px;
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-art,
      .hero-immersive::after,
      .hero-mist {
        animation: none;
      }
    }

    .entry-img {
      display: block;
      width: calc(100% + 36px);
      height: auto;
      margin: -20px -18px 10px;
      border-radius: calc(var(--radius) - 1px) calc(var(--radius) - 1px) 0 0;
      background: var(--ink-2);
    }
    .entry .tag.live { background: rgba(20, 16, 29, 0.6); }
    .entry .tag.soon { background: rgba(20, 16, 29, 0.6); }

    .explore { display: grid; grid-template-columns: 1fr; gap: 12px; }
    @media (min-width: 560px) { .explore { grid-template-columns: 1fr 1fr; } }
    @media (min-width: 880px) { .explore { grid-template-columns: 1fr 1fr 1fr; } }
    .ex-card { display: flex; flex-direction: row; align-items: center; gap: 14px; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); padding: 12px; transition: border-color .15s ease, transform .15s ease; }
    .ex-card:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); transform: translateY(-2px); }
    .ex-thumb {
      flex: 0 0 auto; width: 64px; height: 64px; border-radius: 10px; overflow: hidden;
      display: flex; align-items: center; justify-content: center; border: 1px solid var(--line);
    }
    .ex-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .ex-thumb-letter { font-family: var(--display); font-weight: 700; font-size: 1.6rem; color: rgba(255,255,255,0.9); }
    .ex-body { display: flex; flex-direction: column; min-width: 0; }
    .ex-k { font-family: var(--display); font-weight: 600; font-size: 1.05rem; color: var(--mist); }
    .ex-d { color: var(--muted); font-size: 0.82rem; margin: 2px 0 6px; }
    .ex-go { font-family: var(--mono); font-size: 0.7rem; color: var(--candle); }

    .prev-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 10px; }
    .prev-list a { display: flex; gap: 14px; align-items: stretch; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); padding: 12px; transition: border-color .15s ease, transform .15s ease; }
    .prev-list a:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); transform: translateY(-2px); }
    .pl-thumb { flex: 0 0 auto; width: 160px; height: 84px; object-fit: cover; border-radius: 10px; border: 1px solid var(--line); }
    .pl-body { min-width: 0; display: block; }
    .pl-tag { display: block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--faint); }
    .pl-title { display: block; font-family: var(--display); font-weight: 600; font-size: 1.08rem; color: var(--mist); margin: 3px 0 2px; }
    .pl-dek { display: block; color: var(--muted); font-size: 0.86rem; }
    .pl-meta { display: block; font-family: var(--mono); font-size: 0.68rem; color: var(--faint); margin-top: 6px; }
    .prev-all { margin: 14px 0 0; font-family: var(--mono); font-size: 0.8rem; }
    .prev-all a { color: var(--candle); }
    @media (max-width: 520px) {
      .prev-list a { flex-direction: column; }
      .pl-thumb { width: 100%; height: auto; aspect-ratio: 1200 / 630; }
    }

    .launch-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 14px;
      max-width: 720px;
    }
    .launch-strip a {
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 999px;
      background: rgba(21,16,29,0.48);
      color: var(--mist);
      font-family: var(--mono);
      font-size: 0.72rem;
      padding: 7px 10px;
      text-decoration: none;
      backdrop-filter: blur(10px);
    }
