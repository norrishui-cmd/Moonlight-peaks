---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const faq = [
  { q: '¿Se puede decorar la propia cabaña en Moonlight Peaks?', a: 'Sí — reportado: puedes personalizar el interior de la cabaña y el entorno de la finca, colocar y girar muebles, y hacer decoraciones como senderos y luces de hadas.' },
  { q: '¿Hay un invernadero en Moonlight Peaks?', a: 'Sí, confirmado: construir el invernadero corresponde a un logro independiente llamado "Perpetual Bloom". Consulta nuestra página dedicada al invernadero para conocer el costo de construcción y lo que ofrece según se vaya confirmando.' },
  { q: '¿Se puede mejorar la casa?', a: 'Confirmado: "Dracula Estate" es el logro correspondiente a mejorar completamente la casa, así que sí existe una ruta real de mejora además de la decoración — aunque los niveles exactos y sus costos aún no tienen fuente. El Granero (4,000 monedas, comprado a Ridge) y el Pozo (1,500 monedas) son otras dos mejoras de construcción ya confirmadas.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Casa y decoración', item: new URL('/es/house', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Casa, decoración e invernadero"
  description="Decoración de cabaña en Moonlight Peaks: muebles confirmados, senderos y luces de hadas, y qué se sabe hasta ahora sobre el invernadero o las mejoras de casa."
  path="/es/house"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Casa y decoración' }]}
  lang="es"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Inicio · Hogar</p>
      <h1>Moonlight Peaks — <em>casa</em> y decoración</h1>
      <p class="intro">
        Más allá de la agricultura, tu cabaña y finca — lo confirmado sobre decoración, separado de
        lo que aún no está verificado. Última actualización: {SITE.updated}.
      </p>

      <h2>Decorando tu cabaña</h2>
      <p>
        Reportado: el sistema de decoración de Moonlight Peaks incluye colocar y girar muebles,
        personalizar el interior de la cabaña, y crear decoraciones como senderos y luces de hadas
        para la finca.
      </p>

      <h2>El invernadero — confirmado que existe</h2>
      <p>
        Confirmado: construir el invernadero corresponde a un logro independiente de Steam llamado
        "Perpetual Bloom". Reportado por la comunidad: tener un invernadero también ayudaría a lograr
        varios otros objetivos relacionados con la agricultura, por lo que vale la pena priorizar su
        construcción. Consulta nuestra <a href="/farm/greenhouse">página del invernadero</a> para el
        costo de construcción y detalles de espacio, que se actualizarán conforme se confirme más información.
      </p>

      <h2>Mejoras de construcción confirmadas hasta ahora</h2>
      <p>
        Confirmado: "Dracula Estate" es el logro correspondiente a mejorar completamente la casa, así
        que sí existe una ruta real de mejora además de la decoración — los niveles exactos y costos
        aún no tienen fuente. Otras dos compras de construcción confirmadas:
        <strong>el Granero</strong> (4,000 monedas más materiales, comprado a Ridge, obligatorio antes
        de comprar animales) y <strong>el Pozo</strong> (reportado en 1,500 monedas, ayuda con el riego).
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Relacionado: <a href="/farming">Agricultura</a>, <a href="/character-creator">Creador de personaje</a>,
        <a href="/es/beginner-guide">Guía para principiantes</a>.
      </div>
    </div>
  </article>
</Base>
