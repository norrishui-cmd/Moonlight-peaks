---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';
import YouTube from '../../components/YouTube.astro';
import { characters, typeLabels } from '../../data/characters';

const familyNameEs: Record<string, string> = {
  'Vampire (Ambrosia)': 'Vampiro · Familia Ambrosia',
  'Vampire (Dracula)': 'Vampiro · Familia Drácula',
  'Witch (Webb)': 'Bruja · Familia Webb',
  'Werewolf (Logan)': 'Hombre lobo · Familia Logan',
  'Mermaid (Hosu)': 'Sirena · Familia Hosu',
  'Seer (Khazan)': 'Vidente · Familia Khazan',
  'Human (Henderson)': 'Humano · Familia Henderson',
  'Unknown': 'Sin familia',
};
const typeEs: Record<string, string> = {
  vampire: 'Vampiro', werewolf: 'Hombre lobo', witch: 'Bruja', mermaid: 'Sirena',
  seer: 'Vidente', ghost: 'Fantasma', human: 'Humano', other: 'Otro',
};
const statusEs: Record<string, string> = { confirmed: 'Confirmado', reported: 'Reportado', datamined: 'Extraído de archivos', unconfirmed: 'No confirmado' };

const romanceable = characters.filter((c) => c.romanceable === true);
const groups = new Map<string, typeof romanceable>();
for (const c of romanceable) {
  const key = c.family || 'Unknown';
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(c);
}
const familyGroups = [...groups.entries()].sort((a, b) => b[1].length - a[1].length);

const faq = [
  { q: '¿Cuántos personajes conquistables hay en Moonlight Peaks?', a: 'Confirmado al lanzamiento: 23, según la presentación oficial de romance — antes se citaban unos 15. Se reparten en seis familias (Ambrosia, Webb, Logan, Hosu, Khazan, Henderson) más dos comodines sin familia: la Muerte y el demonio del amor Llemi.' },
  { q: '¿Qué nivel de corazón necesitas para salir en citas y para casarte?', a: 'Confirmado: las citas se desbloquean en el Nivel de Corazón 4. Puedes proponer matrimonio en el Nivel de Corazón 8. La boda ocurre dentro de una semana tras la propuesta, con vampiros y hombres lobo del pueblo asistiendo.' },
  { q: '¿Puedes salir con varias personas a la vez?', a: 'Sí, confirmado. Tus parejas lo notarán y comentarán, pero es celos leves, no un sistema de rivalidad estricto. El matrimonio en sí es estrictamente monógamo.' },
  { q: '¿Qué pasa si rechazas demasiadas citas?', a: 'Confirmado: rechazar las invitaciones de una pareja con demasiada frecuencia provoca una ruptura; luego se mostrará distante unos días antes de perdonarte.' },
  { q: '¿Puedes casarte en Moonlight Peaks? ¿Puedes tener hijos?', a: 'Sí puedes casarte — tu cónyuge se muda a tu granja y desbloquea un nuevo evento de corazón, y puedes convertirlo en vampiro. No hay hijos, confirmado por varias fuentes sin planes anunciados de añadirlo. Casarte con un personaje mayor como Orlock, que ya tiene hijos, se reporta que te convierte en padrastro/madrastra.' },
  { q: '¿El romance está limitado por género?', a: 'No. Las citas son completamente neutrales en género, así que puedes conquistar a cualquier residente conquistable sin importar cómo construyas a tu propio vampiro.' },
  { q: '¿Puede un vampiro tener una relación con un hombre lobo?', a: 'Sí. Los vampiros y hombres lobo del pueblo rara vez se llevan bien y suelen discutir, así que conquistar a un hombre lobo como Saga significa cruzar esa división — parte de la gracia.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Romance', item: `${SITE.url}/es/romance` },
  ] },
];
---
<Base
  title="Moonlight Peaks Romance — 23 Personajes Conquistables y Matrimonio"
  description="Guía de romance de Moonlight Peaks: 23 personajes conquistables confirmados, citas neutrales en género, Nivel de Corazón 4 para citas / 8 para propuesta, y las siete familias."
  path="/es/romance"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Romance y familias' }]}
  lang="es"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entrada · Corazones</p>
      <h1>El <em>romance</em> de Moonlight Peaks y las siete familias</h1>
      <p class="intro">
        El romance es una característica estelar de {GAME.title}: 23 residentes conquistables
        confirmados, citas neutrales en género, y matrimonio (aunque sin hijos). Esta página se
        genera directamente desde nuestra base de datos de personajes. Actualizado {SITE.updated}.
      </p>

      <div class="romance-video">
        <YouTube id="YFb9capELQw" title="Moonlight Peaks romance video" />
      </div>

      <h2>Cómo funciona realmente el romance</h2>
      <p>
        Confirmado al lanzamiento: habla con los residentes y dales regalos para subir tu relación,
        registrada en un menú que muestra tus regalos recientes y sus reacciones. El
        <strong>Nivel de Corazón 4</strong> desbloquea las citas — se desarrollan como minijuegos
        (como armar un ramo en los colores que tu cita pide) en vez de escenas pasivas. El
        <strong>Nivel de Corazón 8</strong> desbloquea la propuesta de matrimonio; la boda ocurre
        dentro de una semana, con vampiros y hombres lobo del pueblo asistiendo.
      </p>
      <p>
        Puedes salir con varias personas a la vez — lo notarán y comentarán, pero son celos leves,
        no rivalidad estricta. El matrimonio en sí es estrictamente monógamo, y rechazar citas con
        demasiada frecuencia provoca una ruptura (con un período de enfriamiento). Tras la boda, tu
        cónyuge se muda a tu granja y puede convertirse en vampiro. Construir relaciones también
        desbloquea planos y materiales de crafteo.
      </p>

      <h2>Empieza aquí: planea tu ruta de romance</h2>
      <p>Con 23 opciones y sin base de datos completa de regalos/eventos aún, una lista corta es mejor que intentarlo con todos:</p>
      <div class="rp-steps">
        <a class="rp-step" href="/tools/romance-match-quiz">
          <span class="rp-step-num">1</span>
          <strong>Haz el quiz</strong>
          <span>Un match divertido basado en pistas reales para acotar tu elección.</span>
        </a>
        <a class="rp-step" href="/tools/families-explorer">
          <span class="rp-step-num">2</span>
          <strong>Explora por familia</strong>
          <span>Ve los 23 personajes conquistables agrupados por su familia real.</span>
        </a>
        <a class="rp-step" href="/tools/romance-planner">
          <span class="rp-step-num">3</span>
          <strong>Arma tu lista corta</strong>
          <span>Guarda tus elecciones y notas privadamente en tu navegador.</span>
        </a>
        <a class="rp-step" href="/tools/gift-tracker">
          <span class="rp-step-num">4</span>
          <strong>Registra tus regalos</strong>
          <span>Anota tus propios hallazgos hasta que exista una guía completa.</span>
        </a>
      </div>

      <h2>Lo básico</h2>
      <p>
        23 residentes son conquistables, repartidos en seis familias — vampiros (Ambrosia), hombres
        lobo (Logan), brujas (Webb), sirenas (Hosu), videntes (Khazan) y humanos (Henderson) — más
        dos comodines sin familia: la Muerte y el demonio del amor Llemi.
      </p>

      <h2>Los 23 personajes conquistables, por familia</h2>
      <p>Datos extraídos directamente de nuestra base de personajes — cada nombre enlaza a su perfil completo (en inglés por ahora).</p>
      {familyGroups.map(([family, members]) => (
        <div class="romance-family-group">
          <h3>{familyNameEs[family] || family} <span class="rf-count">({members.length})</span></h3>
          <table class="facts">
            <tr><th>Personaje</th><th>Tipo</th><th>Estado</th></tr>
            {members.map((c) => (
              <tr>
                <td><a href={`/characters/${c.id}`}>{c.name}</a></td>
                <td>{typeEs[c.type] || typeLabels[c.type] || c.type}</td>
                <td>{statusEs[c.status] || c.status}</td>
              </tr>
            ))}
          </table>
        </div>
      ))}

      <h2>Guía de regalos</h2>
      <p>
        La mayoría de las listas de regalos aún no son públicas — <strong>Saga</strong> es la
        primera confirmada (le encanta el vino blanco). Consulta su
        <a href="/characters/saga">perfil</a> y usa el <a href="/tools/gift-tracker">rastreador de regalos</a>
        para anotar tus propios hallazgos.
      </p>

      <h2>Preguntas frecuentes</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Entrada post-lanzamiento, generada desde la base de datos de personajes. Relacionado:
        <a href="/characters">todos los personajes</a>, <a href="/families">las siete familias</a>,
        <a href="/es/beginner-guide">guía para principiantes en español</a>.
      </div>
    </div>
  </article>
  <style>
    .romance-family-group { margin: 20px 0; }
    .romance-family-group h3 { margin: 0 0 8px; }
    .rf-count { color: var(--muted); font-weight: 400; font-size: 0.85rem; }
    .rp-steps { display: grid; grid-template-columns: 1fr; gap: 10px; margin: 14px 0 24px; }
    @media (min-width: 640px) { .rp-steps { grid-template-columns: 1fr 1fr; } }
    .rp-step {
      display: flex; flex-direction: column; gap: 4px; border: 1px solid var(--line); border-radius: 14px;
      background: var(--surface); padding: 14px 16px; text-decoration: none; position: relative;
      transition: border-color .15s ease;
    }
    .rp-step:hover { border-color: color-mix(in srgb, var(--candle) 45%, var(--line)); }
    .rp-step-num {
      position: absolute; top: 12px; right: 14px; font-family: var(--mono); font-size: 0.7rem; color: var(--candle);
      border: 1px solid color-mix(in srgb, var(--candle) 40%, var(--line)); border-radius: 999px; width: 20px; height: 20px;
      display: flex; align-items: center; justify-content: center;
    }
    .rp-step strong { font-family: var(--display); font-weight: 600; font-size: 0.94rem; color: var(--mist); padding-right: 26px; }
    .rp-step span:last-child { font-size: 0.8rem; color: var(--faint); line-height: 1.4; }
    .romance-video { margin: clamp(1.6rem, 4vw, 2.6rem) 0 clamp(2rem, 5vw, 3rem); }
  </style>
</Base>
