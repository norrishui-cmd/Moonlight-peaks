---
import TopicPage from '../../../components/TopicPage.astro';
import { demoSection, demo } from '../../../data/demo';
import { demoEs } from '../../../i18n/demo-es';

export function getStaticPaths() {
  const translated = demo.filter((it) => demoEs[it.slug]);
  return translated.map((it, i) => {
    const tr = demoEs[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...translated[(i - 1 + translated.length) % translated.length], ...demoEs[translated[(i - 1 + translated.length) % translated.length].slug] },
        next: { ...translated[(i + 1) % translated.length], ...demoEs[translated[(i + 1) % translated.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const esSection = { ...demoSection, base: '/es/demo', label: 'Demo', eyebrow: 'Demo' };
---
<TopicPage section={esSection} item={item} prev={prev} next={next} lang="es" basePath="/es/demo" />
