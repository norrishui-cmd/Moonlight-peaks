---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { farmlandCrops, herbCrops, treeCrops } from '../../../data/farm-crops';

const cropDetailSlugs: Record<string, string> = {
  'Blood Grapes': 'blood-grapes', 'Rice': 'rice', 'Drikker': 'drikker', 'Gobbler': 'gobbler',
  'Hold Me Close': 'hold-me-close', 'Mandrake': 'mandrake', 'Weeping Wicca': 'weeping-wicca',
  'Common Mushroom': 'instant-growth-mushrooms', 'Frosteria': 'instant-growth-mushrooms',
  'Glowglammer': 'instant-growth-mushrooms', 'Yellow Glowglammer': 'instant-growth-mushrooms',
  'Volacio Mushroom': 'instant-growth-mushrooms', 'Amanita': 'instant-growth-mushrooms',
};

const faq = [
  { q: '¿Cuántos cultivos hay en Moonlight Peaks?', a: `Confirmado vía la wiki oficial: ${farmlandCrops.length} cultivos de campo, ${herbCrops.length} cultivos de jardín de hierbas, y ${treeCrops.length} cultivos de árbol — divididos en tres categorías de siembra según dónde crece cada uno.` },
  { q: '¿Cuáles son las tres categorías de cultivos en Moonlight Peaks?', a: 'Confirmado: cultivos de campo (plantados en tierra cultivada), cultivos de jardín de hierbas (necesitan una estructura dedicada de Jardín de Hierbas), y cultivos de árbol (plantados directamente sobre pasto, sin necesidad de arar).' },
  { q: '¿Qué cultivos en Moonlight Peaks son mágicos?', a: 'Confirmado: los cultivos mágicos solo se pueden regar con Aquaflux (agua mágica), no con una regadera normal. Varios también tienen peculiaridades únicas — Gobbler necesita ser alimentado con peces o criaturas, Drikker necesita su taza llena de agua, Mandrake produce una versión Enojada o Feliz dependiendo de las mandrágoras cercanas, y Weeping Wicca llora para regar automáticamente un área de 3x3 a su alrededor.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Granja', item: `${SITE.url}/es/farm` },
    { '@type': 'ListItem', position: 3, name: 'Cultivos', item: `${SITE.url}/es/farm/crops` },
  ] },
];
---
<Base
  title="Cultivos de Moonlight Peaks — Base de datos completa (campo, hierbas y árboles)"
  description="La base de datos completa de cultivos de Moonlight Peaks: más de 30 cultivos de campo, cultivos de jardín de hierbas, y cultivos de árbol, obtenidos de la wiki oficial."
  path="/es/farm/crops"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Granja', href: '/es/farm' }, { label: 'Cultivos' }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Granja · Base de datos</p>
      <h1>Cultivos de <em>Moonlight Peaks</em></h1>
      <p class="intro">
        La base de datos completa de cultivos, obtenida de la wiki oficial de Moonlight Peaks. Los
        cultivos se dividen en tres categorías según dónde se plantan — campo, jardín de hierbas, o
        árbol — y algunos son mágicos, lo que significa que solo se pueden regar con Aquaflux en
        lugar de una regadera normal.
      </p>

      <h2>Cultivos de campo ({farmlandCrops.length})</h2>
      <table class="facts">
        <tr><th>Cultivo</th><th>Estaciones</th><th>¿Mágico?</th><th>Notas</th></tr>
        {farmlandCrops.map((c) => (
          <tr>
            <td>{cropDetailSlugs[c.name] ? <a href={`/es/farm/crops/${cropDetailSlugs[c.name]}`}>{c.name}</a> : c.name}</td>
            <td>{c.seasons.length ? c.seasons.join(', ') : '—'}</td>
            <td>{c.magical ? 'Sí' : 'No'}</td>
            <td>
              {c.harvestDays && <>Cosecha en {c.harvestDays} días{c.regrowDays ? `, rebrota en ${c.regrowDays}` : ''}{c.yieldPerHarvest ? `, ${c.yieldPerHarvest}/cosecha` : ''}{c.sellPrice ? `, vende ${c.sellPrice}g` : ''}{c.seedPrice ? ` (semillas ${c.seedPrice}g)` : ''}. </>}
              {c.note}
            </td>
          </tr>
        ))}
      </table>

      <h2>Cultivos de jardín de hierbas ({herbCrops.length})</h2>
      <p>Confirmado: los cultivos de jardín de hierbas necesitan una estructura dedicada de Jardín de Hierbas y no se pueden plantar directamente en campo normal.</p>
      <table class="facts">
        <tr><th>Hierba</th><th>¿Mágico?</th><th>¿Tiene forma seca?</th></tr>
        {herbCrops.map((h) => (
          <tr><td>{h.name}</td><td>{h.magical ? 'Sí' : 'No'}</td><td>{h.hasDriedForm ? 'Sí' : 'No'}</td></tr>
        ))}
      </table>

      <h2>Cultivos de árbol ({treeCrops.length})</h2>
      <p>Confirmado: los cultivos de árbol se plantan directamente sobre pasto, sin necesidad de arar.</p>
      <table class="facts">
        <tr><th>Árbol</th><th>Estaciones</th><th>¿Mágico?</th><th>Notas</th></tr>
        {treeCrops.map((t) => (
          <tr><td>{t.name}</td><td>{t.seasons.join(', ')}</td><td>{t.magical ? 'Sí' : 'No'}</td><td>{t.note || '—'}</td></tr>
        ))}
      </table>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Obtenido de la wiki oficial de Moonlight Peaks (moonlightpeaks.wiki.gg). Relacionado:
        <a href="/es/farm">Centro de la granja</a>, <a href="/es/farm/farm-helpers">ayudantes de granja</a>,
        <a href="/es/farming">guía de agricultura</a>.
      </div>
    </div>
  </article>
</Base>
