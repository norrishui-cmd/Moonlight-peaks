---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';
import { cropDetailsEs } from '../../../../data/farm-crop-details-es';

export function getStaticPaths() {
  return Object.entries(cropDetailsEs).map(([slug, data]) => ({ params: { slug }, props: { slug, data } }));
}

const { slug, data } = Astro.props as { slug: string; data: (typeof cropDetailsEs)[string] };

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: data.faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Granja', item: `${SITE.url}/es/farm` },
    { '@type': 'ListItem', position: 3, name: 'Cultivos', item: `${SITE.url}/es/farm/crops` },
    { '@type': 'ListItem', position: 4, name: data.name, item: `${SITE.url}/es/farm/crops/${slug}` },
  ] },
];
---
<Base
  title={`${data.name} — Guía de cultivos de Moonlight Peaks`}
  description={data.dek}
  path={`/es/farm/crops/${slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: 'Granja', href: '/es/farm' }, { label: 'Cultivos', href: '/es/farm/crops' }, { label: data.name }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Granja · {data.category}</p>
      <h1><em>{data.name}</em></h1>
      <p class="intro">{data.dek}</p>

      {data.body.map((p) => (<p>{p}</p>))}

      <h2>FAQ</h2>
      <div class="faq">
        {data.faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Obtenido de la wiki oficial de Moonlight Peaks. Relacionado:
        <a href="/es/farm/crops">todos los cultivos</a>, <a href="/es/farm">Centro de la granja</a>,
        <a href="/es/farm/farm-helpers">ayudantes de granja</a>.
      </div>
    </div>
  </article>
</Base>
