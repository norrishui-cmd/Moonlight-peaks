---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const faq = [
  { q: '¿Cuántas veces se puede mejorar la casa en Moonlight Peaks?', a: 'Confirmado vía la wiki oficial: cuatro veces. Cada mejora añade una nueva expansión a la casa.' },
  { q: '¿Cómo se desbloquean las mejoras de la casa en Moonlight Peaks?', a: 'Confirmado: las mejoras solo están disponibles después de completar la misión "Arregla el techo", dada por Ridge al principio del juego.' },
  { q: '¿Dónde se compran las mejoras de la casa en Moonlight Peaks?', a: 'Confirmado: las mejoras se compran en el Howling Hammer usando monedas y madera. Cada mejora toma una noche de juego en completarse.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Granja', item: `${SITE.url}/es/farm` },
    { '@type': 'ListItem', position: 3, name: 'Casa', item: `${SITE.url}/es/farm/house` },
  ] },
];
---
<Base
  title="Casa de Moonlight Peaks — Mejoras, costo y misión Arregla el techo"
  description="Confirmado: la casa de Moonlight Peaks se mejora 4 veces a través del Howling Hammer, desbloqueada por la misión Arregla el techo de Ridge."
  path="/es/farm/house"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Granja', href: '/es/farm' }, { label: 'Casa' }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Granja · Casa</p>
      <h1>Tu <em>casa</em></h1>
      <p class="intro">
        Confirmado vía la wiki oficial: tu hogar permanente es una pequeña casa de piedra que se
        puede mejorar cuatro veces, con cada mejora añadiendo una nueva expansión.
      </p>

      <h2>Desbloqueando mejoras</h2>
      <p>
        Confirmado: las mejoras de la casa solo están disponibles después de completar la misión
        <strong>"Arregla el techo"</strong>, dada por Ridge al principio del juego. Una vez
        desbloqueadas, las mejoras se compran en el <strong>Howling Hammer</strong> usando monedas
        y madera, y cada una toma una sola noche de juego en completarse.
      </p>

      <h2>Muebles y desorden inicial</h2>
      <p>
        Confirmado: la primera etapa de la casa ya incluye varias decoraciones básicas y objetos
        funcionales — un ataúd de madera, una estación de cocina, una mesa de trabajo, una planta
        de interior, y una caja. Cuando obtienes la casa por primera vez, el interior y el área
        circundante también tienen desorden (basura, montones de hojas, piedras) que se puede limpiar.
      </p>

      <h2>Personalización exterior</h2>
      <p>
        Confirmado: la personalización exterior también está disponible a través del Howling
        Hammer. Algunas opciones de personalización solo se desbloquean una vez que has alcanzado
        la etapa final (cuarta) de la casa.
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Obtenido de la wiki oficial de Moonlight Peaks (moonlightpeaks.wiki.gg). Relacionado:
        <a href="/es/farm">Centro de la granja</a>, <a href="/characters/ridge">Ridge</a>,
        <a href="/items/decorations">decoraciones</a>.
      </div>
    </div>
  </article>
</Base>
