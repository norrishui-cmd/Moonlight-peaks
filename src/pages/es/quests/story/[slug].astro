---
import Base from '../../../../layouts/Base.astro';
import { SITE, GAME } from '../../../../consts';
import { storyQuests, storyQuestBySlug } from '../../../../data/quests-story';
import { storyQuestsEs, storyChaptersEs } from '../../../../i18n/quests-story-es';

export function getStaticPaths() {
  return storyQuests.filter((q) => storyQuestsEs[q.slug]).map((q) => ({ params: { slug: q.slug }, props: { q } }));
}

const { q } = Astro.props as { q: (typeof storyQuests)[number] };
const tr = storyQuestsEs[q.slug];
const chapter = storyChaptersEs.find((c) => c.number === q.chapter)!;
const prev = storyQuests[storyQuests.indexOf(q) - 1];
const next = q.leadsTo ? storyQuestBySlug.get(q.leadsTo) : undefined;
const statusLabel = q.status === 'confirmed' ? 'Confirmado' : 'Reportado';

const faq = [
  { q: `¿Cómo desbloqueo "${tr.title}" en Moonlight Peaks?`, a: tr.unlock || 'Esta misión continúa directamente del punto de historia anterior — consulta el enlace de misión previa abajo.' },
  { q: `¿Cuál es la recompensa de "${tr.title}"?`, a: tr.reward || 'No hay una recompensa de objeto directa confirmada para esta misión todavía.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Guía de misiones', item: `${SITE.url}/es/quests` },
    { '@type': 'ListItem', position: 3, name: 'Historia principal', item: `${SITE.url}/es/quests/story` },
    { '@type': 'ListItem', position: 4, name: tr.title, item: `${SITE.url}/es/quests/story/${q.slug}` },
  ] },
];
---
<Base
  title={`${tr.title} — Guía de misiones de Moonlight Peaks`}
  description={`Misión "${tr.title}" de ${GAME.title}: ${tr.summary.slice(0, 100)}`}
  path={`/es/quests/story/${q.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: 'Guía de misiones', href: '/es/quests' }, { label: 'Historia principal', href: '/es/quests/story' }, { label: tr.title }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Historia principal · Capítulo {q.chapter}: {chapter.title} · <span class="tag-community">{statusLabel}</span></p>
      <h1>{tr.title}</h1>

      {tr.unlock && (
        <div class="callout">
          <strong>Cómo desbloquear:</strong> {tr.unlock}
        </div>
      )}

      <h2>Qué sucede</h2>
      <p>{tr.summary}</p>

      {tr.reward && (
        <>
          <h2>Recompensa</h2>
          <p>{tr.reward}</p>
        </>
      )}

      {tr.troubleshooting && tr.troubleshooting.length > 0 && (
        <>
          <h2>¿Atascado? Qué revisar</h2>
          <div class="faq">
            {tr.troubleshooting.map((t) => (
              <details open>
                <summary>{t.q}</summary>
                <p>{t.a}</p>
              </details>
            ))}
          </div>
        </>
      )}

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <nav class="prevnext" aria-label="Navegación de misiones">
        {prev && storyQuestsEs[prev.slug] ? <a href={`/es/quests/story/${prev.slug}`}>← {storyQuestsEs[prev.slug].title}</a> : <span />}
        <a href="/es/quests/story">Todos los capítulos</a>
        {next && storyQuestsEs[next.slug] ? <a href={`/es/quests/story/${next.slug}`}>{storyQuestsEs[next.slug].title} →</a> : <span />}
      </nav>

      <div class="callout wip">
        Relacionado: <a href="/es/quests">Centro de misiones</a>, <a href="/es/quests/side">Misiones secundarias</a>,
        <a href="/es/beginner-guide">Guía para principiantes</a>.
      </div>
    </div>
  </article>

  <style>
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 7px;
      vertical-align: middle;
    }
    .prevnext { display: flex; justify-content: space-between; gap: 10px; margin: 22px 0; font-family: var(--mono); font-size: 0.82rem; }
    .prevnext a { color: var(--candle); }
  </style>
</Base>
