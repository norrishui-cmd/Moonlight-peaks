---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
      { '@type': 'ListItem', position: 2, name: 'Herramientas', item: `${SITE.url}/es/tools` },
      { '@type': 'ListItem', position: 3, name: 'Planificador de ganancias agrícolas', item: new URL('/es/tools/farming-profit-planner', SITE.url).href },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Planificador de ganancias agrícolas de Moonlight Peaks',
    applicationCategory: 'GameApplication',
    operatingSystem: 'Web',
    url: new URL('/es/tools/farming-profit-planner', SITE.url).href,
    description: 'Una calculadora de ganancias de cultivos de Moonlight Peaks para precio de semilla, precio de venta, días de crecimiento, cosechas repetidas y planificación de fertilizantes.',
  },
];
---
<Base
  title="Planificador de ganancias agrícolas de Moonlight Peaks - Calculadora y mejores cultivos"
  description="Planifica las ganancias de cultivos de Moonlight Peaks con una calculadora agrícola lista para usar. Compara precio de semilla, precio de venta, días de crecimiento, número de cosechas y supuestos de fertilizantes."
  path="/es/tools/farming-profit-planner"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Herramientas', href: '/es/tools' }, { label: 'Planificador de ganancias' }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Herramienta / Planificador agrícola</p>
      <h1>Moonlight Peaks — <em>Planificador de ganancias agrícolas</em></h1>
      <p class="intro">
        Compara cultivos por ganancia por noche una vez que se confirmen los precios reales de
        {GAME.title}. Hasta que se verifiquen los datos de lanzamiento, usa los campos manuales de
        abajo para probar escenarios sin presentar valores de cultivo desconocidos como definitivos.
      </p>

      <section class="profit-tool" data-profit-tool>
        <form class="profit-form">
          <label><span>Nombre del cultivo</span><input data-crop value="Cultivo por confirmar" /></label>
          <label><span>Precio de semilla</span><input data-seed type="number" min="0" value="0" /></label>
          <label><span>Precio de venta por cosecha</span><input data-sell type="number" min="0" value="0" /></label>
          <label><span>Días de crecimiento</span><input data-days type="number" min="1" value="1" /></label>
          <label><span>Número de cosechas</span><input data-harvests type="number" min="1" value="1" /></label>
          <label><span>Costos adicionales</span><input data-extra type="number" min="0" value="0" /></label>
          <button type="button" class="btn btn-primary" data-add>Añadir a la comparación</button>
        </form>

        <aside class="profit-result">
          <span class="result-kicker">Estimación actual</span>
          <h2 data-profit>0</h2>
          <p data-profit-copy>Ingresa precios tras el lanzamiento para calcular la ganancia total y la ganancia por día.</p>
        </aside>
      </section>

      <h2>Comparación de cultivos</h2>
      <div class="profit-table-wrap">
        <table class="profit-table">
          <thead>
            <tr>
              <th>Cultivo</th>
              <th>Semilla</th>
              <th>Venta</th>
              <th>Días</th>
              <th>Cosechas</th>
              <th>Ganancia total</th>
              <th>Ganancia/día</th>
            </tr>
          </thead>
          <tbody data-rows>
            <tr><td colspan="7">Añade cultivos cuando los datos de lanzamiento estén disponibles.</td></tr>
          </tbody>
        </table>
      </div>

      <div class="callout">
        Regla de datos seguros: los nombres de cultivos, precios de semilla, valores de venta, tiempo
        de crecimiento, efectos de fertilizantes y reglas de regeneración deben verificarse en el
        juego real o materiales oficiales antes de tratarse como contenido de guía.
      </div>
    </div>
  </article>

  <script>
    const root = document.querySelector('[data-profit-tool]');
    const rowsEl = document.querySelector('[data-rows]');
    if (root && rowsEl) {
      const els = {
        crop: root.querySelector('[data-crop]'),
        seed: root.querySelector('[data-seed]'),
        sell: root.querySelector('[data-sell]'),
        days: root.querySelector('[data-days]'),
        harvests: root.querySelector('[data-harvests]'),
        extra: root.querySelector('[data-extra]'),
        add: root.querySelector('[data-add]'),
        profit: root.querySelector('[data-profit]'),
        copy: root.querySelector('[data-profit-copy]'),
      };
      const key = 'moonlight-farming-planner-v1';
      let rows = JSON.parse(localStorage.getItem(key) || '[]');
      const num = (el) => Math.max(0, Number(el.value || 0));
      const calc = () => {
        const seed = num(els.seed);
        const sell = num(els.sell);
        const days = Math.max(1, num(els.days));
        const harvests = Math.max(1, num(els.harvests));
        const extra = num(els.extra);
        const totalRevenue = sell * harvests;
        const totalProfit = totalRevenue - seed - extra;
        const perDay = totalProfit / days;
        els.profit.textContent = Math.round(totalProfit).toString();
        els.copy.textContent = `${perDay.toFixed(2)} de ganancia por día durante ${days} día(s).`;
        return { crop: els.crop.value || 'Cultivo por confirmar', seed, sell, days, harvests, totalProfit, perDay };
      };
      const renderRows = () => {
        rowsEl.innerHTML = rows.length ? rows.map((r) => `
          <tr>
            <td>${r.crop}</td>
            <td>${r.seed}</td>
            <td>${r.sell}</td>
            <td>${r.days}</td>
            <td>${r.harvests}</td>
            <td>${Math.round(r.totalProfit)}</td>
            <td>${Number(r.perDay).toFixed(2)}</td>
          </tr>
        `).join('') : '<tr><td colspan="7">Añade cultivos cuando los datos de lanzamiento estén disponibles.</td></tr>';
      };
      const save = () => localStorage.setItem(key, JSON.stringify(rows.slice(-12)));
      root.addEventListener('input', calc);
      els.add.addEventListener('click', () => {
        rows.push(calc());
        save();
        renderRows();
      });
      calc();
      renderRows();
    }
  </script>

  <style>
    .profit-tool { display: grid; grid-template-columns: minmax(0, 1fr) 300px; gap: 18px; margin: 28px 0; }
    @media (max-width: 820px) { .profit-tool { grid-template-columns: 1fr; } }
    .profit-form, .profit-result {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--surface);
      padding: 18px;
    }
    .profit-form { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
    @media (max-width: 640px) { .profit-form { grid-template-columns: 1fr; } }
    .profit-form label span { display: block; margin-bottom: 6px; color: var(--mist); font-weight: 600; }
    .profit-form input {
      width: 100%;
      min-height: 44px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--ink);
      color: var(--mist);
      padding: 0 12px;
      font: inherit;
    }
    .profit-form button { grid-column: 1 / -1; justify-content: center; }
    .result-kicker { font-family: var(--mono); color: var(--candle); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; }
    .profit-result h2 { font-size: 3rem; margin: 8px 0; }
    .profit-result p { color: var(--muted); }
    .profit-table-wrap { overflow-x: auto; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); }
    .profit-table { width: 100%; min-width: 720px; border-collapse: collapse; }
    .profit-table th, .profit-table td { border-bottom: 1px solid var(--line); padding: 10px 12px; text-align: left; }
    .profit-table th { color: var(--candle); font-family: var(--mono); font-size: 0.68rem; text-transform: uppercase; }
    .profit-table tr:last-child td { border-bottom: 0; }
  </style>
</Base>
