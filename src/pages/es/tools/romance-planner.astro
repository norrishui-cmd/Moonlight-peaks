---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { characters, typeLabels } from '../../../data/characters';

const typeLabelsEs: Record<string, string> = {
  vampire: 'Vampiro', werewolf: 'Hombre lobo', witch: 'Bruja', mermaid: 'Sirena',
  seer: 'Vidente', ghost: 'Fantasma', human: 'Humano', other: 'Otro',
};
const statusLabelsEs: Record<string, string> = { confirmed: 'Confirmado', reported: 'Reportado', datamined: 'Dataminado', unconfirmed: 'No confirmado' };

const candidates = characters
  .filter((c) => c.status !== 'unconfirmed' && c.romanceable !== false)
  .map((c) => ({
    id: c.id,
    name: c.name,
    family: c.family && c.family !== 'Unknown' ? c.family : null,
    type: typeLabelsEs[c.type] || typeLabels[c.type],
    status: statusLabelsEs[c.status] || c.status,
    href: `/characters/${c.id}`,
  }));

const prepTasks = [
  { id: 'read-profile', t: 'Lee el perfil e información conocida de tus favoritos' },
  { id: 'check-home', t: 'Anota la ubicación conocida de la casa de tus favoritos (ver "Información conocida" en el perfil)' },
  { id: 'check-family', t: 'Comprueba a qué familia pertenecen y las tensiones familiares reportadas' },
  { id: 'check-status', t: 'Confirma su nivel de precisión actual (confirmado / reportado / dataminado)' },
  { id: 'try-quiz', t: 'Haz el cuestionario de compatibilidad romántica para una segunda opinión' },
  { id: 'plan-day-one', t: 'Decide con quién quieres hablar primero el día 1' },
  { id: 'bookmark-page', t: 'Guarda esta página en marcadores — tu lista y notas se guardan en este dispositivo' },
];

const faq = [
  { q: '¿Esta herramienta usa datos reales de regalos o afinidad?', a: 'No. Aún no se confirman datos de regalos, afinidad o eventos, así que nada de eso se muestra aquí. Esta herramienta solo rastrea tu propia lista, notas y lista de preparación — todo guardado de forma privada en tu navegador, no en nuestro servidor.' },
  { q: '¿Mi lista se mantendrá después del lanzamiento?', a: 'Sí, mientras uses el mismo navegador y dispositivo y no borres los datos del sitio. En cuanto se confirmen datos reales de romance, ampliaremos esta herramienta para usarlos.' },
  { q: '¿Mis datos se envían a algún lado?', a: 'No. Todo se guarda solo en el almacenamiento local de tu navegador. No lo vemos, no lo guardamos en ningún servidor, y no lo usamos para nada.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Herramientas', item: `${SITE.url}/es/tools` },
    { '@type': 'ListItem', position: 3, name: 'Planificador de romance', item: new URL('/es/tools/romance-planner', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'Planificador de romance de Moonlight Peaks',
    applicationCategory: 'GameApplication', operatingSystem: 'Web',
    url: new URL('/es/tools/romance-planner', SITE.url).href,
    description: 'Una lista de candidatos románticos previa al lanzamiento y rastreador de preparación para Moonlight Peaks, guardado localmente en tu navegador.' },
];
---
<Base
  title="Planificador de romance de Moonlight Peaks — Lista de favoritos y rastreador de progreso"
  description="Elige tus favoritos románticos de Moonlight Peaks, añade notas personales y rastrea tu progreso con cada uno — guardado de forma privada en tu navegador, sin datos inventados de regalos."
  path="/es/tools/romance-planner"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Herramientas', href: '/es/tools' }, { label: 'Planificador de romance' }]}
  lang="es"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Herramienta · Romance</p>
      <h1>Planificador de <em>romance</em></h1>
      <p class="intro">
        Elige a quién quieres considerar de las 23 opciones románticas confirmadas, haz tus propias
        notas y rastrea tu progreso con cada uno. Todo aquí se guarda de forma privada en tu
        navegador — sin cuenta, sin servidor, y sin datos inventados de regalos o afinidad.
      </p>

      <h2>Tu lista de favoritos</h2>
      <p class="rp-sub">Toca un personaje para añadirlo o quitarlo de tu lista.</p>
      <div id="rp-candidates" class="rp-candidates">
        {candidates.map((c) => (
          <button type="button" class="rp-candidate" data-rp-id={c.id} data-rp-href={c.href} data-rp-name={c.name}>
            <span class="rp-star" aria-hidden="true">☆</span>
            <span class="rp-name">{c.name}</span>
            <span class="rp-meta">{c.family ? `${c.family} · ` : ''}{c.status}</span>
          </button>
        ))}
      </div>

      <h2>Tus notas</h2>
      <div id="rp-shortlist-empty" class="callout wip">Tu lista está vacía — toca un personaje arriba para añadirlo.</div>
      <div id="rp-notes-list" class="rp-notes-list"></div>

      <h2>Lista de preparación para el día de lanzamiento</h2>
      <ul id="rp-prep-list" class="rp-prep-list">
        {prepTasks.map((task) => (
          <li>
            <label>
              <input type="checkbox" data-rp-task={task.id} />
              <span>{task.t}</span>
            </label>
          </li>
        ))}
      </ul>

      <div class="rp-actions">
        <button type="button" id="rp-clear" class="rq-btn">Borrar mi lista y notas</button>
      </div>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Relacionado: <a href="/romance">Romance y matrimonio</a>, <a href="/tools/romance-match-quiz">Cuestionario de compatibilidad romántica</a>,
        <a href="/tools/romance-gift-finder">Buscador de regalos románticos</a>, <a href="/characters">Todos los personajes</a>.
      </div>
    </div>
  </article>

  <style>
    .rp-sub { color: var(--faint); font-size: 0.8rem; margin: -6px 0 12px; }
    .rp-candidates { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin: 0 0 24px; }
    @media (min-width: 640px) { .rp-candidates { grid-template-columns: repeat(3, 1fr); } }
    .rp-candidate {
      display: flex; flex-direction: column; align-items: flex-start; gap: 2px; text-align: left;
      border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 10px 12px;
      cursor: pointer; transition: border-color .15s ease;
    }
    .rp-candidate:hover { border-color: color-mix(in srgb, var(--candle) 45%, var(--line)); }
    .rp-candidate.is-picked { border-color: var(--candle); background: color-mix(in srgb, var(--candle) 10%, var(--surface)); }
    .rp-candidate .rp-star { font-size: 0.9rem; color: var(--faint); }
    .rp-candidate.is-picked .rp-star { color: var(--candle); }
    .rp-candidate .rp-name { font-family: var(--display); font-weight: 600; font-size: 0.88rem; color: var(--mist); }
    .rp-candidate .rp-meta { font-family: var(--mono); font-size: 0.66rem; color: var(--faint); }
    .rp-notes-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
    .rp-note-card { border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 12px 14px; }
    .rp-note-card .rp-note-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
    .rp-note-card strong { font-family: var(--display); font-size: 0.94rem; }
    .rp-note-card a { font-family: var(--mono); font-size: 0.7rem; color: var(--candle); }
    .rp-note-card textarea {
      width: 100%; min-height: 64px; background: var(--ink-2); border: 1px solid var(--line); border-radius: 8px;
      color: var(--mist); font-family: inherit; font-size: 0.84rem; padding: 8px 10px; resize: vertical;
    }
    .rp-prep-list { list-style: none; margin: 0 0 20px; padding: 0; display: flex; flex-direction: column; gap: 6px; }
    .rp-prep-list label { display: flex; align-items: center; gap: 10px; font-size: 0.86rem; color: var(--muted); cursor: pointer; }
    .rp-prep-list input { accent-color: var(--candle); }
    .rp-actions { margin: 0 0 24px; }
  </style>

  <script>
    (function () {
      var KEY_SHORTLIST = 'mp-romance-shortlist';
      var KEY_NOTES = 'mp-romance-notes';
      var KEY_PREP = 'mp-romance-prep';

      function readJSON(key, fallback) {
        try {
          var raw = localStorage.getItem(key);
          return raw ? JSON.parse(raw) : fallback;
        } catch (e) { return fallback; }
      }
      function writeJSON(key, val) {
        try { localStorage.setItem(key, JSON.stringify(val)); } catch (e) {}
      }

      var shortlist = readJSON(KEY_SHORTLIST, []);
      var notes = readJSON(KEY_NOTES, {});
      var prep = readJSON(KEY_PREP, {});

      var candidateEls = document.querySelectorAll('.rp-candidate');
      var notesList = document.getElementById('rp-notes-list');
      var emptyMsg = document.getElementById('rp-shortlist-empty');

      function renderCandidates() {
        candidateEls.forEach(function (el) {
          var id = el.getAttribute('data-rp-id');
          el.classList.toggle('is-picked', shortlist.indexOf(id) > -1);
          var star = el.querySelector('.rp-star');
          if (star) star.textContent = shortlist.indexOf(id) > -1 ? '★' : '☆';
        });
      }

      function renderNotes() {
        notesList.innerHTML = '';
        if (shortlist.length === 0) { emptyMsg.hidden = false; return; }
        emptyMsg.hidden = true;
        shortlist.forEach(function (id) {
          var el = document.querySelector('.rp-candidate[data-rp-id="' + id + '"]');
          if (!el) return;
          var name = el.getAttribute('data-rp-name');
          var href = el.getAttribute('data-rp-href');
          var card = document.createElement('div');
          card.className = 'rp-note-card';
          var head = document.createElement('div');
          head.className = 'rp-note-head';
          var strong = document.createElement('strong');
          strong.textContent = name;
          var link = document.createElement('a');
          link.href = href;
          link.textContent = 'Ver perfil';
          head.appendChild(strong);
          head.appendChild(link);
          var textarea = document.createElement('textarea');
          textarea.placeholder = 'Notas sobre ' + name + '…';
          textarea.value = notes[id] || '';
          textarea.addEventListener('input', function () {
            notes[id] = textarea.value;
            writeJSON(KEY_NOTES, notes);
          });
          card.appendChild(head);
          card.appendChild(textarea);
          notesList.appendChild(card);
        });
      }

      candidateEls.forEach(function (el) {
        el.addEventListener('click', function () {
          var id = el.getAttribute('data-rp-id');
          var idx = shortlist.indexOf(id);
          if (idx > -1) { shortlist.splice(idx, 1); }
          else { shortlist.push(id); }
          writeJSON(KEY_SHORTLIST, shortlist);
          renderCandidates();
          renderNotes();
        });
      });

      document.querySelectorAll('[data-rp-task]').forEach(function (box) {
        var id = box.getAttribute('data-rp-task');
        box.checked = !!prep[id];
        box.addEventListener('change', function () {
          prep[id] = box.checked;
          writeJSON(KEY_PREP, prep);
        });
      });

      var clearBtn = document.getElementById('rp-clear');
      if (clearBtn) {
        clearBtn.addEventListener('click', function () {
          if (!window.confirm('¿Borrar tu lista, notas y lista de preparación? Esto no se puede deshacer.')) return;
          shortlist = []; notes = {}; prep = {};
          writeJSON(KEY_SHORTLIST, shortlist);
          writeJSON(KEY_NOTES, notes);
          writeJSON(KEY_PREP, prep);
          renderCandidates();
          renderNotes();
          document.querySelectorAll('[data-rp-task]').forEach(function (box) { box.checked = false; });
        });
      }

      renderCandidates();
      renderNotes();
    })();
  </script>
</Base>
