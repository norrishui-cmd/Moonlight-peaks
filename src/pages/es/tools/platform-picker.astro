---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
      { '@type': 'ListItem', position: 2, name: 'Herramientas', item: `${SITE.url}/es/tools` },
      { '@type': 'ListItem', position: 3, name: 'Selector de plataforma', item: new URL('/es/tools/platform-picker', SITE.url).href },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Selector de plataforma de Moonlight Peaks',
    applicationCategory: 'GameApplication',
    operatingSystem: 'Web',
    url: new URL('/es/tools/platform-picker', SITE.url).href,
    description: 'Un selector de plataforma de Moonlight Peaks para Steam, Steam Deck, Nintendo Switch, Switch 2 y Android.',
  },
];
---
<Base
  title="Selector de plataforma de Moonlight Peaks - ¿Steam, Switch 2, Steam Deck o Android?"
  description="Usa este selector de plataforma de Moonlight Peaks para decidir si Steam, Steam Deck, Nintendo Switch, Switch 2 o Android es la mejor opción para ti."
  path="/es/tools/platform-picker"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Herramientas', href: '/es/tools' }, { label: 'Selector de plataforma' }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Herramienta / Selector de plataforma</p>
      <h1>Moonlight Peaks — <em>Selector de plataforma</em></h1>
      <p class="intro">
        ¿No sabes dónde jugar {GAME.title}? Elige lo que más te importa y esta herramienta te
        recomendará una plataforma según datos de plataforma confirmados, disponibilidad de demo y
        suposiciones cuidadosas.
      </p>

      <section class="picker-shell" data-platform-picker>
        <div class="picker-panel">
          <h2>Tus prioridades</h2>
          <label>
            <span>Forma principal de jugar</span>
            <select data-field="playstyle">
              <option value="desk">En escritorio o laptop</option>
              <option value="handheld">Sobre todo en modo portátil</option>
              <option value="tv">En TV o sofá</option>
              <option value="mobile">En teléfono o dispositivo móvil</option>
            </select>
          </label>
          <fieldset>
            <legend>¿Qué te importa más?</legend>
            <label><input type="checkbox" value="demo" checked /> Quiero el acceso más fácil a la demo</label>
            <label><input type="checkbox" value="performance" /> Me importa el rendimiento y los parches</label>
            <label><input type="checkbox" value="portable" /> Quiero jugar de forma portátil</label>
            <label><input type="checkbox" value="lowest-price" /> Quiero el precio probable más bajo</label>
            <label><input type="checkbox" value="controller" /> Prefiero control con mando/sofá</label>
          </fieldset>
        </div>

        <div class="picker-result" aria-live="polite">
          <span class="result-kicker">Recomendación</span>
          <h2 data-result-title>Steam</h2>
          <p data-result-copy>Steam es la opción más segura si quieres actualizaciones rápidas, acceso en PC/Mac y el acceso más amplio a la demo antes del lanzamiento.</p>
          <div class="score-list" data-score-list></div>
          <a class="btn btn-primary" data-result-link href="/platforms">Abrir guía de plataformas</a>
        </div>
      </section>

      <h2>Datos de plataforma usados por este selector</h2>
      <table class="facts">
        <tr><th>Fecha de lanzamiento</th><td>{GAME.releaseLabel}</td></tr>
        <tr><th>Plataformas confirmadas</th><td>{GAME.platforms.join(', ')}</td></tr>
        <tr><th>Demo</th><td>{GAME.demo}</td></tr>
        <tr><th>Precio</th><td>{GAME.price}; la edición Switch 2 probablemente sea más alta.</td></tr>
      </table>

      <div class="callout">
        Esta es una herramienta de planificación, no una prueba de rendimiento. La verificación
        final de Steam Deck, los requisitos de Android y el rendimiento en Switch deben revisarse
        de nuevo al lanzamiento.
      </div>
    </div>
  </article>

  <script>
    const tools = document.querySelector('[data-platform-picker]');
    if (tools) {
      const platforms = [
        {
          id: 'steam',
          title: 'Steam',
          href: '/platforms',
          copy: 'Steam es la opción más segura si quieres actualizaciones rápidas, acceso en PC/Mac y el acceso más amplio a la demo antes del lanzamiento.',
          weights: { desk: 5, handheld: 1, tv: 1, mobile: 0, demo: 3, performance: 3, portable: 0, 'lowest-price': 2, controller: 1 },
        },
        {
          id: 'steam-deck',
          title: 'Steam Deck',
          href: '/platforms/steam-deck',
          copy: 'Steam Deck encaja mejor si quieres jugar de forma portátil sin salir del ecosistema Steam.',
          weights: { desk: 1, handheld: 5, tv: 1, mobile: 0, demo: 2, performance: 2, portable: 4, 'lowest-price': 1, controller: 2 },
        },
        {
          id: 'switch-2',
          title: 'Nintendo Switch 2',
          href: '/platforms/switch-2',
          copy: 'Switch 2 es la mejor opción de consola si quieres una versión nativa más reciente de Nintendo y jugar cómodamente en el sofá.',
          weights: { desk: 0, handheld: 4, tv: 5, mobile: 0, demo: 2, performance: 3, portable: 4, 'lowest-price': 0, controller: 4 },
        },
        {
          id: 'switch',
          title: 'Nintendo Switch',
          href: '/platforms',
          copy: 'Nintendo Switch es una buena opción si ya tienes la consola y quieres jugar en modo portátil o en TV sin usar una PC.',
          weights: { desk: 0, handheld: 4, tv: 4, mobile: 0, demo: 2, performance: 0, portable: 4, 'lowest-price': 1, controller: 4 },
        },
        {
          id: 'android',
          title: 'Android / Google Play',
          href: '/platforms/android',
          copy: 'Android es la opción para jugadores móviles, pero los requisitos del dispositivo y el control deben confirmarse al lanzamiento.',
          weights: { desk: 0, handheld: 2, tv: 0, mobile: 5, demo: 0, performance: 0, portable: 4, 'lowest-price': 1, controller: 0 },
        },
      ];

      const playstyle = tools.querySelector('[data-field="playstyle"]');
      const checks = [...tools.querySelectorAll('input[type="checkbox"]')];
      const resultTitle = tools.querySelector('[data-result-title]');
      const resultCopy = tools.querySelector('[data-result-copy]');
      const resultLink = tools.querySelector('[data-result-link]');
      const scoreList = tools.querySelector('[data-score-list]');

      const render = () => {
        const selected = [playstyle.value, ...checks.filter((item) => item.checked).map((item) => item.value)];
        const scored = platforms
          .map((platform) => ({
            ...platform,
            score: selected.reduce((sum, key) => sum + (platform.weights[key] || 0), 0),
          }))
          .sort((a, b) => b.score - a.score);
        const best = scored[0];
        resultTitle.textContent = best.title;
        resultCopy.textContent = best.copy;
        resultLink.href = best.href;
        scoreList.innerHTML = scored
          .map((item) => `<div><span>${item.title}</span><strong>${item.score}</strong></div>`)
          .join('');
      };

      playstyle.addEventListener('change', render);
      checks.forEach((item) => item.addEventListener('change', render));
      render();
    }
  </script>

  <style>
    .picker-shell { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 0.9fr); gap: 18px; margin-top: 28px; align-items: stretch; }
    @media (max-width: 820px) { .picker-shell { grid-template-columns: 1fr; } }
    .picker-panel, .picker-result { border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); padding: 18px; }
    .picker-panel h2, .picker-result h2 { margin-top: 0; }
    .picker-panel label span, .picker-panel legend { display: block; color: var(--mist); font-weight: 600; margin-bottom: 8px; }
    .picker-panel select {
      width: 100%;
      min-height: 44px;
      color: var(--mist);
      background: var(--ink);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 0 12px;
      font: inherit;
    }
    .picker-panel fieldset { border: 0; padding: 0; margin: 22px 0 0; display: grid; gap: 10px; }
    .picker-panel fieldset label { display: flex; gap: 10px; align-items: flex-start; color: var(--muted); }
    .picker-panel input { accent-color: var(--candle); margin-top: 5px; }
    .result-kicker { font-family: var(--mono); font-size: 0.7rem; color: var(--candle); text-transform: uppercase; letter-spacing: 0.12em; }
    .score-list { display: grid; gap: 8px; margin: 18px 0; }
    .score-list div { display: flex; justify-content: space-between; gap: 12px; border-bottom: 1px solid var(--line); padding-bottom: 7px; color: var(--muted); }
    .score-list strong { color: var(--candle); font-family: var(--mono); }
  </style>
</Base>
