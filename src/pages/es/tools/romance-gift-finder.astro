---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';
import { characters, typeLabels } from '../../../data/characters';

const typeLabelsEs: Record<string, string> = {
  vampire: 'Vampiro', werewolf: 'Hombre lobo', witch: 'Bruja', mermaid: 'Sirena',
  seer: 'Vidente', ghost: 'Fantasma', human: 'Humano', other: 'Otro',
};
const familyLabelEs: Record<string, string> = { Vampire: 'Vampiro', Werewolf: 'Hombre lobo', Witch: 'Bruja', 'Unknown family': 'Familia desconocida' };

const romanceCharacters = characters
  .filter((character) => character.status !== 'unconfirmed' && character.romanceable !== false)
  .map((character) => ({
    id: character.id,
    name: character.name,
    family: ['Vampire', 'Werewolf', 'Witch'].includes(character.family) ? character.family : 'Unknown family',
    type: typeLabelsEs[character.type] || typeLabels[character.type],
    romance: character.romanceable === true ? 'Romanceable' : 'Por confirmar',
    status: character.status,
    href: `/characters/${character.id}`,
    note: character.desc,
    clues: character.knownInfo || [],
    gifts: (character.lovedGifts?.length || character.likedGifts?.length)
      ? [
          character.lovedGifts?.length ? `Le encanta: ${character.lovedGifts.join(', ')}` : '',
          character.likedGifts?.length ? `Le gusta: ${character.likedGifts.join(', ')}` : '',
          character.dislikedGifts?.length ? `No le gusta: ${character.dislikedGifts.join(', ')}` : '',
        ].filter(Boolean).join(' | ')
      : 'Aún no verificado',
  }));

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
      { '@type': 'ListItem', position: 2, name: 'Herramientas', item: `${SITE.url}/es/tools` },
      { '@type': 'ListItem', position: 3, name: 'Buscador de regalos románticos', item: new URL('/es/tools/romance-gift-finder', SITE.url).href },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Buscador de regalos románticos de Moonlight Peaks',
    applicationCategory: 'GameApplication',
    operatingSystem: 'Web',
    url: new URL('/es/tools/romance-gift-finder', SITE.url).href,
    description: 'Una herramienta de planificación de romance y regalos de Moonlight Peaks que separa personajes confirmados de regalos que aún necesitan verificación en el juego real.',
  },
];
---
<Base
  title="Buscador de regalos románticos de Moonlight Peaks - Personajes, regalos y verificación"
  description="Encuentra personajes románticos de Moonlight Peaks, el estado de verificación de regalos, pistas de familia y notas de relación seguras para el lanzamiento, sin datos inventados de regalos favoritos."
  path="/es/tools/romance-gift-finder"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Herramientas', href: '/es/tools' }, { label: 'Buscador de regalos' }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Herramienta / Regalos románticos</p>
      <h1>Moonlight Peaks — <em>Buscador de regalos románticos</em></h1>
      <p class="intro">
        Usa este rastreador para encontrar candidatos románticos conocidos y ver qué detalles de
        regalos aún necesitan verificación tras el lanzamiento. No marcaremos ningún objeto como
        regalo favorito hasta que esté confirmado en el juego real.
      </p>

      <section class="gift-tool" data-gift-tool>
        <div class="gift-controls">
          <label>
            <span>Elegir residente</span>
            <select data-character-select>
              {romanceCharacters.map((character) => (
                <option value={character.id}>{character.name}</option>
              ))}
            </select>
          </label>
          <label>
            <span>Filtrar por familia/tipo</span>
            <select data-family-filter>
              <option value="all">Todos los candidatos conocidos</option>
              <option value="Vampire">Vampiro</option>
              <option value="Werewolf">Hombre lobo</option>
              <option value="Witch">Bruja</option>
              <option value="Other">Otro / por confirmar</option>
            </select>
          </label>
        </div>

        <div class="gift-result" aria-live="polite">
          <span class="tool-status" data-status>Romanceable</span>
          <h2 data-name>{romanceCharacters[0]?.name}</h2>
          <p data-note>{romanceCharacters[0]?.note}</p>
          <table class="facts compact">
            <tr><th>Familia / Tipo</th><td data-family>{familyLabelEs[romanceCharacters[0]?.family] || romanceCharacters[0]?.family} / {romanceCharacters[0]?.type}</td></tr>
            <tr><th>Datos de regalos</th><td data-gifts>Aún no verificado</td></tr>
            <tr><th>Próximo paso</th><td data-next>Vuelve a comprobar los regalos que gustan y encantan después de {GAME.releaseLabel}.</td></tr>
          </table>
          <div class="gift-clues" data-clues></div>
          <a class="btn btn-ghost" data-profile href={romanceCharacters[0]?.href || '/characters'}>Abrir perfil del personaje</a>
        </div>
      </section>

      <h2>Cómo funciona el seguimiento de regalos en el juego</h2>
      <p>
        Confirmado: el menú de relaciones registra los últimos 8 regalos que le diste a cada
        residente, y muestra si les gustó, encantó o no les gustó — así que experimentar tiene bajo
        riesgo, porque puedes revisar qué funcionó. <span class="tag-community">Reportado por la
        comunidad</span>: regalar el objeto favorito de un residente en su cumpleaños le da un
        impulso de amistad mayor de lo normal. Dos trucos generales se aplican a muchos residentes:
        combinar el color de un regalo con su color favorito, y regalos hechos a mano como ramos de
        flores arreglados y piezas bordadas.
      </p>

      <h2>Política de verificación de regalos</h2>
      <div class="verification-grid">
        <div>
          <strong>Verificado</strong>
          <p>Confirmado directamente en el juego real o en una fuente oficial. Estos se pueden listar como regalos favoritos o que gustan.</p>
        </div>
        <div>
          <strong>Reportado</strong>
          <p>Visto en avances, material grabado o reportes de la comunidad. Pistas útiles, pero no definitivas hasta comprobarse en el juego.</p>
        </div>
        <div>
          <strong>Aún no verificado</strong>
          <p>Se muestra cuando se conoce un personaje pero sus regalos exactos no están confirmados. Esto evita falsa seguridad y protege la calidad del sitio.</p>
        </div>
      </div>

      <h2>Candidatos románticos conocidos en este rastreador</h2>
      <div class="candidate-grid">
        {romanceCharacters.map((character) => (
          <a class="candidate-card" href={character.href}>
            <span>{character.romance} / {character.status}</span>
            <strong>{character.name}</strong>
            <em>{familyLabelEs[character.family] || character.family} / {character.type}</em>
          </a>
        ))}
      </div>

      <div class="callout">
        Relacionado: <a href="/romance">Guía de romance</a>, <a href="/characters">Todos los personajes</a>, <a href="/families">Familias</a>, y <a href="/faq/can-you-get-married-in-moonlight-peaks">FAQ de matrimonio</a>.
      </div>
    </div>
  </article>

  <script type="application/json" id="romanceGiftData" set:html={JSON.stringify(romanceCharacters)}></script>
  <script>
    const root = document.querySelector('[data-gift-tool]');
    const dataScript = document.getElementById('romanceGiftData');
    if (root && dataScript) {
      const characters = JSON.parse(dataScript.textContent || '[]');
      const select = root.querySelector('[data-character-select]');
      const filter = root.querySelector('[data-family-filter]');
      const status = root.querySelector('[data-status]');
      const name = root.querySelector('[data-name]');
      const note = root.querySelector('[data-note]');
      const family = root.querySelector('[data-family]');
      const gifts = root.querySelector('[data-gifts]');
      const next = root.querySelector('[data-next]');
      const clues = root.querySelector('[data-clues]');
      const profile = root.querySelector('[data-profile]');

      const render = () => {
        const selected = characters.find((item) => item.id === select.value) || characters[0];
        if (!selected) return;
        status.textContent = `${selected.romance} / ${selected.status}`;
        name.textContent = selected.name;
        note.textContent = selected.note;
        family.textContent = `${selected.family} / ${selected.type}`;
        gifts.textContent = selected.gifts;
        next.textContent = selected.romance === 'Romanceable'
          ? 'Al lanzamiento, primero prueba regalos universalmente gustados, luego registra los favoritos a partir de diálogo y aumentos de relación.'
          : 'Mantén a este residente en el rastreador hasta que se verifique su estado romántico y sus reacciones a regalos.';
        profile.href = selected.href;
        clues.innerHTML = selected.clues.length
          ? `<h3>Pistas conocidas actuales</h3><ul>${selected.clues.map((item) => `<li>${item}</li>`).join('')}</ul>`
          : '<h3>Pistas conocidas actuales</h3><p>Aún no se han confirmado pistas específicas sobre regalos.</p>';
      };

      const rebuildOptions = () => {
        const value = filter.value;
        const visible = characters.filter((item) => value === 'all' || item.type === value || (value === 'Other' && item.family === 'Unknown family'));
        select.innerHTML = visible.map((item) => `<option value="${item.id}">${item.name}</option>`).join('');
        render();
      };

      filter.addEventListener('change', rebuildOptions);
      select.addEventListener('change', render);
      render();
    }
  </script>

  <style>
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 8px;
      margin-right: 6px; vertical-align: middle;
    }
    .gift-tool { display: grid; grid-template-columns: minmax(250px, 0.75fr) minmax(0, 1.25fr); gap: 18px; margin: 28px 0 34px; }
    @media (max-width: 820px) { .gift-tool { grid-template-columns: 1fr; } }
    .gift-controls, .gift-result { border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); padding: 18px; }
    .gift-controls { display: grid; gap: 18px; align-content: start; }
    .gift-controls span { display: block; color: var(--mist); font-weight: 600; margin-bottom: 8px; }
    .gift-controls select {
      width: 100%;
      min-height: 44px;
      color: var(--mist);
      background: var(--ink);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 0 12px;
      font: inherit;
    }
    .gift-result h2 { margin-top: 8px; }
    .tool-status { font-family: var(--mono); font-size: 0.68rem; color: var(--candle); text-transform: uppercase; letter-spacing: 0.12em; }
    .facts.compact th, .facts.compact td { padding: 9px 0; }
    .gift-clues { margin: 14px 0; }
    .gift-clues ul { margin-top: 6px; }
    .verification-grid, .candidate-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
    @media (max-width: 820px) { .verification-grid, .candidate-grid { grid-template-columns: 1fr; } }
    .verification-grid > div, .candidate-card { border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 15px; }
    .verification-grid p { margin-bottom: 0; color: var(--muted); font-size: 0.92rem; }
    .candidate-card { display: flex; flex-direction: column; gap: 5px; transition: transform .15s ease, border-color .15s ease; }
    .candidate-card:hover { transform: translateY(-2px); border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); }
    .candidate-card span { font-family: var(--mono); font-size: 0.66rem; color: var(--faint); text-transform: uppercase; letter-spacing: 0.1em; }
    .candidate-card strong { color: var(--mist); font-family: var(--display); font-size: 1.16rem; }
    .candidate-card em { color: var(--muted); font-style: normal; font-size: 0.88rem; }
  </style>
</Base>
