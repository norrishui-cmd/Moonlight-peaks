---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
      { '@type': 'ListItem', position: 2, name: 'Herramientas', item: `${SITE.url}/es/tools` },
      { '@type': 'ListItem', position: 3, name: 'Enviador de datos', item: new URL('/es/tools/submit-data', SITE.url).href },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Enviador de datos de Moonlight Peaks',
    applicationCategory: 'GameApplication',
    operatingSystem: 'Web',
    url: new URL('/es/tools/submit-data', SITE.url).href,
    description: 'Una herramienta local de borrador de Moonlight Peaks para enviar datos de la semana de lanzamiento sobre objetos, recetas, ubicaciones, regalos y errores.',
  },
];
---
<Base
  title="Enviador de datos de Moonlight Peaks - Comparte peces, objetos, regalos, recetas y errores"
  description="Redacta envíos de datos de lanzamiento de Moonlight Peaks para peces, criaturas, recetas, pociones, regalos, ubicaciones, tiendas, errores y otros descubrimientos verificados."
  path="/es/tools/submit-data"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Herramientas', href: '/es/tools' }, { label: 'Enviador de datos' }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Herramienta / Datos de la comunidad</p>
      <h1>Moonlight Peaks — <em>Enviador de datos</em></h1>
      <p class="intro">
        Prepara tus descubrimientos de la semana de lanzamiento para revisión manual: peces,
        criaturas, recetas, pociones, regalos de NPCs, tiendas, ubicaciones, errores y notas de
        plataforma. Nada se publica automáticamente.
      </p>

      <section class="submit-shell" data-submit-tool>
        <form class="submit-form">
          <label>
            <span>Tipo de dato</span>
            <select name="type">
              <option>Pez</option>
              <option>Criatura</option>
              <option>Receta</option>
              <option>Poción</option>
              <option>Regalo de NPC</option>
              <option>Ubicación</option>
              <option>Tienda</option>
              <option>Error o problema</option>
              <option>Otro</option>
            </select>
          </label>
          <label><span>Nombre o título</span><input name="name" placeholder="ej. por confirmar" /></label>
          <label><span>Ubicación / fuente</span><input name="location" placeholder="Dónde lo encontraste" /></label>
          <label><span>Temporada / hora / clima</span><input name="conditions" placeholder="Si es relevante" /></label>
          <label><span>Precio / valor / efecto</span><input name="value" placeholder="Si es visible en el juego" /></label>
          <label><span>Nota de evidencia</span><input name="evidence" placeholder="Captura de pantalla, publicación oficial u observación en el juego real" /></label>
          <label class="wide"><span>Notas</span><textarea name="notes" rows="5" placeholder="Añade el texto exacto, ingredientes de recetas, reacción del personaje, pasos del error u otros detalles."></textarea></label>
          <button type="button" class="btn btn-primary" data-save>Guardar borrador localmente</button>
        </form>

        <aside class="review-card">
          <span>Política de revisión</span>
          <h2>Solo revisión manual</h2>
          <p>
            Los borradores se guardan en tu navegador y se pueden exportar. Publica solo después de
            verificar fuentes oficiales, capturas de pantalla del juego real o evidencia repetible
            en el juego.
          </p>
          <button type="button" class="btn btn-ghost" data-export>Exportar JSON</button>
        </aside>
      </section>

      <h2>Borradores guardados</h2>
      <div class="draft-list" data-drafts></div>

      <div class="callout">
        Regla de fuentes recomendada: cita canales oficiales, páginas de tienda o publicaciones
        neutrales en redes sociales siempre que sea posible. No cites páginas de wikis competidoras
        como fuente de datos publicados.
      </div>
    </div>
  </article>

  <script>
    const root = document.querySelector('[data-submit-tool]');
    const draftsEl = document.querySelector('[data-drafts]');
    if (root && draftsEl) {
      const key = 'moonlight-data-drafts-v1';
      const form = root.querySelector('.submit-form');
      const saveButton = root.querySelector('[data-save]');
      const exportButton = root.querySelector('[data-export]');
      let drafts = JSON.parse(localStorage.getItem(key) || '[]');

      const save = () => localStorage.setItem(key, JSON.stringify(drafts));
      const render = () => {
        draftsEl.innerHTML = drafts.length ? drafts.map((draft, index) => `
          <article class="draft-card">
            <span>${draft.type}</span>
            <h3>${draft.name || 'Borrador sin título'}</h3>
            <p>${draft.notes || 'Aún sin notas.'}</p>
            <small>${draft.location || 'Ubicación pendiente'} - ${draft.evidence || 'Evidencia pendiente'}</small>
            <button type="button" data-delete="${index}">Eliminar</button>
          </article>
        `).join('') : '<p class="empty">Aún no hay borradores locales.</p>';
      };

      saveButton.addEventListener('click', () => {
        const data = Object.fromEntries(new FormData(form).entries());
        data.createdAt = new Date().toISOString();
        drafts.unshift(data);
        drafts = drafts.slice(0, 25);
        save();
        form.reset();
        render();
      });
      draftsEl.addEventListener('click', (event) => {
        const button = event.target.closest('button[data-delete]');
        if (!button) return;
        drafts.splice(Number(button.dataset.delete), 1);
        save();
        render();
      });
      exportButton.addEventListener('click', async () => {
        const text = JSON.stringify(drafts, null, 2);
        await navigator.clipboard.writeText(text);
        exportButton.textContent = 'JSON copiado';
        setTimeout(() => { exportButton.textContent = 'Exportar JSON'; }, 1600);
      });
      render();
    }
  </script>

  <style>
    .submit-shell { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 18px; margin: 28px 0; }
    @media (max-width: 860px) { .submit-shell { grid-template-columns: 1fr; } }
    .submit-form, .review-card, .draft-card, .empty {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--surface);
    }
    .submit-form { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; padding: 18px; }
    @media (max-width: 640px) { .submit-form { grid-template-columns: 1fr; } }
    .submit-form .wide, .submit-form button { grid-column: 1 / -1; }
    .submit-form span { display: block; margin-bottom: 6px; color: var(--mist); font-weight: 600; }
    .submit-form input, .submit-form select, .submit-form textarea {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--ink);
      color: var(--mist);
      padding: 11px 12px;
      font: inherit;
    }
    .review-card { padding: 18px; align-self: start; }
    .review-card > span { font-family: var(--mono); color: var(--candle); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; }
    .review-card p { color: var(--muted); }
    .draft-list { display: grid; gap: 10px; }
    .draft-card, .empty { padding: 14px; }
    .draft-card span { color: var(--candle); font-family: var(--mono); font-size: 0.68rem; text-transform: uppercase; }
    .draft-card h3 { margin: 5px 0; }
    .draft-card p { color: var(--muted); margin: 0 0 8px; }
    .draft-card small { color: var(--faint); }
    .draft-card button { float: right; border: 1px solid var(--line); border-radius: 999px; background: transparent; color: var(--muted); padding: 4px 9px; cursor: pointer; }
  </style>
</Base>
