---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const faq = [
  { q: '¿Cuántos Soul Blobs hay en Moonlight Peaks?', a: 'Confirmado al lanzamiento: 100 Soul Blobs, repartidos por el mundo del juego.' },
  { q: '¿Cómo se atrapan los Soul Blobs en Moonlight Peaks?', a: 'Confirmado: con la red, la misma herramienta usada para atrapar insectos — no a mano.' },
  { q: '¿Qué se obtiene por recolectar todos los Soul Blobs?', a: 'Confirmado: el Reloj Antiguo, que extiende la noche de los 15 minutos por defecto a 25 minutos.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Colección', item: `${SITE.url}/es/collections` },
    { '@type': 'ListItem', position: 3, name: 'Soul Blobs', item: `${SITE.url}/es/collections/soul-blobs` },
  ] },
];
---
<Base
  title="Moonlight Peaks Soul Blobs: los 100 y la recompensa del Reloj Antiguo"
  description="Confirmado: 100 Soul Blobs están repartidos por Moonlight Peaks, atrapados con la red. Recolectarlos todos otorga el Reloj Antiguo, que extiende la noche a 25 minutos."
  path="/es/collections/soul-blobs"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Colección', href: '/es/collections' }, { label: 'Soul Blobs' }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Colección · Soul Blobs</p>
      <h1>Moonlight Peaks — <em>Soul Blobs</em></h1>
      <p class="intro">
        Los Soul Blobs son pequeñas almas-calavera que vagan por el mundo del juego — confirmado al
        lanzamiento: 100 en total, con una recompensa realmente útil para quien complete la colección.
      </p>

      <div class="callout">
        <strong>Respuesta rápida:</strong> Death te presenta los Soul Blobs después de su segundo
        encuentro en el pueblo, y te pide atraparlos con la red. Hay 100 en total; recolectarlos
        todos otorga el Reloj Antiguo.
      </div>

      <h2>Cómo se introducen los Soul Blobs</h2>
      <p>
        Confirmado: <a href="/characters/death">Death</a> te presenta los Soul Blobs después de su
        segundo encuentro en el pueblo, y te pide atraparlos con la red — la misma herramienta usada
        para atrapar insectos, no algo separado.
      </p>

      <h2>Qué los distingue de otros coleccionables</h2>
      <p>
        Reportado por la comunidad: los Soul Blobs son la más narrativa de las dos misiones de
        recolección de criaturas del juego (la otra son los <a href="/es/collections/vampsters">Vampster</a>).
        Al atrapar un Soul Blob, el juego te cuenta una pequeña viñeta sobre cómo murió esa alma —
        una pequeña recompensa narrativa por cada hallazgo, en vez de solo marcar una casilla en una lista.
      </p>

      <h2>La recompensa por completar la colección</h2>
      <p>
        Confirmado: recolectar los 100 Soul Blobs otorga el <strong>Reloj Antiguo</strong>, que
        extiende la duración de la noche de los 15 minutos por defecto a 25 minutos — una recompensa
        de comodidad permanente y realmente útil, en vez de solo cosmética.
      </p>

      <h2>Preguntas frecuentes</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Páginas relacionadas: <a href="/es/collections">Centro de colecciones</a>, <a href="/es/collections/vampsters">Vampster</a>,
        <a href="/characters/death">Death</a>, <a href="/es/activities">Pesca y caza de insectos</a>.
      </div>
    </div>
  </article>
</Base>
