---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { critterDetailPages } from '../../../data/collectionDetailPages';

const faq = [
  { q: '¿Cuántas criaturas hay en Moonlight Peaks?', a: 'Confirmado: la colección de criaturas incluye 28 especies documentadas hasta ahora, cada una con estación, ubicación, tipo y precio de venta cuando se han verificado.' },
  { q: '¿Dónde se encuentran las criaturas en Moonlight Peaks?', a: 'Confirmado: la ubicación varía por especie — algunas aparecen en el pueblo, otras en el bosque, la playa, o zonas específicas como Misty Shores. Consulta la página de detalle de cada criatura para su ubicación exacta.' },
  { q: '¿Para qué sirven las criaturas capturadas?', a: 'Se pueden vender por monedas, usar en recetas de cocina o crafteo, o donar a la colección del museo — el uso exacto varía por especie y se indica en cada página de detalle.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Colecciones', item: `${SITE.url}/es/collections` },
    { '@type': 'ListItem', position: 3, name: 'Criaturas', item: `${SITE.url}/es/collections/critters` },
  ] },
];
---
<Base
  title="Moonlight Peaks Criaturas — Colección completa de pequeños seres"
  description="Colección confirmada de criaturas de Moonlight Peaks: 28 especies documentadas con estación, ubicación, tipo y precio de venta."
  path="/es/collections/critters"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Colecciones', href: '/es/collections' }, { label: 'Criaturas' }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Colección · Criaturas</p>
      <h1>Las <em>criaturas</em> de Moonlight Peaks</h1>
      <p class="intro">
        Confirmado: la colección de criaturas de Moonlight Peaks incluye {critterDetailPages.length}
        especies documentadas hasta ahora, cada una con su propia estación, ubicación, tipo y
        precio de venta cuando se han verificado.
      </p>

      <h2>Qué determina qué criaturas aparecen</h2>
      <p>
        Confirmado: al igual que con los peces, la ubicación y la estación afectan qué criaturas
        puedes encontrar en un momento dado. Una criatura que no ves una noche podría simplemente
        estar esperando las condiciones correctas, no significa que falte del juego.
      </p>

      <h2>Lista completa de criaturas ({critterDetailPages.length} especies)</h2>
      <p>Haz clic en cada criatura para ver su página de detalle con estación, ubicación, tipo y precio de venta.</p>
      <ul class="fish-link-list">
        {critterDetailPages.map((c) => (
          <li><a href={`/es/collections/critters/${c.slug}`}>{c.name}</a></li>
        ))}
      </ul>

      <h2>Preguntas frecuentes</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Relacionado: <a href="/es/collections">Centro de colecciones</a>, <a href="/es/collections/fish">peces</a>,
        <a href="/es/activities">actividades</a>.
      </div>
    </div>
  </article>

  <style>
    .fish-link-list {
      list-style: none; padding: 0; margin: 12px 0 24px;
      display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 8px;
    }
    .fish-link-list a {
      display: block; border: 1px solid var(--line); border-radius: 10px; padding: 8px 12px;
      background: var(--surface); color: var(--candle); text-decoration: none; font-size: 0.88rem;
    }
    .fish-link-list a:hover { border-color: color-mix(in srgb, var(--candle) 54%, var(--line)); }
  </style>
</Base>
