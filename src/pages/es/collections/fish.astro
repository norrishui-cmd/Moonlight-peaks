---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { fishDetailPages } from '../../../data/collectionDetailPages';

const faq = [
  { q: '¿Cómo se consigue la primera caña de pescar en Moonlight Peaks?', a: 'Confirmado: dentro de tus primeras noches de juego, conoces a Noel junto al río. Te reta a un concurso — atrapar 3 tipos de peces diferentes antes que él — sin límite de tiempo, así que es fácil ganar, y te da tu primera caña de pescar más una bonificación de monedas.' },
  { q: '¿Cuántos peces hay en Moonlight Peaks?', a: 'Confirmado: 22 especies. Cada una tiene un precio base de venta y un valor de energía al comerlo, ambos aumentan con calidad de 1 y 2 estrellas. Consulta la lista de abajo para la página de detalle de cada pez.' },
  { q: '¿Qué afecta a qué peces se pueden pescar en Moonlight Peaks?', a: 'Confirmado: la ubicación, la estación, el clima y la hora del día afectan todos a qué se puede pescar en ese momento.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Colecciones', item: `${SITE.url}/es/collections` },
    { '@type': 'ListItem', position: 3, name: 'Peces', item: `${SITE.url}/es/collections/fish` },
  ] },
];
---
<Base
  title="Moonlight Peaks Peces — 22 especies y cómo conseguir la primera caña"
  description="Pesca confirmada de Moonlight Peaks: cómo conseguir tu primera caña de pescar de Noel, 22 especies de peces, niveles de calidad, y qué afecta a qué peces se pueden pescar."
  path="/es/collections/fish"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Colecciones', href: '/es/collections' }, { label: 'Peces' }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Colección · Peces</p>
      <h1>Los <em>peces</em> de Moonlight Peaks</h1>
      <p class="intro">
        Confirmado por dos fuentes independientes de la semana de lanzamiento: la pesca se basa en
        una colección real de 22 especies, que varía según la ubicación, la hora y el clima.
      </p>

      <h2>Consigue tu primera caña de pescar</h2>
      <p>
        Confirmado: dentro de tus primeras noches de juego, conoces a <a href="/characters/noel">Noel</a>
        junto al río. Te reta a un concurso — atrapar 3 tipos de peces diferentes antes que él — sin
        límite de tiempo, así que es fácil ganar — y te da tu primera caña de pescar más una
        bonificación de monedas.
      </p>

      <h2>Especies de peces y qué las hace variar</h2>
      <p>
        Confirmado: la colección llega hasta 22 especies. Cuál se puede pescar depende de la
        ubicación, la estación, el clima y la hora del día, así que un pez que no encuentras una
        noche podría simplemente estar esperando las condiciones correctas, no significa que no
        exista en el juego.
      </p>

      <h2>Niveles de calidad</h2>
      <p>
        Confirmado: cada pez tiene un precio base de venta y un valor de energía base al comerlo,
        ambos aumentan con calidad de 1 y 2 estrellas — vale la pena buscar activamente capturas de
        mayor calidad incluso de la misma especie.
      </p>

      <h2>Lista completa de peces (22 especies)</h2>
      <p>Haz clic en cada pez para ver su página de detalle con ubicación, rareza, hora de aparición, tamaño y precio de venta.</p>
      <ul class="fish-link-list">
        {fishDetailPages.map((f) => (
          <li><a href={`/es/collections/fish/${f.slug}`}>{f.name}</a></li>
        ))}
      </ul>

      <h2>Preguntas frecuentes</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Relacionado: <a href="/es/collections">Centro de colecciones</a>, <a href="/es/activities">actividad de pesca</a>,
        <a href="/characters/noel">Noel</a>, <a href="/items/cooking">cocina</a>.
      </div>
    </div>
  </article>

  <style>
    .fish-link-list {
      list-style: none; padding: 0; margin: 12px 0 24px;
      display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 8px;
    }
    .fish-link-list a {
      display: block; border: 1px solid var(--line); border-radius: 10px; padding: 8px 12px;
      background: var(--surface); color: var(--candle); text-decoration: none; font-size: 0.88rem;
    }
    .fish-link-list a:hover { border-color: color-mix(in srgb, var(--candle) 54%, var(--line)); }
  </style>
</Base>
