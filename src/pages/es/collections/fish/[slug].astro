---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';
import { fishDetailPages } from '../../../../data/collectionDetailPages';

export function getStaticPaths() {
  return fishDetailPages.map((entry, index) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      previous: fishDetailPages[index - 1],
      next: fishDetailPages[index + 1],
    },
  }));
}

const { entry, previous, next } = Astro.props;
const labelEs: Record<string, string> = {
  'Location': 'Ubicación', 'Rarity': 'Rareza', 'Spawns during': 'Aparece durante',
  'Size': 'Tamaño', 'Consumption value': 'Valor al comer', 'Sell price': 'Precio de venta',
};
const fact = (label: string) => entry.facts.find((item: any) => item.label === label)?.value || '-';
const hasIcon = entry.icon.startsWith('/images/');
const pagePath = `/es/collections/fish/${entry.slug}`;
const title = `${entry.name} — Guía de Peces de Moonlight Peaks`;
const description = `Ubicación, rareza, momento de aparición, tamaño y precio de venta de ${entry.name} en Moonlight Peaks.`;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
      { '@type': 'ListItem', position: 2, name: 'Colecciones', item: `${SITE.url}/es/collections` },
      { '@type': 'ListItem', position: 3, name: 'Peces', item: `${SITE.url}/es/collections/fish` },
      { '@type': 'ListItem', position: 4, name: entry.name, item: `${SITE.url}${pagePath}` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: `¿Dónde se pesca ${entry.name} en Moonlight Peaks?`,
        acceptedAnswer: { '@type': 'Answer', text: `Según los datos actualmente confirmados, la ubicación es ${fact('Location')}. Los campos marcados con "-" todavía esperan verificación en el juego real.` },
      },
      {
        '@type': 'Question',
        name: `¿Cuál es el valor de ${entry.name}?`,
        acceptedAnswer: { '@type': 'Answer', text: `Según los datos actualmente confirmados, el precio de venta es ${fact('Sell price')} y el valor al comerlo es ${fact('Consumption value')}.` },
      },
    ],
  },
];
---
<Base
  title={title}
  description={description}
  path={pagePath}
  jsonLd={jsonLd}
  crumbs={[{ label: 'Colecciones', href: '/es/collections' }, { label: 'Peces', href: '/es/collections/fish' }, { label: entry.name }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Colección · Peces</p>
      <section class="detail-hero">
        <div>
          <h1>{entry.name} <em>(pez)</em></h1>
          <p class="intro">
            Página de detalle del pez {entry.name} en Moonlight Peaks, basada en los datos
            confirmados de la tabla de colección. Los valores no confirmados se muestran como
            <strong>-</strong> hasta que se verifiquen en el juego real.
          </p>
        </div>
        <div class="detail-icon" aria-hidden={!hasIcon}>
          {hasIcon ? <img src={entry.icon} alt={`Icono de ${entry.name}`} loading="eager" /> : <span>Sin icono</span>}
        </div>
      </section>

      <section class="fact-grid" aria-label={`Datos de ${entry.name}`}>
        {entry.facts.map((item: any) => (
          <div class="fact-card">
            <span>{labelEs[item.label] ?? item.label}</span>
            <strong>{item.value}</strong>
          </div>
        ))}
      </section>

      <h2>Notas sobre {entry.name}</h2>
      <p>
        {entry.name} aparece en la base de datos actual de peces de Moonlight Peaks. Ubicación,
        rareza, momento de aparición, tamaño, valor de consumo y precio de venta — todo en una
        sola página.
      </p>
      <p>
        Nota de uso: <strong>{entry.use}</strong>. Los campos marcados con "-" significan que las
        capturas de pantalla proporcionadas todavía no muestran un valor confirmado.
      </p>
      <p class="source-note">
        Nota de fuente: esta página usa la tabla de colección de peces confirmada de Moonlight
        Peaks, y se ampliará conforme se confirmen nuevos datos oficiales o del juego real.
      </p>

      <h2>Páginas relacionadas</h2>
      <div class="related-grid">
        <a href="/es/collections/fish">Lista de peces</a>
        <a href="/es/collections">Centro de colecciones</a>
      </div>

      <nav class="detail-nav" aria-label="Navegación de detalle de peces">
        {previous ? <a href={`/es/collections/fish/${previous.slug}`}>← {previous.name}</a> : <span />}
        {next ? <a href={`/es/collections/fish/${next.slug}`}>{next.name} →</a> : <span />}
      </nav>
    </div>
  </article>
  <style>
    .detail-hero {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 20px;
      align-items: start;
    }
    .detail-icon {
      width: 140px;
      height: 140px;
      border-radius: 16px;
      border: 1px solid var(--line);
      background: var(--surface);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .detail-icon img { width: 100%; height: 100%; object-fit: contain; }
    .detail-icon span { color: var(--faint); font-size: 0.7rem; text-transform: uppercase; }
    .fact-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
      margin: 18px 0 28px;
    }
    .fact-card {
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--surface);
      padding: 14px;
    }
    .fact-card span {
      display: block;
      color: var(--candle);
      font-family: var(--mono);
      font-size: 0.68rem;
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    .fact-card strong { color: var(--text); font-size: 1rem; }
    .related-grid, .detail-nav {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 10px;
      margin-top: 12px;
    }
    .source-note { border-left: 3px solid var(--candle); padding-left: 14px; color: var(--muted); }
    .related-grid a, .detail-nav a {
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 12px 14px;
      background: var(--surface);
      color: var(--candle);
      font-family: var(--mono);
      text-decoration: none;
    }
    @media (max-width: 640px) {
      .detail-hero { grid-template-columns: 1fr; }
      .detail-icon { width: 112px; height: 112px; }
    }
  </style>
</Base>
