---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const entries = [
  { title: 'Fecha de lanzamiento y plataformas', desc: 'Disponible desde el 7 de julio en Steam, Switch, Switch 2 y Android — precio y demo gratuita.', href: '/release-date', img: '/card-release.webp' },
  { title: 'Guía para principiantes', desc: 'Lo que realmente importa en tu primera semana — confirmado desde el juego real.', href: '/beginner-guide', img: '/card-guide.webp' },
  { title: 'Romance y familias', desc: '23 opciones de romance confirmadas, las siete familias y los regalos favoritos.', href: '/romance', img: '/card-romance.webp' },
  { title: 'Cultivos y granja', desc: 'Uvas de sangre, el Granero y el ganado mágico — datos confirmados.', href: '/farming', img: '/card-crops.webp' },
  { title: 'Magia', desc: 'Cómo arreglar la varita rota, Moon Fruit y la progresión de maná.', href: '/magic', img: '/card-guide.webp' },
  { title: 'Personajes', desc: 'Todos los residentes, sus familias y quién puede ser conquistado.', href: '/characters', img: '/count-dracula.webp' },
  { title: 'Ubicaciones', desc: 'El pueblo, tu granja, Howling Marshes y otros lugares confirmados.', href: '/locations', img: '/hero-loc-town.webp' },
  { title: 'Problemas conocidos', desc: 'Cierres inesperados, problemas de mando y soluciones confirmadas.', href: '/known-issues', img: '/card-guide.webp' },
];

const explore = [
  { k: 'Romance', d: 'Niveles de corazón, citas y matrimonio', href: '/romance', img: '/card-romance.webp' },
  { k: 'Familias', d: 'Las siete familias sobrenaturales del pueblo', href: '/families', img: '/hero-fam-vampires.webp' },
  { k: 'Actividades', d: 'Pesca, magia, manualidades y pasatiempos acogedores', href: '/activities', img: '/hero-act-seasonal-events.webp' },
  { k: 'Objetos', d: 'Herramientas, pociones, decoraciones y otras categorías', href: '/items', img: null, c1: '#3a4a2f', c2: '#8ab06a' },
  { k: 'Preguntas frecuentes', d: 'Respuestas rápidas a las preguntas más comunes', href: '/faq', img: '/card-faq.webp' },
  { k: 'Misiones', d: 'Guía de "A Bridge Too Far" y otras misiones confirmadas', href: '/quests', img: '/hero-first-five-minutes.webp' },
];

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'WebSite', name: 'Moonlight Peaks Wiki & Guide (Español)',
  url: `${SITE.url}/es`, inLanguage: 'es',
  description: 'Guía en español hecha por fans de Moonlight Peaks, el life-sim de vampiros: información de lanzamiento, guía para principiantes, romance y problemas conocidos.',
};
---
<Base
  title="Moonlight Peaks Guía en Español — Lanzamiento y Problemas Conocidos"
  description="Tu guía en español hecha por fans de Moonlight Peaks, el cozy life-sim de vampiros. Disponible desde el 7 de julio de 2026. Consejos, romance y problemas conocidos."
  path="/es"
  jsonLd={jsonLd}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">El almanaque de campo de un vampiro granjero</p>
      <h1><em>Moonlight Peaks</em> ya está disponible.</h1>
      <p class="intro">
        La guía cozy-gótica del life-sim de vampiros de {GAME.developer}. {GAME.title} se lanzó el
        7 de julio de 2026 y ya está disponible. Esta guía se actualiza con información real y
        verificada del juego.
      </p>
      <p class="callout wip">
        Esta versión en español cubre las páginas más importantes por ahora. El resto del contenido
        (artículos, algunos perfiles de personajes) todavía está solo en inglés — lo iremos
        traduciendo por partes. Los enlaces de esta página te llevarán a esas páginas en inglés
        hasta que estén disponibles en español.
      </p>

      <h2>Empieza por aquí</h2>
      <div class="es-grid">
        {entries.map((e) => (
          <a class="es-card" href={e.href}>
            <img src={e.img} alt="" loading="lazy" width="64" height="64" />
            <span>
              <strong>{e.title}</strong>
              <em>{e.desc}</em>
            </span>
          </a>
        ))}
      </div>

      <h2>Explora el mundo</h2>
      <div class="es-grid">
        {explore.map((x) => (
          <a class="es-card" href={x.href}>
            <span class="es-thumb" style={!x.img ? `background: linear-gradient(135deg, ${x.c1}, ${x.c2})` : undefined}>
              {x.img ? <img src={x.img} alt="" loading="lazy" width="64" height="64" /> : <span class="es-thumb-letter">{x.k[0]}</span>}
            </span>
            <span>
              <strong>{x.k}</strong>
              <em>{x.d}</em>
            </span>
          </a>
        ))}
      </div>
    </div>
  </article>

  <style>
    .page { padding: 32px 0 60px; }
    .eyebrow { font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--faint); }
    h1 { font-family: var(--display); font-size: 2rem; margin: 6px 0 14px; }
    h1 em { color: var(--candle); font-style: normal; }
    .intro { color: var(--muted); font-size: 1rem; line-height: 1.6; max-width: 640px; margin-bottom: 16px; }
    .callout.wip { border-left: 2px solid var(--candle); background: var(--ink-2); padding: 12px 16px; border-radius: 0 10px 10px 0; color: var(--muted); font-size: 0.88rem; margin: 0 0 32px; }
    h2 { font-family: var(--display); font-size: 1.3rem; margin: 28px 0 12px; }
    .es-grid { display: grid; grid-template-columns: 1fr; gap: 10px; }
    @media (min-width: 640px) { .es-grid { grid-template-columns: 1fr 1fr; } }
    .es-card { display: flex; align-items: center; gap: 12px; border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 12px; transition: border-color .15s ease; }
    .es-card:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); }
    .es-card img { border-radius: 10px; object-fit: cover; width: 64px; height: 64px; flex: 0 0 auto; }
    .es-thumb { flex: 0 0 auto; width: 64px; height: 64px; border-radius: 10px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--line); }
    .es-thumb-letter { font-family: var(--display); font-weight: 700; font-size: 1.4rem; color: rgba(255,255,255,0.9); }
    .es-card span:not(.es-thumb) { display: flex; flex-direction: column; min-width: 0; }
    .es-card strong { font-family: var(--display); font-weight: 600; font-size: 0.96rem; color: var(--mist); }
    .es-card em { font-style: normal; font-size: 0.8rem; color: var(--faint); margin-top: 2px; }
  </style>
</Base>
