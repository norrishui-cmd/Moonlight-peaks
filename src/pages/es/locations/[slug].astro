---
import TopicPage from '../../../components/TopicPage.astro';
import { locationsSection, locations } from '../../../data/locations';
import { locationsEs } from '../../../i18n/locations-es';

export function getStaticPaths() {
  const translated = locations.filter((it) => locationsEs[it.slug]);
  return translated.map((it, i) => {
    const tr = locationsEs[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...translated[(i - 1 + translated.length) % translated.length], ...locationsEs[translated[(i - 1 + translated.length) % translated.length].slug] },
        next: { ...translated[(i + 1) % translated.length], ...locationsEs[translated[(i + 1) % translated.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const esSection = { ...locationsSection, base: '/es/locations', label: 'Ubicaciones', eyebrow: 'Mundo' };
---
<TopicPage section={esSection} item={item} prev={prev} next={next} lang="es" basePath="/es/locations" />
