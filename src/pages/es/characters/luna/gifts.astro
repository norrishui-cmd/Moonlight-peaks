---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: '¿Qué regalo le gusta más a Luna?',
    acceptedAnswer: { '@type': 'Answer', text: 'A Luna le encantan el Tulipán Morado, la Azalea Morada y la Rosa Blanca.' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Personajes', item: `${SITE.url}/es/characters` },
    { '@type': 'ListItem', position: 3, name: 'Luna', item: `${SITE.url}/es/characters/luna` },
  ] },
];
---
<Base
  title="Regalos favoritos de Luna | Guía de personajes de Moonlight Peaks"
  description="Preferencias de regalos confirmadas de Luna en Moonlight Peaks — qué le encanta, qué le gusta y qué evitar."
  path="/es/characters/luna/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Personajes', href: '/es/characters' }, { label: 'Luna', href: '/es/characters/luna' }, { label: 'Regalos' }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Personajes · Regalos</p>
      <h1>Regalos favoritos de <em>Luna</em></h1>
      <p class="intro">
        Datos de regalos confirmados para Luna, basados en pruebas de la semana de lanzamiento.
      </p>

      <h2>Le encanta</h2>
      <p>Confirmado que a Luna le encantan: Tulipán Morado, Azalea Morada y Rosa Blanca.</p>

      <h2>Le gusta</h2>
      <p>Además de sus favoritos, a Luna también le gusta: Uva de Sangre.</p>

      <h2>No le gusta</h2>
      <p>Evita con Luna: Lata de Frijoles Oxidada. Confirmado que esto reduce el afecto.</p>

      <div class="callout wip">
        Páginas relacionadas: <a href="/es/characters/luna">perfil de Luna</a>,
        <a href="/es/characters">todos los personajes</a>, <a href="/characters/luna/gifts">versión completa en inglés</a>.
      </div>
    </div>
  </article>
</Base>
