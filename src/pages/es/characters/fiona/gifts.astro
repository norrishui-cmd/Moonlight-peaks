---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: '¿Qué regalo le gusta más a Fiona?',
    acceptedAnswer: { '@type': 'Answer', text: 'A Fiona le encantan las Fresas (Strawberries) por encima de todo.' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Personajes', item: `${SITE.url}/es/characters` },
    { '@type': 'ListItem', position: 3, name: 'Fiona', item: `${SITE.url}/es/characters/fiona` },
  ] },
];
---
<Base
  title="Regalos favoritos de Fiona | Guía de personajes de Moonlight Peaks"
  description="Preferencias de regalos confirmadas de Fiona en Moonlight Peaks — qué le encanta, qué le gusta y qué evitar."
  path="/es/characters/fiona/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Personajes', href: '/es/characters' }, { label: 'Fiona', href: '/es/characters/fiona' }, { label: 'Regalos' }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Personajes · Regalos</p>
      <h1>Regalos favoritos de <em>Fiona</em></h1>
      <p class="intro">
        Datos de regalos confirmados para Fiona, basados en pruebas de la semana de lanzamiento.
      </p>

      <h2>Le encanta</h2>
      <p>Confirmado que a Fiona le encantan: Fresas (Strawberries).</p>

      <h2>Le gusta</h2>
      <p>Además de su favorito, a Fiona también le gusta: Tulipán Morado, Azalea Morada, Lavanda Morada, Huevo y Jugo de Luna.</p>

      <h2>No le gusta</h2>
      <p>Evita con Fiona: Semillas de Cebolla. Confirmado que esto reduce el afecto.</p>

      <div class="callout wip">
        Páginas relacionadas: <a href="/es/characters/fiona">perfil de Fiona</a>,
        <a href="/es/characters">todos los personajes</a>, <a href="/characters/fiona/gifts">versión completa en inglés</a>.
      </div>
    </div>
  </article>
</Base>
