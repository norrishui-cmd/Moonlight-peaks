---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: '¿Qué regalo le gusta más a Saga?',
    acceptedAnswer: { '@type': 'Answer', text: 'A Saga le encanta el Vino Blanco (White Wine) por encima de todo.' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Personajes', item: `${SITE.url}/es/characters` },
    { '@type': 'ListItem', position: 3, name: 'Saga', item: `${SITE.url}/es/characters/saga` },
  ] },
];
---
<Base
  title="Regalos favoritos de Saga | Guía de personajes de Moonlight Peaks"
  description="Preferencias de regalos confirmadas de Saga en Moonlight Peaks — qué le encanta, qué le gusta y qué evitar."
  path="/es/characters/saga/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Personajes', href: '/es/characters' }, { label: 'Saga', href: '/es/characters/saga' }, { label: 'Regalos' }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Personajes · Regalos</p>
      <h1>Regalos favoritos de <em>Saga</em></h1>
      <p class="intro">
        Datos de regalos confirmados para Saga, basados en pruebas de la semana de lanzamiento
        de medios internacionales (TheGamer, publicado el 7 de julio de 2026).
      </p>

      <h2>Le encanta</h2>
      <p>Confirmado que a Saga le encanta: Vino Blanco (White Wine). La opción más efectiva para profundizar la relación rápidamente.</p>

      <h2>Le gusta</h2>
      <p>Además de su favorito, a Saga también le gusta: Vino Tinto (Red Wine), Cerveza, flores individuales (no ramos), Tulipán Morado, Azalea Rosa, Uva de Sangre, Jugo de Fresa y Sopa Gazpacho.</p>

      <h2>No le gusta</h2>
      <p>Evita con Saga: ramos de flores (varias flores juntas) y Barra de Cobre. Confirmado que reducen el afecto.</p>

      <div class="callout wip">
        Páginas relacionadas: <a href="/es/characters/saga">perfil de Saga</a>,
        <a href="/es/characters">todos los personajes</a>, <a href="/characters/saga/gifts">versión completa en inglés</a>.
      </div>
    </div>
  </article>
</Base>
