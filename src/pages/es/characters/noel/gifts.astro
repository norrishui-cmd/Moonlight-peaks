---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: '¿Qué regalo le gusta más a Noel?',
    acceptedAnswer: { '@type': 'Answer', text: 'A Noel le encanta el Huevo Dorado (Golden Egg) por encima de todo.' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Personajes', item: `${SITE.url}/es/characters` },
    { '@type': 'ListItem', position: 3, name: 'Noel', item: `${SITE.url}/es/characters/noel` },
  ] },
];
---
<Base
  title="Regalos favoritos de Noel | Guía de personajes de Moonlight Peaks"
  description="Preferencias de regalos confirmadas de Noel en Moonlight Peaks — qué le encanta, qué le gusta y qué evitar."
  path="/es/characters/noel/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Personajes', href: '/es/characters' }, { label: 'Noel', href: '/es/characters/noel' }, { label: 'Regalos' }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Personajes · Regalos</p>
      <h1>Regalos favoritos de <em>Noel</em></h1>
      <p class="intro">
        Datos de regalos confirmados para Noel, basados en pruebas de la semana de lanzamiento.
      </p>

      <h2>Le encanta</h2>
      <p>Confirmado que a Noel le encanta: Huevo Dorado (Golden Egg). La opción más efectiva para profundizar la relación rápidamente.</p>

      <h2>Le gusta</h2>
      <p>Además de su favorito, a Noel también le gusta: Uva de Sangre, Jugo de Uva de Sangre, Jugo de Fresa y Pez Glibby.</p>

      <h2>No le gusta</h2>
      <p>Evita con Noel: Tulipán Morado y Azalea Rosa — flores populares con la mayoría de los demás personajes, pero confirmadas como no deseadas por él.</p>

      <div class="callout wip">
        Páginas relacionadas: <a href="/es/characters/noel">perfil de Noel</a>,
        <a href="/es/characters">todos los personajes</a>, <a href="/characters/noel/gifts">versión completa en inglés</a>.
      </div>
    </div>
  </article>
</Base>
