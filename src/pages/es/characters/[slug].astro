---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { characters } from '../../../data/characters';
import { charTranslations } from '../../../i18n/characters-data';

export function getStaticPaths() {
  return Object.keys(charTranslations.es).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const base = characters.find((c) => c.id === slug)!;
const tr = charTranslations.es[slug as keyof typeof charTranslations.es];

const url = new URL(`/es/characters/${slug}`, SITE.url).href;
const imgAbs = base.img ? new URL(base.img, SITE.url).href : undefined;
const statusLabel =
  base.status === 'confirmed' ? 'Confirmado'
  : base.status === 'reported' ? 'Reportado'
  : base.status === 'datamined' ? 'Datamined'
  : 'Sin confirmar';
const romanceText = base.romanceable === true ? tr.romanceYes : base.romanceable === false ? tr.romanceNo : tr.romanceTbc;

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Personajes', item: `${SITE.url}/es/characters` },
    { '@type': 'ListItem', position: 3, name: tr.name, item: url },
  ] },
  { '@context': 'https://schema.org', '@type': 'Person', name: tr.name, description: tr.desc, ...(imgAbs ? { image: imgAbs } : {}) },
];
---
<Base
  title={`${tr.name} - Guia de personajes de Moonlight Peaks`}
  description={`${tr.name} en Moonlight Peaks: ${tr.desc} Familia, estado de romance e informacion conocida hasta ahora.`}
  path={`/es/characters/${slug}`}
  jsonLd={jsonLd}
  ogImage={base.img}
  crumbs={[{ label: 'Personajes', href: '/es/characters' }, { label: tr.name }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Personaje · {tr.typeLabel}</p>

      <div class="chead">
        <div class="cavatar">
          {base.img ? (
            <img src={base.img} alt={`${tr.name} portrait`} width="160" height="160" />
          ) : (
            <span class="fallback-avatar" style={`background: linear-gradient(135deg, ${base.c1}, ${base.c2})`}>{tr.name.charAt(0)}</span>
          )}
        </div>
        <div class="cmeta">
          <h1>{tr.name}</h1>
          <div class="ctags">
            <span class={`cbadge ${base.status === 'confirmed' ? 'is-conf' : base.status === 'reported' ? 'is-rep' : base.status === 'datamined' ? 'is-dm' : 'is-unc'}`}>{statusLabel}</span>
            <span class="ctag fam">{tr.familyLabel}</span>
            {base.romanceable === true && <span class="ctag heart">Romanceable</span>}
            {base.romanceable === false && <span class="ctag">No romanceable</span>}
            {base.romanceable === null && <span class="ctag">Romance por confirmar</span>}
          </div>
          <p class="cdesc">{tr.desc}</p>
        </div>
      </div>

      <h2>Lo que sabemos</h2>
      <ul>{tr.knownInfo.map((k) => (<li>{k}</li>))}</ul>

      <h2>Romance</h2>
      <p>{romanceText}</p>

      <div class="callout">
        Mas: <a href="/es/characters">todos los personajes</a>, <a href="/romance">romance</a>,
        <a href="/families">familias</a> y <a href="/characters">fichas completas en ingles</a>.
      </div>
    </div>
  </article>
</Base>
