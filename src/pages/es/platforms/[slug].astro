---
import TopicPage from '../../../components/TopicPage.astro';
import { platformsSection, platforms } from '../../../data/platforms';
import { platformsEs } from '../../../i18n/platforms-es';

export function getStaticPaths() {
  return platforms.filter((it) => platformsEs[it.slug]).map((it, i, arr) => {
    const tr = platformsEs[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...arr[(i - 1 + arr.length) % arr.length], ...platformsEs[arr[(i - 1 + arr.length) % arr.length].slug] },
        next: { ...arr[(i + 1) % arr.length], ...platformsEs[arr[(i + 1) % arr.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const esSection = { ...platformsSection, base: '/es/platforms', label: 'Plataformas', eyebrow: 'Plataforma' };
---
<TopicPage section={esSection} item={item} prev={prev} next={next} lang="es" basePath="/es/platforms" />
