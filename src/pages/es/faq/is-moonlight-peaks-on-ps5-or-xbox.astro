---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: '¿Moonlight Peaks está disponible en PS5 o Xbox?',
    acceptedAnswer: { '@type': 'Answer', text: 'No — no se ha anunciado ninguna versión para PlayStation o Xbox. Las plataformas confirmadas son Steam, Steam Deck, Nintendo Switch, Nintendo Switch 2 y Android.' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: `${SITE.url}/es/faq` },
  ] },
];
---
<Base
  title="¿Moonlight Peaks está disponible en PS5 o Xbox?"
  description="No — Moonlight Peaks no está disponible en PS5 o Xbox. Plataformas confirmadas: Steam, Steam Deck, Switch, Switch 2, Android."
  path="/es/faq/is-moonlight-peaks-on-ps5-or-xbox"
  jsonLd={jsonLd}
  crumbs={[{ label: 'FAQ', href: '/es/faq' }, { label: 'PS5/Xbox' }]}
  lang="es"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">FAQ</p>
      <h1>¿Moonlight Peaks está disponible en <em>PS5 o Xbox</em>?</h1>
      <p class="intro">
        En resumen: no. No se ha anunciado ninguna versión para PlayStation o Xbox. Las
        plataformas confirmadas son Steam, Steam Deck, Nintendo Switch, Nintendo Switch 2 y
        Android.
      </p>
      <p>Si más adelante se anuncia una versión para PS5 o Xbox, actualizaremos esta página.</p>
      <div class="callout wip">
        Más información: <a href="/es/platforms">plataformas</a>,
        <a href="/es/release-date">fecha de lanzamiento</a>.
      </div>
    </div>
  </article>
</Base>
