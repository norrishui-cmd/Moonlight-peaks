---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';
import YouTube from '../../components/YouTube.astro';

const facts = [
  ['Precio', 'Gratis'],
  ['Dónde jugarla', 'Steam y Nintendo eShop, compatible con Switch 2'],
  ['Progreso transferible', 'Sin confirmación; trata la demo como una muestra aparte'],
  ['Actividades incluidas', 'Creación de personaje, pesca, arreglos florales, bordado e interacciones tempranas con el pueblo'],
  ['Lanzamiento completo', GAME.releaseLabel],
];

const faq = [
  { q: '¿La demo de Moonlight Peaks es gratis?', a: 'Sí. La demo es gratuita en Steam y Nintendo eShop.' },
  { q: '¿El progreso de la demo se transfiere?', a: 'No se ha anunciado transferencia confirmada, así que empieza el juego completo desde cero salvo que las notas oficiales del lanzamiento digan lo contrario.' },
  { q: '¿Qué se puede hacer en la demo?', a: 'La demo muestra el creador de personaje, una muestra de actividades cozy como pesca, arreglos florales y bordado, además de interacciones tempranas con residentes.' },
  { q: '¿La demo está en Switch 2?', a: 'La demo de Nintendo eShop se puede jugar en Switch y Switch 2.' },
  { q: '¿Debería probar la demo antes de comprar?', a: 'Sí, si quieres probar el tono, los controles y el bucle inicial antes del lanzamiento.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Demo', item: `${SITE.url}/es/demo` },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
];
---
<Base
  title="Moonlight Peaks — Guía de la Demo: Descarga, Contenido y FAQ"
  description="Guía de la demo de Moonlight Peaks: dónde descargarla, qué incluye, si el progreso se transfiere, acceso en Switch y Steam, consejos y limitaciones conocidas."
  path="/es/demo"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Demo' }]}
  lang="es"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Hub · Demo</p>
      <h1>Guía de la <em>demo</em> de Moonlight Peaks</h1>
      <p class="intro">
        La demo gratuita de Moonlight Peaks es la forma más segura de probar este cozy life-sim de
        vampiros antes del lanzamiento completo el {GAME.releaseLabel}. Aquí explicamos dónde
        descargarla, qué incluye y qué no se transfiere.
      </p>

      <div class="demo-video">
        <YouTube id="BvfEwKHmMfg" title="Moonlight Peaks demo video" />
      </div>

      <h2>Datos rápidos</h2>
      <table class="facts">
        {facts.map((row) => (<tr><th>{row[0]}</th><td>{row[1]}</td></tr>))}
      </table>

      <h2>Para qué sirve mejor la demo</h2>
      <p>
        Usa la demo para decidir si el tono, los controles, la cámara y las actividades cozy más
        lentas funcionan para ti. No está pensada para revelar todos los sistemas. Los valores exactos
        de cultivos, las tablas completas de regalos, las misiones tardías y las listas de colección
        completas pertenecen al lanzamiento completo.
      </p>
      <ul>
        <li><strong>Prueba el ambiente:</strong> la demo es más útil como comprobación de tono y controles.</li>
        <li><strong>Prueba actividades tempranas:</strong> pesca, arreglos florales, bordado e introducciones de residentes dan una muestra útil.</li>
        <li><strong>No sobre-optimices:</strong> como el progreso no está confirmado que se transfiera, trata la demo como práctica.</li>
        <li><strong>Compara plataformas:</strong> los jugadores de Steam, Switch y Switch 2 deben revisar controles y rendimiento por separado.</li>
      </ul>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Relacionado: <a href="/es/release-date">fecha de lanzamiento</a>,
        <a href="/es/platforms">plataformas</a>, <a href="/demo">guías detalladas de la demo</a> (en inglés).
      </div>
    </div>
  </article>
</Base>
