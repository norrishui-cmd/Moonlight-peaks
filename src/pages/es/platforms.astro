---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const facts = [
  ['Fecha de lanzamiento', GAME.releaseLabel],
  ['Precio', `${GAME.price} (edición Nintendo Switch 2: $39.99)`],
  ['Plataformas', GAME.platforms.join(', ')],
  ['Demo gratuita', GAME.demo],
  ['Requisitos del sistema', 'Consulta Steam para los requisitos oficiales de PC/Mac; usa la demo para probarlo en la práctica'],
  ['Idiomas', GAME.languages.join(', ')],
  ['PS5 / Xbox / iOS', 'No anunciado'],
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/es` },
    { '@type': 'ListItem', position: 2, name: 'Plataformas', item: `${SITE.url}/es/platforms` },
  ] },
];
---
<Base
  title="Moonlight Peaks — Plataformas: Switch, Switch 2, Steam y Precio"
  description="Dónde jugar Moonlight Peaks: Switch, Switch 2, Steam (PC y Mac), Steam Deck y Android — precio, la demo gratuita y el estado de PS5/Xbox/iOS."
  path="/es/platforms"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Plataformas' }]}
  lang="es"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entrada · Plataformas</p>
      <h1>Moonlight Peaks — <em>plataformas</em> y precio</h1>
      <p class="intro">
        Moonlight Peaks se lanza el {GAME.releaseLabel}. Aquí puedes ver dónde jugarlo, cuánto cuesta,
        y cómo funciona la demo gratuita.
      </p>

      <h2>De un vistazo</h2>
      <table class="facts">
        {facts.map((f) => (<tr><th>{f[0]}</th><td>{f[1]}</td></tr>))}
      </table>

      <h2>Dónde jugarlo</h2>
      <p>
        Moonlight Peaks está confirmado en Steam (PC y Mac), Steam Deck, Nintendo Switch, Nintendo
        Switch 2, y Android vía Google Play. Cada plataforma tiene su propia guía detallada — por
        ahora disponibles en inglés — con notas específicas sobre rendimiento, controles y precio.
      </p>

      <h2>¿Moonlight Peaks está en PlayStation, Xbox o iOS?</h2>
      <p>
        No se ha anunciado ninguna versión para PlayStation, Xbox o iOS. Las plataformas confirmadas
        son Steam (PC y Mac), Steam Deck, Nintendo Switch, Nintendo Switch 2, y Android vía Google
        Play. Si esto cambia, actualizaremos esta página.
      </p>

      <div class="callout wip">
        Relacionado: <a href="/release-date">fecha de lanzamiento</a>, <a href="/demo">la demo</a>,
        <a href="/system-requirements">requisitos del sistema</a>, <a href="/languages">idiomas</a>,
        <a href="/compare">comparar con otros cozy sims</a>, <a href="/faq">FAQ completa</a> (en inglés) ·
        <a href="/es/faq">FAQ en español</a>.
      </div>
    </div>
  </article>
</Base>
