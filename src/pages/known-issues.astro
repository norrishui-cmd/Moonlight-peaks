---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';

const issueRows = [
  ['Steam Deck crash on startup', 'Player-reported · Workaround available', 'Multiple players report the game crashing on launch, even after reinstalling and verifying files. Reported fix: switch the Steam Deck compatibility tool to Proton 9.0-4. Not an official Valve or developer fix — a repeated player workaround.'],
  ['Micro-freezes / stutter every few seconds', 'Player-reported · No confirmed fix', 'Reported by players on high-end PCs (e.g. RTX 5090) as well as mid-range hardware, so it does not appear to be a hardware-specific issue. No confirmed workaround is currently documented — some players report partial relief from updating GPU drivers and setting Moonlight Peaks to "High performance" in system graphics settings, but this isn\u2019t confirmed to work reliably.'],
  ['Crash when leaving the farm', 'Player-reported · No confirmed fix', 'Some players report a reliable crash specifically when exiting the farm area. No confirmed workaround is currently documented; verifying game files is a general troubleshooting step some try, without confirmed success.'],
  ['Controller stops responding mid-game', 'Player-reported · Workaround available', 'Controller works during character creation but then stops responding, with button-mapping options greyed out in Settings. Player-reported workaround: unplugging/reconnecting the controller, or switching to keyboard/mouse.'],
  ['NPC gets stuck / can\u2019t be talked to', 'Player-reported · No confirmed fix', 'Reported with Orlock specifically getting stuck in one spot and becoming untalkable. Reloading the area and sleeping to the next day have both failed to fix it for affected players.'],
  ['Can\u2019t interact with objects indoors', 'Player-reported · No confirmed fix', 'Some players report being unable to click on objects inside their house (e.g. the coffin to sleep, pets) while outdoor interactions work fine.'],
  ['Switch 2 loading times', 'Confirmed by reviewers · No confirmed fix', 'Multiple reviewers flagged long loading times specifically on Nintendo Switch 2 as the main technical complaint. No official fix announced yet.'],
  ['Accessories not displaying on character', 'Player-reported · No confirmed fix', 'Some players report that certain equipped accessories (e.g. arm/wrist items) don\u2019t visually render on the character model even though they\u2019re equipped. Platform pattern isn\u2019t clearly isolated yet in available reports. No confirmed workaround is currently documented.'],
  ['Graphics settings reset when switching devices', 'Player-reported · No confirmed fix', 'Players using Steam Cloud across multiple PCs report graphics/display settings not carrying over, requiring manual reconfiguration on each device even though saves sync. No confirmed workaround is currently documented — this may be expected behavior for display settings specifically rather than a bug, but that hasn\u2019t been confirmed either.'],
  ['UI/text size on handheld (Steam Deck / Switch)', 'Player-reported · No confirmed fix', 'Some handheld players report on-screen text and menus feeling small on a handheld display. No confirmed workaround or in-game text-size option is currently documented.'],
];

const reportChecklist = [
  'Exact platform and storefront',
  'Game version or build date if visible',
  'What happened and what you were doing',
  'Whether it repeats after restarting',
  'Any official note, patch note, or neutral source confirming the issue',
];

const faq = [
  {
    q: 'Why does Moonlight Peaks keep freezing or stuttering?',
    a: 'Confirmed player reports (including on high-end PCs) describe brief freezes every few seconds regardless of hardware, so this doesn\u2019t appear to be a hardware-specific problem. There\u2019s no official fix yet — updating your GPU drivers and setting the game to "High performance" in your system\u2019s graphics settings are the most common partial mitigations reported so far.',
  },
  {
    q: 'Moonlight Peaks crashes on startup on Steam Deck — how do I fix it?',
    a: 'Multiple players report this. The most repeated fix: open the game\u2019s Properties in Steam, go to Compatibility, and switch the Proton version to 9.0-4.',
  },
  {
    q: 'My controller stopped working in Moonlight Peaks — what do I do?',
    a: 'This is a reported, unresolved issue — the controller works during character creation but stops responding afterward, with control-remapping options greyed out. No confirmed fix exists yet; try disconnecting and reconnecting your controller, or switch to keyboard/mouse in the meantime.',
  },
  {
    q: 'An NPC in Moonlight Peaks is stuck and I can\u2019t talk to them — help?',
    a: 'This has been reported (notably with Orlock getting stuck in place). Reloading the area and sleeping to the next day have not fixed it for affected players so far; there\u2019s no confirmed fix yet, so consider reporting it to support@xseedgames.com with your platform and a description.',
  },
  {
    q: 'Are there known Moonlight Peaks bugs at launch?',
    a: 'Yes — see the tracker above for the specific issues currently being reported and their status. We only list something here once it\u2019s backed by official notes, repeated player reports, or reliable neutral coverage.',
  },
  {
    q: 'Where should save or cloud save problems go?',
    a: 'Save and cloud save reports belong here first, then on a dedicated save file page once exact paths and fixes are verified.',
  },
  {
    q: 'Should I trust random fix posts?',
    a: 'Use caution. A fix should be repeatable, platform-specific, and ideally backed by official notes or multiple independent reports before it is treated as reliable.',
  },
  {
    q: 'Why aren\u2019t my accessories showing up on my character?',
    a: 'Player-reported: some equipped accessories, particularly arm/wrist items, don\u2019t visually render even though they\u2019re equipped. No confirmed workaround is currently documented.',
  },
  {
    q: 'Why did my graphics settings reset after switching PCs?',
    a: 'Player-reported: some players using Steam Cloud across multiple PCs find graphics/display settings don\u2019t carry over, even though save files sync correctly. No confirmed workaround is currently documented, and it isn\u2019t confirmed whether this is intended behavior or a bug.',
  },
  {
    q: 'Is the UI too small on Steam Deck or Switch?',
    a: 'Player-reported: some handheld players find on-screen text and menus small. No confirmed workaround or in-game text-size setting is currently documented — see the platform pages linked below for other handheld-specific notes.',
  },
  {
    q: 'Does this page replace official support?',
    a: 'No. For unresolved issues, email support@xseedgames.com with your platform, a crash dump if available, and a description of what happened.',
  },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Known issues', item: new URL('/known-issues', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })) },
  {
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: 'Moonlight Peaks known issues',
    description: 'Launch-week known issues tracker for Moonlight Peaks crashes, saves, controller input, Steam Deck, Switch, and performance notes.',
    url: new URL('/known-issues', SITE.url).href,
    author: { '@type': 'Organization', name: SITE.brand },
    publisher: { '@type': 'Organization', name: SITE.brand },
    about: { '@type': 'VideoGame', name: GAME.title, gamePlatform: GAME.platforms },
  },
];
---
<Base
  title="Moonlight Peaks Known Issues: Crashes, Controllers, Loading & Fixes"
  description="Moonlight Peaks known issues: Steam Deck crashes, controller problems, freezing, accessories not displaying, and loading times — clearly labeled confirmed vs. player-reported, with workarounds where they exist."
  path="/known-issues"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Known issues' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Launch / Known issues</p>
      <h1>Moonlight Peaks <em>known issues</em></h1>
      <p class="intro">
        A launch-week tracker for confirmed bugs, crashes, saves, controller problems, and
        platform-specific reports — sourced from official support notes and Steam Community
        discussions, updated as fixes are confirmed.
      </p>

      <h2>Save file location</h2>
      <p>
        Confirmed by the developers: on Windows, saves are at
        <code>%USERPROFILE%/AppData/LocalLow/Little Chicken Game Company/Moonlight Peaks/</code>.
        On Mac, they're at <code>~/Library/Application Support/Little Chicken Game Company/Moonlight Peaks/</code>.
        Crash dumps on Windows are typically under <code>%LOCALAPPDATA%\CrashDumps</code>, from
        "Moonlight Peaks.exe" — attach these if you email support.
      </p>

      <h2>Current tracker</h2>
      <table class="facts">
        {issueRows.map((row) => (<tr><th>{row[0]}</th><td><strong>{row[1]}</strong><br />{row[2]}</td></tr>))}
      </table>

      <h2>Before listing an issue</h2>
      <p>
        Launch-week bug pages can become messy fast. Keep this page useful by separating confirmed
        issues from one-off reports, and by naming the exact platform whenever possible.
      </p>
      <ul>
        {reportChecklist.map((item) => (<li>{item}</li>))}
      </ul>

      <h2>Related checks</h2>
      <div class="link-grid">
        <a href="/best-settings">Best settings</a>
        <a href="/system-requirements">System requirements</a>
        <a href="/platforms/steam-deck">Steam Deck</a>
        <a href="/platforms/switch">Nintendo Switch</a>
        <a href="/platforms/switch-2">Nintendo Switch 2</a>
        <a href="/launch-day">Launch day hub</a>
      </div>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </article>

  <style>
    .link-grid { display: grid; grid-template-columns: 1fr; gap: 10px; margin-top: 10px; }
    @media (min-width: 640px) { .link-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    .link-grid a { border: 1px solid var(--line); border-radius: 10px; background: var(--surface); color: var(--mist); padding: 12px 14px; text-decoration: none; }
    .link-grid a:hover { border-color: color-mix(in srgb, var(--candle) 55%, var(--line)); }
  </style>
</Base>
