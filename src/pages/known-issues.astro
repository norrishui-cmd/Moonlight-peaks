---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';

const issueRows = [
  ['Steam Deck crash on startup', 'Confirmed workaround', 'Multiple players report the game crashing on launch, even after reinstalling and verifying files. Reported fix: switch the Steam Deck compatibility tool to Proton 9.0-4.'],
  ['Micro-freezes / stutter every few seconds', 'Confirmed, unresolved', 'Reported by players on high-end PCs (e.g. RTX 5090) as well as mid-range hardware, so it does not appear to be a hardware-specific issue. No official fix yet — try updating GPU drivers and setting Moonlight Peaks to "High performance" in your system\u2019s graphics settings as a partial mitigation.'],
  ['Crash when leaving the farm', 'Reported, unresolved', 'Some players report a reliable crash specifically when exiting the farm area. No official fix yet — try verifying game files.'],
  ['Controller stops responding mid-game', 'Reported, unresolved', 'Controller works during character creation but then stops responding, with button-mapping options greyed out in Settings. No confirmed fix yet; try unplugging/reconnecting the controller or switching to keyboard/mouse as a workaround.'],
  ['NPC gets stuck / can\u2019t be talked to', 'Reported, unresolved', 'Reported with Orlock specifically getting stuck in one spot and becoming untalkable. Reloading the area and sleeping to the next day have both failed to fix it for affected players.'],
  ['Can\u2019t interact with objects indoors', 'Reported, unresolved', 'Some players report being unable to click on objects inside their house (e.g. the coffin to sleep, pets) while outdoor interactions work fine.'],
  ['Switch 2 loading times', 'Confirmed by reviewers', 'Multiple reviewers flagged long loading times specifically on Nintendo Switch 2 as the main technical complaint; no official fix announced yet.'],
];

const reportChecklist = [
  'Exact platform and storefront',
  'Game version or build date if visible',
  'What happened and what you were doing',
  'Whether it repeats after restarting',
  'Any official note, patch note, or neutral source confirming the issue',
];

const faq = [
  {
    q: 'Why does Moonlight Peaks keep freezing or stuttering?',
    a: 'Confirmed player reports (including on high-end PCs) describe brief freezes every few seconds regardless of hardware, so this doesn\u2019t appear to be a hardware-specific problem. There\u2019s no official fix yet — updating your GPU drivers and setting the game to "High performance" in your system\u2019s graphics settings are the most common partial mitigations reported so far.',
  },
  {
    q: 'Moonlight Peaks crashes on startup on Steam Deck — how do I fix it?',
    a: 'Multiple players report this. The most repeated fix: open the game\u2019s Properties in Steam, go to Compatibility, and switch the Proton version to 9.0-4.',
  },
  {
    q: 'My controller stopped working in Moonlight Peaks — what do I do?',
    a: 'This is a reported, unresolved issue — the controller works during character creation but stops responding afterward, with control-remapping options greyed out. No confirmed fix exists yet; try disconnecting and reconnecting your controller, or switch to keyboard/mouse in the meantime.',
  },
  {
    q: 'An NPC in Moonlight Peaks is stuck and I can\u2019t talk to them — help?',
    a: 'This has been reported (notably with Orlock getting stuck in place). Reloading the area and sleeping to the next day have not fixed it for affected players so far; there\u2019s no confirmed fix yet, so consider reporting it to support@xseedgames.com with your platform and a description.',
  },
  {
    q: 'Are there known Moonlight Peaks bugs at launch?',
    a: 'Yes — see the tracker above for the specific issues currently being reported and their status. We only list something here once it\u2019s backed by official notes, repeated player reports, or reliable neutral coverage.',
  },
  {
    q: 'Where should save or cloud save problems go?',
    a: 'Save and cloud save reports belong here first, then on a dedicated save file page once exact paths and fixes are verified.',
  },
  {
    q: 'Should I trust random fix posts?',
    a: 'Use caution. A fix should be repeatable, platform-specific, and ideally backed by official notes or multiple independent reports before it is treated as reliable.',
  },
  {
    q: 'Does this page replace official support?',
    a: 'No. For unresolved issues, email support@xseedgames.com with your platform, a crash dump if available, and a description of what happened.',
  },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Known issues', item: new URL('/known-issues', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })) },
  {
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: 'Moonlight Peaks known issues',
    description: 'Launch-week known issues tracker for Moonlight Peaks crashes, saves, controller input, Steam Deck, Switch, and performance notes.',
    url: new URL('/known-issues', SITE.url).href,
    author: { '@type': 'Organization', name: SITE.brand },
    publisher: { '@type': 'Organization', name: SITE.brand },
    about: { '@type': 'VideoGame', name: GAME.title, gamePlatform: GAME.platforms },
  },
];
---
<Base
  title="Moonlight Peaks Known Issues — Crashes, Controller & Freezing Fixes"
  description="Confirmed Moonlight Peaks bugs and fixes: Steam Deck crash on startup, controller not working, freezing/stutter, stuck NPCs, save file locations, and Switch 2 loading times."
  path="/known-issues"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Known issues' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Launch / Known issues</p>
      <h1>Moonlight Peaks <em>known issues</em></h1>
      <p class="intro">
        A launch-week tracker for confirmed bugs, crashes, saves, controller problems, and
        platform-specific reports — sourced from official support notes and Steam Community
        discussions, updated as fixes are confirmed.
      </p>

      <h2>Save file location</h2>
      <p>
        Confirmed by the developers: on Windows, saves are at
        <code>%USERPROFILE%/AppData/LocalLow/Little Chicken Game Company/Moonlight Peaks/</code>.
        On Mac, they're at <code>~/Library/Application Support/Little Chicken Game Company/Moonlight Peaks/</code>.
        Crash dumps on Windows are typically under <code>%LOCALAPPDATA%\CrashDumps</code>, from
        "Moonlight Peaks.exe" — attach these if you email support.
      </p>

      <h2>Current tracker</h2>
      <table class="facts">
        {issueRows.map((row) => (<tr><th>{row[0]}</th><td><strong>{row[1]}</strong><br />{row[2]}</td></tr>))}
      </table>

      <h2>Before listing an issue</h2>
      <p>
        Launch-week bug pages can become messy fast. Keep this page useful by separating confirmed
        issues from one-off reports, and by naming the exact platform whenever possible.
      </p>
      <ul>
        {reportChecklist.map((item) => (<li>{item}</li>))}
      </ul>

      <h2>Related checks</h2>
      <div class="link-grid">
        <a href="/best-settings">Best settings</a>
        <a href="/system-requirements">System requirements</a>
        <a href="/platforms/steam-deck">Steam Deck</a>
        <a href="/platforms/switch">Nintendo Switch</a>
        <a href="/platforms/switch-2">Nintendo Switch 2</a>
        <a href="/launch-day">Launch day hub</a>
      </div>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </article>

  <style>
    .link-grid { display: grid; grid-template-columns: 1fr; gap: 10px; margin-top: 10px; }
    @media (min-width: 640px) { .link-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    .link-grid a { border: 1px solid var(--line); border-radius: 10px; background: var(--surface); color: var(--mist); padding: 12px 14px; text-decoration: none; }
    .link-grid a:hover { border-color: color-mix(in srgb, var(--candle) 55%, var(--line)); }
  </style>
</Base>
