---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Noel 最喜欢什么礼物?',
    acceptedAnswer: { '@type': 'Answer', text: 'Noel 最爱的是黄金蛋(Golden Egg)。' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '角色', item: `${SITE.url}/zh/characters` },
    { '@type': 'ListItem', position: 3, name: 'Noel', item: `${SITE.url}/zh/characters/noel` },
  ] },
];
---
<Base
  title="Noel 喜欢的礼物 | Moonlight Peaks 角色指南"
  description="Moonlight Peaks 中 Noel 已确认的礼物偏好——最爱、喜欢和要避开的礼物。"
  path="/zh/characters/noel/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: '角色', href: '/zh/characters' }, { label: 'Noel', href: '/zh/characters/noel' }, { label: '礼物' }]}
  lang="zh"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">角色 · 礼物</p>
      <h1>Noel 喜欢的<em>礼物</em></h1>
      <p class="intro">基于首发周测试确认的 Noel 礼物数据。</p>

      <h2>最爱</h2>
      <p>已确认 Noel 最爱:黄金蛋(Golden Egg)。是快速拉近关系最有效的选择。</p>

      <h2>喜欢</h2>
      <p>除了最爱的礼物之外,Noel 也喜欢:Blood Grape、Blood Grape 果汁、草莓汁和 Glibby 鱼。</p>

      <h2>不喜欢</h2>
      <p>要避开的:紫色郁金香和粉色杜鹃花——这两种花对大多数其他角色都很受欢迎,但已确认是他不喜欢的礼物。</p>

      <div class="callout wip">
        相关页面:<a href="/zh/characters/noel">Noel 资料</a>,
        <a href="/zh/characters">所有角色</a>,<a href="/characters/noel/gifts">完整英文版</a>。
      </div>
    </div>
  </article>
</Base>
