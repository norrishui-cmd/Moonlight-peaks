---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Sabrina 最喜欢什么礼物?',
    acceptedAnswer: { '@type': 'Answer', text: 'Sabrina 最爱紫色郁金香和紫色鸡蛋花。' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '角色', item: `${SITE.url}/zh/characters` },
    { '@type': 'ListItem', position: 3, name: 'Sabrina', item: `${SITE.url}/zh/characters/sabrina` },
  ] },
];
---
<Base
  title="Sabrina 喜欢的礼物 | Moonlight Peaks 角色指南"
  description="Moonlight Peaks 中 Sabrina 已确认的礼物偏好——最爱、喜欢和要避开的礼物。"
  path="/zh/characters/sabrina/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: '角色', href: '/zh/characters' }, { label: 'Sabrina', href: '/zh/characters/sabrina' }, { label: '礼物' }]}
  lang="zh"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">角色 · 礼物</p>
      <h1>Sabrina 喜欢的<em>礼物</em></h1>
      <p class="intro">基于首发周测试确认的 Sabrina 礼物数据。</p>

      <h2>最爱</h2>
      <p>已确认 Sabrina 最爱:紫色郁金香和紫色鸡蛋花。</p>

      <h2>喜欢</h2>
      <p>除了最爱的礼物之外,Sabrina 也喜欢:Blood Grape 和 Blood Grape 果汁。</p>

      <h2>不喜欢</h2>
      <p>要避开的:洋葱种子和粉色海螺壳。已确认会降低好感度。</p>

      <div class="callout wip">
        相关页面:<a href="/zh/characters/sabrina">Sabrina 资料</a>,
        <a href="/zh/characters">所有角色</a>,<a href="/characters/sabrina/gifts">完整英文版</a>。
      </div>
    </div>
  </article>
</Base>
