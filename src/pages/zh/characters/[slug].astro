---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { characters } from '../../../data/characters';
import { charTranslations } from '../../../i18n/characters-data';

export function getStaticPaths() {
  return Object.keys(charTranslations.zh).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const base = characters.find((c) => c.id === slug)!;
const tr = charTranslations.zh[slug as keyof typeof charTranslations.zh];

const url = new URL(`/zh/characters/${slug}`, SITE.url).href;
const imgAbs = base.img ? new URL(base.img, SITE.url).href : undefined;
const statusLabel =
  base.status === 'confirmed' ? '已确认'
  : base.status === 'reported' ? '报道信息'
  : base.status === 'datamined' ? '数据挖掘'
  : '未确认';
const romanceText = base.romanceable === true ? tr.romanceYes : base.romanceable === false ? tr.romanceNo : tr.romanceTbc;

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '角色', item: `${SITE.url}/zh/characters` },
    { '@type': 'ListItem', position: 3, name: tr.name, item: url },
  ] },
  { '@context': 'https://schema.org', '@type': 'Person', name: tr.name, description: tr.desc, ...(imgAbs ? { image: imgAbs } : {}) },
];
---
<Base
  title={`${tr.name} - Moonlight Peaks 角色攻略`}
  description={`Moonlight Peaks 里的${tr.name}: ${tr.desc} 所属家族、恋爱状态和目前已知信息。`}
  path={`/zh/characters/${slug}`}
  jsonLd={jsonLd}
  ogImage={base.img}
  crumbs={[{ label: '角色', href: '/zh/characters' }, { label: tr.name }]}
  lang="zh"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">角色 · {tr.typeLabel}</p>

      <div class="chead">
        <div class="cavatar">
          {base.img ? (
            <img src={base.img} alt={`${tr.name} portrait`} width="160" height="160" />
          ) : (
            <span class="fallback-avatar" style={`background: linear-gradient(135deg, ${base.c1}, ${base.c2})`}>{tr.name.charAt(0)}</span>
          )}
        </div>
        <div class="cmeta">
          <h1>{tr.name}</h1>
          <div class="ctags">
            <span class={`cbadge ${base.status === 'confirmed' ? 'is-conf' : base.status === 'reported' ? 'is-rep' : base.status === 'datamined' ? 'is-dm' : 'is-unc'}`}>{statusLabel}</span>
            <span class="ctag fam">{tr.familyLabel}</span>
            {base.romanceable === true && <span class="ctag heart">可恋爱</span>}
            {base.romanceable === false && <span class="ctag">不可恋爱</span>}
            {base.romanceable === null && <span class="ctag">恋爱状态待确认</span>}
          </div>
          <p class="cdesc">{tr.desc}</p>
        </div>
      </div>

      <h2>目前已知信息</h2>
      <ul>{tr.knownInfo.map((k) => (<li>{k}</li>))}</ul>

      <h2>恋爱情况</h2>
      <p>{romanceText}</p>

      <div class="callout">
        相关页面: <a href="/zh/characters">中文角色列表</a>、<a href="/romance">恋爱攻略</a>、
        <a href="/families">家族</a>、<a href="/characters">英文完整角色资料</a>。
      </div>
    </div>
  </article>
</Base>
