---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Saga 最喜欢什么礼物?',
    acceptedAnswer: { '@type': 'Answer', text: 'Saga 最爱的是白葡萄酒(White Wine)。' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '角色', item: `${SITE.url}/zh/characters` },
    { '@type': 'ListItem', position: 3, name: 'Saga', item: `${SITE.url}/zh/characters/saga` },
  ] },
];
---
<Base
  title="Saga 喜欢的礼物 | Moonlight Peaks 角色指南"
  description="Moonlight Peaks 中 Saga 已确认的礼物偏好——最爱、喜欢和要避开的礼物。"
  path="/zh/characters/saga/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: '角色', href: '/zh/characters' }, { label: 'Saga', href: '/zh/characters/saga' }, { label: '礼物' }]}
  lang="zh"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">角色 · 礼物</p>
      <h1>Saga 喜欢的<em>礼物</em></h1>
      <p class="intro">
        基于国际媒体首发周测试(TheGamer,2026 年 7 月 7 日发布)确认的 Saga 礼物数据。
      </p>

      <h2>最爱</h2>
      <p>已确认 Saga 最爱:白葡萄酒(White Wine)。是快速拉近关系最有效的选择。</p>

      <h2>喜欢</h2>
      <p>除了最爱的礼物之外,Saga 也喜欢:红葡萄酒(Red Wine)、啤酒、单支的花(不是花束)、紫色郁金香、粉色杜鹃花、Blood Grape、草莓汁和西班牙冷汤。</p>

      <h2>不喜欢</h2>
      <p>要避开的:花束(多支花捆在一起)和铜条。已确认会降低好感度。</p>

      <div class="callout wip">
        相关页面:<a href="/zh/characters/saga">Saga 资料</a>,
        <a href="/zh/characters">所有角色</a>,<a href="/characters/saga/gifts">完整英文版</a>。
      </div>
    </div>
  </article>
</Base>
