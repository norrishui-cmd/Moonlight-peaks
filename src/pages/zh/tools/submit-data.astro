---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
      { '@type': 'ListItem', position: 2, name: '工具', item: `${SITE.url}/zh/tools` },
      { '@type': 'ListItem', position: 3, name: '数据提交工具', item: new URL('/zh/tools/submit-data', SITE.url).href },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Moonlight Peaks 数据提交工具',
    applicationCategory: 'GameApplication',
    operatingSystem: 'Web',
    url: new URL('/zh/tools/submit-data', SITE.url).href,
    description: '一个本地的Moonlight Peaks发售周数据提交草稿工具,涵盖物品、食谱、地点、礼物和错误。',
  },
];
---
<Base
  title="Moonlight Peaks 数据提交工具 - 分享鱼类、物品、礼物、食谱与错误"
  description="为Moonlight Peaks鱼类、小生物、食谱、药水、礼物、地点、商店、错误和其他已验证的发现,起草发售周数据提交内容。"
  path="/zh/tools/submit-data"
  jsonLd={jsonLd}
  crumbs={[{ label: '工具', href: '/zh/tools' }, { label: '数据提交工具' }]}
  lang="zh"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">工具 / 社区数据</p>
      <h1>Moonlight Peaks <em>数据提交工具</em></h1>
      <p class="intro">
        为发售周的发现整理内容以便人工审核:鱼类、小生物、食谱、药水、NPC礼物、商店、地点、
        错误和平台备注。没有任何内容会被自动发布。
      </p>

      <section class="submit-shell" data-submit-tool>
        <form class="submit-form">
          <label>
            <span>数据类型</span>
            <select name="type">
              <option>鱼类</option>
              <option>小生物</option>
              <option>食谱</option>
              <option>药水</option>
              <option>NPC礼物</option>
              <option>地点</option>
              <option>商店</option>
              <option>错误或问题</option>
              <option>其他</option>
            </select>
          </label>
          <label><span>名称或标题</span><input name="name" placeholder="例如:待确认" /></label>
          <label><span>地点/来源</span><input name="location" placeholder="你在哪里发现的" /></label>
          <label><span>季节/时间/天气</span><input name="conditions" placeholder="如果相关的话" /></label>
          <label><span>价格/数值/效果</span><input name="value" placeholder="如果游戏内可见" /></label>
          <label><span>证据备注</span><input name="evidence" placeholder="截图、官方帖子或实机观察" /></label>
          <label class="wide"><span>备注</span><textarea name="notes" rows="5" placeholder="添加确切文字、食谱材料、角色反应、错误重现步骤或其他细节。"></textarea></label>
          <button type="button" class="btn btn-primary" data-save>本地保存草稿</button>
        </form>

        <aside class="review-card">
          <span>审核方针</span>
          <h2>仅限人工审核</h2>
          <p>
            草稿保存在你的浏览器里,可以导出。请只在核实过官方来源、实机截图或可重现的
            游戏内证据后再发布。
          </p>
          <button type="button" class="btn btn-ghost" data-export>导出JSON</button>
        </aside>
      </section>

      <h2>已保存的草稿</h2>
      <div class="draft-list" data-drafts></div>

      <div class="callout">
        推荐引用规则:尽量引用官方渠道、商店页面或中立的社交媒体帖子。
        不要把竞争对手的wiki页面作为已发布数据的引用来源。
      </div>
    </div>
  </article>

  <script>
    const root = document.querySelector('[data-submit-tool]');
    const draftsEl = document.querySelector('[data-drafts]');
    if (root && draftsEl) {
      const key = 'moonlight-data-drafts-v1';
      const form = root.querySelector('.submit-form');
      const saveButton = root.querySelector('[data-save]');
      const exportButton = root.querySelector('[data-export]');
      let drafts = JSON.parse(localStorage.getItem(key) || '[]');

      const save = () => localStorage.setItem(key, JSON.stringify(drafts));
      const render = () => {
        draftsEl.innerHTML = drafts.length ? drafts.map((draft, index) => `
          <article class="draft-card">
            <span>${draft.type}</span>
            <h3>${draft.name || '未命名草稿'}</h3>
            <p>${draft.notes || '还没有备注。'}</p>
            <small>${draft.location || '地点待定'} - ${draft.evidence || '证据待定'}</small>
            <button type="button" data-delete="${index}">删除</button>
          </article>
        `).join('') : '<p class="empty">还没有本地草稿。</p>';
      };

      saveButton.addEventListener('click', () => {
        const data = Object.fromEntries(new FormData(form).entries());
        data.createdAt = new Date().toISOString();
        drafts.unshift(data);
        drafts = drafts.slice(0, 25);
        save();
        form.reset();
        render();
      });
      draftsEl.addEventListener('click', (event) => {
        const button = event.target.closest('button[data-delete]');
        if (!button) return;
        drafts.splice(Number(button.dataset.delete), 1);
        save();
        render();
      });
      exportButton.addEventListener('click', async () => {
        const text = JSON.stringify(drafts, null, 2);
        await navigator.clipboard.writeText(text);
        exportButton.textContent = 'JSON已复制';
        setTimeout(() => { exportButton.textContent = '导出JSON'; }, 1600);
      });
      render();
    }
  </script>

  <style>
    .submit-shell { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 18px; margin: 28px 0; }
    @media (max-width: 860px) { .submit-shell { grid-template-columns: 1fr; } }
    .submit-form, .review-card, .draft-card, .empty {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--surface);
    }
    .submit-form { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; padding: 18px; }
    @media (max-width: 640px) { .submit-form { grid-template-columns: 1fr; } }
    .submit-form .wide, .submit-form button { grid-column: 1 / -1; }
    .submit-form span { display: block; margin-bottom: 6px; color: var(--mist); font-weight: 600; }
    .submit-form input, .submit-form select, .submit-form textarea {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--ink);
      color: var(--mist);
      padding: 11px 12px;
      font: inherit;
    }
    .review-card { padding: 18px; align-self: start; }
    .review-card > span { font-family: var(--mono); color: var(--candle); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; }
    .review-card p { color: var(--muted); }
    .draft-list { display: grid; gap: 10px; }
    .draft-card, .empty { padding: 14px; }
    .draft-card span { color: var(--candle); font-family: var(--mono); font-size: 0.68rem; text-transform: uppercase; }
    .draft-card h3 { margin: 5px 0; }
    .draft-card p { color: var(--muted); margin: 0 0 8px; }
    .draft-card small { color: var(--faint); }
    .draft-card button { float: right; border: 1px solid var(--line); border-radius: 999px; background: transparent; color: var(--muted); padding: 4px 9px; cursor: pointer; }
  </style>
</Base>
