---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const achievements = [
  { name: 'Discover all locations', desc: '找到Moonlight Peaks的每一个地点。' },
  { name: 'A Farming Monopoly', desc: '赚取1,000,000金币。' },
  { name: 'Skulls in a Net', desc: '收集全部Soul Blobs。' },
  { name: 'Back to the Den', desc: '把所有Vampster送回它们的巢穴。' },
  { name: 'Making Mina Proud', desc: '烹饪25种不同的食谱。' },
  { name: "Albertus' Helper", desc: '完成公告板上的25个工作。' },
  { name: 'Magic at Max Capacity', desc: '达到法力值上限。' },
  { name: 'Fully Energized', desc: '达到体力值上限。' },
  { name: 'Moonlit Stretching', desc: '参加你的第一次瑜伽课。' },
  { name: 'Back in Place', desc: '归还所有塑料椅子。' },
  { name: 'Tree Hugger', desc: '爱上一棵树。' },
  { name: 'The Pumpking', desc: '遇见一个奇特的南瓜。' },
  { name: 'Raiders of the Lost Art', desc: '完成Elvira的寻宝任务。' },
  { name: 'A Childhood Dream', desc: '和Ridge一起建一座树屋。' },
  { name: 'Nokturna Master', desc: '收集全部Nokturna卡牌。' },
  { name: 'Awooooo!', desc: '在满月期间和一位狼人角色对话(社区报告)。' },
  { name: 'AFKitten', desc: '连续抚摸你的Hellkitten 5分钟(社区报告)。' },
  { name: 'Cartographer', desc: '发现Moonlight Peaks的每一个地点,包括只有解锁变身形态后才能到达的区域(社区报告)。' },
  { name: 'Rightful Ritualist', desc: '激活镇上所有的女巫圈(社区报告)。' },
  { name: 'Call of the Current', desc: '解锁人鱼/水之形态——确认在游戏后期解锁,但这第三种形态的具体解锁条件仍未确认。' },
  { name: 'Perpetual Bloom', desc: '建造一座温室。' },
  { name: 'Dracula Estate', desc: '把房屋完全升级。' },
  { name: 'Vampire with a Wand', desc: '解锁魔法,并施放任意一个法术一次。' },
  { name: 'Master of Witchcraft', desc: '把每一个法术都升到满级。' },
  { name: 'A Magical Toolbelt', desc: '把任意工具升级为附魔版本。' },
  { name: 'A Magical Cocktail', desc: '让每种药水效果同时生效。' },
  { name: 'New Beginnings', desc: '种下你的第一株作物——通常是你游戏内的第一个动作。' },
  { name: 'Purrgatory', desc: '解锁Hellkitten形态。' },
  { name: 'Wings of the Night', desc: '解锁蝙蝠形态。' },
  { name: 'Out of the Mist', desc: '通过主线任务解除Misty Shores的诅咒。' },
  { name: 'To the Depths', desc: '打开地下墓室的入口。' },
  { name: 'Happy New Year!', desc: '完整经历游戏内一整年的四个季节。' },
  { name: 'A Generous Donor', desc: '总共送出299份礼物。' },
  { name: 'Serial Gifter', desc: '一晚之内送出25份对方喜爱的礼物。' },
  { name: 'Social Butterfly', desc: '和每一位角色的好感度都达到4颗心。' },
  { name: 'Tied the Knot', desc: '把一段恋爱关系推到顶点并求婚。' },
  { name: 'Buddies for Afterlife', desc: '像对待其他居民一样,和Death建立友谊。' },
];

const faq = [
  { q: 'Moonlight Peaks有多少个成就?', a: '发售时确认:Steam成就总数大约在59-60个之间(不同信源报告的数字略有差异)。目前公开查到具体名称的有37个——上方表格是已确认的内容。' },
  { q: 'Moonlight Peaks有Steam集换卡吗?', a: '有——Steam商店页面列出了Steam成就、Steam集换卡、Steam云存档,以及完整的手柄支持。' },
  { q: '最难或最冷门的成就是什么?', a: '几个已确认的名称听起来更像是有趣的、容易错过的成就,而不是纯粹的刷数值——"Tree Hugger"(爱上一棵树)和"The Pumpking"(遇见一个奇特的南瓜)听起来都跟特定的一次性互动有关,而不是重复动作。' },
  { q: '有跟恋爱或人际关系相关的成就吗?', a: '有,确认:"Social Butterfly"(和每位角色都达到4颗心)、"Tied the Knot"(把恋爱推到顶点并求婚)、"A Generous Donor"(总共送出299份礼物)、"Serial Gifter"(一晚送出25份喜爱的礼物),以及"Buddies for Afterlife"(和Death建立友谊)都属于恋爱/关系类标签。"A Childhood Dream"(和Ridge建树屋)和"Raiders of the Lost Art"(Elvira的寻宝任务)也跟特定的具名居民相关。' },
  { q: '有建造温室对应的成就吗?', a: '有,确认:"Perpetual Bloom"是建造温室后获得的成就。' },
  { q: '哪些成就跟变身形态相关?', a: '确认:"Purrgatory"(Hellkitten形态)、"Wings of the Night"(蝙蝠形态),以及"Call of the Current"(人鱼/水之形态,游戏后期解锁)。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '成就', item: new URL('/zh/achievements', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks 成就 — 完整Steam成就攻略"
  description="Moonlight Peaks确认有59个成就。查看目前已查到名称的成就,从收集Soul Blobs到赚取100万金币。"
  path="/zh/achievements"
  jsonLd={jsonLd}
  crumbs={[{ label: '成就' }]}
  lang="zh"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">入门 · 成就</p>
      <h1>Moonlight Peaks <em>成就</em></h1>
      <p class="intro">
        发售时确认:{GAME.title}共有<strong>59个Steam成就</strong>,还有Steam集换卡、云存档和完整
        手柄支持。目前只有部分成就名称是公开的——本页只列出已经查到来源的内容,会随着更多确认
        持续增加。最后更新:{SITE.updated}。
      </p>

      <h2>已确认的成就(共59个中的{achievements.length}个)</h2>
      <table class="facts">
        <tr><th>成就</th><th>解锁方式</th></tr>
        {achievements.map((a) => (
          <tr>
            <td>{a.name}</td>
            <td>{a.desc}</td>
          </tr>
        ))}
      </table>

      <div class="callout">
        还有45个成就在这里尚未命名——我们只列出从真实Steam成就数据里查到的内容,不做猜测。
        请随着更多确认持续关注更新。
      </div>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        相关:<a href="/items">物品</a>、<a href="/farming">农业</a>、
        <a href="/characters/albertus">Albertus(公告板)</a>、<a href="/characters/ridge">Ridge</a>、
        <a href="/characters/elvira">Elvira</a>、<a href="/nokturna">Nokturna卡牌游戏</a>。
      </div>
    </div>
  </article>
</Base>
