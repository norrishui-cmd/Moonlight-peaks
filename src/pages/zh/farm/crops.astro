---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { farmlandCrops, herbCrops, treeCrops } from '../../../data/farm-crops';

const cropDetailSlugs: Record<string, string> = {
  'Blood Grapes': 'blood-grapes', 'Rice': 'rice', 'Drikker': 'drikker', 'Gobbler': 'gobbler',
  'Hold Me Close': 'hold-me-close', 'Mandrake': 'mandrake', 'Weeping Wicca': 'weeping-wicca',
  'Common Mushroom': 'instant-growth-mushrooms', 'Frosteria': 'instant-growth-mushrooms',
  'Glowglammer': 'instant-growth-mushrooms', 'Yellow Glowglammer': 'instant-growth-mushrooms',
  'Volacio Mushroom': 'instant-growth-mushrooms', 'Amanita': 'instant-growth-mushrooms',
};

const faq = [
  { q: '月光峰一共有多少种作物?', a: `经官方wiki确认:${farmlandCrops.length}种田地作物、${herbCrops.length}种草药园作物，以及${treeCrops.length}种树木作物——按种植地点分成三大类。` },
  { q: '月光峰的三种作物类别是什么?', a: '确认:田地作物(种在耕好的田地上)、草药园作物(需要专门的草药园建筑)，以及树木作物(直接种在草地上，无需耕地)。' },
  { q: '月光峰哪些作物是魔法作物?', a: '确认:魔法作物只能用Aquaflux(魔法水)浇灌，不能用普通浇水壶。有几种还有独特的机制——Gobbler需要喂鱼或喂虫子，Drikker需要往它的杯子里倒水，Mandrake会根据附近是否有其他曼德拉草，长出愤怒版或开心版，Weeping Wicca会哭泣，自动浇灌周围3x3的地块。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '农场', item: `${SITE.url}/zh/farm` },
    { '@type': 'ListItem', position: 3, name: '作物', item: `${SITE.url}/zh/farm/crops` },
  ] },
];
---
<Base
  title="月光峰作物 — 完整数据库(田地、草药园与树木)"
  description="月光峰完整作物数据库:30多种田地作物、草药园作物与树木作物，资料来自官方wiki——季节、是否魔法作物、特殊机制。"
  path="/zh/farm/crops"
  jsonLd={jsonLd}
  crumbs={[{ label: '农场', href: '/zh/farm' }, { label: '作物' }]}
  lang="zh"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">农场 · 数据库</p>
      <h1>月光峰<em>作物</em></h1>
      <p class="intro">
        完整的作物数据库，来自月光峰官方wiki。作物按种植地点分为三大类——田地、草药园或树木——
        部分是魔法作物，意味着只能用Aquaflux浇灌，而不能用普通浇水壶。仅收录已确认的事实;
        具体售价和生长时间只在已确认的情况下才填写。
      </p>

      <h2>田地作物({farmlandCrops.length}种)</h2>
      <table class="facts">
        <tr><th>作物</th><th>季节</th><th>魔法作物?</th><th>备注</th></tr>
        {farmlandCrops.map((c) => (
          <tr>
            <td>{cropDetailSlugs[c.name] ? <a href={`/zh/farm/crops/${cropDetailSlugs[c.name]}`}>{c.name}</a> : c.name}</td>
            <td>{c.seasons.length ? c.seasons.join('、') : '—'}</td>
            <td>{c.magical ? '是' : '否'}</td>
            <td>
              {c.harvestDays && <>{c.harvestDays}天成熟{c.regrowDays ? `，${c.regrowDays}天后再生` : ''}{c.yieldPerHarvest ? `，每次收获${c.yieldPerHarvest}个` : ''}{c.sellPrice ? `，售价${c.sellPrice}金` : ''}{c.seedPrice ? `(种子${c.seedPrice}金)` : ''}。</>}
              {c.note}
            </td>
          </tr>
        ))}
      </table>

      <h2>草药园作物({herbCrops.length}种)</h2>
      <p>确认:草药园作物需要专门的草药园建筑，不能直接种在普通田地上。</p>
      <table class="facts">
        <tr><th>草药</th><th>魔法作物?</th><th>有干燥形态?</th></tr>
        {herbCrops.map((h) => (
          <tr><td>{h.name}</td><td>{h.magical ? '是' : '否'}</td><td>{h.hasDriedForm ? '是' : '否'}</td></tr>
        ))}
      </table>

      <h2>树木作物({treeCrops.length}种)</h2>
      <p>确认:树木作物直接种在草地上，不需要耕地。</p>
      <table class="facts">
        <tr><th>树木</th><th>季节</th><th>魔法作物?</th><th>备注</th></tr>
        {treeCrops.map((t) => (
          <tr><td>{t.name}</td><td>{t.seasons.join('、')}</td><td>{t.magical ? '是' : '否'}</td><td>{t.note || '—'}</td></tr>
        ))}
      </table>

      <h2>常见问题</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        资料来源:月光峰官方wiki(moonlightpeaks.wiki.gg)。具体售价、生长时间和产量只在信源
        确认的情况下才填写。相关:
        <a href="/zh/farm">农场中心</a>, <a href="/zh/farm/farm-helpers">农场助手</a>,
        <a href="/zh/farming">种田指南</a>。
      </div>
    </div>
  </article>
</Base>
