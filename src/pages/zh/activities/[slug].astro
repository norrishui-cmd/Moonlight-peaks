---
import TopicPage from '../../../components/TopicPage.astro';
import { activitiesSection, activities } from '../../../data/activities';
import { activitiesZh } from '../../../i18n/activities-zh';

export function getStaticPaths() {
  const translated = activities.filter((it) => activitiesZh[it.slug]);
  return translated.map((it, i) => {
    const tr = activitiesZh[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...translated[(i - 1 + translated.length) % translated.length], ...activitiesZh[translated[(i - 1 + translated.length) % translated.length].slug] },
        next: { ...translated[(i + 1) % translated.length], ...activitiesZh[translated[(i + 1) % translated.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const zhSection = { ...activitiesSection, base: '/zh/activities', label: '活动', eyebrow: '玩法' };
---
<TopicPage section={zhSection} item={item} prev={prev} next={next} lang="zh" basePath="/zh/activities" />
