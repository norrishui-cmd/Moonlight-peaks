---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const facts = [
  ['发售日期', GAME.releaseLabel],
  ['价格', `${GAME.price}(Nintendo Switch 2 版:$39.99)`],
  ['平台', GAME.platforms.join(', ')],
  ['免费试玩版', GAME.demo],
  ['配置需求', '具体的 PC/Mac 官方配置要求请以 Steam 页面为准;想实际感受表现,建议先玩试玩版'],
  ['语言支持', GAME.languages.join(', ')],
  ['PS5 / Xbox / iOS', '未公布'],
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '平台攻略', item: `${SITE.url}/zh/platforms` },
  ] },
];
---
<Base
  title="Moonlight Peaks 平台攻略 —— Switch、Switch 2、Steam 与价格"
  description="Moonlight Peaks 能在哪玩:Switch、Switch 2、Steam(PC 与 Mac)、Steam Deck 与 Android——价格、免费试玩版,以及 PS5/Xbox/iOS 的现状。"
  path="/zh/platforms"
  jsonLd={jsonLd}
  crumbs={[{ label: '平台攻略' }]}
  lang="zh"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">词条 · 平台</p>
      <h1>Moonlight Peaks 的<em>平台</em>与价格</h1>
      <p class="intro">
        Moonlight Peaks 已于 {GAME.releaseLabel} 发售,现已上线。这里汇总了能在哪玩、多少钱,
        以及免费试玩版是怎么运作的。
      </p>

      <h2>一览表</h2>
      <table class="facts">
        {facts.map((f) => (<tr><th>{f[0]}</th><td>{f[1]}</td></tr>))}
      </table>

      <h2>能在哪玩</h2>
      <p>
        Moonlight Peaks 确认会登陆 Steam(PC 与 Mac)、Steam Deck、Nintendo Switch、
        Nintendo Switch 2,以及通过 Google Play 上线的 Android 版。每个平台都有各自的详细攻略——
        目前只有英文版——里面有关于性能表现、操作方式和价格的具体说明。
      </p>

      <h2>Moonlight Peaks 会上 PlayStation、Xbox 或 iOS 吗?</h2>
      <p>
        目前没有公布 PlayStation、Xbox 或 iOS 版本。已确认的平台是 Steam(PC 与 Mac)、
        Steam Deck、Nintendo Switch、Nintendo Switch 2,以及通过 Google Play 上线的 Android 版。
        如果情况有变,我们会更新这个页面。
      </p>

      <div class="callout wip">
        相关内容:<a href="/release-date">发售日期</a>、<a href="/demo">试玩版</a>、
        <a href="/system-requirements">配置需求</a>、<a href="/languages">语言支持</a>、
        <a href="/compare">和其它温馨模拟游戏对比</a>、<a href="/faq">完整版 FAQ</a>(英文)·
        <a href="/zh/faq">中文版 FAQ</a>。
      </div>
    </div>
  </article>
</Base>
