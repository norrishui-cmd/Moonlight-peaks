---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const issueRows = [
  ['门bug(强制重启当天)', '已确认 · 已在1.1.38补丁修复', '走过某些门会导致游戏出错,强制玩家重启当天进度。经官方1.1.38补丁说明确认已修复。'],
  ['"慢速行走"故障', '已确认 · 已在1.1.38补丁修复', '一个会让玩家角色卡在减速行走状态的移动故障。经官方1.1.38补丁说明确认已修复。'],
  ['树篱/装饰品放置后变色', '玩家报告 · 尚无确认修复', '一些玩家报告放置的树篱(比如粉色)在放置后视觉上会反复变成另一种颜色(比如绿色)。官方补丁说明目前还没有列为已修复。'],
  ['Steam Deck启动崩溃', '玩家报告 · 有变通方法', '多位玩家报告游戏启动时崩溃,即使重装并验证文件后依然如此。报告的解决方法:把Steam Deck兼容工具切换到Proton 9.0-4。这不是Valve或开发者的官方修复,而是玩家反复验证过的变通方法。'],
  ['每隔几秒微卡顿', '玩家报告 · 尚无确认修复', '在高端PC(比如RTX 5090)和中端硬件上都有玩家报告,所以看起来不是特定硬件的问题。目前没有确认有效的解决办法——一些玩家报告更新显卡驱动、把游戏设为系统显卡设置里的"高性能"模式能有部分缓解,但这没有被确认能稳定生效。'],
  ['离开农场时崩溃', '玩家报告 · 尚无确认修复', '一些玩家报告在退出农场区域时会稳定崩溃。目前没有确认有效的解决办法;验证游戏文件是一些人会尝试的通用排查步骤,但没有确认成功过。'],
  ['手柄游戏中途失去响应', '玩家报告 · 有变通方法', '手柄在角色创建时能用,之后就没反应了,设置里的按键映射选项变灰——一些报告认为这和游戏更新后紧接着出现有关。玩家报告的变通方法:拔插手柄,或改用键盘鼠标。'],
  ['NPC卡住/无法对话', '玩家报告 · 尚无确认修复', '有报告特别提到Orlock卡在一个地方,无法对话。重新加载区域和睡到第二天,对受影响的玩家都没能解决问题。'],
  ['室内无法与物品互动', '玩家报告 · 尚无确认修复', '一些玩家报告无法点击房子里的物品(比如用来睡觉的棺材、宠物),而室外互动正常。'],
  ['Switch 2加载时间', '评测者确认 · 尚无确认修复', '多位评测者指出Nintendo Switch 2上偏长的加载时间是主要的技术槽点。官方尚未宣布修复。'],
  ['角色身上的配饰不显示', '玩家报告 · 尚无确认修复', '一些玩家报告某些已装备的配饰(比如手臂/手腕物品)即使已装备,也不会在角色模型上视觉呈现出来。目前的报告里还没有清楚归纳出明确的平台规律。没有确认有效的解决办法。'],
  ['更换设备后画面设置重置', '玩家报告 · 尚无确认修复', '在多台PC上使用Steam云存档的玩家报告画面/显示设置不会同步过去,即使存档本身同步正常,也需要在每台设备上手动重新配置。目前没有确认有效的解决办法——这也可能是显示设置本身的预期行为而非bug,但这一点也没有被确认。'],
  ['掌机(Steam Deck / Switch)UI/文字大小', '玩家报告 · 尚无确认修复', '一些掌机玩家报告屏幕文字和菜单在掌机屏幕上显得偏小。目前没有确认的变通方法或游戏内文字大小选项。'],
];

const reportChecklist = [
  '具体的平台和商店渠道',
  '游戏版本号或构建日期(如果能看到)',
  '发生了什么、当时在做什么',
  '重启后是否会重复出现',
  '任何能佐证该问题的官方说明、补丁说明或中立信源',
];

const faq = [
  {
    q: '为什么Moonlight Peaks一直卡顿或冻结?',
    a: '已确认的玩家报告(包括在高端PC上)描述不论硬件如何都会每隔几秒短暂冻结一下,所以看起来不是特定硬件的问题。目前还没有官方修复——更新显卡驱动、把游戏设为系统显卡设置里的"高性能"模式,是目前报告最多的部分缓解方法。',
  },
  {
    q: 'Moonlight Peaks在Steam Deck上启动崩溃——怎么解决?',
    a: '多位玩家报告了这个问题。最常见的解决方法:在Steam里打开游戏的属性,进入兼容性,把Proton版本切换到9.0-4。',
  },
  {
    q: '我的手柄在Moonlight Peaks里失灵了——怎么办?',
    a: '这是一个已报告、尚未解决的问题——手柄在角色创建时能用,之后就没反应了,按键重映射选项变灰。玩家报告也提到这会在游戏更新后反复出现(比如Xbox手柄在其他游戏里正常,但更新后在本作里没反应)。目前还没有确认的修复方法;可以先尝试拔插手柄,或暂时改用键盘鼠标。',
  },
  {
    q: 'Moonlight Peaks发过补丁了吗?修复了什么?',
    a: '发过——确认已发布1.1.38补丁。根据官方补丁说明,它修复了两个报告最多的早期bug:一个会强制玩家重启当天的"门bug",以及一个"慢速行走"故障。多位玩家已确认这两个具体修复在补丁后对他们生效。',
  },
  {
    q: '为什么我的树篱或装饰品放置后会变色?',
    a: '玩家报告:一些玩家发现放置的树篱(比如粉色)在放置后会视觉上变成另一种颜色(绿色),反复尝试也是如此。官方补丁说明目前还没有把它列为已修复——暂时当作一个悬而未决的报告处理。',
  },
  {
    q: '掌机/Steam Deck有文字大小设置吗?',
    a: '目前没有记录。一些掌机玩家报告屏幕文字和菜单显得偏小,目前没有确认的游戏内文字大小选项或变通方法。',
  },
  {
    q: 'Moonlight Peaks里一个NPC卡住了,无法对话——怎么办?',
    a: '这个问题已被报告(特别是Orlock卡在原地的情况)。重新加载区域和睡到第二天,对受影响的玩家目前都没能解决;还没有确认的修复方法,可以考虑把平台和问题描述发邮件到support@xseedgames.com反馈。',
  },
  {
    q: 'Moonlight Peaks发售时有哪些已知bug?',
    a: '有——请查看上方的追踪表,了解目前正在报告的具体问题及其状态。我们只在有官方说明、多方玩家重复报告,或可靠中立信源佐证后才会在这里列出。',
  },
  {
    q: '存档或云存档问题应该反馈到哪里?',
    a: '存档和云存档相关的报告先记录在这里,等具体路径和修复方法被验证后,会移到专门的存档页面。',
  },
  {
    q: '应该相信随便看到的修复帖子吗?',
    a: '请谨慎对待。一个修复方法在被当作可靠之前,应该是可重复的、针对特定平台的,理想情况下还要有官方说明或多个独立报告的佐证。',
  },
  {
    q: '为什么我的配饰没有显示在角色身上?',
    a: '玩家报告:一些已装备的配饰,特别是手臂/手腕物品,即使已装备也不会视觉呈现出来。目前没有确认的变通方法。',
  },
  {
    q: '为什么换了台PC之后画面设置重置了?',
    a: '玩家报告:一些在多台PC上使用Steam云存档的玩家发现画面/显示设置不会同步过去,即使存档文件本身同步正常。目前没有确认的变通方法,也没有确认这是预期行为还是bug。',
  },
  {
    q: 'Steam Deck或Switch上的UI是不是太小了?',
    a: '玩家报告:一些掌机玩家觉得屏幕文字和菜单偏小。目前没有确认的变通方法或游戏内文字大小设置——具体平台相关笔记请查看下方链接的平台页面。',
  },
  {
    q: '这个页面能代替官方支持吗?',
    a: '不能。对于尚未解决的问题,请把你的平台、崩溃转储文件(如果有)和问题描述发邮件到support@xseedgames.com。XSEED Games也运营着官方Discord(discord.gg/xseedgames),据报告团队会在里面和社区互动。',
  },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '已知问题', item: new URL('/zh/known-issues', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })) },
  {
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: 'Moonlight Peaks 已知问题',
    description: 'Moonlight Peaks发售周已知问题追踪:崩溃、存档、手柄输入、Steam Deck、Switch和性能相关笔记。',
    url: new URL('/zh/known-issues', SITE.url).href,
    author: { '@type': 'Organization', name: SITE.brand },
    publisher: { '@type': 'Organization', name: SITE.brand },
    about: { '@type': 'VideoGame', name: GAME.title, gamePlatform: GAME.platforms },
  },
];
---
<Base
  title="Moonlight Peaks 已知问题:崩溃、手柄、加载与修复方法"
  description="Moonlight Peaks已知问题:Steam Deck崩溃、手柄问题、卡顿、配饰不显示,以及加载时间——清楚标注已确认还是玩家报告,并附上现有的解决方法。"
  path="/zh/known-issues"
  jsonLd={jsonLd}
  crumbs={[{ label: '已知问题' }]}
  lang="zh"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">发售 · 已知问题</p>
      <h1>Moonlight Peaks <em>已知问题</em></h1>
      <p class="intro">
        发售周已确认bug、崩溃、存档、手柄问题和平台相关报告的追踪表——信息来自官方支持说明和
        Steam社区讨论,随修复被确认持续更新。
      </p>

      <h2>存档文件位置</h2>
      <p>
        开发者确认:在Windows上,存档位于
        <code>%USERPROFILE%/AppData/LocalLow/Little Chicken Game Company/Moonlight Peaks/</code>。
        在Mac上,位于<code>~/Library/Application Support/Little Chicken Game Company/Moonlight Peaks/</code>。
        Windows上的崩溃转储文件通常在<code>%LOCALAPPDATA%\CrashDumps</code>下,来自
        "Moonlight Peaks.exe"——发邮件求助时请附上这些文件。
      </p>

      <h2>当前追踪表</h2>
      <table class="facts">
        {issueRows.map((row) => (<tr><th>{row[0]}</th><td><strong>{row[1]}</strong><br />{row[2]}</td></tr>))}
      </table>

      <h2>反馈问题前请注意</h2>
      <p>
        发售周的bug页面很容易变得混乱。请通过区分已确认问题和单次报告,并尽可能标明具体平台,
        让这个页面保持有用。
      </p>
      <ul>
        {reportChecklist.map((item) => (<li>{item}</li>))}
      </ul>

      <h2>相关检查</h2>
      <div class="link-grid">
        <a href="/zh/best-settings">最佳设置</a>
        <a href="/zh/system-requirements">系统需求</a>
        <a href="/platforms/steam-deck">Steam Deck</a>
        <a href="/platforms/switch">Nintendo Switch</a>
        <a href="/platforms/switch-2">Nintendo Switch 2</a>
        <a href="/zh/launch-day">发售日专题</a>
      </div>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </article>

  <style>
    .link-grid { display: grid; grid-template-columns: 1fr; gap: 10px; margin-top: 10px; }
    @media (min-width: 640px) { .link-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    .link-grid a { border: 1px solid var(--line); border-radius: 10px; background: var(--surface); color: var(--mist); padding: 12px 14px; text-decoration: none; }
    .link-grid a:hover { border-color: color-mix(in srgb, var(--candle) 55%, var(--line)); }
  </style>
</Base>
