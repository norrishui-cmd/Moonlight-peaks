---
import TopicPage from '../../../components/TopicPage.astro';
import { platformsSection, platforms } from '../../../data/platforms';
import { platformsZh } from '../../../i18n/platforms-zh';

export function getStaticPaths() {
  return platforms.filter((it) => platformsZh[it.slug]).map((it, i, arr) => {
    const tr = platformsZh[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...arr[(i - 1 + arr.length) % arr.length], ...platformsZh[arr[(i - 1 + arr.length) % arr.length].slug] },
        next: { ...arr[(i + 1) % arr.length], ...platformsZh[arr[(i + 1) % arr.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const zhSection = { ...platformsSection, base: '/zh/platforms', label: '平台', eyebrow: '平台' };
---
<TopicPage section={zhSection} item={item} prev={prev} next={next} lang="zh" basePath="/zh/platforms" />
