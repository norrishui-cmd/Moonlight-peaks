---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';
import { faqs } from '../../../data/faq';
import { faqZh } from '../../../i18n/faq-zh';

const catLabelZh: Record<string, string> = {
  platforms: '平台、价格 & 试玩版', romance: '恋爱与结婚', characters: '角色',
  world: '世界与玩法', farming: '农耕与经济', general: '通用',
};
const cats = ['platforms', 'romance', 'characters', 'world', 'farming', 'general'] as const;
const translated = faqs.filter((f) => faqZh[f.slug]);
const plain = (slug: string) => {
  const tr = faqZh[slug];
  return [tr.a, ...(tr.more || [])].join(' ');
};

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '常见问题', item: `${SITE.url}/zh/faq` },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: translated.map((f) => ({
    '@type': 'Question', name: faqZh[f.slug].q, acceptedAnswer: { '@type': 'Answer', text: plain(f.slug) },
  })) },
];
---
<Base
  title="Moonlight Peaks 常见问题 — 发售、恋爱、试玩版 & 更多"
  description="关于 Moonlight Peaks 最常见问题的解答:发售日期、价格、平台、多人模式、战斗、结婚、恋爱选项、试玩版和玩法。"
  path="/zh/faq"
  jsonLd={jsonLd}
  crumbs={[{ label: '常见问题' }]}
  lang="zh"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">枢纽 · 常见问题</p>
      <h1>{GAME.title} <em>常见问题</em></h1>
      <p class="intro">
        自 2026 年 7 月 7 日发售以来,玩家们关于 {GAME.title} 最常问的问题,这里提供快速且有
        来源支持的答案。每个问题都有自己的页面。我们只回答已确认或据报道的内容,尚不清楚的
        内容会明确标注,而不是靠猜测填补。最近更新:{SITE.updated}。
      </p>

      <h2>怎么使用这份常见问题</h2>
      <p>
        需要快速答案时用这个页面,然后打开链接的攻略了解更多细节。平台和试玩版相关问题通常
        指向发售页面,恋爱和角色相关问题则指向礼物、日程、好感度事件和家族页面。
      </p>

      {cats.map((cat) => {
        const items = translated.filter((f) => f.cat === cat);
        if (items.length === 0) return null;
        return (
          <section class="grp">
            <div class="grp-head"><h2>{catLabelZh[cat]}</h2><span class="note">{items.length} 个问题</span></div>
            <ul class="q-list">
              {items.map((f) => (
                <li><a href={`/zh/faq/${f.slug}`}>{faqZh[f.slug].q}</a></li>
              ))}
            </ul>
          </section>
        );
      })}

      <div class="callout wip">
        目前已有 {translated.length} 条常见问题被翻译为中文。英文版提供全部 {faqs.length} 条——
        <a href="/faq">英文常见问题页面</a>。
      </div>
    </div>
  </article>

  <style>
    .grp { margin: 28px 0; }
    .grp-head { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; border-bottom: 1px solid var(--line); padding-bottom: 6px; margin-bottom: 10px; }
    .grp-head h2 { margin: 0; }
    .note { font-family: var(--mono); font-size: 0.72rem; color: var(--faint); white-space: nowrap; }
    .q-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; }
    .q-list a { display: block; padding: 8px 0; color: var(--mist); text-decoration: none; border-bottom: 1px dashed var(--line); }
    .q-list a:hover { color: var(--candle); }
  </style>
</Base>
