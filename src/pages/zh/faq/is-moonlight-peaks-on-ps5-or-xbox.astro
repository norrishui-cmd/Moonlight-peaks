---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Moonlight Peaks 有 PS5 或 Xbox 版本吗?',
    acceptedAnswer: { '@type': 'Answer', text: '没有——没有公布任何 PlayStation 或 Xbox 版本。已确认的平台是 Steam、Steam Deck、Nintendo Switch、Nintendo Switch 2 和 Android。' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '常见问题', item: `${SITE.url}/zh/faq` },
  ] },
];
---
<Base
  title="Moonlight Peaks 有 PS5 或 Xbox 版本吗?"
  description="没有——Moonlight Peaks 没有 PS5 或 Xbox 版本。已确认平台:Steam、Steam Deck、Switch、Switch 2、Android。"
  path="/zh/faq/is-moonlight-peaks-on-ps5-or-xbox"
  jsonLd={jsonLd}
  crumbs={[{ label: '常见问题', href: '/zh/faq' }, { label: 'PS5/Xbox' }]}
  lang="zh"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">常见问题</p>
      <h1>Moonlight Peaks 有 <em>PS5 或 Xbox</em> 版本吗?</h1>
      <p class="intro">
        简单说:没有。没有公布任何 PlayStation 或 Xbox 版本。已确认的平台是 Steam、Steam Deck、
        Nintendo Switch、Nintendo Switch 2 和 Android。
      </p>
      <p>如果之后公布了 PS5 或 Xbox 版本,我们会更新这个页面。</p>
      <div class="callout wip">
        延伸阅读:<a href="/zh/platforms">平台</a>、<a href="/zh/release-date">发售日期</a>。
      </div>
    </div>
  </article>
</Base>
