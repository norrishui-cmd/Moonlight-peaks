---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Moonlight Peaks 是多人游戏吗?',
    acceptedAnswer: { '@type': 'Answer', text: '不是——Moonlight Peaks 是纯单人游戏。没有公布任何多人或联机合作模式;Steam 上标注为单人游戏。' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '常见问题', item: `${SITE.url}/zh/faq` },
  ] },
];
---
<Base
  title="Moonlight Peaks 是多人游戏吗?"
  description="不是——Moonlight Peaks 是纯单人游戏。没有公布任何多人或联机合作模式。"
  path="/zh/faq/is-moonlight-peaks-multiplayer"
  jsonLd={jsonLd}
  crumbs={[{ label: '常见问题', href: '/zh/faq' }, { label: '是多人游戏吗?' }]}
  lang="zh"
>
  <article class="page">
    <div class="wrap">
      <h1>Moonlight Peaks 是<em>多人游戏</em>吗?</h1>
      <p class="intro">
        不是——已确认:Moonlight Peaks 是纯单人体验。没有公布任何多人或联机合作模式,Steam
        商店页面上也标注为单人游戏。
      </p>
      <div class="callout wip">
        相关页面:<a href="/zh/faq">所有常见问题</a>,
        <a href="/faq/is-moonlight-peaks-multiplayer">完整英文版</a>。
      </div>
    </div>
  </article>
</Base>
