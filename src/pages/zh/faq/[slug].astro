---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';
import { faqs, faqCatLabels } from '../../../data/faq';
import { faqZh } from '../../../i18n/faq-zh';

export function getStaticPaths() {
  const translated = faqs.filter((f) => faqZh[f.slug]);
  return translated.map((f, i) => ({
    params: { slug: f.slug },
    props: { f, tr: faqZh[f.slug], prev: translated[(i - 1 + translated.length) % translated.length], next: translated[(i + 1) % translated.length] },
  }));
}

const { f, tr, prev, next } = Astro.props as {
  f: (typeof faqs)[number]; tr: { q: string; a: string; more?: string[] };
  prev: (typeof faqs)[number]; next: (typeof faqs)[number];
};
const url = new URL(`/zh/faq/${f.slug}`, SITE.url).href;
const plain = [tr.a, ...(tr.more || [])].join(' ');

const catLabelZh: Record<string, string> = {
  platforms: '平台、价格 & 试玩版', romance: '恋爱与结婚', characters: '角色',
  world: '世界与玩法', farming: '农耕与经济', general: '通用',
};

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '常见问题', item: `${SITE.url}/zh/faq` },
    { '@type': 'ListItem', position: 3, name: tr.q, item: url },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: tr.q, acceptedAnswer: { '@type': 'Answer', text: plain },
  }] },
];
---
<Base
  title={`${tr.q} · Moonlight Peaks`}
  description={plain.length > 155 ? plain.slice(0, 152) + '…' : plain}
  path={`/zh/faq/${f.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: '常见问题', href: '/zh/faq' }, { label: tr.q }]}
  lang="zh"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">常见问题 · {catLabelZh[f.cat] ?? faqCatLabels[f.cat]}</p>
      <h1>{tr.q}</h1>
      <p class="intro">{tr.a}</p>
      {tr.more && tr.more.map((m) => (<p>{m}</p>))}

      {f.related && f.related.length > 0 && (
        <div class="callout">
          <strong>相关:</strong>{' '}
          {f.related.map((r, i) => (<>{i > 0 ? ' · ' : ''}<a href={r.href}>{r.label}</a></>))}
        </div>
      )}

      <p class="cnote">我们只回答关于 {GAME.title} 已确认或据报道的内容;尚不清楚的内容会标注出来并持续更新。</p>

      <nav class="prevnext" aria-label="常见问题导航">
        <a href={`/zh/faq/${prev.slug}`}>← 上一个</a>
        <a href="/zh/faq">所有常见问题</a>
        <a href={`/zh/faq/${next.slug}`}>下一个 →</a>
      </nav>
    </div>
  </article>

  <style>
    .cnote { font-size: 0.74rem; color: var(--faint); margin: 14px 0 0; }
    .prevnext { display: flex; justify-content: space-between; gap: 10px; margin: 18px 0 0; font-family: var(--mono); font-size: 0.8rem; }
    .prevnext a { color: var(--candle); }
  </style>
</Base>
