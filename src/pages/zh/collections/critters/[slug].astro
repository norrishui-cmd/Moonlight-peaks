---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';
import { critterDetailPages } from '../../../../data/collectionDetailPages';

export function getStaticPaths() {
  return critterDetailPages.map((entry, index) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      previous: critterDetailPages[index - 1],
      next: critterDetailPages[index + 1],
    },
  }));
}

const { entry, previous, next } = Astro.props;
const labelZh: Record<string, string> = {
  'Season': '季节', 'Location': '地点', 'Type': '类型', 'Sells for': '售价',
};
const fact = (label: string) => entry.facts.find((item: any) => item.label === label)?.value || '-';
const hasIcon = entry.icon.startsWith('/images/');
const pagePath = `/zh/collections/critters/${entry.slug}`;
const title = `${entry.name} — 月光峰小生物图鉴`;
const description = `月光峰"${entry.name}"的季节、地点、类型和售价一览。`;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
      { '@type': 'ListItem', position: 2, name: '收藏', item: `${SITE.url}/zh/collections` },
      { '@type': 'ListItem', position: 3, name: '小生物', item: `${SITE.url}/zh/collections/critters` },
      { '@type': 'ListItem', position: 4, name: entry.name, item: `${SITE.url}${pagePath}` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: `月光峰的${entry.name}在哪里能找到?`,
        acceptedAnswer: { '@type': 'Answer', text: `根据目前已确认的数据，地点是${fact('Location')}，出现在${fact('Season')}。标记为"-"的字段仍在实机中等待确认。` },
      },
      {
        '@type': 'Question',
        name: `${entry.name}值多少钱?`,
        acceptedAnswer: { '@type': 'Answer', text: `根据目前已确认的数据，售价为${fact('Sells for')}。` },
      },
    ],
  },
];
---
<Base
  title={title}
  description={description}
  path={pagePath}
  jsonLd={jsonLd}
  crumbs={[{ label: '收藏', href: '/zh/collections' }, { label: '小生物', href: '/zh/collections/critters' }, { label: entry.name }]}
  lang="zh"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">收藏 · 小生物</p>
      <section class="detail-hero">
        <div>
          <h1>{entry.name} <em>(小生物)</em></h1>
          <p class="intro">
            月光峰小生物{entry.name}的详情页面，基于已确认的收藏数据表。未确认的数值会显示为
            <strong>-</strong>，直到在实机中得到确认。
          </p>
        </div>
        <div class="detail-icon" aria-hidden={!hasIcon}>
          {hasIcon ? <img src={entry.icon} alt={`${entry.name}图标`} loading="eager" /> : <span>暂无图标</span>}
        </div>
      </section>

      <section class="fact-grid" aria-label={`${entry.name}的数据`}>
        {entry.facts.map((item: any) => (
          <div class="fact-card">
            <span>{labelZh[item.label] ?? item.label}</span>
            <strong>{item.value}</strong>
          </div>
        ))}
      </section>

      <h2>关于{entry.name}</h2>
      <p>
        {entry.name}出现在月光峰目前已知的小生物收藏数据中。季节、地点、类型和售价——都在这
        一页里。
      </p>
      <p>
        用途备注: <strong>{entry.use}</strong>。标记为"-"的字段，说明提供的截图资料里尚未显示
        已确认的数值。
      </p>
      <p class="source-note">
        资料来源说明:本页使用已确认的月光峰小生物收藏数据表，随着新的官方或实机数据确认后会
        持续扩充。
      </p>

      <h2>相关页面</h2>
      <div class="related-grid">
        <a href="/zh/collections/critters">小生物列表</a>
        <a href="/zh/collections">收藏中心</a>
      </div>

      <nav class="detail-nav" aria-label="小生物详情导航">
        {previous ? <a href={`/zh/collections/critters/${previous.slug}`}>← {previous.name}</a> : <span />}
        {next ? <a href={`/zh/collections/critters/${next.slug}`}>{next.name} →</a> : <span />}
      </nav>
    </div>
  </article>
  <style>
    .detail-hero {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 20px;
      align-items: start;
    }
    .detail-icon {
      width: 140px;
      height: 140px;
      border-radius: 16px;
      border: 1px solid var(--line);
      background: var(--surface);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .detail-icon img { width: 100%; height: 100%; object-fit: contain; }
    .detail-icon span { color: var(--faint); font-size: 0.7rem; text-transform: uppercase; }
    .fact-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
      margin: 18px 0 28px;
    }
    .fact-card {
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--surface);
      padding: 14px;
    }
    .fact-card span {
      display: block;
      color: var(--candle);
      font-family: var(--mono);
      font-size: 0.68rem;
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    .fact-card strong { color: var(--text); font-size: 1rem; }
    .related-grid, .detail-nav {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 10px;
      margin-top: 12px;
    }
    .source-note { border-left: 3px solid var(--candle); padding-left: 14px; color: var(--muted); }
    .related-grid a, .detail-nav a {
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 12px 14px;
      background: var(--surface);
      color: var(--candle);
      font-family: var(--mono);
      text-decoration: none;
    }
    @media (max-width: 640px) {
      .detail-hero { grid-template-columns: 1fr; }
      .detail-icon { width: 112px; height: 112px; }
    }
  </style>
</Base>
