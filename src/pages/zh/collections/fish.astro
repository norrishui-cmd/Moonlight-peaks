---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { fishDetailPages } from '../../../data/collectionDetailPages';

const faq = [
  { q: '月光峰的第一根鱼竿怎么获得?', a: '确认:游戏开始后几天内会在河边遇到Noel。他会向你发起挑战，比他先钓到3种不同的鱼——没有时间限制，很容易赢——赢了之后会获得鱼竿和一笔金币奖励。' },
  { q: '月光峰一共有多少种鱼?', a: '确认:22种。每种都有基础售价和恢复的能量值，两者在1星、2星品质下都会提升。下方列表可以查看每种鱼的详细页面。' },
  { q: '月光峰能钓到什么鱼受什么影响?', a: '确认:地点、季节、天气和时间段都会影响当时能钓到的鱼。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '收藏', item: `${SITE.url}/zh/collections` },
    { '@type': 'ListItem', position: 3, name: '鱼类', item: `${SITE.url}/zh/collections/fish` },
  ] },
];
---
<Base
  title="月光峰鱼类 — 约22种鱼与第一根鱼竿的获取方式"
  description="月光峰已确认的钓鱼信息:如何从Noel那里获得第一根鱼竿、约22种鱼、品质分级，以及影响能钓到什么鱼的因素。"
  path="/zh/collections/fish"
  jsonLd={jsonLd}
  crumbs={[{ label: '收藏', href: '/zh/collections' }, { label: '鱼类' }]}
  lang="zh"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">收藏 · 鱼类</p>
      <h1>月光峰的<em>鱼类</em></h1>
      <p class="intro">
        经两个独立的发售周信源确认:钓鱼系统基于一份真实存在、约22种的收藏名单，能钓到什么
        取决于地点、时间段和天气。
      </p>

      <h2>获得第一根鱼竿</h2>
      <p>
        确认:游戏开始几天内，你会在河边遇到<a href="/characters/noel">Noel</a>。他会向你发起
        挑战，比他先钓到3种不同的鱼——没有时间限制，很容易赢——赢了之后会获得第一根鱼竿和一笔
        金币奖励。
      </p>

      <h2>鱼类种类与变化因素</h2>
      <p>
        确认:收藏名单大约有22种。能钓到哪种取决于地点、季节、天气和时间段，所以某个夜晚没找到
        的鱼，可能只是在等条件凑齐，而不是游戏里根本没有这种鱼。
      </p>

      <h2>品质分级</h2>
      <p>
        确认:每种鱼都有基础售价和食用后恢复的基础能量值，两者在1星、2星品质下都会提升——即使
        是同一种鱼，积极追求更高品质的渔获也是值得的。
      </p>

      <h2>鱼类图鉴(全22种)</h2>
      <p>点击每种鱼，可以查看它的生息地、稀有度、出现时间段、体型和售价详情页面。</p>
      <ul class="fish-link-list">
        {fishDetailPages.map((f) => (
          <li><a href={`/zh/collections/fish/${f.slug}`}>{f.name}</a></li>
        ))}
      </ul>

      <h2>常见问题</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        相关页面: <a href="/zh/collections">收藏中心</a>、<a href="/zh/activities">钓鱼活动</a>、
        <a href="/characters/noel">Noel</a>、<a href="/items/cooking">烹饪</a>。
      </div>
    </div>
  </article>

  <style>
    .fish-link-list {
      list-style: none; padding: 0; margin: 12px 0 24px;
      display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 8px;
    }
    .fish-link-list a {
      display: block; border: 1px solid var(--line); border-radius: 10px; padding: 8px 12px;
      background: var(--surface); color: var(--candle); text-decoration: none; font-size: 0.88rem;
    }
    .fish-link-list a:hover { border-color: color-mix(in srgb, var(--candle) 54%, var(--line)); }
  </style>
</Base>
