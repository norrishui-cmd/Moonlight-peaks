---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { critterDetailPages } from '../../../data/collectionDetailPages';

const faq = [
  { q: '月光峰的小生物有什么用?', a: '确认:捕获的小生物(以及鱼)可以作为家里的装饰摆放——稀有或可爱的品种，值得留下而不是卖掉。' },
  { q: '月光峰的小生物会随季节变化吗?', a: '会，确认:和钓鱼一样，季节和天气会决定出现哪些虫子和小生物。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '收藏', item: `${SITE.url}/zh/collections` },
    { '@type': 'ListItem', position: 3, name: '小生物', item: `${SITE.url}/zh/collections/critters` },
  ] },
];
---
<Base
  title="月光峰小生物 — 捕获、季节与家居装饰"
  description="确认:月光峰的小生物和虫子会随季节和天气变化，捕获后可以作为家居装饰摆放。"
  path="/zh/collections/critters"
  jsonLd={jsonLd}
  crumbs={[{ label: '收藏', href: '/zh/collections' }, { label: '小生物' }]}
  lang="zh"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">收藏 · 小生物</p>
      <h1>月光峰的<em>小生物</em></h1>
      <p class="intro">
        经早期进度攻略确认:捕获的虫子和小生物不只是用来出售和烹饪的——捕获到的每一种都可以
        作为家居装饰摆放。
      </p>

      <h2>捕获小生物</h2>
      <p>
        确认:抓虫子很快就能上手，但容易挥空，小生物移动很快，挥空会消耗体力。和钓鱼一样，
        出现的虫子会随季节和天气变化，所以某个夜晚没找到的小生物，可能只是在等条件凑齐。
      </p>

      <h2>作为装饰摆放</h2>
      <p>
        确认:稀有或可爱的品种值得留下而不是卖掉——无论是鱼还是虫子，捕获到的生物都可以摆放
        在家里作为装饰品。装饰相关内容请参见<a href="/zh/farm/house">你的房屋</a>页面。
      </p>

      <h2>小生物图鉴</h2>
      <p>点击每个条目，可以查看季节、栖息地、类型和售价详情页面。标记为"-"的字段尚未确认。</p>
      <ul class="fish-link-list">
        {critterDetailPages.map((c) => (
          <li><a href={`/zh/collections/critters/${c.slug}`}>{c.name}</a></li>
        ))}
      </ul>

      <h2>目前仍在核实的信息</h2>
      <ul>
        <li>下方详情页中标记为"-"的出现地点、季节和天气。</li>
        <li>除了展示以外，小生物能不能作为礼物赠送或出售。</li>
      </ul>

      <h2>常见问题</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        相关页面: <a href="/zh/collections">收藏中心</a>、<a href="/environment">环境</a>、
        <a href="/map">地图</a>、<a href="/zh/activities">活动</a>。
      </div>
    </div>
  </article>

  <style>
    .fish-link-list {
      list-style: none; padding: 0; margin: 12px 0 24px;
      display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 8px;
    }
    .fish-link-list a {
      display: block; border: 1px solid var(--line); border-radius: 10px; padding: 8px 12px;
      background: var(--surface); color: var(--candle); text-decoration: none; font-size: 0.88rem;
    }
    .fish-link-list a:hover { border-color: color-mix(in srgb, var(--candle) 54%, var(--line)); }
  </style>
</Base>
