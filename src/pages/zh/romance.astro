---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';
import YouTube from '../../components/YouTube.astro';
import { characters, typeLabels } from '../../data/characters';

const familyNameZh: Record<string, string> = {
  'Vampire (Ambrosia)': '吸血鬼 · 安布罗西亚家族',
  'Vampire (Dracula)': '吸血鬼 · 德古拉家族',
  'Witch (Webb)': '女巫 · 韦伯家族',
  'Werewolf (Logan)': '狼人 · 洛根家族',
  'Mermaid (Hosu)': '美人鱼 · 侯苏家族',
  'Seer (Khazan)': '先知 · 卡赞家族',
  'Human (Henderson)': '人类 · 亨德森家族',
  'Unknown': '不属于任何家族',
};
const typeZh: Record<string, string> = {
  vampire: '吸血鬼', werewolf: '狼人', witch: '女巫', mermaid: '美人鱼',
  seer: '先知', ghost: '幽灵', human: '人类', other: '其他',
};

const romanceable = characters.filter((c) => c.romanceable === true);
const groups = new Map<string, typeof romanceable>();
for (const c of romanceable) {
  const key = c.family || 'Unknown';
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(c);
}
const familyGroups = [...groups.entries()].sort((a, b) => b[1].length - a[1].length);

const statusZh: Record<string, string> = { confirmed: '已确认', reported: '已报道', datamined: '数据挖掘', unconfirmed: '未确认' };

const faq = [
  { q: 'Moonlight Peaks 里有多少可攻略角色?', a: '发售时官方公布确认为 23 位——早期报道曾提到 15 位左右,说明这个数字在开发过程中涨了不少。分布在六大家族(安布罗西亚、韦伯、洛根、侯苏、卡赞、亨德森),外加两位不属于任何家族的"编外"角色:Death 和爱情恶魔 Llemi。' },
  { q: '什么好感度可以开始约会、什么时候能求婚?', a: '已确认:好感度达到 4 级解锁约会;达到 8 级可以求婚。求婚后一周内举行婚礼,镇上的吸血鬼和狼人都会来参加。' },
  { q: '可以同时和多个角色约会吗?', a: '可以,已确认。同时追求多人的话,对方会察觉并吐槽你,不过只是轻微的"吃醋",不是硬性的竞争机制。正式结婚后则是严格一对一。' },
  { q: '拒绝约会邀请太多次会怎样?', a: '已确认:如果经常拒绝对方的约会邀请,会导致分手,对方会先冷淡你几天,之后才会重新原谅你。' },
  { q: 'Moonlight Peaks 里能结婚吗?能生孩子吗?', a: '可以结婚,结婚后配偶会搬进你的农场,并解锁一段新的专属剧情;还能把配偶变成吸血鬼。但游戏里没有生育系统——多个信息源确认,且开发商暂无相关计划。娶像 Orlock 这样已有孩子的角色,据报道会让你成为继父/继母。' },
  { q: '恋爱对象受性别限制吗?', a: '不受限制。约会系统完全性别中立,不管你怎么捏自己的吸血鬼角色,都能追求任何一位可攻略居民。' },
  { q: '吸血鬼能和狼人谈恋爱吗?', a: '可以。镇上的吸血鬼和狼人关系一向不太好,经常拌嘴,所以追求像 Saga 这样的狼人角色,意味着要跨越这层隔阂——这也是乐趣所在。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '恋爱攻略', item: `${SITE.url}/zh/romance` },
  ] },
];
---
<Base
  title="Moonlight Peaks 恋爱攻略——23位可攻略角色与结婚系统"
  description="Moonlight Peaks 恋爱系统全解:确认的23位可攻略角色、性别中立约会、好感度4级解锁约会/8级可求婚、结婚(无子女)与七大家族。"
  path="/zh/romance"
  jsonLd={jsonLd}
  crumbs={[{ label: '恋爱与家族' }]}
  lang="zh"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">词条 · 恋爱</p>
      <h1>Moonlight Peaks <em>恋爱系统</em>与七大家族</h1>
      <p class="intro">
        恋爱是 {GAME.title} 的招牌玩法之一:确认的 23 位可攻略角色、性别中立的恋爱系统、
        以及结婚(但没有孩子)。本页数据直接来自我们的角色数据库,角色信息更新后本页会自动同步。
        更新于 {SITE.updated}。
      </p>

      <div class="romance-video">
        <YouTube id="YFb9capELQw" title="Moonlight Peaks romance video" />
      </div>

      <h2>恋爱机制是怎么运作的</h2>
      <p>
        已确认:通过对话和送礼提升好感度,关系菜单会记录你最近送出的礼物和对方的反应。
        <strong>好感度 4 级</strong>解锁约会——约会是小游戏形式(比如按对方要求的颜色扎一束花),
        而不是被动过场动画。<strong>好感度 8 级</strong>解锁求婚;婚礼在求婚后一周内举行,
        镇上的吸血鬼和狼人都会来参加。
      </p>
      <p>
        可以同时追求多人——对方会察觉并吐槽,但只是轻微吃醋,不是硬性竞争;正式结婚后则严格一对一,
        经常拒绝约会邀请会导致分手(有几天冷静期)。婚后配偶会搬进你的农场,解锁新剧情,还能把配偶
        变成吸血鬼。建立关系还会解锁专属图纸和制作材料,不只是恋爱本身的回报。
      </p>

      <h2>从这里开始:规划你的恋爱路线</h2>
      <p>23 位候选、目前全网还没有完整的礼物/好感事件数据库,先锁定几位再深入,比想追遍全镇更实际:</p>
      <div class="rp-steps">
        <a class="rp-step" href="/tools/romance-match-quiz">
          <span class="rp-step-num">1</span>
          <strong>做个小测试</strong>
          <span>基于真实线索的趣味匹配,帮你缩小心动对象的范围。</span>
        </a>
        <a class="rp-step" href="/tools/families-explorer">
          <span class="rp-step-num">2</span>
          <strong>按家族浏览</strong>
          <span>查看全部23位可攻略角色的真实家族关系。</span>
        </a>
        <a class="rp-step" href="/tools/romance-planner">
          <span class="rp-step-num">3</span>
          <strong>建立候补名单</strong>
          <span>把你的选择和笔记私密保存在浏览器里。</span>
        </a>
        <a class="rp-step" href="/tools/gift-tracker">
          <span class="rp-step-num">4</span>
          <strong>记录你的送礼结果</strong>
          <span>官方礼物清单还没公开前,自己记录每次送礼的反应。</span>
        </a>
      </div>

      <h2>基本情况</h2>
      <p>
        23 位可攻略居民,分布在六大家族——吸血鬼(安布罗西亚)、狼人(洛根)、女巫(韦伯)、
        美人鱼(侯苏)、先知(卡赞)、人类(亨德森)——外加两位不属于任何家族的角色:Death 和爱情恶魔 Llemi。
        与各家族的关系预计会影响节日活动、礼物,以及哪些门会向你敞开。
      </p>

      <h2>全部23位可攻略角色,按家族分组</h2>
      <p>数据直接来自角色数据库——点击角色名查看完整档案(角色详情页目前为英文)。</p>
      {familyGroups.map(([family, members]) => (
        <div class="romance-family-group">
          <h3>{familyNameZh[family] || family} <span class="rf-count">({members.length}位)</span></h3>
          <table class="facts">
            <tr><th>角色</th><th>类型</th><th>确认状态</th></tr>
            {members.map((c) => (
              <tr>
                <td><a href={`/characters/${c.id}`}>{c.name}</a></td>
                <td>{typeZh[c.type] || typeLabels[c.type] || c.type}</td>
                <td>{statusZh[c.status] || c.status}</td>
              </tr>
            ))}
          </table>
        </div>
      ))}

      <h2>礼物攻略</h2>
      <p>
        大部分角色的完整礼物清单目前全网都还没公开——目前唯一确认的是 <strong>Saga</strong>
        (她最爱白葡萄酒)。查看她的<a href="/characters/saga">角色档案</a>了解详情,
        并可以用<a href="/tools/gift-tracker">送礼记录工具</a>记录你自己的发现。
      </p>

      <h2>常见问题</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        发售后词条,数据直接来自角色数据库。相关内容:
        <a href="/characters">全部角色</a>、<a href="/families">七大家族</a>、
        <a href="/zh/character-creator">角色创建(中文)</a>、<a href="/zh/beginner-guide">新手攻略(中文)</a>。
      </div>
    </div>
  </article>
  <style>
    .romance-family-group { margin: 20px 0; }
    .romance-family-group h3 { margin: 0 0 8px; }
    .rf-count { color: var(--muted); font-weight: 400; font-size: 0.85rem; }
    .rp-steps { display: grid; grid-template-columns: 1fr; gap: 10px; margin: 14px 0 24px; }
    @media (min-width: 640px) { .rp-steps { grid-template-columns: 1fr 1fr; } }
    .rp-step {
      display: flex; flex-direction: column; gap: 4px; border: 1px solid var(--line); border-radius: 14px;
      background: var(--surface); padding: 14px 16px; text-decoration: none; position: relative;
      transition: border-color .15s ease;
    }
    .rp-step:hover { border-color: color-mix(in srgb, var(--candle) 45%, var(--line)); }
    .rp-step-num {
      position: absolute; top: 12px; right: 14px; font-family: var(--mono); font-size: 0.7rem; color: var(--candle);
      border: 1px solid color-mix(in srgb, var(--candle) 40%, var(--line)); border-radius: 999px; width: 20px; height: 20px;
      display: flex; align-items: center; justify-content: center;
    }
    .rp-step strong { font-family: var(--display); font-weight: 600; font-size: 0.94rem; color: var(--mist); padding-right: 26px; }
    .rp-step span:last-child { font-size: 0.8rem; color: var(--faint); line-height: 1.4; }
    .romance-video { margin: clamp(1.6rem, 4vw, 2.6rem) 0 clamp(2rem, 5vw, 3rem); }
  </style>
</Base>
