---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';
import YouTube from '../../components/YouTube.astro';

const named = [
  { name: '德古拉伯爵', slug: 'count-dracula', family: '吸血鬼', note: '你的父亲。故事核心人物——不可攻略。', status: 'confirmed' },
  { name: 'Saga', slug: 'saga', family: '狼人', note: '开发商公开介绍过的居民,情绪状态会随满月变化。', status: 'reported' },
  { name: 'Mina', slug: 'mina', family: '—', note: '开发商公开介绍过的居民,恋爱状态待确认。', status: 'reported' },
  { name: 'Orlock', slug: 'orlock', family: '吸血鬼', note: '某个吸血鬼家族的家主。', status: 'reported' },
  { name: 'Luna', slug: 'luna', family: '女巫', note: '一位务农的女巫。', status: 'reported' },
  { name: '南瓜头', slug: 'pumpkin-head', family: '—', note: '镇上活动的戏剧主持人。', status: 'reported' },
  { name: 'Logan', slug: 'logan', family: '狼人', note: '住着一栋造型独特的狼人房子。', status: 'reported' },
  { name: 'Death', slug: 'death', family: '—', note: '数据挖掘发现的居民,有自己的家("Death 的小屋");恋爱状态纯属推测,未确认。', status: 'datamined' },
];

const faq = [
  { q: 'Moonlight Peaks 里有多少可攻略角色?', a: '大约两打(24 位左右)。早期报道曾提到 15 位,说明这个数字在开发过程中涨了不少,开发商也表示未来还想继续增加。' },
  { q: 'Moonlight Peaks 里能结婚吗?', a: '可以,你能和恋爱对象结婚。游戏里没有孩子这个设定。' },
  { q: '恋爱对象受性别限制吗?', a: '不受限制。角色模型刻意设计成性别中立,不管你怎么捏自己的吸血鬼角色,都能追求任何符合条件的居民。' },
  { q: '吸血鬼能和狼人谈恋爱吗?', a: '可以。镇上的吸血鬼和狼人关系一向不太好,经常拌嘴,所以追求像 Saga 这样的狼人角色,意味着要跨越这层隔阂——这也是乐趣所在。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '恋爱攻略', item: `${SITE.url}/zh/romance` },
  ] },
];
---
<Base
  title="Moonlight Peaks —— 恋爱与结婚:可攻略角色"
  description="Moonlight Peaks 的恋爱系统:约两打可攻略居民、性别中立的恋爱、结婚(无子女)、七大家族,以及目前已知的具名角色。"
  path="/zh/romance"
  jsonLd={jsonLd}
  crumbs={[{ label: '恋爱与家族' }]}
  lang="zh"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">词条 · 恋爱</p>
      <h1>Moonlight Peaks 的<em>恋爱</em>与七大家族</h1>
      <p class="intro">
        恋爱是 {GAME.title} 的招牌玩法之一:一整座住满超自然单身居民的小镇、性别中立的恋爱系统、
        以及结婚(但没有孩子)。这里汇总了目前已确认的信息,和那些要等正式版才能验证的内容分开说明。
      </p>

      <div class="romance-video">
        <YouTube id="YFb9capELQw" title="Moonlight Peaks romance video" />
      </div>

      <h2>从这里开始:规划你的恋爱路线</h2>
      <p>
        目前还没有确定的礼物清单或好感度机制,但在 {GAME.releaseLabel} 之前,有一套诚实可行的
        准备方式,按顺序分四步:
      </p>
      <div class="rp-steps">
        <a class="rp-step" href="/tools/romance-match-quiz">
          <span class="rp-step-num">1</span>
          <strong>做个小测试</strong>
          <span>基于真实线索的趣味匹配,帮你缩小心动对象的范围。</span>
        </a>
        <a class="rp-step" href="/previews/day-one-romance-route">
          <span class="rp-step-num">2</span>
          <strong>查看 Day-1 路线</strong>
          <span>看看哪些居民已经在数据挖掘文件里有了住址线索。</span>
        </a>
        <a class="rp-step" href="/tools/romance-planner">
          <span class="rp-step-num">3</span>
          <strong>建立候补名单</strong>
          <span>用恋爱追求追踪器把你的选择和笔记私密保存在浏览器里。</span>
        </a>
        <a class="rp-step" href="/previews/what-to-expect-from-romance-mechanics">
          <span class="rp-step-num">4</span>
          <strong>调整预期</strong>
          <span>开玩之前先弄清楚哪些是同类游戏惯例、哪些是真正确认的机制。</span>
        </a>
      </div>

      <h2>基本情况</h2>
      <p>
        小镇七大家族——吸血鬼、狼人、女巫、美人鱼等等——里分布着约两打可攻略居民。你可以和他们交朋友
        或谈恋爱,建立关系,最终步入婚姻。和各家族的关系预计会影响节日活动、礼物,以及哪些门会向你敞开。
      </p>

      <h2>目前已知的具名角色</h2>
      <p>目前只有德古拉伯爵是一手来源确认的故事核心人物;其余角色出现在开发商公开信息和发售前的报道里,会在正式发售时进一步核实。</p>
      <table class="facts">
        <tr><th>角色</th><th>家族 / 状态</th></tr>
        {named.map((c) => (
          <tr>
            <td><strong><a href={`/characters/${c.slug}`}>{c.name}</a></strong> {(c.status === 'reported' || c.status === 'datamined') && <span style="color:var(--faint);font-family:var(--mono);font-size:0.7rem">{c.status}</span>}<br /><span style="color:var(--muted);font-size:0.85rem">{c.note}</span></td>
            <td>{c.family === '—' ? '—' : c.family}</td>
          </tr>
        ))}
      </table>

      <h2>礼物攻略</h2>
      <p>
        每个角色喜欢/中意的礼物,会在 {GAME.releaseLabel} 正式版确认后公布,并做成一个礼物追踪工具。
        在游戏里得到验证之前,我们不会把任何礼物标注成"喜欢"。
      </p>

      <h2>常见问题</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        这是发售前的占位词条。正式发售后会升级成完整角色名单加礼物追踪工具。相关内容:
        <a href="/characters">全部角色</a>、<a href="/families">七大家族</a>、
        <a href="/zh/characters">角色(中文)</a>。
      </div>
    </div>
  </article>
</Base>
