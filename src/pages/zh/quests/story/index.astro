---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';
import { storyQuests } from '../../../../data/quests-story';
import { storyQuestsZh, storyChaptersZh } from '../../../../i18n/quests-story-zh';

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '任务攻略', item: `${SITE.url}/zh/quests` },
    { '@type': 'ListItem', position: 3, name: '主线任务', item: `${SITE.url}/zh/quests/story` },
  ],
};
---
<Base
  title="月光峰主线任务攻略 — 按章节划分"
  description="月光峰确认的主线任务，按5个章节整理，从初到小镇一直到婚礼篇章。已与多个发售周信源交叉验证。"
  path="/zh/quests/story"
  jsonLd={jsonLd}
  crumbs={[{ label: '任务攻略', href: '/zh/quests' }, { label: '主线任务' }]}
  lang="zh"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">任务 · 主线</p>
      <h1><em>主线任务</em>攻略</h1>
      <p class="intro">
        共{storyQuests.length}个主线任务，分为{storyChaptersZh.length}个章节。选择你目前所在的章节——
        每个章节内的任务都按确认的顺序排列。
      </p>

      {storyChaptersZh.map((ch) => {
        const quests = storyQuests.filter((q) => q.chapter === ch.number && storyQuestsZh[q.slug]);
        return (
          <section class="chapter">
            <div class="chapter-head">
              <span class="chapter-num">第{ch.number}章</span>
              <h2>{ch.title}</h2>
            </div>
            <p class="chapter-dek">{ch.dek}</p>
            <ol class="quest-list">
              {quests.map((q) => (
                <li>
                  <a href={`/zh/quests/story/${q.slug}`}>{storyQuestsZh[q.slug].title}</a>
                  {q.status === 'reported' && <span class="tag-community">据报告</span>}
                </li>
              ))}
            </ol>
          </section>
        );
      })}

      <div class="callout wip">
        信源已在发售周交叉验证(Neoseeker任务日志、Bonus Action、Output Lag、Into Indie Games)。
        相关: <a href="/zh/quests">任务中心</a>, <a href="/zh/quests/side">支线任务</a>。
      </div>
    </div>
  </article>

  <style>
    .chapter { margin: 26px 0; padding-top: 18px; border-top: 1px solid var(--line); }
    .chapter:first-of-type { border-top: none; padding-top: 0; }
    .chapter-head { display: flex; align-items: baseline; gap: 10px; }
    .chapter-num { font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--candle); white-space: nowrap; }
    .chapter-head h2 { margin: 0; }
    .chapter-dek { color: var(--muted); font-size: 0.92rem; margin: 4px 0 12px; }
    .quest-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; counter-reset: qnum; }
    .quest-list li { counter-increment: qnum; padding: 8px 0; border-bottom: 1px dashed var(--line); display: flex; align-items: center; gap: 8px; }
    .quest-list li::before { content: counter(qnum) "."; color: var(--faint); font-family: var(--mono); font-size: 0.8rem; }
    .quest-list a { color: var(--mist); text-decoration: none; flex: 1; }
    .quest-list a:hover { color: var(--candle); }
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 7px;
    }
  </style>
</Base>
