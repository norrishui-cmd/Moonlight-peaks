---
import Base from '../../../../layouts/Base.astro';
import { SITE, GAME } from '../../../../consts';
import { sideQuests } from '../../../../data/quests-side';
import { sideQuestsZh } from '../../../../i18n/quests-side-zh';

export function getStaticPaths() {
  const translated = sideQuests.filter((q) => sideQuestsZh[q.slug]);
  return translated.map((q, i) => ({
    params: { slug: q.slug },
    props: { q, prev: translated[(i - 1 + translated.length) % translated.length], next: translated[(i + 1) % translated.length] },
  }));
}

const { q, prev, next } = Astro.props as { q: (typeof sideQuests)[number]; prev: (typeof sideQuests)[number]; next: (typeof sideQuests)[number] };
const tr = sideQuestsZh[q.slug];
const statusLabel = q.status === 'confirmed' ? '已确认' : '据报告';
const troubleshooting = tr.troubleshooting || [];
const allFaq = [...troubleshooting, { q: `"${tr.title}"是什么?`, a: tr.summary }];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: allFaq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '任务攻略', item: `${SITE.url}/zh/quests` },
    { '@type': 'ListItem', position: 3, name: '支线任务', item: `${SITE.url}/zh/quests/side` },
    { '@type': 'ListItem', position: 4, name: tr.title, item: `${SITE.url}/zh/quests/side/${q.slug}` },
  ] },
];
---
<Base
  title={`${tr.title} — 月光峰攻略`}
  description={`${GAME.title}"${tr.title}": ${(troubleshooting[0]?.q || tr.summary).slice(0, 100)}`}
  path={`/zh/quests/side/${q.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: '任务攻略', href: '/zh/quests' }, { label: '支线任务', href: '/zh/quests/side' }, { label: tr.title }]}
  lang="zh"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">支线任务 · <span class="tag-community">{statusLabel}</span></p>
      <h1>{tr.title}</h1>
      <p class="intro">{tr.summary}</p>

      {tr.reward && (
        <div class="callout">
          <strong>奖励:</strong> {tr.reward}
        </div>
      )}

      {troubleshooting.length > 0 && (
        <>
          <h2>卡关了?检查这些</h2>
          <div class="faq">
            {troubleshooting.map((f) => (
              <details open>
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))}
          </div>
        </>
      )}

      <nav class="prevnext" aria-label="支线任务导航">
        <a href={`/zh/quests/side/${prev.slug}`}>← {sideQuestsZh[prev.slug].title}</a>
        <a href="/zh/quests/side">所有支线任务</a>
        <a href={`/zh/quests/side/${next.slug}`}>{sideQuestsZh[next.slug].title} →</a>
      </nav>
    </div>
  </article>

  <style>
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 7px;
      vertical-align: middle;
    }
    .prevnext { display: flex; justify-content: space-between; gap: 10px; margin: 22px 0; font-family: var(--mono); font-size: 0.82rem; }
    .prevnext a { color: var(--candle); }
  </style>
</Base>
