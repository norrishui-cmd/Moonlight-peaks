---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';
import { cropDetailsJa } from '../../../../data/farm-crop-details-ja';

export function getStaticPaths() {
  return Object.entries(cropDetailsJa).map(([slug, data]) => ({ params: { slug }, props: { slug, data } }));
}

const { slug, data } = Astro.props as { slug: string; data: (typeof cropDetailsJa)[string] };

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: data.faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: '農場', item: `${SITE.url}/ja/farm` },
    { '@type': 'ListItem', position: 3, name: '作物', item: `${SITE.url}/ja/farm/crops` },
    { '@type': 'ListItem', position: 4, name: data.name, item: `${SITE.url}/ja/farm/crops/${slug}` },
  ] },
];
---
<Base
  title={`${data.name} — Moonlight Peaks 作物ガイド`}
  description={data.dek}
  path={`/ja/farm/crops/${slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: '農場', href: '/ja/farm' }, { label: '作物', href: '/ja/farm/crops' }, { label: data.name }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">農場 · {data.category}</p>
      <h1><em>{data.name}</em></h1>
      <p class="intro">{data.dek}</p>

      {data.body.map((p) => (<p>{p}</p>))}

      <h2>よくある質問</h2>
      <div class="faq">
        {data.faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        公式Moonlight Peaks Wikiより。関連ページ:
        <a href="/ja/farm/crops">全作物一覧</a>、<a href="/ja/farm">農場ハブ</a>、
        <a href="/ja/farm/farm-helpers">ファームヘルパー</a>。
      </div>
    </div>
  </article>
</Base>
