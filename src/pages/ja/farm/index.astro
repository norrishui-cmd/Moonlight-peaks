---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';

const entries = [
  { group: 'データベース', title: '作物', desc: '完全な作物データベース——30種類以上の農地作物、ハーブ園の植物、樹木作物を季節・魔法属性つきで掲載。', href: '/ja/farm/crops' },
  { group: '家', title: '家', desc: 'Howling Hammerで4回アップグレードできる家の仕組み。「Fix the Roof」クエストで解放。', href: '/ja/farm/house' },
  { group: '建物', title: '納屋', desc: '納屋の費用・広さ・解放方法——4,000ゴールド、10x6マス、動物4匹まで収容可能。', href: '/ja/farm/barn' },
  { group: '建物', title: '温室', desc: '温室の拡張について現時点で確認されている情報。', href: '/ja/farm/greenhouse' },
  { group: '生物', title: '動物', desc: '確認済みの動物一覧、飼い方、餌やり、生産物について。', href: '/ja/farm/animals' },
  { group: '設備', title: 'ファームヘルパー', desc: '確認済みの加工設備16種類全て——炉、樽、精製機などをレシピつきで掲載。', href: '/ja/farm/farm-helpers' },
];

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: '農場', item: `${SITE.url}/ja/farm` },
  ],
};
---
<Base
  title="Moonlight Peaks 農場 — 作物・家・納屋・温室・動物"
  description="Moonlight Peaksの農場セクションを日本語で:作物、家の拡張、納屋、温室、家畜、ファームヘルパー設備——すべて公式wikiに基づいています。"
  path="/ja/farm"
  jsonLd={jsonLd}
  crumbs={[{ label: '農場' }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">ハブ・農場</p>
      <h1>{GAME.title}の<em>農場</em></h1>
      <p class="intro">
        自分の農場を発展させるための情報——何を育てるか、家や納屋がどう拡張するか、農場を支える
        動物や設備について。以下の内容の多くは公式Moonlight Peaks Wikiから直接引用しています。
      </p>

      <div class="itg">
        {entries.map((e) => (
          <a class="itcard" href={e.href}>
            <span class="itgroup">{e.group}</span>
            <h3>{e.title}</h3>
            <p>{e.desc}</p>
          </a>
        ))}
      </div>

      <div class="callout wip">
        関連ページ: <a href="/ja/farming">農業ガイド</a>、<a href="/ja/locations">ロケーション</a>、
        <a href="/ja/items">アイテム</a>、<a href="/farm">英語版(詳細)</a>。
      </div>
    </div>
  </article>

  <style>
    .itg { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 6px 0 18px; }
    @media (min-width: 640px) { .itg { grid-template-columns: 1fr 1fr; } }
    @media (min-width: 980px) { .itg { grid-template-columns: 1fr 1fr 1fr; } }
    .itcard {
      display: block; border: 1px solid var(--line); border-radius: 14px;
      background: var(--surface); padding: 14px; color: inherit; text-decoration: none;
      transition: border-color .15s ease, transform .15s ease;
    }
    .itcard:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); transform: translateY(-2px); }
    .itgroup { font-family: var(--mono); color: var(--faint); text-transform: uppercase; letter-spacing: 0.04em; font-size: 0.62rem; }
    .itcard h3 { font-family: var(--display); font-weight: 600; font-size: 1rem; margin: 4px 0 6px; }
    .itcard p { color: #ded3e6; font-size: 0.84rem; margin: 0 0 10px; }
  </style>
</Base>
