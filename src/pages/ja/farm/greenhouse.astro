---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const faq = [
  { q: 'Moonlight Peaksで温室は何をしますか?', a: 'コミュニティ報告:保護された追加の栽培スペースを提供します。屋外の畑がいっぱいになった時や、魔法作物用のスペースが欲しい時に便利です。正確な建設費用、解放条件、栽培ルールを変えるかどうかはここではまだ独自に確認できていません。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: '農場', item: `${SITE.url}/ja/farm` },
    { '@type': 'ListItem', position: 3, name: '温室', item: `${SITE.url}/ja/farm/greenhouse` },
  ] },
];
---
<Base
  title="Moonlight Peaks 温室 — 現時点で確認されていること"
  description="Moonlight Peaksの温室について確認されていること:保護された追加の栽培スペース。推測せず、正直に現状を掲載しています。"
  path="/ja/farm/greenhouse"
  jsonLd={jsonLd}
  crumbs={[{ label: '農場', href: '/ja/farm' }, { label: '温室' }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">農場・温室</p>
      <h1><em>温室</em></h1>
      <p class="intro">
        コミュニティ報告:温室は保護された追加の栽培スペースを提供する農場拡張です。既存の畑が
        いっぱいになった時に便利とされています。それ以上の建設費用、解放条件、農業をどう変える
        かについては独自に確認できていないため、推測せずこのページは短く留めています。
      </p>

      <h2>現在確認中の情報</h2>
      <ul>
        <li>建設費用と必要な素材。</li>
        <li>解放するクエストやストーリーの節目(もしあれば)。</li>
        <li>季節を変えるか、天候から保護するか。</li>
        <li>実際にどれくらいの栽培スペースが追加されるか。</li>
      </ul>

      <h2>よくある質問</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        実際の温室データが確認され次第、このページを更新します。関連ページ:
        <a href="/ja/farm">農場ハブ</a>、<a href="/ja/farm/crops">作物</a>、<a href="/ja/farm/house">家</a>。
      </div>
    </div>
  </article>
</Base>
