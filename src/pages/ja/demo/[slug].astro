---
import TopicPage from '../../../components/TopicPage.astro';
import { demoSection, demo } from '../../../data/demo';
import { demoJa } from '../../../i18n/demo-ja';

export function getStaticPaths() {
  const translated = demo.filter((it) => demoJa[it.slug]);
  return translated.map((it, i) => {
    const tr = demoJa[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...translated[(i - 1 + translated.length) % translated.length], ...demoJa[translated[(i - 1 + translated.length) % translated.length].slug] },
        next: { ...translated[(i + 1) % translated.length], ...demoJa[translated[(i + 1) % translated.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const jaSection = { ...demoSection, base: '/ja/demo', label: 'デモ', eyebrow: 'デモ' };
---
<TopicPage section={jaSection} item={item} prev={prev} next={next} lang="ja" basePath="/ja/demo" />
