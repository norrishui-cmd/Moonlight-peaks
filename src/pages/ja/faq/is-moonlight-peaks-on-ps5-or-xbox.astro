---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'ムーンライト・ピークスはPS5やXboxでプレイできますか?',
    acceptedAnswer: { '@type': 'Answer', text: '結論から言うと、いいえ。PlayStationやXbox版は現時点で発表されていません。確認済みの対応プラットフォームはSteam、Steam Deck、Nintendo Switch、Nintendo Switch 2、Androidです。' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: `${SITE.url}/ja/faq` },
  ] },
];
---
<Base
  title="ムーンライト・ピークスはPS5やXboxでプレイできますか?"
  description="いいえ——ムーンライト・ピークスはPS5やXboxに対応していません。確認済みの対応プラットフォームはSteam、Steam Deck、Switch、Switch 2、Androidです。"
  path="/ja/faq/is-moonlight-peaks-on-ps5-or-xbox"
  jsonLd={jsonLd}
  crumbs={[{ label: 'FAQ', href: '/ja/faq' }, { label: 'PS5/Xbox' }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">FAQ</p>
      <h1>ムーンライト・ピークスは<em>PS5やXbox</em>でプレイできますか?</h1>
      <p class="intro">
        結論から言うと、いいえ。PlayStationやXbox版は現時点で発表されていません。確認済みの
        対応プラットフォームはSteam、Steam Deck、Nintendo Switch、Nintendo Switch 2、Androidです。
      </p>
      <p>今後PS5やXbox版が発表された場合は、このページを更新します。</p>
      <div class="callout wip">
        関連: <a href="/ja/platforms">対応機種ガイド</a>、<a href="/ja/release-date">発売日</a>。
      </div>
    </div>
  </article>
</Base>
