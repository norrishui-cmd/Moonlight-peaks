---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'ムーンライト・ピークスはマルチプレイ対応ですか?',
    acceptedAnswer: { '@type': 'Answer', text: 'いいえ——ムーンライト・ピークスは完全なシングルプレイヤーゲームです。マルチプレイやCo-opは発表されておらず、Steamでもシングルプレイヤーとして掲載されています。' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: `${SITE.url}/ja/faq` },
  ] },
];
---
<Base
  title="ムーンライト・ピークスはマルチプレイ対応ですか?"
  description="いいえ——ムーンライト・ピークスは完全なシングルプレイヤーゲームです。マルチプレイやCo-opは発表されていません。"
  path="/ja/faq/is-moonlight-peaks-multiplayer"
  jsonLd={jsonLd}
  crumbs={[{ label: 'FAQ', href: '/ja/faq' }, { label: 'マルチプレイ' }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">FAQ</p>
      <h1>ムーンライト・ピークスは<em>マルチプレイ</em>対応ですか?</h1>
      <p class="intro">
        いいえ——ムーンライト・ピークスは完全なシングルプレイヤーゲームです。マルチプレイや
        Co-opは発表されておらず、Steamでもシングルプレイヤーとして掲載されています。あるプレイヤーが
        Steamコミュニティのディスカッションで開発者に直接オンラインCo-opについて質問しましたが、
        確認は得られませんでした。
      </p>
      <div class="callout wip">
        関連: <a href="/ja/platforms">対応機種ガイド</a>。
      </div>
    </div>
  </article>
</Base>
