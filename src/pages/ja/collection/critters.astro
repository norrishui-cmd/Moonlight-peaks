---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const faq = [
  { q: 'Moonlight Peaksで小動物は何に使えますか?', a: '確認済み:捕まえた小動物(や魚)は家の装飾として飾ることができます——珍しいものや可愛いものは売らずに取っておく価値があります。' },
  { q: 'Moonlight Peaksで小動物は季節によって変わりますか?', a: 'はい、確認済み:釣りと同様、季節と天候によって異なる虫や小動物が出現します。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: 'コレクション', item: `${SITE.url}/ja/collection` },
    { '@type': 'ListItem', position: 3, name: '小動物', item: `${SITE.url}/ja/collection/critters` },
  ] },
];
---
<Base
  title="Moonlight Peaks 小動物 — 捕獲、季節、家の装飾"
  description="確認済み:Moonlight Peaksの小動物や虫は季節と天候によって変化し、捕まえたものは家の装飾として飾ることができます。"
  path="/ja/collection/critters"
  jsonLd={jsonLd}
  crumbs={[{ label: 'コレクション', href: '/ja/collection' }, { label: '小動物' }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">コレクション・小動物</p>
      <h1>Moonlight Peaksの<em>小動物</em></h1>
      <p class="intro">
        序盤の進行ガイドで確認済み:捕まえた虫や小さな生き物は売却や料理だけのものではありません
        ——捕まえたものはどれも家の装飾として飾ることができます。
      </p>

      <h2>小動物の捕獲</h2>
      <p>
        確認済み:虫取りはすぐに覚えられますが失敗しやすく、小動物は素早く動くため空振りすると
        エネルギーを消費します。釣りと同様、季節と天候によって出現する虫が変わるため、ある夜に
        見つからない小動物も、単に条件が揃うのを待っているだけかもしれません。
      </p>

      <h2>装飾として飾る</h2>
      <p>
        確認済み:珍しいものや可愛いものは売らずに取っておく価値があります——魚や虫を問わず、
        捕まえた生き物はどれも家の中に装飾品として置くことができます。装飾については
        <a href="/ja/farm/house">あなたの家</a>のページをご覧ください。
      </p>

      <h2>現在確認中の情報</h2>
      <ul>
        <li>小動物ごとの完全な出現場所一覧。</li>
        <li>種類ごとの完全な季節・天候ルール。</li>
        <li>展示以外に、小動物を贈ったり売ったりできるか。</li>
      </ul>

      <h2>よくある質問</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        関連ページ: <a href="/ja/collection">コレクションハブ</a>、<a href="/environment">環境</a>、
        <a href="/map">マップ</a>、<a href="/ja/activities">アクティビティ</a>。
      </div>
    </div>
  </article>
</Base>
