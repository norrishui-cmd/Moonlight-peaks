---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const faq = [
  { q: 'Moonlight Peaksでコウモリに変身できますか?', a: 'はい、確認済みです。吸血鬼として、コウモリに変身できます。夜の町を素早く移動する手段です。' },
  { q: 'ヘルキティ(Hellkitten)形態とは何ですか?', a: '確認済み:三つ目のヘルキティの相棒にも変身できます。ヘルキティ形態では移動速度が上がり、シャベルなしで畑を耕せます(消費エネルギーはごく僅か)。' },
  { q: '他にどんな姿に変身できますか?', a: '現在確認されているのはコウモリとヘルキティの2種類のみです。開発元は他にも姿があると示唆していますが、完全なリストはまだ公開されていません。' },
  { q: '変身はどうやって解放されますか?', a: '確認済み:ヘルキティ形態の解放には4つのクエスト——「A Bridge Too Far」「Tension in the Crest Garden」「A Croak and a Crest」「The Dinner Party」——のクリアが必要です。解放後は魔法ホイール(左肩ボタン)で形態を切り替えます。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: '変身', item: `${SITE.url}/ja/shapeshifting` },
  ] },
];
---
<Base
  title="Moonlight Peaks — 変身:コウモリとその他の姿"
  description="Moonlight Peaksの変身の仕組み:夜に移動するためのコウモリへの変身、開発元がほのめかしている他の姿、吸血鬼の力との関係。"
  path="/ja/shapeshifting"
  jsonLd={jsonLd}
  crumbs={[{ label: '変身' }]}
  lang="ja"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">エントリー・変身</p>
      <h1>Moonlight Peaksの<em>変身</em></h1>
      <p class="intro">
        {GAME.title}で吸血鬼であることの特典の一つが、姿を変えられることです。変身について実際に
        確認されていること、そして開発元がこれまでほのめかしているだけのことをまとめました。
        最終更新:{SITE.updated}。
      </p>

      <h2>コウモリになって移動する</h2>
      <p>
        確認されている代表的な姿は、定番の吸血鬼コウモリです。コウモリに変身すると夜の町を素早く
        飛び回ることができ、日の出前に農作業や用事、人付き合いをこなす際に便利です。
      </p>

      <h2>ヘルキティ形態——移動速度アップと無料の耕作</h2>
      <p>
        確認済み:4つのクエスト——「A Bridge Too Far」「Tension in the Crest Garden」
        「A Croak and a Crest」「The Dinner Party」——をクリアすると、三つ目の
        <strong>ヘルキティ</strong>の相棒に変身できるようになります。ヘルキティ形態では
        マップ上の移動が明らかに速くなり、Yボタンを押すとシャベルなしで畑を耕せます
        (消費エネルギーはごく僅か)——見た目だけでなく実用的な形態です。
      </p>

      <h2>他の姿もほのめかされている</h2>
      <p>
        開発スタジオは、コウモリとヘルキティ以外の姿にも変身できるようになると予告していますが、
        完全なセットとそれぞれの用途については、まだ詳しく明らかにされていません。
      </p>

      <h2>吸血鬼の力の一部</h2>
      <p>
        変身は他の超自然的な能力と並んで存在し、町のあらゆる魅力を探索する助けになります。
        <a href="/magic">魔術やポーション</a>とも自然に組み合わさります——そしてあなたの
        (不)生活の他の全てと同じく、日が昇る前に棺に戻るというルールの中で機能します。
      </p>

      <h2>現在確認中の情報</h2>
      <ul>
        <li>コウモリ以外に取れる<strong>姿の完全なリスト</strong>。</li>
        <li>各形態がどう<strong>解放</strong>され、何に役立つか。</li>
        <li>エネルギー、タイミング、変身できる場所・できない場所などの制限。</li>
      </ul>

      <h2>よくある質問</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        発売後のエントリー、実際のゲームデータで随時更新中。関連ページ:
        <a href="/magic">魔法とポーション</a>、<a href="/character-creator">キャラクター作成</a>、
        <a href="/ja/beginner-guide">初心者ガイド</a>(日本語)。
      </div>
    </div>
  </article>
</Base>
