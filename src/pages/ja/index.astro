---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const entries = [
  { title: '発売日と対応機種', desc: '7月7日にSteam、Switch、Switch 2、Androidで配信開始。価格と無料体験版情報。', href: '/release-date', img: '/card-release.webp' },
  { title: '初心者ガイド', desc: '最初の1週間で本当に重要なこと——正式版から確認した情報。', href: '/beginner-guide', img: '/card-guide.webp' },
  { title: '恋愛と家族', desc: '23人の確認済み恋愛対象、7つの家族、好みの贈り物。', href: '/romance', img: '/card-romance.webp' },
  { title: '農業とファーム', desc: 'ブラッドグレープ、バーン、魔法の家畜——確認済みデータ。', href: '/farming', img: '/card-crops.webp' },
  { title: '魔法システム', desc: '壊れた杖の直し方、Moon Fruit、マナの進行。', href: '/magic', img: '/card-guide.webp' },
  { title: 'キャラクター', desc: '住民全員の家族構成と、誰が恋愛対象になれるか。', href: '/characters', img: '/count-dracula.webp' },
  { title: 'ロケーション', desc: '町、農場、Howling Marshesなど確認済みの場所。', href: '/locations', img: '/hero-loc-town.webp' },
  { title: '既知の不具合', desc: 'クラッシュ、コントローラーの問題と確認済みの対処法。', href: '/known-issues', img: '/card-guide.webp' },
];

const explore = [
  { k: '恋愛システム', d: '好感度、デート、結婚の仕組み', href: '/romance', img: '/card-romance.webp' },
  { k: '家族', d: '町に住む7つの超自然的な家族', href: '/families', img: '/hero-fam-vampires.webp' },
  { k: 'アクティビティ', d: '釣り、魔法、手芸、のんびり過ごせる遊び', href: '/activities', img: '/hero-act-seasonal-events.webp' },
  { k: 'アイテム', d: '道具、ポーション、インテリアなどのカテゴリ', href: '/items', img: null, c1: '#3a4a2f', c2: '#8ab06a' },
  { k: 'よくある質問', d: 'よくある質問への簡潔な回答', href: '/faq', img: '/card-faq.webp' },
  { k: 'クエスト', d: '「A Bridge Too Far」など確認済みクエスト攻略', href: '/quests', img: '/hero-first-five-minutes.webp' },
];

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'WebSite', name: 'Moonlight Peaks Wiki & Guide（日本語）',
  url: `${SITE.url}/ja`, inLanguage: 'ja',
  description: 'ヴァンパイア・ライフシム「Moonlight Peaks」の日本語ファンガイド。発売情報、初心者ガイド、恋愛、既知の不具合。',
};
---
<Base
  title="「ムーンライト・ピークス -ヴァンパイアのゴシックライフ-」日本語攻略ガイド"
  description="ヴァンパイアのゴシックライフを描くコージーなライフシム「ムーンライト・ピークス」の日本語ファンガイド。7月8日(Steam)/7月9日(Switch)発売、配信中。初心者ガイド、恋愛、既知の不具合。"
  path="/ja"
  jsonLd={jsonLd}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">吸血鬼農家のフィールド暦</p>
      <h1><em>ムーンライト・ピークス -ヴァンパイアのゴシックライフ-</em>配信中。</h1>
      <p class="intro">
        {GAME.developer}が贈るヴァンパイア・ライフシムの、コージー・ゴシック系攻略ガイド。
        日本国内ではSteam版が2026年7月8日、Nintendo Switch/Switch 2版が7月9日に発売され、
        現在配信中です。パブリッシャーはクラウディッドレパードエンタテインメント。
        このガイドは実際のゲーム内容を随時確認しながら更新しています。
      </p>
      <p class="callout wip">
        この日本語版では、現時点で最も重要なページのみを掲載しています。その他のコンテンツ(記事、一部のキャラクタープロフィール)
        はまだ英語のみです——順次翻訳していきます。日本語版が用意されるまで、このページのリンクは英語ページへ移動します。
      </p>

      <h2>まずはここから</h2>
      <div class="es-grid">
        {entries.map((e) => (
          <a class="es-card" href={e.href}>
            <img src={e.img} alt="" loading="lazy" width="64" height="64" />
            <span>
              <strong>{e.title}</strong>
              <em>{e.desc}</em>
            </span>
          </a>
        ))}
      </div>

      <h2>世界を探索する</h2>
      <div class="es-grid">
        {explore.map((x) => (
          <a class="es-card" href={x.href}>
            <span class="es-thumb" style={!x.img ? `background: linear-gradient(135deg, ${x.c1}, ${x.c2})` : undefined}>
              {x.img ? <img src={x.img} alt="" loading="lazy" width="64" height="64" /> : <span class="es-thumb-letter">{x.k[0]}</span>}
            </span>
            <span>
              <strong>{x.k}</strong>
              <em>{x.d}</em>
            </span>
          </a>
        ))}
      </div>

      <h2>今、詰まっている人が多い問題</h2>
      <p class="trending-note">みんなが今まさに検索している内容</p>
      <ul class="trending-list">
        <li><a href="/ja/magic">壊れた杖の直し方</a></li>
        <li><a href="/ja/locations/mines">Cave of Echoesの解放方法</a></li>
        <li><a href="/ja/quests/side/ui-softlock-after-shop">店を出た後にUIが固まる問題</a></li>
        <li><a href="/ja/quests/side/lost-save-data">セーブデータが消えた時の対処法</a></li>
        <li><a href="/ja/quests/side/npc-stuck-cant-interact">NPCが固まって話しかけられない</a></li>
        <li><a href="/ja/quests/story/a-bridge-too-far">A Bridge Too Farクエスト攻略</a></li>
      </ul>
    </div>
  </article>

  <style>
    .page { padding: 32px 0 60px; }
    .eyebrow { font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--faint); }
    h1 { font-family: var(--display); font-size: 2rem; margin: 6px 0 14px; }
    h1 em { color: var(--candle); font-style: normal; }
    .intro { color: var(--muted); font-size: 1rem; line-height: 1.7; max-width: 640px; margin-bottom: 16px; }
    .callout.wip { border-left: 2px solid var(--candle); background: var(--ink-2); padding: 12px 16px; border-radius: 0 10px 10px 0; color: var(--muted); font-size: 0.88rem; margin: 0 0 32px; }
    h2 { font-family: var(--display); font-size: 1.3rem; margin: 28px 0 12px; }
    .es-grid { display: grid; grid-template-columns: 1fr; gap: 10px; }
    @media (min-width: 640px) { .es-grid { grid-template-columns: 1fr 1fr; } }
    .es-card { display: flex; align-items: center; gap: 12px; border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 12px; transition: border-color .15s ease; }
    .es-card:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); }
    .es-card img { border-radius: 10px; object-fit: cover; width: 64px; height: 64px; flex: 0 0 auto; }
    .es-thumb { flex: 0 0 auto; width: 64px; height: 64px; border-radius: 10px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--line); }
    .es-thumb-letter { font-family: var(--display); font-weight: 700; font-size: 1.4rem; color: rgba(255,255,255,0.9); }
    .es-card span:not(.es-thumb) { display: flex; flex-direction: column; min-width: 0; }
    .es-card strong { font-family: var(--display); font-weight: 600; font-size: 0.96rem; color: var(--mist); }
    .es-card em { font-style: normal; font-size: 0.8rem; color: var(--faint); margin-top: 2px; }
    .trending-note { font-size: 0.82rem; color: var(--faint); margin: 4px 0 0; }
    .trending-list { list-style: none; margin: 12px 0 0; padding: 0; display: grid; grid-template-columns: 1fr; gap: 8px; }
    @media (min-width: 640px) { .trending-list { grid-template-columns: 1fr 1fr; } }
    .trending-list a {
      display: block; padding: 10px 14px; border: 1px solid var(--line); border-radius: 10px;
      color: var(--mist); text-decoration: none; font-size: 0.9rem; background: var(--surface);
      transition: border-color .15s ease;
    }
    .trending-list a:hover { border-color: color-mix(in srgb, var(--candle) 45%, var(--line)); color: var(--candle); }
  </style>
</Base>
