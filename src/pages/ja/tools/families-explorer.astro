---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';
import { characters, typeLabels } from '../../../data/characters';

const known = characters.filter((c) => c.status !== 'unconfirmed');
const groups = new Map();
for (const c of known) {
  const key = c.family || 'Unknown';
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key).push(c);
}
const familyEntries = [...groups.entries()].sort((a, b) => {
  if (a[0] === 'Unknown') return 1;
  if (b[0] === 'Unknown') return -1;
  return b[1].length - a[1].length;
});

const typeLabelsJa: Record<string, string> = {
  vampire: '吸血鬼', werewolf: '狼男', witch: '魔女', mermaid: '人魚',
  seer: '預言者', ghost: '幽霊', human: '人間', other: 'その他',
};

const jsonLd = [
  {
    '@context': 'https://schema.org', '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
      { '@type': 'ListItem', position: 2, name: 'ツール', item: `${SITE.url}/ja/tools` },
      { '@type': 'ListItem', position: 3, name: '七つの一族エクスプローラー', item: new URL('/ja/tools/families-explorer', SITE.url).href },
    ],
  },
  {
    '@context': 'https://schema.org', '@type': 'WebApplication',
    name: 'ムーンライト・ピークス 七つの一族エクスプローラー', applicationCategory: 'GameApplication', operatingSystem: 'Web',
    url: new URL('/ja/tools/families-explorer', SITE.url).href,
    description: 'ムーンライト・ピークスの七つの超自然的な一族と、確認済み・報告済みのメンバーを探索できるインタラクティブツール。',
  },
];
---
<Base
  title="ムーンライト・ピークス 七つの一族エクスプローラー — 吸血鬼・狼男・魔女など"
  description="ムーンライト・ピークスの七つの超自然的な一族——Ambrosia、Webb、Logan、Khazanなど——を探索し、それぞれの一族に属する住民を確認状況別に絞り込めます。"
  path="/ja/tools/families-explorer"
  jsonLd={jsonLd}
  crumbs={[{ label: 'ツール', href: '/ja/tools' }, { label: '一族エクスプローラー' }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">ツール / 一族エクスプローラー</p>
      <h1>ムーンライト・ピークス <em>七つの一族</em>エクスプローラー</h1>
      <p class="intro">
        {GAME.title}は七つの超自然的な一族(どこにも属さない「普通の人間」も含む)を軸に構成されています。
        名前が判明している住民を、wikiの他のページと同じ確認済み・報告済み・データマイニングの
        ステータスでグループ分けしています——ここでは何も創作していません。最終更新:{SITE.updated}。
      </p>

      <section class="fam-shell" data-fam-explorer>
        <aside class="fam-panel">
          <h2>絞り込み</h2>
          <label>
            <span>一族</span>
            <select data-family>
              <option value="all">すべての一族</option>
              {familyEntries.map(([name]) => <option value={name}>{name}</option>)}
            </select>
          </label>
          <label>
            <span>タイプ</span>
            <select data-type>
              <option value="all">すべてのタイプ</option>
              {[...new Set(known.map((c) => c.type))].map((t) => <option value={t}>{typeLabelsJa[t] || typeLabels[t] || t}</option>)}
            </select>
          </label>
          <label class="checkline"><input data-romance-only type="checkbox" /> 恋愛可能のみ</label>
          <div class="fam-stats"><strong data-count>{known.length}</strong><span>人表示中</span></div>
        </aside>

        <div class="fam-groups" data-groups>
          {familyEntries.map(([name, members]) => (
            <div class="fam-group" data-family-name={name}>
              <h3>{name} <span class="fam-count">({members.length})</span></h3>
              <div class="fam-cards">
                {members.map((m) => (
                  <a
                    class="fam-card"
                    href={`/characters/${m.id}`}
                    data-type={m.type}
                    data-romance={String(m.romanceable === true)}
                    style={`--c1:${m.c1};--c2:${m.c2}`}
                  >
                    <span class="fam-avatar">{m.name.charAt(0)}</span>
                    <span class="fam-name">{m.name}</span>
                    <span class="fam-meta">{typeLabelsJa[m.type] || typeLabels[m.type] || m.type} · {m.status}</span>
                    {m.romanceable === true && <span class="fam-heart" aria-label="恋愛可能">♥</span>}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <div class="callout">
        一族名とメンバーは、wiki全体で使用している確認済み・報告済み・データマイニングのラベルに
        準拠しています。発売週の報道が検証され次第、このリストは増えていきます——出典については
        各住民の<a href="/characters">詳細プロフィール</a>をご確認ください。
      </div>
    </div>
  </article>

  <script define:vars={{}}>
    const root = document.querySelector('[data-fam-explorer]');
    if (root) {
      const familySel = root.querySelector('[data-family]');
      const typeSel = root.querySelector('[data-type]');
      const romanceOnly = root.querySelector('[data-romance-only]');
      const groupsEl = root.querySelector('[data-groups]');
      const count = root.querySelector('[data-count]');

      const render = () => {
        const fam = familySel.value;
        const type = typeSel.value;
        const romance = romanceOnly.checked;
        let shown = 0;
        groupsEl.querySelectorAll('.fam-group').forEach((group) => {
          const groupFam = group.dataset.familyName;
          let groupVisible = fam === 'all' || fam === groupFam;
          let anyCardVisible = false;
          group.querySelectorAll('.fam-card').forEach((card) => {
            const matchesType = type === 'all' || card.dataset.type === type;
            const matchesRomance = !romance || card.dataset.romance === 'true';
            const visible = groupVisible && matchesType && matchesRomance;
            card.style.display = visible ? '' : 'none';
            if (visible) { anyCardVisible = true; shown++; }
          });
          group.style.display = anyCardVisible ? '' : 'none';
        });
        count.textContent = shown;
      };
      [familySel, typeSel, romanceOnly].forEach((el) => el.addEventListener('input', render));
      render();
    }
  </script>

  <style>
    .fam-shell { display: grid; grid-template-columns: 240px minmax(0, 1fr); gap: 18px; margin: 28px 0; }
    @media (max-width: 820px) { .fam-shell { grid-template-columns: 1fr; } }
    .fam-panel { border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); padding: 16px; display: grid; gap: 14px; align-self: start; }
    .fam-panel h2 { margin: 0; }
    .fam-panel label span { display: block; margin-bottom: 6px; color: var(--mist); font-weight: 600; }
    .fam-panel select { width: 100%; min-height: 44px; border: 1px solid var(--line); border-radius: 10px; background: var(--ink); color: var(--mist); padding: 0 12px; font: inherit; }
    .checkline { display: flex; gap: 9px; align-items: center; color: var(--muted); }
    .fam-stats { border-top: 1px solid var(--line); padding-top: 12px; }
    .fam-stats strong { display: block; color: var(--candle); font-family: var(--display); font-size: 2rem; }
    .fam-stats span { color: var(--muted); }

    .fam-groups { display: grid; gap: 22px; }
    .fam-group h3 { margin: 0 0 10px; color: var(--mist); }
    .fam-count { color: var(--muted); font-weight: 400; }
    .fam-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 10px; }
    .fam-card {
      position: relative; display: grid; gap: 6px; justify-items: center; text-align: center;
      border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface);
      padding: 14px 8px; text-decoration: none; transition: transform 0.15s ease, border-color 0.15s ease;
    }
    .fam-card:hover { transform: translateY(-2px); border-color: var(--c2, var(--candle)); }
    .fam-avatar {
      width: 44px; height: 44px; border-radius: 50%; display: grid; place-items: center;
      font-family: var(--display); font-size: 1.2rem; color: #fff;
      background: linear-gradient(135deg, var(--c1, #444), var(--c2, #888));
    }
    .fam-name { color: var(--mist); font-weight: 600; }
    .fam-meta { color: var(--muted); font-size: 0.72rem; font-family: var(--mono); text-transform: uppercase; }
    .fam-heart { position: absolute; top: 8px; right: 10px; color: var(--candle); }
  </style>
</Base>
