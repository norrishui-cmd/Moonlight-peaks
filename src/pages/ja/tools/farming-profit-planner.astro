---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
      { '@type': 'ListItem', position: 2, name: 'ツール', item: `${SITE.url}/ja/tools` },
      { '@type': 'ListItem', position: 3, name: '農業利益プランナー', item: new URL('/ja/tools/farming-profit-planner', SITE.url).href },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'ムーンライト・ピークス 農業利益プランナー',
    applicationCategory: 'GameApplication',
    operatingSystem: 'Web',
    url: new URL('/ja/tools/farming-profit-planner', SITE.url).href,
    description: '種の価格、売却価格、成長日数、収穫回数、肥料計画のためのムーンライト・ピークス作物利益計算ツール。',
  },
];
---
<Base
  title="ムーンライト・ピークス 農業利益プランナー — 作物計算機とおすすめ作物"
  description="実際の価格データを使ってムーンライト・ピークスの作物利益を計算。種の価格、売却価格、成長日数、収穫回数、肥料の前提条件を比較できます。"
  path="/ja/tools/farming-profit-planner"
  jsonLd={jsonLd}
  crumbs={[{ label: 'ツール', href: '/ja/tools' }, { label: '農業利益プランナー' }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">ツール / 農業プランナー</p>
      <h1>ムーンライト・ピークス <em>農業利益プランナー</em></h1>
      <p class="intro">
        実際の{GAME.title}の価格が判明したら、1晩あたりの利益で作物を比較できます。実機データが
        確認されるまでは、未確認の作物価値を確定情報のように扱わず、以下の手動入力欄でシナリオを
        試してみてください。
      </p>

      <section class="profit-tool" data-profit-tool>
        <form class="profit-form">
          <label><span>作物名</span><input data-crop value="確認中の作物" /></label>
          <label><span>種の価格</span><input data-seed type="number" min="0" value="0" /></label>
          <label><span>収穫あたりの売却価格</span><input data-sell type="number" min="0" value="0" /></label>
          <label><span>成長日数</span><input data-days type="number" min="1" value="1" /></label>
          <label><span>収穫回数</span><input data-harvests type="number" min="1" value="1" /></label>
          <label><span>追加コスト</span><input data-extra type="number" min="0" value="0" /></label>
          <button type="button" class="btn btn-primary" data-add>比較に追加</button>
        </form>

        <aside class="profit-result">
          <span class="result-kicker">現在の見積もり</span>
          <h2 data-profit>0</h2>
          <p data-profit-copy>発売後に価格を入力すると、合計利益と1日あたりの利益が計算されます。</p>
        </aside>
      </section>

      <h2>作物比較</h2>
      <div class="profit-table-wrap">
        <table class="profit-table">
          <thead>
            <tr>
              <th>作物</th>
              <th>種</th>
              <th>売却</th>
              <th>日数</th>
              <th>収穫回数</th>
              <th>合計利益</th>
              <th>利益/日</th>
            </tr>
          </thead>
          <tbody data-rows>
            <tr><td colspan="7">実機データが確認され次第、作物を追加してください。</td></tr>
          </tbody>
        </table>
      </div>

      <div class="callout">
        安全なデータのルール:作物名、種の価格、売却価格、成長時間、肥料の効果、再生ルールは、
        ガイドコンテンツとして扱う前に、実際のゲームプレイまたは公式資料で検証する必要があります。
      </div>
    </div>
  </article>

  <script>
    const root = document.querySelector('[data-profit-tool]');
    const rowsEl = document.querySelector('[data-rows]');
    if (root && rowsEl) {
      const els = {
        crop: root.querySelector('[data-crop]'),
        seed: root.querySelector('[data-seed]'),
        sell: root.querySelector('[data-sell]'),
        days: root.querySelector('[data-days]'),
        harvests: root.querySelector('[data-harvests]'),
        extra: root.querySelector('[data-extra]'),
        add: root.querySelector('[data-add]'),
        profit: root.querySelector('[data-profit]'),
        copy: root.querySelector('[data-profit-copy]'),
      };
      const key = 'moonlight-farming-planner-v1';
      let rows = JSON.parse(localStorage.getItem(key) || '[]');
      const num = (el) => Math.max(0, Number(el.value || 0));
      const calc = () => {
        const seed = num(els.seed);
        const sell = num(els.sell);
        const days = Math.max(1, num(els.days));
        const harvests = Math.max(1, num(els.harvests));
        const extra = num(els.extra);
        const totalRevenue = sell * harvests;
        const totalProfit = totalRevenue - seed - extra;
        const perDay = totalProfit / days;
        els.profit.textContent = Math.round(totalProfit).toString();
        els.copy.textContent = `${days}日間で1日あたり${perDay.toFixed(2)}の利益。`;
        return { crop: els.crop.value || '確認中の作物', seed, sell, days, harvests, totalProfit, perDay };
      };
      const renderRows = () => {
        rowsEl.innerHTML = rows.length ? rows.map((r) => `
          <tr>
            <td>${r.crop}</td>
            <td>${r.seed}</td>
            <td>${r.sell}</td>
            <td>${r.days}</td>
            <td>${r.harvests}</td>
            <td>${Math.round(r.totalProfit)}</td>
            <td>${Number(r.perDay).toFixed(2)}</td>
          </tr>
        `).join('') : '<tr><td colspan="7">実機データが確認され次第、作物を追加してください。</td></tr>';
      };
      const save = () => localStorage.setItem(key, JSON.stringify(rows.slice(-12)));
      root.addEventListener('input', calc);
      els.add.addEventListener('click', () => {
        rows.push(calc());
        save();
        renderRows();
      });
      calc();
      renderRows();
    }
  </script>

  <style>
    .profit-tool { display: grid; grid-template-columns: minmax(0, 1fr) 300px; gap: 18px; margin: 28px 0; }
    @media (max-width: 820px) { .profit-tool { grid-template-columns: 1fr; } }
    .profit-form, .profit-result {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--surface);
      padding: 18px;
    }
    .profit-form { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
    @media (max-width: 640px) { .profit-form { grid-template-columns: 1fr; } }
    .profit-form label span { display: block; margin-bottom: 6px; color: var(--mist); font-weight: 600; }
    .profit-form input {
      width: 100%;
      min-height: 44px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--ink);
      color: var(--mist);
      padding: 0 12px;
      font: inherit;
    }
    .profit-form button { grid-column: 1 / -1; justify-content: center; }
    .result-kicker { font-family: var(--mono); color: var(--candle); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; }
    .profit-result h2 { font-size: 3rem; margin: 8px 0; }
    .profit-result p { color: var(--muted); }
    .profit-table-wrap { overflow-x: auto; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); }
    .profit-table { width: 100%; min-width: 720px; border-collapse: collapse; }
    .profit-table th, .profit-table td { border-bottom: 1px solid var(--line); padding: 10px 12px; text-align: left; }
    .profit-table th { color: var(--candle); font-family: var(--mono); font-size: 0.68rem; text-transform: uppercase; }
    .profit-table tr:last-child td { border-bottom: 0; }
  </style>
</Base>
