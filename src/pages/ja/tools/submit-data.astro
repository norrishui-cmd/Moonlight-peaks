---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
      { '@type': 'ListItem', position: 2, name: 'ツール', item: `${SITE.url}/ja/tools` },
      { '@type': 'ListItem', position: 3, name: 'データ送信ツール', item: new URL('/ja/tools/submit-data', SITE.url).href },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'ムーンライト・ピークス データ送信ツール',
    applicationCategory: 'GameApplication',
    operatingSystem: 'Web',
    url: new URL('/ja/tools/submit-data', SITE.url).href,
    description: '発売週に発見したアイテム・レシピ・場所・選物・バグをまとめるムーンライト・ピークスのローカル下書きツール。',
  },
];
---
<Base
  title="ムーンライト・ピークス データ送信ツール - 魚・アイテム・選物・レシピ・バグを共有"
  description="ムーンライト・ピークスの魚、小生物、レシピ、物薬、選物、場所、店、バグ、その他確認済みの発見内容の発売時データ提出を下書きします。"
  path="/ja/tools/submit-data"
  jsonLd={jsonLd}
  crumbs={[{ label: 'ツール', href: '/ja/tools' }, { label: 'データ送信ツール' }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">ツール / コミュニティデータ</p>
      <h1>ムーンライト・ピークス <em>データ送信ツール</em></h1>
      <p class="intro">
        発売週の発見内容を手動レビュー用に準備できます:魚、小生物、レシピ、物薬、NPCの選物、
        店、場所、バグ、プラットフォームに関するメモなど。自動で公開されることはありません。
      </p>

      <section class="submit-shell" data-submit-tool>
        <form class="submit-form">
          <label>
            <span>データの種類</span>
            <select name="type">
              <option>魚</option>
              <option>小生物</option>
              <option>レシピ</option>
              <option>物薬</option>
              <option>NPCの選物</option>
              <option>場所</option>
              <option>店</option>
              <option>バグ・不具合</option>
              <option>その他</option>
            </select>
          </label>
          <label><span>名前・タイトル</span><input name="name" placeholder="例:確認中" /></label>
          <label><span>場所・出典</span><input name="location" placeholder="どこで見つけたか" /></label>
          <label><span>季節・時間帯・天気</span><input name="conditions" placeholder="関係があれば" /></label>
          <label><span>価格・値・効果</span><input name="value" placeholder="ゲーム内で確認できれば" /></label>
          <label><span>証拠メモ</span><input name="evidence" placeholder="スクリーンショット、公式投稿、実機での観察内容" /></label>
          <label class="wide"><span>メモ</span><textarea name="notes" rows="5" placeholder="正確な文言、レシピの材料、キャラクターの反応、バグの再現手順などを追加してください。"></textarea></label>
          <button type="button" class="btn btn-primary" data-save>下書きをローカルに保存</button>
        </form>

        <aside class="review-card">
          <span>レビューポリシー</span>
          <h2>手動レビューのみ</h2>
          <p>
            下書きはブラウザに保存され、書き出すことができます。公式情報源、実機のスクリーン
            ショット、再現可能なゲーム内証拠を確認した後にのみ公開してください。
          </p>
          <button type="button" class="btn btn-ghost" data-export>JSONを書き出す</button>
        </aside>
      </section>

      <h2>保存済みの下書き</h2>
      <div class="draft-list" data-drafts></div>

      <div class="callout">
        推奨される出典ルール:可能な限り公式チャンネル、ストアページ、中立的なSNS投稿を出典として
        引用してください。公開データの出典として、競合するwikiページを引用しないでください。
      </div>
    </div>
  </article>

  <script>
    const root = document.querySelector('[data-submit-tool]');
    const draftsEl = document.querySelector('[data-drafts]');
    if (root && draftsEl) {
      const key = 'moonlight-data-drafts-v1';
      const form = root.querySelector('.submit-form');
      const saveButton = root.querySelector('[data-save]');
      const exportButton = root.querySelector('[data-export]');
      let drafts = JSON.parse(localStorage.getItem(key) || '[]');

      const save = () => localStorage.setItem(key, JSON.stringify(drafts));
      const render = () => {
        draftsEl.innerHTML = drafts.length ? drafts.map((draft, index) => `
          <article class="draft-card">
            <span>${draft.type}</span>
            <h3>${draft.name || '無題の下書き'}</h3>
            <p>${draft.notes || 'まだメモがありません。'}</p>
            <small>${draft.location || '場所未定'} - ${draft.evidence || '証拠未定'}</small>
            <button type="button" data-delete="${index}">削除</button>
          </article>
        `).join('') : '<p class="empty">まだローカルの下書きがありません。</p>';
      };

      saveButton.addEventListener('click', () => {
        const data = Object.fromEntries(new FormData(form).entries());
        data.createdAt = new Date().toISOString();
        drafts.unshift(data);
        drafts = drafts.slice(0, 25);
        save();
        form.reset();
        render();
      });
      draftsEl.addEventListener('click', (event) => {
        const button = event.target.closest('button[data-delete]');
        if (!button) return;
        drafts.splice(Number(button.dataset.delete), 1);
        save();
        render();
      });
      exportButton.addEventListener('click', async () => {
        const text = JSON.stringify(drafts, null, 2);
        await navigator.clipboard.writeText(text);
        exportButton.textContent = 'JSONをコピーしました';
        setTimeout(() => { exportButton.textContent = 'JSONを書き出す'; }, 1600);
      });
      render();
    }
  </script>

  <style>
    .submit-shell { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 18px; margin: 28px 0; }
    @media (max-width: 860px) { .submit-shell { grid-template-columns: 1fr; } }
    .submit-form, .review-card, .draft-card, .empty {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--surface);
    }
    .submit-form { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; padding: 18px; }
    @media (max-width: 640px) { .submit-form { grid-template-columns: 1fr; } }
    .submit-form .wide, .submit-form button { grid-column: 1 / -1; }
    .submit-form span { display: block; margin-bottom: 6px; color: var(--mist); font-weight: 600; }
    .submit-form input, .submit-form select, .submit-form textarea {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--ink);
      color: var(--mist);
      padding: 11px 12px;
      font: inherit;
    }
    .review-card { padding: 18px; align-self: start; }
    .review-card > span { font-family: var(--mono); color: var(--candle); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; }
    .review-card p { color: var(--muted); }
    .draft-list { display: grid; gap: 10px; }
    .draft-card, .empty { padding: 14px; }
    .draft-card span { color: var(--candle); font-family: var(--mono); font-size: 0.68rem; text-transform: uppercase; }
    .draft-card h3 { margin: 5px 0; }
    .draft-card p { color: var(--muted); margin: 0 0 8px; }
    .draft-card small { color: var(--faint); }
    .draft-card button { float: right; border: 1px solid var(--line); border-radius: 999px; background: transparent; color: var(--muted); padding: 4px 9px; cursor: pointer; }
  </style>
</Base>
