---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';
import { characters } from '../../../data/characters';

const cast = ['saga', 'luna', 'orlock', 'the-warlock', 'death', 'mina']
  .map((id) => characters.find((c) => c.id === id))
  .filter(Boolean);

const results: Record<string, { tagline: string; blurb: string }> = {
  saga: {
    tagline: 'あなたは満月とともに変化するエネルギーを持つ人を求めている。',
    blurb: 'Sagaは確認済みの狼男ロマンス対象です——開発者は彼女のエネルギーが満月とともに変化すると説明しています。夜ごとに違う一面を見せてくれる相手が欲しいなら、彼女がおすすめです。',
  },
  luna: {
    tagline: 'あなたは安定していて、緑の指を持ち、少し魔法的な人を求めている。',
    blurb: 'Lunaは農業を営む魔女として報告されています——おそらく呪文や園芸の知識を最初に教えてくれる存在です。地に足がついていて頼りになり、あなたの作物が何を必要としているか正確に知っていそうです。',
  },
  orlock: {
    tagline: 'あなたは古き良き魅力と少しの権力を求めている。',
    blurb: 'Orlockは吸血鬼一族の長として報告されています——旧世界の影響力を持ち、部屋に入るだけで空気を変えるような存在です。',
  },
  'the-warlock': {
    tagline: 'あなたは自信、魅力、そしてそれを一切隠さない人を求めている。',
    blurb: 'あるハンズオンプレビューでは、自己陶酔的で口説くのをやめない術士として登場しました。本名はまだ確認されていませんが——そのエネルギーは本物です。',
  },
  death: {
    tagline: 'あなたは町中が少し恐れているような相手を求めている。',
    blurb: 'Deathは発売前のデータマイニングファイルに登場する名前で、自分の家(「死神の小屋」)まで持っています。発売前の一部の噂ではロマンス対象の可能性も囁かれていました——確定ではありませんが、もし本当になったら、あなたが最初に予想していたことになります。',
  },
  mina: {
    tagline: 'あなたは謎を求めていて、すぐに解けなくても構わない。',
    blurb: 'Minaは開発者によって名前が明かされていますが、それ以外の情報はほとんどまだ公開されていません。時にはそれこそが魅力です:発売時に何が分かるか、まっさらな状態で楽しめます。',
  },
};

const questions = [
  {
    q: '町に来た最初の夜、あなたの心を惹きつけるのは?',
    options: [
      { t: '古い吸血鬼の館とその秘密', s: 'orlock' },
      { t: 'すぐにでも植えられそうな畑', s: 'luna' },
      { t: '遠くから聞こえる遠吠え', s: 'saga' },
      { t: '誰も見つけていない静かな場所', s: 'death' },
    ],
  },
  {
    q: '到着から5分以内に誰かに口説かれました。あなたは:',
    options: [
      { t: '思わず魅了されてしまう', s: 'the-warlock' },
      { t: '丁寧にかわす——ここには仕事をしに来たのだから', s: 'luna' },
      { t: '同じ勢いで返す', s: 'saga' },
      { t: '本当の狙いは何だろうと考える', s: 'orlock' },
    ],
  },
  {
    q: '訪れてみたい家を選ぶなら:',
    options: [
      { t: '何世代も続く壮大な一族の屋敷', s: 'orlock' },
      { t: '個人的なこだわりが感じられる静かな家', s: 'orlock' },
      { t: '作物が一番よく育つ場所ならどこでも', s: 'luna' },
      { t: '町の半分が避けているような場所', s: 'death' },
    ],
  },
  {
    q: '町の七つの一族のドラマについてどう思う?',
    options: [
      { t: '旧世界の政治みたいなもの——勝つ側についていたい', s: 'orlock' },
      { t: '私には関係ない、農場を運営しなくちゃ', s: 'luna' },
      { t: '正直言って、ちょっとワクワクする', s: 'the-warlock' },
      { t: 'むしろ完全に関わりたくない', s: 'mina' },
    ],
  },
  {
    q: '町に満月が昇りました。あなたは何をしていますか?',
    options: [
      { t: '窓から眺めながら、何かが変わるのを感じている', s: 'saga' },
      { t: '夜に咲く花の手入れをしている', s: 'luna' },
      { t: '誰にも見られない場所にいる', s: 'death' },
      { t: '月明かりの下で自分の家が美しく見えるか確認している', s: 'orlock' },
    ],
  },
  {
    q: '町の誰かが、みんなにとって完全な謎の存在です。あなたの反応は:',
    options: [
      { t: '興味をそそられる——もっと知りたい', s: 'mina' },
      { t: '魅力的だけど、警戒は緩めない', s: 'the-warlock' },
      { t: 'まさに私のタイプだ', s: 'death' },
      { t: '自信と地位のある相手の方が信頼できる', s: 'orlock' },
    ],
  },
];

const faq = [
  { q: 'このクイズは公式ですか、それとも実際のゲームデータに基づいていますか?', a: 'これは単なるお楽しみコンテンツです。結果の選択肢は、開発者の公開情報、ハンズオンのプレスプレビュー、発売前のデータマイニングファイルなど、各キャラクターの性格に関する実際の出典付きのヒントを基に作られています——ただし、マッチング自体は公式の相性システムではなく、私たちなりの軽い解釈です。' },
  { q: 'このクイズで誰が一番良い選物や恋愛ルートを持っているか分かりますか?', a: 'いいえ——選物の好み、恋愛イベント、関係性の仕組みはまだどこにも確認されていません。実際に検証済みの内容とまだ保留中の内容については、ロマンスギフトファインダーをご覧ください。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: 'ツール', item: `${SITE.url}/ja/tools` },
    { '@type': 'ListItem', position: 3, name: 'ロマンス相性診断クイズ', item: new URL('/ja/tools/romance-match-quiz', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'ムーンライト・ピークス ロマンス相性診断クイズ',
    applicationCategory: 'GameApplication', operatingSystem: 'Web',
    url: new URL('/ja/tools/romance-match-quiz', SITE.url).href,
    description: '実際の出典付き性格ヒントを基に、ムーンライト・ピークスのロマンス対象とあなたの相性を診断する軽いクイズ——架空の相性データは使用していません。' },
];
---
<Base
  title="ムーンライト・ピークス ロマンス相性診断クイズ — あなたのお相手を見つけよう"
  description="実際の出典付きキャラクターヒントを使って、ムーンライト・ピークスのロマンス対象との相性を診断する楽しいクイズ——架空の選物や相性データは使用していません。"
  path="/ja/tools/romance-match-quiz"
  jsonLd={jsonLd}
  crumbs={[{ label: 'ツール', href: '/ja/tools' }, { label: 'ロマンス相性診断クイズ' }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">ツール・ロマンス</p>
      <h1>ロマンス<em>相性診断</em>クイズ</h1>
      <p class="intro">
        6つの簡単な質問を、開発者の公開情報、プレスのハンズオンプレビュー、発売前のデータ
        マイニングファイルから得た実際の性格ヒントと照らし合わせます。あくまでお楽しみ
        コンテンツです——これが何であり、何でないかは下のFAQをご覧ください。
      </p>

      <div id="quiz-root" class="quiz-root">
        <div id="quiz-questions"></div>
        <div id="quiz-result" class="quiz-result" hidden></div>
        <div class="quiz-controls">
          <button type="button" id="quiz-restart" class="rq-btn" hidden>もう一度診断する</button>
        </div>
      </div>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        関連ページ: <a href="/tools/romance-gift-finder">ロマンスギフトファインダー</a>、
        <a href="/romance">ロマンスと結婚</a>、<a href="/characters">全キャラクター</a>。
      </div>
    </div>
  </article>

  <style>
    .quiz-root { margin: 18px 0 28px; }
    .rq-question { border: 1px solid var(--line); border-radius: 14px; background: var(--surface); padding: 16px; margin-bottom: 14px; }
    .rq-question h3 { font-family: var(--display); font-weight: 600; font-size: 1rem; margin: 0 0 12px; color: var(--mist); }
    .rq-options { display: grid; grid-template-columns: 1fr; gap: 8px; }
    @media (min-width: 640px) { .rq-options { grid-template-columns: 1fr 1fr; } }
    .rq-option {
      text-align: left; font-size: 0.86rem; color: var(--muted); border: 1px solid var(--line);
      border-radius: 10px; background: var(--ink-2); padding: 10px 12px; cursor: pointer;
      transition: border-color .15s ease, color .15s ease, background .15s ease;
    }
    .rq-option:hover { border-color: color-mix(in srgb, var(--candle) 45%, var(--line)); color: var(--mist); }
    .rq-option.is-picked { border-color: var(--candle); color: var(--candle); background: color-mix(in srgb, var(--candle) 10%, var(--ink-2)); }
    .quiz-result { border: 1px solid color-mix(in srgb, var(--candle) 40%, var(--line)); border-radius: 16px; background: var(--surface); padding: 20px; text-align: center; }
    .quiz-result h2 { font-family: var(--display); font-size: 1.3rem; margin: 4px 0 6px; }
    .quiz-result .qr-tagline { color: var(--candle); font-size: 0.94rem; margin: 0 0 12px; }
    .quiz-result .qr-blurb { color: var(--muted); font-size: 0.88rem; line-height: 1.6; max-width: 480px; margin: 0 auto 16px; }
    .quiz-result a.qr-profile { display: inline-block; font-family: var(--mono); font-size: 0.8rem; color: var(--candle); border: 1px solid color-mix(in srgb, var(--candle) 45%, var(--line)); border-radius: 999px; padding: 8px 18px; }
    .quiz-controls { text-align: center; margin-top: 14px; }
    .rq-btn { font-family: var(--mono); font-size: 0.78rem; color: var(--muted); border: 1px solid var(--line); border-radius: 999px; background: var(--surface); padding: 8px 18px; cursor: pointer; }
    .rq-btn:hover { color: var(--candle); border-color: color-mix(in srgb, var(--candle) 45%, var(--line)); }
    .rq-progress { font-family: var(--mono); font-size: 0.68rem; color: var(--faint); margin-bottom: 6px; }
  </style>

  <script define:vars={{ questions, results, cast: cast.map((c) => ({ id: c!.id, name: c!.name })) }}>
    (function () {
      var qWrap = document.getElementById('quiz-questions');
      var resultBox = document.getElementById('quiz-result');
      var restartBtn = document.getElementById('quiz-restart');
      var current = 0;
      var scores = {};

      var profileHref = {};
      cast.forEach(function (c) { profileHref[c.id] = '/characters/' + c.id; });

      function renderQuestion(i) {
        qWrap.innerHTML = '';
        var q = questions[i];
        var box = document.createElement('div');
        box.className = 'rq-question';
        var progress = document.createElement('div');
        progress.className = 'rq-progress';
        progress.textContent = '質問 ' + (i + 1) + ' / ' + questions.length;
        var h3 = document.createElement('h3');
        h3.textContent = q.q;
        var opts = document.createElement('div');
        opts.className = 'rq-options';
        q.options.forEach(function (opt) {
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'rq-option';
          btn.textContent = opt.t;
          btn.addEventListener('click', function () {
            scores[opt.s] = (scores[opt.s] || 0) + 1;
            current++;
            if (current < questions.length) { renderQuestion(current); }
            else { showResult(); }
          });
          opts.appendChild(btn);
        });
        box.appendChild(progress);
        box.appendChild(h3);
        box.appendChild(opts);
        qWrap.appendChild(box);
      }

      function showResult() {
        var best = null, bestScore = -1;
        Object.keys(scores).forEach(function (k) {
          if (scores[k] > bestScore) { bestScore = scores[k]; best = k; }
        });
        if (!best) best = 'mina';
        var info = results[best];
        var name = (cast.filter(function (c) { return c.id === best; })[0] || {}).name || best;

        qWrap.style.display = 'none';
        resultBox.hidden = false;
        resultBox.innerHTML =
          '<p class="rq-progress">あなたのお相手</p>' +
          '<h2>' + name + '</h2>' +
          '<p class="qr-tagline">' + info.tagline + '</p>' +
          '<p class="qr-blurb">' + info.blurb + '</p>' +
          '<a class="qr-profile" href="' + profileHref[best] + '">' + name + 'のプロフィールを見る</a>';
        restartBtn.hidden = false;
      }

      restartBtn.addEventListener('click', function () {
        current = 0; scores = {};
        qWrap.style.display = '';
        resultBox.hidden = true;
        restartBtn.hidden = true;
        renderQuestion(0);
      });

      renderQuestion(0);
    })();
  </script>
</Base>
