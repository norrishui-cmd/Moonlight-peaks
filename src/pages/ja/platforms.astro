---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const facts = [
  ['発売日', GAME.releaseLabel],
  ['価格', `${GAME.price}(Nintendo Switch 2版:$39.99)。日本国内価格(クラウディッドレパードエンタテインメント公式):通常版5,390円、Nintendo Switch 2 Edition版5,940円(いずれも税込)、Switch→Switch 2 Editionアップグレードパス550円。`],
  ['対応機種', GAME.platforms.join(', ')],
  ['無料体験版', GAME.demo],
  ['動作環境', 'PC/Mac版の公式要件はSteamでご確認ください。実際の動作は体験版で試すのが確実です'],
  ['対応言語', GAME.languages.join(', ')],
  ['PS5 / Xbox / iOS', '発表なし'],
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: '対応機種', item: `${SITE.url}/ja/platforms` },
  ] },
];
---
<Base
  title="「ムーンライト・ピークス -ヴァンパイアのゴシックライフ-」対応機種・価格"
  description="Moonlight Peaksをプレイできる場所:Switch、Switch 2、Steam(PC/Mac)、Steam Deck、Android——価格、無料体験版、PS5/Xbox/iOS対応状況について。"
  path="/ja/platforms"
  jsonLd={jsonLd}
  crumbs={[{ label: '対応機種' }]}
  lang="ja"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">エントリー・対応機種</p>
      <h1>Moonlight Peaksの<em>対応機種</em>と価格</h1>
      <p class="intro">
        Moonlight Peaksは{GAME.releaseLabel}に発売され、現在配信中です。どこでプレイできるか、価格はいくらか、
        そして無料体験版がどう機能するかをまとめました。
      </p>

      <h2>ひと目でわかる情報</h2>
      <table class="facts">
        {facts.map((f) => (<tr><th>{f[0]}</th><td>{f[1]}</td></tr>))}
      </table>

      <h2>どこでプレイできるか</h2>
      <p>
        Moonlight PeaksはSteam(PC/Mac)、Steam Deck、Nintendo Switch、Nintendo Switch 2、
        Google Play経由のAndroidで発売が確定しています。それぞれの機種には、パフォーマンスや
        操作方法、価格に関する詳細情報をまとめた専用ガイドがあります——現時点では英語版のみです。
      </p>

      <h2>Moonlight PeaksはPlayStation、Xbox、iOSに対応していますか?</h2>
      <p>
        PlayStation、Xbox、iOS版は発表されていません。確定している対応機種はSteam(PC/Mac)、
        Steam Deck、Nintendo Switch、Nintendo Switch 2、Google Play経由のAndroidです。
        状況が変わり次第、このページを更新します。
      </p>

      <div class="callout wip">
        関連ページ:<a href="/release-date">発売日</a>、<a href="/demo">体験版</a>、
        <a href="/system-requirements">動作環境</a>、<a href="/languages">対応言語</a>、
        <a href="/compare">他のコージーシムとの比較</a>、<a href="/faq">FAQ完全版</a>(英語)・
        各プラットフォームの詳細:<a href="/ja/platforms/steam-deck">Steam Deck</a>、
        <a href="/ja/platforms/switch">Switch</a>、<a href="/ja/platforms/switch-2">Switch 2</a>、
        <a href="/ja/platforms/android">Android</a>。
        <a href="/ja/faq">FAQ(日本語)</a>。
      </div>
    </div>
  </article>
</Base>
