---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';
import YouTube from '../../components/YouTube.astro';
import News from '../../components/News.astro';
import { characters, typeLabels } from '../../data/characters';

const familyNameJa: Record<string, string> = {
  'Vampire (Ambrosia)': '吸血鬼 · アンブロシア家',
  'Vampire (Dracula)': '吸血鬼 · ドラキュラ家',
  'Witch (Webb)': '魔女 · ウェッブ家',
  'Werewolf (Logan)': '人狼 · ローガン家',
  'Mermaid (Hosu)': '人魚 · ホス家',
  'Seer (Khazan)': '予知者 · カザン家',
  'Human (Henderson)': '人間 · ヘンダーソン家',
  'Unknown': '家族に属さない',
};
const typeJa: Record<string, string> = {
  vampire: '吸血鬼', werewolf: '人狼', witch: '魔女', mermaid: '人魚',
  seer: '予知者', ghost: '幽霊', human: '人間', other: 'その他',
};
const statusJa: Record<string, string> = { confirmed: '確認済み', reported: '報道あり', datamined: 'データマイニング', unconfirmed: '未確認' };

const romanceable = characters.filter((c) => c.romanceable === true);
const groups = new Map<string, typeof romanceable>();
for (const c of romanceable) {
  const key = c.family || 'Unknown';
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(c);
}
const familyGroups = [...groups.entries()].sort((a, b) => b[1].length - a[1].length);

const faq = [
  { q: 'Moonlight Peaksの恋愛対象は何人いますか?', a: '発売時点で公式ローンチのロマンス紹介により23人と確認されています——以前は15人前後と報じられていました。6つの家族(アンブロシア、ウェッブ、ローガン、ホス、カザン、ヘンダーソン)と、どの家族にも属さない2人(死神とラブデーモンのLlemi)に分かれます。' },
  { q: 'デートと結婚にはそれぞれ何ハート必要ですか?', a: '確認済み:ハートレベル4でデートが解禁され、ハートレベル8でプロポーズ可能になります。結婚式はプロポーズから1週間以内に行われ、町の吸血鬼と人狼が参列します。' },
  { q: '複数人と同時に交際できますか?', a: 'はい、確認済みです。複数人を同時に口説くと相手は気づいてコメントしますが、軽い嫉妬程度で、厳格な対抗システムではありません。結婚自体は完全に一夫一婦制です。' },
  { q: 'デートの誘いを断り続けるとどうなりますか?', a: '確認済み:パートナーからのデートの誘いを断りすぎると別れてしまい、その後数日間よそよそしくなった後に許してくれます。' },
  { q: 'Moonlight Peaksで結婚できますか?子供は作れますか?', a: '結婚は可能です——配偶者はあなたの農場に引っ越してきて新しいハートイベントが解禁され、配偶者を吸血鬼に変えることもできます。子供は作れません(複数の情報源で確認済み、追加予定もなし)。Orlockのような既に子供がいるキャラクターと結婚すると、継父母になると報じられています。' },
  { q: '恋愛は性別によって制限されますか?', a: 'いいえ。デートは完全に性別を問わない設計になっており、自分の吸血鬼キャラをどう作っても、恋愛対象となる住民全員を口説くことができます。' },
  { q: '吸血鬼は人狼と交際できますか?', a: 'できます。町の吸血鬼と人狼は仲が良くなく、よく小競り合いをしています。そのためSagaのような人狼を口説くことは、その溝を越えることを意味します——それも魅力の一つです。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: '恋愛', item: `${SITE.url}/ja/romance` },
  ] },
];
---
<Base
  title="ムーンライト・ピークス 恋愛ガイド -ヴァンパイアのゴシックライフ- 23人の恋愛対象"
  description="Moonlight Peaksの恋愛システム完全ガイド:確認済み23人の恋愛対象、性別を問わない交際、ハートレベル4でデート解禁/8でプロポーズ、結婚(子供なし)と七つの家族。"
  path="/ja/romance"
  jsonLd={jsonLd}
  crumbs={[{ label: '恋愛と家族' }]}
  lang="ja"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">エントリー · ハート</p>
      <h1>Moonlight Peaksの<em>恋愛</em>と七つの家族</h1>
      <p class="intro">
        恋愛は{GAME.title}の目玉機能です:確認済み23人の恋愛対象、性別を問わない交際、そして
        結婚(子供はなし)。このページはキャラクターデータベースから直接生成されているため、
        データが更新されると自動的に反映されます。更新日: {SITE.updated}。
      </p>

      <div class="romance-video">
        <YouTube id="YFb9capELQw" title="Moonlight Peaks romance video" />
      </div>

      <h2>恋愛システムの実際の仕組み</h2>
      <p>
        確認済み:住民と会話したり贈り物をしたりして関係を深めます。関係メニューには最近渡した
        贈り物とその反応が表示されます。<strong>ハートレベル4</strong>でデートが解禁されます——
        デートは受動的なシーンではなく、ミニゲーム形式(相手の指定した色で花束を作るなど)で進みます。
        <strong>ハートレベル8</strong>でプロポーズが解禁され、結婚式は1週間以内に行われ、
        町の吸血鬼と人狼が参列します。
      </p>
      <p>
        複数人と同時に交際することも可能です——相手は気づいてコメントしますが、軽い嫉妬程度で
        厳格な対抗システムではありません。結婚自体は完全に一夫一婦制で、デートの誘いを断りすぎると
        破局(その後クールダウン期間あり)します。結婚後、配偶者は農場に引っ越してきて、
        吸血鬼に変えることも可能です。関係を深めることで設計図や制作素材も解禁されます。
      </p>

      <h2>まずはここから:恋愛ルートを計画する</h2>
      <p>23人の選択肢があり、完全な贈り物・イベントデータベースはまだ存在しないため、全員を同時に狙うより数人に絞るのが現実的です:</p>
      <div class="rp-steps">
        <a class="rp-step" href="/tools/romance-match-quiz">
          <span class="rp-step-num">1</span>
          <strong>診断クイズを受ける</strong>
          <span>実際の手がかりに基づいた楽しいマッチングで対象を絞り込めます。</span>
        </a>
        <a class="rp-step" href="/tools/families-explorer">
          <span class="rp-step-num">2</span>
          <strong>家族別に見る</strong>
          <span>23人の恋愛対象を実際の家族関係で分類して閲覧できます。</span>
        </a>
        <a class="rp-step" href="/tools/romance-planner">
          <span class="rp-step-num">3</span>
          <strong>候補リストを作る</strong>
          <span>選択とメモをブラウザに非公開で保存できます。</span>
        </a>
        <a class="rp-step" href="/tools/gift-tracker">
          <span class="rp-step-num">4</span>
          <strong>贈り物の結果を記録する</strong>
          <span>公式リストが揃うまで自分の発見を記録しましょう。</span>
        </a>
      </div>

      <h2>基本情報</h2>
      <p>
        23人の住民が恋愛対象で、6つの家族——吸血鬼(アンブロシア)、人狼(ローガン)、魔女(ウェッブ)、
        人魚(ホス)、予知者(カザン)、人間(ヘンダーソン)——と、どの家族にも属さない死神とラブデーモンの
        Llemiに分かれます。
      </p>

      <h2>23人の恋愛対象、家族別一覧</h2>
      <p>キャラクターデータベースから直接生成——各名前から完全なプロフィール(現在は英語)にリンクしています。</p>
      {familyGroups.map(([family, members]) => (
        <div class="romance-family-group">
          <h3>{familyNameJa[family] || family} <span class="rf-count">({members.length}人)</span></h3>
          <table class="facts">
            <tr><th>キャラクター</th><th>タイプ</th><th>確認状況</th></tr>
            {members.map((c) => (
              <tr>
                <td><a href={`/characters/${c.id}`}>{c.name}</a></td>
                <td>{typeJa[c.type] || typeLabels[c.type] || c.type}</td>
                <td>{statusJa[c.status] || c.status}</td>
              </tr>
            ))}
          </table>
        </div>
      ))}

      <h2>贈り物ガイド</h2>
      <p>
        ほとんどのキャラクターの贈り物リストはまだ公開されていません——<strong>Saga</strong>が
        確認済みの最初の例です(白ワインが大好物)。<a href="/characters/saga">プロフィール</a>を
        確認し、<a href="/tools/gift-tracker">贈り物トラッカー</a>で自分の発見を記録しましょう。
      </p>

      <h2>最新の恋愛関連アップデート</h2>
      <News category="romance" limit={5} />

      <h2>よくある質問</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        発売後のエントリー、キャラクターデータベースから生成。関連ページ:
        <a href="/characters">全キャラクター</a>、<a href="/families">七つの家族</a>、
        <a href="/ja/beginner-guide">初心者ガイド(日本語)</a>。
      </div>
    </div>
  </article>
  <style>
    .romance-family-group { margin: 20px 0; }
    .romance-family-group h3 { margin: 0 0 8px; }
    .rf-count { color: var(--muted); font-weight: 400; font-size: 0.85rem; }
    .rp-steps { display: grid; grid-template-columns: 1fr; gap: 10px; margin: 14px 0 24px; }
    @media (min-width: 640px) { .rp-steps { grid-template-columns: 1fr 1fr; } }
    .rp-step {
      display: flex; flex-direction: column; gap: 4px; border: 1px solid var(--line); border-radius: 14px;
      background: var(--surface); padding: 14px 16px; text-decoration: none; position: relative;
      transition: border-color .15s ease;
    }
    .rp-step:hover { border-color: color-mix(in srgb, var(--candle) 45%, var(--line)); }
    .rp-step-num {
      position: absolute; top: 12px; right: 14px; font-family: var(--mono); font-size: 0.7rem; color: var(--candle);
      border: 1px solid color-mix(in srgb, var(--candle) 40%, var(--line)); border-radius: 999px; width: 20px; height: 20px;
      display: flex; align-items: center; justify-content: center;
    }
    .rp-step strong { font-family: var(--display); font-weight: 600; font-size: 0.94rem; color: var(--mist); padding-right: 26px; }
    .rp-step span:last-child { font-size: 0.8rem; color: var(--faint); line-height: 1.4; }
    .romance-video { margin: clamp(1.6rem, 4vw, 2.6rem) 0 clamp(2rem, 5vw, 3rem); }
  </style>
</Base>
