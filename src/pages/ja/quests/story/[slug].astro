---
import Base from '../../../../layouts/Base.astro';
import { SITE, GAME } from '../../../../consts';
import { storyQuests, storyQuestBySlug } from '../../../../data/quests-story';
import { storyQuestsJa, storyChaptersJa } from '../../../../i18n/quests-story-ja';

export function getStaticPaths() {
  return storyQuests.filter((q) => storyQuestsJa[q.slug]).map((q) => ({ params: { slug: q.slug }, props: { q } }));
}

const { q } = Astro.props as { q: (typeof storyQuests)[number] };
const tr = storyQuestsJa[q.slug];
const chapter = storyChaptersJa.find((c) => c.number === q.chapter)!;
const prev = storyQuests[storyQuests.indexOf(q) - 1];
const next = q.leadsTo ? storyQuestBySlug.get(q.leadsTo) : undefined;
const statusLabel = q.status === 'confirmed' ? '確認済み' : '報告済み';

const faq = [
  { q: `ムーンライト・ピークスで「${tr.title}」を解放するには?`, a: tr.unlock || 'このクエストは前のストーリー展開から直接続きます——下記の前提クエストリンクをご覧ください。' },
  { q: `「${tr.title}」の報酬は?`, a: tr.reward || 'このクエストの直接的なアイテム報酬はまだ確認されていません。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: 'クエストガイド', item: `${SITE.url}/ja/quests` },
    { '@type': 'ListItem', position: 3, name: 'メインストーリー', item: `${SITE.url}/ja/quests/story` },
    { '@type': 'ListItem', position: 4, name: tr.title, item: `${SITE.url}/ja/quests/story/${q.slug}` },
  ] },
];
---
<Base
  title={`${tr.title} — ムーンライト・ピークス クエストガイド`}
  description={`${GAME.title}「${tr.title}」クエスト: ${tr.summary.slice(0, 100)}`}
  path={`/ja/quests/story/${q.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: 'クエストガイド', href: '/ja/quests' }, { label: 'メインストーリー', href: '/ja/quests/story' }, { label: tr.title }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">メインストーリー・第{q.chapter}章: {chapter.title} · <span class="tag-community">{statusLabel}</span></p>
      <h1>{tr.title}</h1>

      {tr.unlock && (
        <div class="callout">
          <strong>解放条件:</strong> {tr.unlock}
        </div>
      )}

      <h2>何が起こるか</h2>
      <p>{tr.summary}</p>

      {tr.reward && (
        <>
          <h2>報酬</h2>
          <p>{tr.reward}</p>
        </>
      )}

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <nav class="prevnext" aria-label="クエストナビゲーション">
        {prev && storyQuestsJa[prev.slug] ? <a href={`/ja/quests/story/${prev.slug}`}>← {storyQuestsJa[prev.slug].title}</a> : <span />}
        <a href="/ja/quests/story">全ての章</a>
        {next && storyQuestsJa[next.slug] ? <a href={`/ja/quests/story/${next.slug}`}>{storyQuestsJa[next.slug].title} →</a> : <span />}
      </nav>

      <div class="callout wip">
        関連ページ: <a href="/ja/quests">クエストハブ</a>, <a href="/ja/quests/side">サブクエスト</a>,
        <a href="/ja/beginner-guide">初心者ガイド</a>。
      </div>
    </div>
  </article>

  <style>
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 7px;
      vertical-align: middle;
    }
    .prevnext { display: flex; justify-content: space-between; gap: 10px; margin: 22px 0; font-family: var(--mono); font-size: 0.82rem; }
    .prevnext a { color: var(--candle); }
  </style>
</Base>
