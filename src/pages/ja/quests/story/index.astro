---
import Base from '../../../../layouts/Base.astro';
import { SITE, GAME } from '../../../../consts';
import { storyQuests } from '../../../../data/quests-story';
import { storyQuestsJa, storyChaptersJa } from '../../../../i18n/quests-story-ja';

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: 'クエストガイド', item: `${SITE.url}/ja/quests` },
    { '@type': 'ListItem', position: 3, name: 'メインストーリー', item: `${SITE.url}/ja/quests/story` },
  ],
};
---
<Base
  title="ムーンライト・ピークス メインストーリークエスト — 章立てガイド"
  description="ムーンライト・ピークスの確認済みメインストーリークエストを、町への到着から結婚式編まで5つの章に整理。複数の発売週ソースで相互検証済み。"
  path="/ja/quests/story"
  jsonLd={jsonLd}
  crumbs={[{ label: 'クエストガイド', href: '/ja/quests' }, { label: 'メインストーリー' }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">クエスト・メインストーリー</p>
      <h1>メインストーリー<em>クエスト</em></h1>
      <p class="intro">
        {storyQuests.length}個のメインストーリークエストを、{storyChaptersJa.length}個の章に整理しています。
        今いる章を選んでください——各章内のクエストは確認済みの順番で並んでいます。
      </p>

      {storyChaptersJa.map((ch) => {
        const quests = storyQuests.filter((q) => q.chapter === ch.number && storyQuestsJa[q.slug]);
        return (
          <section class="chapter">
            <div class="chapter-head">
              <span class="chapter-num">第{ch.number}章</span>
              <h2>{ch.title}</h2>
            </div>
            <p class="chapter-dek">{ch.dek}</p>
            <ol class="quest-list">
              {quests.map((q) => (
                <li>
                  <a href={`/ja/quests/story/${q.slug}`}>{storyQuestsJa[q.slug].title}</a>
                  {q.status === 'reported' && <span class="tag-community">報告済み</span>}
                </li>
              ))}
            </ol>
          </section>
        );
      })}

      <div class="callout wip">
        相互検証済みの発売週攻略(Neoseekerのクエストログ、Bonus Action、Output Lag、Into Indie Games)
        を出典としています。章の分け方は独自の整理方法であり、ゲーム内の公式ラベルではありません。
        関連ページ: <a href="/ja/quests">クエストハブ</a>, <a href="/ja/quests/side">サブクエスト</a>,
        <a href="/quests/story/a-bridge-too-far">A Bridge Too Far(完全攻略、英語)</a>。
      </div>
    </div>
  </article>

  <style>
    .chapter { margin: 26px 0; padding-top: 18px; border-top: 1px solid var(--line); }
    .chapter:first-of-type { border-top: none; padding-top: 0; }
    .chapter-head { display: flex; align-items: baseline; gap: 10px; }
    .chapter-num { font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--candle); white-space: nowrap; }
    .chapter-head h2 { margin: 0; }
    .chapter-dek { color: var(--muted); font-size: 0.92rem; margin: 4px 0 12px; }
    .quest-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; counter-reset: qnum; }
    .quest-list li { counter-increment: qnum; padding: 8px 0; border-bottom: 1px dashed var(--line); display: flex; align-items: center; gap: 8px; }
    .quest-list li::before { content: counter(qnum) "."; color: var(--faint); font-family: var(--mono); font-size: 0.8rem; }
    .quest-list a { color: var(--mist); text-decoration: none; flex: 1; }
    .quest-list a:hover { color: var(--candle); }
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 7px;
    }
  </style>
</Base>
