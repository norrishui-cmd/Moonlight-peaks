---
import Base from '../../../../layouts/Base.astro';
import { SITE, GAME } from '../../../../consts';
import { sideQuests } from '../../../../data/quests-side';
import { sideQuestsJa } from '../../../../i18n/quests-side-ja';

export function getStaticPaths() {
  const translated = sideQuests.filter((q) => sideQuestsJa[q.slug]);
  return translated.map((q, i) => ({
    params: { slug: q.slug },
    props: { q, prev: translated[(i - 1 + translated.length) % translated.length], next: translated[(i + 1) % translated.length] },
  }));
}

const { q, prev, next } = Astro.props as { q: (typeof sideQuests)[number]; prev: (typeof sideQuests)[number]; next: (typeof sideQuests)[number] };
const tr = sideQuestsJa[q.slug];
const statusLabel = q.status === 'confirmed' ? '確認済み' : '報告済み';
const troubleshooting = tr.troubleshooting || [];
const allFaq = [...troubleshooting, { q: `ムーンライト・ピークスで「${tr.title}」とは?`, a: tr.summary }];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: allFaq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: 'クエストガイド', item: `${SITE.url}/ja/quests` },
    { '@type': 'ListItem', position: 3, name: 'サブクエスト', item: `${SITE.url}/ja/quests/side` },
    { '@type': 'ListItem', position: 4, name: tr.title, item: `${SITE.url}/ja/quests/side/${q.slug}` },
  ] },
];
---
<Base
  title={`${tr.title} — ムーンライト・ピークス 攻略`}
  description={`${GAME.title}「${tr.title}」: ${(troubleshooting[0]?.q || tr.summary).slice(0, 90)}`}
  path={`/ja/quests/side/${q.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: 'クエストガイド', href: '/ja/quests' }, { label: 'サブクエスト', href: '/ja/quests/side' }, { label: tr.title }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">サブクエスト · <span class="tag-community">{statusLabel}</span></p>
      <h1>{tr.title}</h1>
      <p class="intro">{tr.summary}</p>

      {tr.reward && (
        <div class="callout">
          <strong>報酬:</strong> {tr.reward}
        </div>
      )}

      {troubleshooting.length > 0 && (
        <>
          <h2>詰まっていますか?確認すべきこと</h2>
          <div class="faq">
            {troubleshooting.map((f) => (
              <details open>
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))}
          </div>
        </>
      )}

      <nav class="prevnext" aria-label="サブクエストナビゲーション">
        <a href={`/ja/quests/side/${prev.slug}`}>← {sideQuestsJa[prev.slug].title}</a>
        <a href="/ja/quests/side">全てのサブクエスト</a>
        <a href={`/ja/quests/side/${next.slug}`}>{sideQuestsJa[next.slug].title} →</a>
      </nav>
    </div>
  </article>

  <style>
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 7px;
      vertical-align: middle;
    }
    .prevnext { display: flex; justify-content: space-between; gap: 10px; margin: 22px 0; font-family: var(--mono); font-size: 0.82rem; }
    .prevnext a { color: var(--candle); }
  </style>
</Base>
