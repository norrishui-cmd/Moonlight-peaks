---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';
import { faqs } from '../../data/faq';
import { faqJa } from '../../i18n/faq-ja';

const catLabelJa: Record<string, string> = {
  platforms: 'プラットフォーム・価格・体験版', romance: '恋愛・結婚', characters: 'キャラクター',
  world: '世界・ゲームプレイ', farming: '農業・経済', general: '一般',
};
const cats = ['platforms', 'romance', 'characters', 'world', 'farming', 'general'] as const;
const translated = faqs.filter((f) => faqJa[f.slug]);
const plain = (slug: string) => {
  const tr = faqJa[slug];
  return [tr.a, ...(tr.more || [])].join(' ');
};

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: 'よくある質問', item: `${SITE.url}/ja/faq` },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: translated.map((f) => ({
    '@type': 'Question', name: faqJa[f.slug].q, acceptedAnswer: { '@type': 'Answer', text: plain(f.slug) },
  })) },
];
---
<Base
  title="ムーンライト・ピークス よくある質問(FAQ) — 発売日、恋愛、体験版など"
  description="ムーンライト・ピークスに関する最もよく聞かれる質問への回答:発売日、価格、プラットフォーム、マルチプレイ、戦闘、結婚、恋愛対象、体験版、ゲームプレイについて。"
  path="/ja/faq"
  jsonLd={jsonLd}
  crumbs={[{ label: 'よくある質問' }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">ハブ・FAQ</p>
      <h1>{GAME.title} <em>よくある質問</em></h1>
      <p class="intro">
        2026年7月7日に発売された{GAME.title}について、プレイヤーが最もよく尋ねる質問への、出典に
        基づいた簡潔な回答です。各質問には個別ページがあります。確認済み・報告済みの内容のみ回答し、
        まだ不明な点は推測せずに明記しています。最終更新:{SITE.updated}。
      </p>

      <h2>このFAQの使い方</h2>
      <p>
        直接的な答えが必要なときはこのページを、詳細が必要なときはリンク先のガイドを開いてください。
        プラットフォームや体験版に関する質問は主に発売日ページへ、恋愛やキャラクターに関する質問は
        プレゼント・スケジュール・ハートイベント・家族のページへつながります。
      </p>

      {cats.map((cat) => {
        const items = translated.filter((f) => f.cat === cat);
        if (items.length === 0) return null;
        return (
          <section class="grp">
            <div class="grp-head"><h2>{catLabelJa[cat]}</h2><span class="note">{items.length}件の質問</span></div>
            <ul class="q-list">
              {items.map((f) => (
                <li><a href={`/ja/faq/${f.slug}`}>{faqJa[f.slug].q}</a></li>
              ))}
            </ul>
          </section>
        );
      })}

      <div class="callout wip">
        現在{translated.length}件のFAQを日本語に翻訳済みです。英語版では全{faqs.length}件をご覧いただけます——
        <a href="/faq">英語版FAQページ</a>。
      </div>
    </div>
  </article>

  <style>
    .grp { margin: 28px 0; }
    .grp-head { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; border-bottom: 1px solid var(--line); padding-bottom: 6px; margin-bottom: 10px; }
    .grp-head h2 { margin: 0; }
    .note { font-family: var(--mono); font-size: 0.72rem; color: var(--faint); white-space: nowrap; }
    .q-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; }
    .q-list a { display: block; padding: 8px 0; color: var(--mist); text-decoration: none; border-bottom: 1px dashed var(--line); }
    .q-list a:hover { color: var(--candle); }
  </style>
</Base>
