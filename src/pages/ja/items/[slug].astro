---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { itemCategories, getItemFramework } from '../../../data/items';
import { itemsJa } from '../../../i18n/items-ja';
import type { ItemCategory } from '../../../data/items';

export function getStaticPaths() {
  return itemCategories.filter((item) => itemsJa[item.slug]).map((item, index, arr) => ({
    params: { slug: item.slug },
    props: { item, prev: arr[(index - 1 + arr.length) % arr.length], next: arr[(index + 1) % arr.length] },
  }));
}

const { item } = Astro.props as { item: ItemCategory };
const tr = itemsJa[item.slug];
const url = new URL(`/ja/items/${item.slug}`, SITE.url).href;
const framework = getItemFramework(item.slug);
const hasRealData = item.slug === 'foraging' || item.slug === 'cooking';
const parseImageCell = (cell: string) => {
  const [src, alt = ''] = cell.slice('image:'.length).split('|');
  return { src, alt };
};

const statusLabelJa: Record<string, string> = {
  confirmed: '確認済み', datamined: 'データ解析', expected: '確認予定',
};

const faq = [
  { q: `ムーンライト・ピークスの${tr.name}とは?`, a: `${tr.name}はムーンライト・ピークスのアイテムカテゴリの一つです。${tr.summary}` },
  { q: `${tr.name}の情報は確定していますか?`, a: item.status === 'confirmed'
      ? `${tr.name}のシステムは確認済みですが、個別のアイテム名や効果は引き続き実機で検証が必要です。`
      : `${tr.name}カテゴリはまだ実機で独自に確認できていません。推測せず、確認でき次第このページを更新します。` },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: 'アイテム', item: `${SITE.url}/ja/items` },
    { '@type': 'ListItem', position: 3, name: tr.name, item: url },
  ] },
];
---
<Base
  title={`${tr.name} | ムーンライト・ピークス アイテムガイド`}
  description={tr.dek}
  path={`/ja/items/${item.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: 'アイテム', href: '/ja/items' }, { label: tr.name }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">アイテム · {statusLabelJa[item.status] ?? item.status}</p>
      <h1><em>{tr.name}</em></h1>
      <p class="intro">{tr.dek}</p>

      <h2>詳細</h2>
      <p>{tr.summary}</p>

      <h2>例</h2>
      <ul>{tr.examples.map((e) => (<li>{e}</li>))}</ul>

      {hasRealData && (
        <>
          <h2>完全なデータテーブル</h2>
          <div class="ja-item-table-wrap">
            <table class="ja-item-table">
              <thead>
                <tr>{framework.columns.map((col) => <th>{col}</th>)}</tr>
              </thead>
              <tbody>
                {framework.rows.map((row) => (
                  <tr>
                    {row.map((cell) => {
                      const image = cell.startsWith('image:') ? parseImageCell(cell) : null;
                      return (
                        <td>
                          {image ? (
                            <img class="ja-item-table-icon" src={image.src} alt={image.alt} loading="lazy" decoding="async" />
                          ) : cell}
                        </td>
                      );
                    })}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="ja-source-note">{framework.sourceNote}</p>
        </>
      )}

      <h2>よくある質問</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        関連: <a href="/ja/items">アイテム一覧</a>、<a href={`/items/${item.slug}`}>英語版(詳細)</a>。
      </div>
    </div>
  </article>

  <style>
    .ja-item-table-wrap { overflow-x: auto; border: 1px solid var(--line); border-radius: 14px; background: var(--surface); margin: 12px 0; }
    .ja-item-table { width: 100%; min-width: 700px; border-collapse: collapse; font-size: 0.84rem; }
    .ja-item-table th, .ja-item-table td { border-bottom: 1px solid var(--line); padding: 10px 12px; text-align: left; vertical-align: top; }
    .ja-item-table th { color: var(--candle); font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.05em; text-transform: uppercase; background: rgba(21, 16, 29, 0.58); white-space: nowrap; }
    .ja-item-table-icon { display: block; width: 68px; height: 68px; object-fit: contain; }
    .ja-item-table tr:last-child td { border-bottom: 0; }
    .ja-source-note { border-left: 3px solid var(--candle-dim); color: #ded3e6; padding-left: 12px; font-size: 0.88rem; }
  </style>
</Base>
