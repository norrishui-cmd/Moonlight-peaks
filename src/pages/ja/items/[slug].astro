---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { itemCategories } from '../../../data/items';
import { itemsJa } from '../../../i18n/items-ja';
import type { ItemCategory } from '../../../data/items';

export function getStaticPaths() {
  return itemCategories.map((item, index) => ({
    params: { slug: item.slug },
    props: { item, prev: itemCategories[(index - 1 + itemCategories.length) % itemCategories.length], next: itemCategories[(index + 1) % itemCategories.length] },
  }));
}

const { item } = Astro.props as { item: ItemCategory };
const tr = itemsJa[item.slug];
const url = new URL(`/ja/items/${item.slug}`, SITE.url).href;

const statusLabelJa: Record<string, string> = {
  confirmed: '確認済み', datamined: 'データ解析', expected: '確認予定',
};

const faq = [
  { q: `ムーンライト・ピークスの${tr.name}とは?`, a: `${tr.name}はムーンライト・ピークスのアイテムカテゴリの一つです。${tr.summary}` },
  { q: `${tr.name}の情報は確定していますか?`, a: item.status === 'confirmed'
      ? `${tr.name}のシステムは確認済みですが、個別のアイテム名や効果は引き続き実機で検証が必要です。`
      : `${tr.name}カテゴリはまだ実機で独自に確認できていません。推測せず、確認でき次第このページを更新します。` },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: 'アイテム', item: `${SITE.url}/ja/items` },
    { '@type': 'ListItem', position: 3, name: tr.name, item: url },
  ] },
];
---
<Base
  title={`${tr.name} | ムーンライト・ピークス アイテムガイド`}
  description={tr.dek}
  path={`/ja/items/${item.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: 'アイテム', href: '/ja/items' }, { label: tr.name }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">アイテム · {statusLabelJa[item.status] ?? item.status}</p>
      <h1><em>{tr.name}</em></h1>
      <p class="intro">{tr.dek}</p>

      <h2>詳細</h2>
      <p>{tr.summary}</p>

      <h2>例</h2>
      <ul>{tr.examples.map((e) => (<li>{e}</li>))}</ul>

      <h2>よくある質問</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        関連: <a href="/ja/items">アイテム一覧</a>、<a href={`/items/${item.slug}`}>英語版(詳細)</a>。
      </div>
    </div>
  </article>
</Base>
