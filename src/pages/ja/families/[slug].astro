---
import TopicPage from '../../../components/TopicPage.astro';
import { familiesSection, families } from '../../../data/families';
import { familiesJa } from '../../../i18n/families-ja';

export function getStaticPaths() {
  return families.filter((it) => familiesJa[it.slug]).map((it, i, arr) => {
    const tr = familiesJa[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...arr[(i - 1 + arr.length) % arr.length], ...familiesJa[arr[(i - 1 + arr.length) % arr.length].slug] },
        next: { ...arr[(i + 1) % arr.length], ...familiesJa[arr[(i + 1) % arr.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const jaSection = { ...familiesSection, base: '/ja/families', label: '家族', eyebrow: '世界' };
---
<TopicPage section={jaSection} item={item} prev={prev} next={next} lang="ja" basePath="/ja/families" />
