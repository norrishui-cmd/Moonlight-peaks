---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'フィオナが好きなプレゼントは?',
    acceptedAnswer: { '@type': 'Answer', text: 'フィオナの一番好きなプレゼントはまだ確認されていませんが、Purple Tulip、Purple Azalea、Purple Lavender、Egg、Moon Juiceなどは好意的に受け取られることが確認されています。' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: 'キャラクター', item: `${SITE.url}/ja/characters` },
    { '@type': 'ListItem', position: 3, name: 'フィオナ', item: `${SITE.url}/ja/characters/fiona` },
  ] },
];
---
<Base
  title="フィオナが好きなプレゼント | ムーンライト・ピークス キャラクターガイド"
  description="ムーンライト・ピークスのフィオナが確認済みで好む・苦手とするプレゼント一覧。"
  path="/ja/characters/fiona/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: 'キャラクター', href: '/ja/characters' }, { label: 'フィオナ', href: '/ja/characters/fiona' }, { label: 'プレゼント' }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">キャラクター・プレゼント</p>
      <h1>フィオナが好きな<em>プレゼント</em></h1>
      <p class="intro">
        発売週の海外メディア調査(TheGamer、2026年7月7日公開)に基づく、フィオナの確認済みプレゼント情報です。
      </p>

      <h2>大好きなプレゼント</h2>
      <p>フィオナの「大好き」ランクのプレゼントはまだ確認されていませんが、好き・苦手なプレゼントは下記の通り確認されています。</p>

      <h2>好きなプレゼント</h2>
      <p>フィオナは次のプレゼントも好みます: Purple Tulip、Purple Azalea、Purple Lavender、Egg、Moon Juice。</p>

      <h2>苦手なプレゼント</h2>
      <p>フィオナに次のプレゼントは避けましょう: Onion Seeds。好感度を下げてしまうことが確認されています。</p>

      <div class="callout wip">
        関連ページ: <a href="/ja/characters/fiona">フィオナのプロフィール</a>、
        <a href="/ja/characters">キャラクター一覧</a>、<a href="/characters/fiona/gifts">英語版(詳細)</a>。
      </div>
    </div>
  </article>
</Base>
