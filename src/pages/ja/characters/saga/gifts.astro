---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'サガが好きなプレゼントは?',
    acceptedAnswer: { '@type': 'Answer', text: 'サガはWhite Wineが大好きです。' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: 'キャラクター', item: `${SITE.url}/ja/characters` },
    { '@type': 'ListItem', position: 3, name: 'サガ', item: `${SITE.url}/ja/characters/saga` },
  ] },
];
---
<Base
  title="サガが好きなプレゼント | ムーンライト・ピークス キャラクターガイド"
  description="ムーンライト・ピークスのサガが確認済みで好む・苦手とするプレゼント一覧。"
  path="/ja/characters/saga/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: 'キャラクター', href: '/ja/characters' }, { label: 'サガ', href: '/ja/characters/saga' }, { label: 'プレゼント' }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">キャラクター・プレゼント</p>
      <h1>サガが好きな<em>プレゼント</em></h1>
      <p class="intro">
        発売週の海外メディア調査(TheGamer、2026年7月7日公開)に基づく、サガの確認済みプレゼント情報です。
      </p>

      <h2>大好きなプレゼント</h2>
      <p>サガが確認済みで大好きなプレゼント: White Wine。関係を早く深めたいときに最も効果的な選択肢です。</p>

      <h2>好きなプレゼント</h2>
      <p>大好きなプレゼントに次いで、サガは次のプレゼントも好みます: Red Wine、Beer、Single flowers (not bouquets)、Purple Tulip、Pink Azalea、Blood Grape、Strawberry Juice、Gazpacho Soup。</p>

      <h2>苦手なプレゼント</h2>
      <p>サガに次のプレゼントは避けましょう: Flower bouquets (multiple flowers)、Copper Bar。好感度を下げてしまうことが確認されています。</p>

      <div class="callout wip">
        関連ページ: <a href="/ja/characters/saga">サガのプロフィール</a>、
        <a href="/ja/characters">キャラクター一覧</a>、<a href="/characters/saga/gifts">英語版(詳細)</a>。
      </div>
    </div>
  </article>
</Base>
