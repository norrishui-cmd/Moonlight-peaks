---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';
import { characters, typeLabels, type CharType } from '../../../data/characters';
import { charTranslations } from '../../../i18n/characters-data';

const translatedSlugs = new Set(['count-dracula', 'saga', 'luna', 'orlock', 'brook', 'the-warlock', 'mina', 'sabrina', 'noel', 'fiona']);
const jaTranslations = charTranslations.ja;

// Japanese labels for character type/family — not claimed as official localization (no verified
// official Japanese UI terminology exists for these), just natural Japanese for this guide.
const typeLabelsJa: Record<CharType, string> = {
  vampire: '吸血鬼', werewolf: '狼男', witch: '魔女', mermaid: '人魚',
  seer: '預言者', ghost: '幽霊', human: '人間', other: 'その他',
};
const familyLabelJa = (family: string): string => {
  if (family.includes('Vampire')) return '吸血鬼一族(アンブロシア)';
  if (family.includes('Werewolf')) return '狼男一族(ローガン)';
  if (family.includes('Witch')) return '魔女一族(ウェッブ)';
  if (family.includes('Mermaid')) return '人魚一族(ホス)';
  if (family.includes('Seer')) return '預言者一族(カザン)';
  if (family.includes('Human')) return '人間一族(ヘンダーソン)';
  return '家族に属さない';
};

const isMainCast = (c: (typeof characters)[number]) => c.romanceable === true || c.id === 'count-dracula';
const mainCast = characters.filter(isMainCast);
const npcs = characters.filter((c) => !isMainCast(c));

function cardHref(id: string): string {
  return translatedSlugs.has(id) ? `/ja/characters/${id}` : `/characters/${id}`;
}
function displayName(c: (typeof characters)[number]): string {
  return translatedSlugs.has(c.id) ? jaTranslations[c.id].name : c.name;
}

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: 'キャラクター', item: `${SITE.url}/ja/characters` },
  ],
};
---
<Base
  title="ムーンライト・ピークス キャラクター一覧(全員) -ヴァンパイアのゴシックライフ-"
  description="ムーンライト・ピークスの全住民一覧を日本語で。恋愛対象23名と、その他のNPC。プロフィール翻訳済みのキャラクターは日本語ページへ、未翻訳は英語ページへリンクします。"
  path="/ja/characters"
  jsonLd={jsonLd}
  crumbs={[{ label: 'キャラクター' }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">エントリー / キャラクター</p>
      <h1>{GAME.title} <em>キャラクター</em>(全住民)</h1>
      <p class="intro">
        確認済みの全住民を、恋愛対象とその他のNPCに分けて掲載しています。プロフィールを日本語に
        翻訳済みのキャラクター(10名)は日本語ページへ、それ以外は現時点で最も情報が充実している
        英語版プロフィールへリンクしています。
      </p>

      <h2>恋愛対象・主要キャラクター({mainCast.length})</h2>
      <div class="cx-grid">
        {mainCast.map((c) => (
          <a class="cx-card" href={cardHref(c.id)}>
            <span class="cx-thumb">
              {c.img ? <img src={c.img} alt="" loading="lazy" width="72" height="72" /> : <span class="cx-letter" style={`background: linear-gradient(135deg, ${c.c1}, ${c.c2})`}>{displayName(c).charAt(0)}</span>}
            </span>
            <span>
              <strong>{displayName(c)}</strong>
              <em>{familyLabelJa(c.family)} ・ {typeLabelsJa[c.type]}</em>
            </span>
          </a>
        ))}
      </div>

      <h2>その他のNPC({npcs.length})</h2>
      <div class="cx-grid">
        {npcs.map((c) => (
          <a class="cx-card" href={cardHref(c.id)}>
            <span class="cx-thumb">
              {c.img ? <img src={c.img} alt="" loading="lazy" width="72" height="72" /> : <span class="cx-letter" style={`background: linear-gradient(135deg, ${c.c1}, ${c.c2})`}>{displayName(c).charAt(0)}</span>}
            </span>
            <span>
              <strong>{displayName(c)}</strong>
              <em>{familyLabelJa(c.family)} ・ {typeLabelsJa[c.type]}</em>
            </span>
          </a>
        ))}
      </div>

      <div class="callout wip">
        現在10名(ドラキュラ伯爵、Saga、Luna、Orlock、Brook、謎の術士、ミナ、サブリナ、ノエル、
        フィオナ)のプロフィールを日本語に翻訳済みです。それ以外のキャラクターをクリックすると、
        確認済み情報がより充実している<a href="/characters">英語版キャラクターページ</a>の
        該当プロフィールに移動します。
      </div>
    </div>
  </article>

  <style>
    .cx-grid { display: grid; grid-template-columns: 1fr; gap: 10px; margin: 8px 0 24px; }
    @media (min-width: 640px) { .cx-grid { grid-template-columns: 1fr 1fr; } }
    .cx-card { display: flex; align-items: center; gap: 12px; border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 12px; transition: border-color .15s ease; }
    .cx-card:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); }
    .cx-thumb { flex: 0 0 auto; width: 72px; height: 72px; border-radius: 10px; overflow: hidden; display: flex; align-items: center; justify-content: center; }
    .cx-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .cx-letter { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-family: var(--display); font-weight: 700; font-size: 1.6rem; color: rgba(255,255,255,0.9); }
    .cx-card span:not(.cx-thumb) { display: flex; flex-direction: column; }
    .cx-card strong { font-family: var(--display); font-weight: 600; font-size: 0.96rem; color: var(--mist); }
    .cx-card em { font-style: normal; font-size: 0.78rem; color: var(--faint); margin-top: 2px; }
  </style>
</Base>
