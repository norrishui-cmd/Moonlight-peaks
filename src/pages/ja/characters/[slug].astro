---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { characters } from '../../../data/characters';
import { charTranslations } from '../../../i18n/characters-data';

export function getStaticPaths() {
  return Object.keys(charTranslations.ja).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const base = characters.find((c) => c.id === slug)!;
const tr = charTranslations.ja[slug as keyof typeof charTranslations.ja];

const url = new URL(`/ja/characters/${slug}`, SITE.url).href;
const imgAbs = base.img ? new URL(base.img, SITE.url).href : undefined;
const statusLabel =
  base.status === 'confirmed' ? '確認済み'
  : base.status === 'reported' ? '報告あり'
  : base.status === 'datamined' ? 'データ解析'
  : '未確認';
const romanceText = base.romanceable === true ? tr.romanceYes : base.romanceable === false ? tr.romanceNo : tr.romanceTbc;

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: 'キャラクター', item: `${SITE.url}/ja/characters` },
    { '@type': 'ListItem', position: 3, name: tr.name, item: url },
  ] },
  { '@context': 'https://schema.org', '@type': 'Person', name: tr.name, description: tr.desc, ...(imgAbs ? { image: imgAbs } : {}) },
];
---
<Base
  title={`${tr.name} - Moonlight Peaks キャラクターガイド`}
  description={`Moonlight Peaksの${tr.name}: ${tr.desc} 家族、恋愛対象かどうか、現時点で判明している情報。`}
  path={`/ja/characters/${slug}`}
  jsonLd={jsonLd}
  ogImage={base.img}
  crumbs={[{ label: 'キャラクター', href: '/ja/characters' }, { label: tr.name }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">キャラクター · {tr.typeLabel}</p>

      <div class="chead">
        <div class="cavatar">
          {base.img ? (
            <img src={base.img} alt={`${tr.name} portrait`} width="160" height="160" />
          ) : (
            <span class="fallback-avatar" style={`background: linear-gradient(135deg, ${base.c1}, ${base.c2})`}>{tr.name.charAt(0)}</span>
          )}
        </div>
        <div class="cmeta">
          <h1>{tr.name}</h1>
          <div class="ctags">
            <span class={`cbadge ${base.status === 'confirmed' ? 'is-conf' : base.status === 'reported' ? 'is-rep' : base.status === 'datamined' ? 'is-dm' : 'is-unc'}`}>{statusLabel}</span>
            <span class="ctag fam">{tr.familyLabel}</span>
            {base.romanceable === true && <span class="ctag heart">恋愛対象</span>}
            {base.romanceable === false && <span class="ctag">恋愛対象外</span>}
            {base.romanceable === null && <span class="ctag">恋愛: 未確認</span>}
          </div>
          <p class="cdesc">{tr.desc}</p>
        </div>
      </div>

      <h2>判明していること</h2>
      <ul>{tr.knownInfo.map((k) => (<li>{k}</li>))}</ul>

      <h2>恋愛について</h2>
      <p>{romanceText}</p>

      {(base.lovedGifts?.length || base.likedGifts?.length || base.dislikedGifts?.length) && (
        <>
          <h2>好きなプレゼント</h2>
          {base.lovedGifts && base.lovedGifts.length > 0 && (
            <p><strong>大好き:</strong> {base.lovedGifts.join('、')}</p>
          )}
          {base.likedGifts && base.likedGifts.length > 0 && (
            <p><strong>好き:</strong> {base.likedGifts.join('、')}</p>
          )}
          {base.dislikedGifts && base.dislikedGifts.length > 0 && (
            <p><strong>苦手:</strong> {base.dislikedGifts.join('、')}</p>
          )}
          <p class="cnote">発売週の海外メディア調査(TheGamer、2026年7月7日公開)に基づく確認データです。</p>
        </>
      )}

      <div class="callout">
        関連ページ: <a href="/ja/characters">キャラクター一覧</a>、<a href="/romance">恋愛ガイド</a>、
        <a href="/families">家族</a>、<a href="/characters">英語版の詳細ページ</a>。
      </div>
    </div>
  </article>
</Base>
