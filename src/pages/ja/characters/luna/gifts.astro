---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'ルナが好きなプレゼントは?',
    acceptedAnswer: { '@type': 'Answer', text: 'ルナはPurple Tulip、Purple Azalea、White Roseが大好きです。' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE.url}/ja` },
    { '@type': 'ListItem', position: 2, name: 'キャラクター', item: `${SITE.url}/ja/characters` },
    { '@type': 'ListItem', position: 3, name: 'ルナ', item: `${SITE.url}/ja/characters/luna` },
  ] },
];
---
<Base
  title="ルナが好きなプレゼント | ムーンライト・ピークス キャラクターガイド"
  description="ムーンライト・ピークスのルナが確認済みで好む・苦手とするプレゼント一覧。"
  path="/ja/characters/luna/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: 'キャラクター', href: '/ja/characters' }, { label: 'ルナ', href: '/ja/characters/luna' }, { label: 'プレゼント' }]}
  lang="ja"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">キャラクター・プレゼント</p>
      <h1>ルナが好きな<em>プレゼント</em></h1>
      <p class="intro">
        発売週の海外メディア調査(TheGamer、2026年7月7日公開)に基づく、ルナの確認済みプレゼント情報です。
      </p>

      <h2>大好きなプレゼント</h2>
      <p>ルナが確認済みで大好きなプレゼント: Purple Tulip、Purple Azalea、White Rose。関係を早く深めたいときに最も効果的な選択肢です。</p>

      <h2>好きなプレゼント</h2>
      <p>大好きなプレゼントに次いで、ルナは次のプレゼントも好みます: Blood Grape。</p>

      <h2>苦手なプレゼント</h2>
      <p>ルナに次のプレゼントは避けましょう: Rusty Bean Can。好感度を下げてしまうことが確認されています。</p>

      <div class="callout wip">
        関連ページ: <a href="/ja/characters/luna">ルナのプロフィール</a>、
        <a href="/ja/characters">キャラクター一覧</a>、<a href="/characters/luna/gifts">英語版(詳細)</a>。
      </div>
    </div>
  </article>
</Base>
