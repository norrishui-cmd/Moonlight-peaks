---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const faq = [
  { q: 'How many Vampsters are there in Moonlight Peaks?', a: 'Confirmed via the official wiki: 53 Vampsters total, scattered across the game\u2019s outdoor areas.' },
  { q: 'Where do you take Vampsters in Moonlight Peaks?', a: 'Confirmed: back to their home, located in a cave in Misty Shores (unlocked via the "A Bridge Too Far" quest).' },
  { q: 'Can you carry more than one Vampster at a time?', a: 'No — you can only carry one Vampster at a time. Interacting with someone, or triggering a cutscene, makes you drop the one you\u2019re carrying.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Collection', item: new URL('/collection', SITE.url).href },
    { '@type': 'ListItem', position: 3, name: 'Vampsters', item: new URL('/collection/vampsters', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Vampsters: All 53 & How to Collect Them"
  description="Moonlight Peaks Vampster guide: what they are, the confirmed total of 53, how to carry them, and where their home is — sourced from the official wiki."
  path="/collection/vampsters"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Collection', href: '/collection' }, { label: 'Vampsters' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Collection · Vampsters</p>
      <h1>Moonlight Peaks <em>Vampsters</em></h1>
      <p class="intro">
        Vampsters are mischievous little creatures that love to hide and cause trouble all over
        Moonlight Peaks, but get sad if they're left alone too long. Confirmed via the official
        wiki: there are 53 of them, and you round each one up and carry it home.
      </p>

      <div class="callout">
        <strong>Quick answer:</strong> Vampsters are lost creatures you find outdoors and carry —
        one at a time — back to their home in a cave in Misty Shores. Confirmed total: 53.
      </div>

      <h2>How the Vampster quest starts</h2>
      <p>
        Community-reported: during your first week or so, a trip to the Cave of Echoes to mine
        copper introduces a Vampster scurrying away near the entrance. Inside, you meet
        <a href="/characters/alina">Alina</a>, who explains that the Vampsters are lost and asks
        for help getting them all home.
      </p>

      <h2>Where to find them</h2>
      <p>
        Confirmed via the official wiki: Vampsters are scattered across Moonlight Peaks, always
        zipping around and hiding in the strangest places. Two confirmed example spots: one is
        inside Luna's house in Moonlit Pines, up her spiral stairs by her bed with a candle on its
        head, and another is inside the Moonlit Tower in Misty Shores, hiding behind a tan leafy
        armchair.
      </p>

      <h2>How to carry and return them</h2>
      <ul>
        <li><strong>One at a time:</strong> confirmed — you can't stack multiple Vampsters; you carry a single one until you place it.</li>
        <li><strong>Their home:</strong> confirmed — a cave in Misty Shores (unlocked via <a href="/quests/a-bridge-too-far">A Bridge Too Far</a>).</li>
        <li><strong>Watch for interruptions:</strong> community-reported — talking to a resident, or any cutscene triggering, makes you drop the Vampster you're carrying, so clear dialogue-heavy areas before you set off.</li>
      </ul>

      <h2>Common problems</h2>
      <ul>
        <li><strong>Lost track of a Vampster after a cutscene:</strong> expected — cutscenes make you drop whichever one you were carrying; it stays where you dropped it.</li>
        <li><strong>Can't find any more Vampsters:</strong> try clearing overgrown grass and bushes with your scythe in areas you haven't fully cleared yet.</li>
      </ul>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Sourced from the official Moonlight Peaks Wiki (moonlightpeaks.wiki.gg). Related:
        <a href="/collection">Collection hub</a>, <a href="/locations/mines">Cave of Echoes</a>,
        <a href="/achievements">achievements</a>, <a href="/characters/alina">Alina</a>.
      </div>
    </div>
  </article>
</Base>
