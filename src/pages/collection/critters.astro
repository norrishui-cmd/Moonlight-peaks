---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';
import { collectionBySlug } from '../../data/collections';

const collection = collectionBySlug.get('critters');
const isImageCell = (cell: string) => cell.startsWith('/images/');

const faq = [
  { q: 'What can you do with critters in Moonlight Peaks?', a: 'Confirmed: any critter (or fish) you catch can be displayed in your home as decoration, so it\u2019s worth keeping something rare or cute instead of selling it.' },
  { q: 'Do critters change by season in Moonlight Peaks?', a: 'Yes, confirmed: like fishing, different seasons and weather bring out different bugs and critters.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Collection', item: new URL('/collection', SITE.url).href },
    { '@type': 'ListItem', position: 3, name: 'Critters', item: new URL('/collection/critters', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Critters — Catching, Seasons & Home Decor"
  description="Confirmed: critters and bugs in Moonlight Peaks change by season and weather, and any one you catch can be displayed in your home as decoration."
  path="/collection/critters"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Collection', href: '/collection' }, { label: 'Critters' }]}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Collection · Critters</p>
      <h1>Moonlight Peaks <em>critters</em></h1>
      <p class="intro">
        Confirmed via a first-week progression guide: bugs and small creatures you catch aren't
        just for selling or cooking — any one you catch can be displayed in your home as decoration.
      </p>

      <h2>Catching critters</h2>
      <p>
        Confirmed: bug catching is quick to learn but easy to fumble, since critters move fast and
        a missed swipe costs energy. Like fishing, different seasons and weather bring out different
        bugs, so a critter you can't find one night may simply be waiting on the right conditions.
      </p>

      <h2>Displaying them as decoration</h2>
      <p>
        Confirmed: it's worth keeping something rare or cute instead of selling it, since any
        creature you catch — fish or bugs alike — can be placed in your home as a decorative piece.
        See <a href="/farm/house">your house</a> for more on decorating.
      </p>

      {collection && (
        <>
          <h2>Critter name table</h2>
          <p>
            The table below uses the critter names, icons, and visible parameters from the screenshots supplied for this site.
            Values that are not visible in the supplied screenshots remain marked as <strong>-</strong>.
          </p>
          <div class="collection-table-wrap">
            <table class="collection-table">
              <thead>
                <tr>
                  {collection.tableColumns.map((column) => <th>{column}</th>)}
                </tr>
              </thead>
              <tbody>
                {collection.tableRows.map((row) => (
                  <tr>
                    {row.map((cell) => (
                      <td>
                        {isImageCell(cell) ? (
                          <img class="collection-cell-icon" src={cell} alt={row[1] || 'Critter icon'} loading="lazy" />
                        ) : cell}
                      </td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </>
      )}

      <h2>Still being verified</h2>
      <ul>
        <li>Full spawn location list per critter.</li>
        <li>Complete season/weather rules per species.</li>
        <li>Whether critters can be gifted or sold, beyond display.</li>
      </ul>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Related: <a href="/collection">Collection hub</a>, <a href="/environment">environment</a>,
        <a href="/map">map</a>, <a href="/activities">activities</a>.
      </div>
    </div>
  </article>
  <style>
    .collection-table-wrap {
      overflow-x: auto;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--surface);
      margin: 12px 0 22px;
    }
    .collection-table {
      width: 100%;
      min-width: 900px;
      border-collapse: collapse;
      font-size: 0.84rem;
    }
    .collection-table th,
    .collection-table td {
      border-bottom: 1px solid var(--line);
      padding: 10px 12px;
      text-align: left;
      vertical-align: middle;
    }
    .collection-table th {
      color: var(--candle);
      font-family: var(--mono);
      font-size: 0.68rem;
      text-transform: uppercase;
      white-space: nowrap;
    }
    .collection-cell-icon {
      width: 56px;
      height: 56px;
      display: block;
      object-fit: contain;
      border-radius: 12px;
      background: rgba(15, 9, 24, 0.45);
    }
  </style>
</Base>
