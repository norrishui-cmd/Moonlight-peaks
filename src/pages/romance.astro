---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';
import YouTube from '../components/YouTube.astro';
import PriorityLinks from '../components/PriorityLinks.astro';
import { romancePriorityLinks } from '../data/priorityLinks';
import { characters, typeLabels } from '../data/characters';

// Dynamically pull every romanceable resident straight from the character data (23 confirmed at
// launch), grouped by family, instead of a stale hand-maintained list.
const romanceable = characters.filter((c) => c.romanceable === true);
const groups = new Map<string, typeof romanceable>();
for (const c of romanceable) {
  const key = c.family || 'Unknown';
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(c);
}
const familyGroups = [...groups.entries()].sort((a, b) => b[1].length - a[1].length);

const famHref = (family: string) =>
  family.includes('Ambrosia') || family.includes('Dracula') ? '/families/vampires'
  : family.includes('Logan') ? '/families/werewolves'
  : family.includes('Webb') ? '/families/witches'
  : family.includes('Hosu') ? '/families/mermaids'
  : family.includes('Khazan') ? '/families/seers'
  : family.includes('Henderson') ? '/families/henderson'
  : '/families';

const faq = [
  { q: 'How many romanceable characters are in Moonlight Peaks?', a: 'Confirmed at launch: 23, via the official launch romance showcase — up from around 15 cited in earlier pre-launch coverage. They span six families (Ambrosia, Webb, Logan, Hosu, Khazan, Henderson) plus two wild cards who belong to no family: Death and the love demon Llemi.' },
  { q: 'Who are the bachelors and marriage candidates in Moonlight Peaks?', a: 'Dating is fully gender-neutral, so Moonlight Peaks doesn\u2019t lock characters into separate bachelor/bachelorette pools — all 23 dateable characters (and marriage candidates) are open to every player. Browse the full list of romance options by family below.' },
  { q: 'What heart level do you need to start dating?', a: 'Confirmed at launch: dating unlocks at Heart Level 4, when you can invite a resident on dates.' },
  { q: 'What heart level do you need to get married?', a: 'Confirmed at launch: you can propose at Heart Level 8. The wedding happens within a week of proposing, and is attended by the town\u2019s vampires and werewolves.' },
  { q: 'Can you date multiple people at once?', a: 'Yes — confirmed at launch. Partners will notice and comment if you\u2019re juggling several of them, but it\u2019s mild jealousy rather than a hard rivalry system. Marriage itself is strictly monogamous.' },
  { q: 'What happens if you turn down too many dates?', a: 'Confirmed at launch: reject a partner\u2019s date invitations too often and they\u2019ll break up with you, then go quiet for a few days before forgiving you.' },
  { q: 'What are dates like in Moonlight Peaks?', a: 'Confirmed at launch: dates play out as short minigames rather than passive scenes — examples include assembling a flower bouquet in colours your partner asks for, or roasting a marshmallow to their preferred doneness.' },
  { q: 'Can you get married in Moonlight Peaks?', a: 'Yes. You can marry one partner, and your spouse moves onto your farm afterward, unlocking a further heart event as your spouse. There are no children.' },
  { q: 'Can you have children in Moonlight Peaks?', a: 'No — confirmed by multiple sources, with no announced plans to add the mechanic. Marrying an older character with existing children (Orlock, for example, is father to Mina and Evan) is reported to make you a step-parent instead.' },
  { q: 'Can you turn your spouse into a vampire?', a: 'Yes, confirmed at launch — marrying a non-vampire partner lets you turn them into a vampire afterward.' },
  { q: 'Is dating gender-locked?', a: 'No. Dating is fully gender-neutral \u2014 every romanceable character is open to every player, regardless of how you build your own vampire.' },
  { q: 'Can a vampire romance a werewolf?', a: 'Yes. Vampires and werewolves in town rarely get along and trade petty spats, so pursuing a werewolf such as Saga means romancing across that divide — which is part of the charm.' },
  { q: 'What do you get from building relationships?', a: 'Confirmed at launch: relationships unlock special blueprints and crafting materials for your farm, plus personal character stories — so courting the whole town pays off beyond romance itself.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Romance', item: new URL('/romance', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Romance Options — Bachelors & Marriage Candidates"
  description="All 23 Moonlight Peaks romance options: bachelors, bachelorettes and marriage candidates, gender-neutral dating, dateable characters by family, and how marriage works."
  path="/romance"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Romance & families' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entry · Hearts</p>
      <h1>Moonlight Peaks <em>romance options</em>, bachelors & marriage candidates</h1>
      <p class="intro">
        Romance is a headline feature of {GAME.title}: 23 confirmed romance options — bachelors,
        bachelorettes, and marriage candidates alike — with gender-neutral dating and marriage (though
        no children). This page is built directly from our character data, so the roster of dateable
        characters below updates automatically as we verify more. Updated {SITE.updated}.
      </p>

      <div class="romance-video">
        <YouTube id="YFb9capELQw" title="Moonlight Peaks romance video" />
      </div>

      <h2>How romance actually works</h2>
      <p>
        Confirmed at launch: talk to residents and give gifts to raise your relationship, tracked in a
        relationship menu that shows recent gifts and their reactions. <strong>Heart Level 4</strong>
        unlocks dating — invites play out as short minigames (like assembling a bouquet in the colours
        your date asks for) rather than passive scenes. <strong>Heart Level 8</strong> unlocks a
        marriage proposal; the wedding happens within a week and is attended by the town's vampires
        and werewolves.
      </p>
      <p>
        You can date several residents at once — partners will notice and comment, but it's mild
        jealousy rather than a hard rivalry. Marriage itself is strictly monogamous, and turning down
        a partner's date invites too often leads to a breakup (with a cooldown before they'll forgive
        you). After marriage, your spouse moves onto your farm, unlocks a further heart event, and can
        be turned into a vampire. Building relationships more broadly unlocks blueprints and crafting
        materials, not just the romance itself.
      </p>

      <h2>Start here: planning your romance route</h2>
      <p>
        With 23 options and no full gift/heart-event database published anywhere yet, a shortlist beats
        trying to court everyone at once. Four steps, in order:
      </p>
      <div class="rp-steps">
        <a class="rp-step" href="/tools/romance-match-quiz">
          <span class="rp-step-num">1</span>
          <strong>Take the quiz</strong>
          <span>A fun, sourced-hints match to narrow down who catches your eye.</span>
        </a>
        <a class="rp-step" href="/tools/families-explorer">
          <span class="rp-step-num">2</span>
          <strong>Browse by family</strong>
          <span>See all 23 romanceable residents grouped by their real family ties.</span>
        </a>
        <a class="rp-step" href="/tools/romance-planner">
          <span class="rp-step-num">3</span>
          <strong>Build your shortlist</strong>
          <span>Save your picks and notes privately in your browser with the Romance Planner.</span>
        </a>
        <a class="rp-step" href="/tools/gift-tracker">
          <span class="rp-step-num">4</span>
          <strong>Log your own gifts</strong>
          <span>Track what you've tried with each resident until the full gift guide fills in.</span>
        </a>
      </div>

      <h2>The basics</h2>
      <p>
        23 residents are dateable, spread across six families — vampires (Ambrosia), werewolves
        (Logan), witches (Webb), mermaids (Hosu), seers (Khazan), and humans (Henderson) — plus two
        wild cards who belong to no family: Death and the love demon Llemi. Standing with a family
        is expected to shape festivals, gifts, and which doors open to you.
      </p>

      <h2>All 23 romanceable residents, by family</h2>
      <p>Pulled directly from our character data — each name links to a full profile with what's confirmed so far.</p>
      {familyGroups.map(([family, members]) => (
        <div class="romance-family-group">
          <h3><a href={famHref(family)}>{family}</a> <span class="rf-count">({members.length})</span></h3>
          <table class="facts">
            <tr><th>Character</th><th>Type</th><th>Status</th></tr>
            {members.map((c) => (
              <tr>
                <td><a href={`/characters/${c.id}`}>{c.name}</a></td>
                <td>{typeLabels[c.type] || c.type}</td>
                <td>{c.status}</td>
              </tr>
            ))}
          </table>
        </div>
      ))}

      <h2>Gift guide</h2>
      <p>
        Full loved/liked/disliked gift lists aren't public for most residents yet — Saga is the first
        with confirmed gift data (she loves white wine). See her <a href="/characters/saga">profile</a>
        for what's verified, and use the <a href="/tools/gift-tracker">Gift Tracker</a> to log your own
        finds until the rest of the roster catches up.
      </p>

      <PriorityLinks
        title="Romance searches to open next"
        note="gifts and heart events"
        links={romancePriorityLinks}
      />

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Post-launch entry, built from live character data. Related:
        <a href="/characters">all characters</a>, <a href="/families">the seven families</a>,
        <a href="/character-creator">character creator</a>, <a href="/beginner-guide">beginner guide</a>.
      </div>
    </div>
  </article>
  <style>
    .romance-family-group { margin: 20px 0; }
    .romance-family-group h3 { margin: 0 0 8px; }
    .rf-count { color: var(--muted); font-weight: 400; font-size: 0.85rem; }
    .rp-steps { display: grid; grid-template-columns: 1fr; gap: 10px; margin: 14px 0 24px; }
    @media (min-width: 640px) { .rp-steps { grid-template-columns: 1fr 1fr; } }
    .rp-step {
      display: flex; flex-direction: column; gap: 4px; border: 1px solid var(--line); border-radius: 14px;
      background: var(--surface); padding: 14px 16px; text-decoration: none; position: relative;
      transition: border-color .15s ease;
    }
    .rp-step:hover { border-color: color-mix(in srgb, var(--candle) 45%, var(--line)); }
    .rp-step-num {
      position: absolute; top: 12px; right: 14px; font-family: var(--mono); font-size: 0.7rem; color: var(--candle);
      border: 1px solid color-mix(in srgb, var(--candle) 40%, var(--line)); border-radius: 999px; width: 20px; height: 20px;
      display: flex; align-items: center; justify-content: center;
    }
    .rp-step strong { font-family: var(--display); font-weight: 600; font-size: 0.94rem; color: var(--mist); padding-right: 26px; }
    .rp-step span:last-child { font-size: 0.8rem; color: var(--faint); line-height: 1.4; }
    .romance-video {
      margin: clamp(1.6rem, 4vw, 2.6rem) 0 clamp(2rem, 5vw, 3rem);
    }
  </style>
</Base>
