---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';
import YouTube from '../components/YouTube.astro';
import PriorityLinks from '../components/PriorityLinks.astro';
import { romancePriorityLinks } from '../data/priorityLinks';

const named = [
  { name: 'Count Dracula', slug: 'count-dracula', family: 'Vampire', note: 'Your father. Story character — not romanceable.', status: 'confirmed' },
  { name: 'Saga', slug: 'saga', family: 'Werewolf', note: 'Townsperson revealed by the developers; her energy shifts with the full moon.', status: 'reported' },
  { name: 'Mina', slug: 'mina', family: '—', note: 'Townsperson revealed by the developers; romance status to verify.', status: 'reported' },
  { name: 'Orlock', slug: 'orlock', family: 'Vampire', note: 'A vampire family head.', status: 'reported' },
  { name: 'Luna', slug: 'luna', family: 'Witch', note: 'A farming witch.', status: 'reported' },
  { name: 'Pumpkin Head', slug: 'pumpkin-head', family: '—', note: 'Theatrical event host around town.', status: 'reported' },
  { name: 'Logan', slug: 'logan', family: 'Werewolf', note: 'Has a distinctive werewolf house.', status: 'reported' },
  { name: 'Death', slug: 'death', family: '—', note: 'Datamined resident with his own home ("Death\u2019s Shack"); romance status is speculation, not confirmed.', status: 'datamined' },
];

const famHref = (family: string) =>
  family === 'Vampire' ? '/families/vampires'
  : family === 'Werewolf' ? '/families/werewolves'
  : family === 'Witch' ? '/families/witches'
  : '/families';

const faq = [
  { q: 'How many romanceable characters are in Moonlight Peaks?', a: 'Around two dozen (roughly 24). Earlier coverage cited 15, so the cast grew during development, and the developers have said they hope to keep adding to it.' },
  { q: 'Can you get married in Moonlight Peaks?', a: 'Yes, you can marry a romance partner. There are no children in the game.' },
  { q: 'Is dating gender-locked?', a: 'No. Character models are intentionally gender-neutral, so you can romance any eligible resident regardless of how you build your own vampire.' },
  { q: 'Can a vampire romance a werewolf?', a: 'Yes. Vampires and werewolves in town rarely get along and trade petty spats, so pursuing a werewolf such as Saga means romancing across that divide — which is part of the charm.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Romance', item: new URL('/romance', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Romance & Marriage — Dateable Characters"
  description="Romance in Moonlight Peaks: around two dozen dateable residents, gender-neutral dating, marriage (no children), the seven families, and named characters so far."
  path="/romance"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Romance & families' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entry · Hearts</p>
      <h1>Moonlight Peaks <em>romance</em> & the seven families</h1>
      <p class="intro">
        Romance is a headline feature of {GAME.title}: a whole town of supernatural singles, gender-neutral
        dating, and marriage (though no children). Here is what is confirmed so far, kept separate from
        what we will only verify once the game is live.
      </p>

      <div class="romance-video">
        <YouTube id="YFb9capELQw" title="Moonlight Peaks romance video" />
      </div>

      <h2>Start here: planning your romance route</h2>
      <p>
        No confirmed gift lists or affection mechanics exist yet, but there's a real, honest way to get
        ready before {GAME.releaseLabel}. Four steps, in order:
      </p>
      <div class="rp-steps">
        <a class="rp-step" href="/tools/romance-match-quiz">
          <span class="rp-step-num">1</span>
          <strong>Take the quiz</strong>
          <span>A fun, sourced-hints match to narrow down who catches your eye.</span>
        </a>
        <a class="rp-step" href="/previews/day-one-romance-route">
          <span class="rp-step-num">2</span>
          <strong>Check the day-one route</strong>
          <span>See which residents already have a known home in datamined files.</span>
        </a>
        <a class="rp-step" href="/tools/romance-planner">
          <span class="rp-step-num">3</span>
          <strong>Build your shortlist</strong>
          <span>Save your picks and notes privately in your browser with the Romance Planner.</span>
        </a>
        <a class="rp-step" href="/previews/what-to-expect-from-romance-mechanics">
          <span class="rp-step-num">4</span>
          <strong>Set your expectations</strong>
          <span>Know what's genre-typical versus actually confirmed before you dive in.</span>
        </a>
      </div>

      <h2>The basics</h2>
      <p>
        Around two dozen residents are dateable, spread across the town's seven families — vampires,
        werewolves, witches, mermaids and more. You can befriend or romance them, build a relationship,
        and ultimately marry. Standing with a family is expected to shape festivals, gifts, and which
        doors open to you.
      </p>

      <h2>Named characters so far</h2>
      <p>Only Count Dracula is first-party confirmed as story-central; the others appear in developer reveals and pre-launch coverage and will be verified at launch.</p>
      <table class="facts">
        <tr><th>Character</th><th>Family / status</th></tr>
        {named.map((c) => (
          <tr>
            <td><strong><a href={`/characters/${c.slug}`}>{c.name}</a></strong> {(c.status === 'reported' || c.status === 'datamined') && <span style="color:var(--faint);font-family:var(--mono);font-size:0.7rem">{c.status}</span>}<br /><span style="color:var(--muted);font-size:0.85rem">{c.note}</span></td>
            <td>{c.family === '—' ? '—' : <a href={famHref(c.family)}>{c.family}</a>}</td>
          </tr>
        ))}
      </table>

      <h2>Gift guide</h2>
      <p>
        Loved and liked gifts for each character will be published — and turned into a gift tracker —
        once the live build confirms them on {GAME.releaseLabel}. We won't list a gift as "loved"
        until it's verified in-game.
      </p>

      <PriorityLinks
        title="Romance searches to open next"
        note="gifts and heart events"
        links={romancePriorityLinks}
      />

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Pre-launch entry. At launch this becomes the full named cast + a gift tracker. Related:
        <a href="/characters">all characters</a>, <a href="/families">the seven families</a>,
        <a href="/activities/character-creator">character creator</a>, <a href="/beginner-guide">beginner guide</a>.
      </div>
    </div>
  </article>
  <style>
    .rp-steps { display: grid; grid-template-columns: 1fr; gap: 10px; margin: 14px 0 24px; }
    @media (min-width: 640px) { .rp-steps { grid-template-columns: 1fr 1fr; } }
    .rp-step {
      display: flex; flex-direction: column; gap: 4px; border: 1px solid var(--line); border-radius: 14px;
      background: var(--surface); padding: 14px 16px; text-decoration: none; position: relative;
      transition: border-color .15s ease;
    }
    .rp-step:hover { border-color: color-mix(in srgb, var(--candle) 45%, var(--line)); }
    .rp-step-num {
      position: absolute; top: 12px; right: 14px; font-family: var(--mono); font-size: 0.7rem; color: var(--candle);
      border: 1px solid color-mix(in srgb, var(--candle) 40%, var(--line)); border-radius: 999px; width: 20px; height: 20px;
      display: flex; align-items: center; justify-content: center;
    }
    .rp-step strong { font-family: var(--display); font-weight: 600; font-size: 0.94rem; color: var(--mist); padding-right: 26px; }
    .rp-step span:last-child { font-size: 0.8rem; color: var(--faint); line-height: 1.4; }
    .romance-video {
      margin: clamp(1.6rem, 4vw, 2.6rem) 0 clamp(2rem, 5vw, 3rem);
    }
  </style>
</Base>
