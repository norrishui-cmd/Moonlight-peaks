---
import Base from '../../../../layouts/Base.astro';
import { SITE, GAME } from '../../../../consts';
import { sideQuests } from '../../../../data/quests-side';
import { sideQuestsDe } from '../../../../i18n/quests-side-de';

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Quest-Guide', item: `${SITE.url}/de/quests` },
    { '@type': 'ListItem', position: 3, name: 'Nebenquests', item: `${SITE.url}/de/quests/side` },
  ],
};
---
<Base
  title="Moonlight Peaks Nebenquests — Jede NPC-Quest & Jedes Nebensystem"
  description="Jede bestätigte Moonlight-Peaks-Nebenquest und NPC-spezifische Anfrage — Angelwettbewerbe, Hausupgrades, das Job-Brett, und die kreaturensammelnden Nebensysteme der Stadt."
  path="/de/quests/side"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Quest-Guide', href: '/de/quests' }, { label: 'Nebenquests' }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Quests · Nebenquests</p>
      <h1>Neben<em>quests</em></h1>
      <p class="intro">
        {sideQuests.length} bestätigte Nebenquests und NPC-spezifische Anfragen, getrennt von der
        <a href="/de/quests/story">Hauptgeschichte-Kette</a>. Diese reichen von einmaligen Quests
        mit einem bestimmten Bewohner bis zu laufenden Nebensystemen wie dem Job-Brett.
      </p>

      <div class="sq-grid">
        {sideQuests.filter((q) => sideQuestsDe[q.slug]).map((q) => (
          <a class="sq-card" href={`/de/quests/side/${q.slug}`}>
            <span class="sq-tag">{q.npc ? q.npc.charAt(0).toUpperCase() + q.npc.slice(1) : 'Nebensystem'}</span>
            <h3>{sideQuestsDe[q.slug].title}</h3>
            <p>{sideQuestsDe[q.slug].summary.length > 130 ? sideQuestsDe[q.slug].summary.slice(0, 127) + '…' : sideQuestsDe[q.slug].summary}</p>
          </a>
        ))}
      </div>

      <div class="callout wip">
        Verwandt: <a href="/de/quests">Quest-Hub</a>, <a href="/de/quests/story">Hauptgeschichte</a>,
        <a href="/collections">Sammlungen</a>, <a href="/de/characters">Charaktere</a>.
      </div>
    </div>
  </article>

  <style>
    .sq-grid { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 22px 0 30px; }
    @media (min-width: 640px) { .sq-grid { grid-template-columns: 1fr 1fr; } }
    .sq-card {
      display: block; border: 1px solid var(--line); border-radius: 14px; background: var(--surface);
      padding: 16px; text-decoration: none; color: inherit;
      transition: border-color .15s ease, transform .15s ease;
    }
    .sq-card:hover { border-color: color-mix(in srgb, var(--candle) 54%, var(--line)); transform: translateY(-2px); }
    .sq-tag { font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--candle); }
    .sq-card h3 { margin: 6px 0 6px; font-size: 1.05rem; }
    .sq-card p { margin: 0; color: #ded3e6; font-size: 0.86rem; }
  </style>
</Base>
