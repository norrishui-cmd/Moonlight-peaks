---
import Base from '../../../../layouts/Base.astro';
import { SITE, GAME } from '../../../../consts';
import { storyQuests, storyQuestBySlug } from '../../../../data/quests-story';
import { storyQuestsDe, storyChaptersDe } from '../../../../i18n/quests-story-de';

export function getStaticPaths() {
  return storyQuests.filter((q) => storyQuestsDe[q.slug]).map((q) => ({ params: { slug: q.slug }, props: { q } }));
}

const { q } = Astro.props as { q: (typeof storyQuests)[number] };
const tr = storyQuestsDe[q.slug];
const chapter = storyChaptersDe.find((c) => c.number === q.chapter)!;
const prev = storyQuests[storyQuests.indexOf(q) - 1];
const next = q.leadsTo ? storyQuestBySlug.get(q.leadsTo) : undefined;
const statusLabel = q.status === 'confirmed' ? 'Bestätigt' : 'Gemeldet';

const faq = [
  { q: `Wie schaltet man "${tr.title}" in Moonlight Peaks frei?`, a: tr.unlock || 'Diese Quest folgt direkt aus dem vorherigen Story-Beat \u2014 siehe den Link zur Voraussetzungsquest unten.' },
  { q: `Was belohnt "${tr.title}"?`, a: tr.reward || 'Für diese Quest wurde noch keine bestätigte direkte Gegenstandsbelohnung dokumentiert.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Quest-Guide', item: `${SITE.url}/de/quests` },
    { '@type': 'ListItem', position: 3, name: 'Hauptgeschichte', item: `${SITE.url}/de/quests/story` },
    { '@type': 'ListItem', position: 4, name: tr.title, item: `${SITE.url}/de/quests/story/${q.slug}` },
  ] },
];
---
<Base
  title={`${tr.title} — Moonlight Peaks Quest-Guide`}
  description={`${GAME.title} "${tr.title}" Quest: ${tr.summary.slice(0, 130)}`}
  path={`/de/quests/story/${q.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: 'Quest-Guide', href: '/de/quests' }, { label: 'Hauptgeschichte', href: '/de/quests/story' }, { label: tr.title }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Hauptgeschichte · Kapitel {q.chapter}: {chapter.title} · <span class="tag-community">{statusLabel}</span></p>
      <h1>{tr.title}</h1>

      {tr.unlock && (
        <div class="callout">
          <strong>Freischaltung:</strong> {tr.unlock}
        </div>
      )}

      <h2>Was passiert</h2>
      <p>{tr.summary}</p>

      {tr.reward && (
        <>
          <h2>Belohnung</h2>
          <p>{tr.reward}</p>
        </>
      )}

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <nav class="prevnext" aria-label="Quest-Navigation">
        {prev && storyQuestsDe[prev.slug] ? <a href={`/de/quests/story/${prev.slug}`}>← {storyQuestsDe[prev.slug].title}</a> : <span />}
        <a href="/de/quests/story">Alle Kapitel</a>
        {next && storyQuestsDe[next.slug] ? <a href={`/de/quests/story/${next.slug}`}>{storyQuestsDe[next.slug].title} →</a> : <span />}
      </nav>

      <div class="callout wip">
        Verwandt: <a href="/de/quests">Quest-Hub</a>, <a href="/de/quests/side">Nebenquests</a>,
        <a href="/de/beginner-guide">Einsteiger-Guide</a>.
      </div>
    </div>
  </article>

  <style>
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 7px;
      vertical-align: middle;
    }
    .prevnext { display: flex; justify-content: space-between; gap: 10px; margin: 22px 0; font-family: var(--mono); font-size: 0.82rem; }
    .prevnext a { color: var(--candle); }
  </style>
</Base>
