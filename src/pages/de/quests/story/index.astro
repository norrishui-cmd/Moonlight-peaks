---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';
import { storyQuests } from '../../../../data/quests-story';
import { storyQuestsDe, storyChaptersDe } from '../../../../i18n/quests-story-de';

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Quest-Guide', item: `${SITE.url}/de/quests` },
    { '@type': 'ListItem', position: 3, name: 'Hauptgeschichte', item: `${SITE.url}/de/quests/story` },
  ],
};
---
<Base
  title="Moonlight Peaks Hauptgeschichte-Quests — Kapitel für Kapitel"
  description="Jede bestätigte Moonlight-Peaks-Hauptgeschichte-Quest, organisiert in 5 Kapitel von der Ankunft in der Stadt bis zum Hochzeits-Handlungsbogen, cross-verifiziert über mehrere Launch-Week-Quellen."
  path="/de/quests/story"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Quest-Guide', href: '/de/quests' }, { label: 'Hauptgeschichte' }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Quests · Hauptgeschichte</p>
      <h1>Hauptgeschichte-<em>Quests</em></h1>
      <p class="intro">
        {storyQuests.length} Hauptgeschichte-Quests, gruppiert in {storyChaptersDe.length} Kapitel.
        Wähle das Kapitel, das zu deinem Fortschritt passt — Quests innerhalb jedes Kapitels sind
        in bestätigter Reihenfolge aufgelistet.
      </p>

      {storyChaptersDe.map((ch) => {
        const quests = storyQuests.filter((q) => q.chapter === ch.number && storyQuestsDe[q.slug]);
        return (
          <section class="chapter">
            <div class="chapter-head">
              <span class="chapter-num">Kapitel {ch.number}</span>
              <h2>{ch.title}</h2>
            </div>
            <p class="chapter-dek">{ch.dek}</p>
            <ol class="quest-list">
              {quests.map((q) => (
                <li>
                  <a href={`/de/quests/story/${q.slug}`}>{storyQuestsDe[q.slug].title}</a>
                  {q.status === 'reported' && <span class="tag-community">Gemeldet</span>}
                </li>
              ))}
            </ol>
          </section>
        );
      })}

      <div class="callout wip">
        Sourced from cross-verified launch-week walkthroughs (Neoseekers Quest-Log, Bonus Action,
        Output Lag, Into Indie Games). Die Kapiteleinteilung ist unsere eigene Organisationsform,
        keine offiziellen In-Game-Labels. Verwandt: <a href="/de/quests">Quest-Hub</a>,
        <a href="/de/quests/side">Nebenquests</a>, <a href="/quests/story/a-bridge-too-far">A Bridge Too Far (voller Walkthrough, Englisch)</a>.
      </div>
    </div>
  </article>

  <style>
    .chapter { margin: 26px 0; padding-top: 18px; border-top: 1px solid var(--line); }
    .chapter:first-of-type { border-top: none; padding-top: 0; }
    .chapter-head { display: flex; align-items: baseline; gap: 10px; }
    .chapter-num { font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--candle); white-space: nowrap; }
    .chapter-head h2 { margin: 0; }
    .chapter-dek { color: var(--muted); font-size: 0.92rem; margin: 4px 0 12px; }
    .quest-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; counter-reset: qnum; }
    .quest-list li { counter-increment: qnum; padding: 8px 0; border-bottom: 1px dashed var(--line); display: flex; align-items: center; gap: 8px; }
    .quest-list li::before { content: counter(qnum) "."; color: var(--faint); font-family: var(--mono); font-size: 0.8rem; }
    .quest-list a { color: var(--mist); text-decoration: none; flex: 1; }
    .quest-list a:hover { color: var(--candle); }
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 7px;
    }
  </style>
</Base>
