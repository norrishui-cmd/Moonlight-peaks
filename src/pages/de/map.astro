---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';
import { markers, categories, markersConfirmed } from '../../data/map-locations';
import GuideImage from '../../components/GuideImage.astro';

const colorOf = Object.fromEntries(categories.map((c) => [c.id, c.color]));
const labelOf = Object.fromEntries(categories.map((c) => [c.id, c.label]));

const faq = [
  { q: 'Gibt es eine interaktive Karte für Moonlight Peaks?', a: 'Ja — diese von Fans erstellte Karte zeigt echte, bestätigte Orts- und Ladennamen (Silverveil Lake, Cave of Echoes, Rathaus, Webb of Wonders, Howling Hammer). Die Positionen sind schematische Annäherungen anhand beschreibender Hinweise aus Guides, nicht aus einem offiziellen Kartenbild gemessen — die Platzierung ist also eher richtungsweisend als exakt.' },
  { q: 'Hat Moonlight Peaks eine Minimap?', a: 'Nein, bestätigt: Es gibt kein Minimap- oder Quest-Marker-System, und die Kamera ist fest statt frei folgend. Die Ingame-Karte ist die wichtigste Navigationshilfe und markiert Gebäude mit einem Ausrufezeichen oder einer funkelnden Aura, wenn das Betreten eine Cutscene auslöst.' },
  { q: 'Wo kann man in Moonlight Peaks angeln?', a: 'Bestätigt: Silverveil Lake unterstützt Angeln und ist die Heimat der Meerjungfrauenfamilie Hosu. Genaue Fischarten und spezifische Angelstellen innerhalb des Sees sind noch nicht belegt — siehe den Angel-Guide für den bisher bestätigten Stand.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Karte', item: new URL('/de/map', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Karte — Angeln, Sammeln & Läden"
  description="Eine interaktive Moonlight Peaks Stadtkarte auf Deutsch: filtere Angelstellen, Sammelgebiete, Läden und Bewohner-Häuser. Mit bestätigten Orten gefüllt."
  path="/de/map"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Karte' }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Einstieg · Karte</p>
      <h1>Moonlight Peaks <em>interaktive Karte</em></h1>
      <p class="intro">
        Filtere die Stadt nach dem, was du suchst, und tippe dann auf einen Marker für Details.
        Aktualisiert {SITE.updated}.
      </p>

      {!markersConfirmed && (
        <div class="callout wip">
          <strong>Schematische Positionen.</strong> Die Markernamen unten (Silverveil Lake, Cave of
          Echoes, Rathaus und mehr) sind echt und bestätigt — aber ihre Platzierung auf dieser Karte
          ist eine Annäherung anhand beschreibender Hinweise aus Guides, nicht aus einem offiziellen
          Kartenbild gemessen. Wir wechseln zu pixelgenauen Koordinaten, sobald wir sie aus dem
          Live-Spiel beziehen können.
        </div>
      )}

      <GuideImage
        imageId="world-map-screenshot"
        contextAlt="Ingame-Übersichtskarten-Screenshot mit Moonlit Pines, der Stadt Moonlight Peaks, Misty Shores und Silverveil Lake"
        caption="Ein echter Ingame-Kartenscreenshot, als Referenz neben unserer schematischen Version unten. Benannte Regionen stimmen mit dem überein, was wir bestätigt haben: Moonlit Pines, Moonlight Peaks (die Stadt), Misty Shores und Silverveil Lake."
      />

      <h2>Bestätigte benannte Gebiete</h2>
      <p>
        Die Markerpositionen unten sind noch Platzhalter, aber diese Bezirksnamen sind aus
        Launch-Week-Berichten bestätigt: <strong>Misty Shores</strong> (das Revier der
        Ambrosia-Familie, erreichbar über die Quest "A Bridge Too Far", mit einem Friedhof, wo du
        Death triffst), <strong>Moonlit Pines</strong> (Sitz des Hexenzirkels), der
        <strong>Pink Grove</strong> (Zuhause des Liebesdämons Llemi, hauptsächlich während Festen
        besucht) und das <strong>Rathaus</strong> (wo du dich beim Bürgermeister anmeldest). Wir
        platzieren diese präzise, sobald genaue Koordinaten verifiziert sind.
      </p>

      <div class="maplegend" id="maplegend">
        {categories.map((c) => (
          <button class="lg" data-cat={c.id} style={`--mk:${c.color}`} type="button" aria-pressed="true">
            <span class="lg-dot"></span>{c.label}
          </button>
        ))}
      </div>

      <div class="mapwrap">
        <svg viewBox="0 0 800 500" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Stilisierte Stadtkarte">
          <rect width="800" height="500" rx="16" fill="#1b1526"/>
          <path d="M0 170 Q220 120 380 210 T800 240 L800 130 Q500 70 250 110 T0 90 Z" fill="#20283f" opacity="0.5"/>
          <path d="M120 470 Q260 360 480 380 T760 300" stroke="#3a567a" stroke-width="20" fill="none" opacity="0.7" stroke-linecap="round"/>
          <ellipse cx="190" cy="330" rx="70" ry="42" fill="#2c4666" opacity="0.85"/>
          <g fill="#33503e" opacity="0.9">
            <polygon points="600,360 628,310 656,360"/><polygon points="636,372 664,322 692,372"/>
            <polygon points="672,360 700,310 728,360"/><polygon points="300,410 324,368 348,410"/>
            <polygon points="336,420 360,378 384,420"/>
          </g>
          <g fill="#3a2f50" opacity="0.9">
            <rect x="150" y="120" width="60" height="44" rx="3"/><rect x="220" y="130" width="44" height="34" rx="3"/>
          </g>
          <g fill="#2f2440" stroke="#4a3a63" stroke-width="2">
            <rect x="372" y="232" width="40" height="34" rx="3"/><rect x="420" y="240" width="34" height="30" rx="3"/>
            <rect x="492" y="248" width="40" height="30" rx="3"/>
          </g>
          <text x="150" y="108" fill="#7c6e90" font-family="monospace" font-size="15">Dein Hof</text>
          <text x="150" y="392" fill="#7c6e90" font-family="monospace" font-size="15">Teich</text>
          <text x="600" y="300" fill="#7c6e90" font-family="monospace" font-size="15">Wald</text>
          <text x="430" y="226" fill="#7c6e90" font-family="monospace" font-size="15">Stadtplatz</text>
        </svg>
        {markers.map((m) => (
          <button
            class={`mk mk-${m.category}`}
            data-cat={m.category}
            data-name={m.name}
            data-note={m.note || ''}
            data-label={labelOf[m.category]}
            style={`left:${m.x}%;top:${m.y}%;--mk:${colorOf[m.category]}`}
            aria-label={m.name}
            type="button"
          ></button>
        ))}
      </div>

      <div class="mapinfo" id="mapinfo">
        <p class="mapinfo-empty">Tippe auf einen Marker, um zu sehen, was dort ist.</p>
      </div>

      <h2>Navigation ohne Minimap</h2>
      <p>
        Über mehrere Quellen bestätigt: Moonlight Peaks hat <strong>keine Minimap und keine
        Quest-Marker</strong> und nutzt eine feste statt frei folgende Kamera — die Ingame-Karte
        (über das Pausemenü geöffnet) ist deine wichtigste Navigationshilfe. Auf dieser Karte
        markieren <strong>Ausrufezeichen-Symbole</strong> Gebäude, bei denen das Betreten eine
        Cutscene auslöst, und eine <strong>funkelnde Aura</strong> um ein Gebäude bedeutet, dass
        das Hineingehen eine auslösen wird — beides lohnt sich zu prüfen, wenn du nach einem noch
        nicht ausgelösten Herz-Event suchst.
      </p>
      <p>
        Für schnelles Vorankommen: der <strong>Hexenkreis</strong> bietet nach Freischaltung eine
        Schnellreise-Option, und auch die <a href="/shapeshifting">Fledermausform</a> deckt schnell
        Boden ab. Zwei Sammelobjekte sind zudem an bestimmte unterirdische Bereiche gebunden —
        Vampsters werden zu einem Loch in den <a href="/locations/crystal-cave">Katakomben</a>
        getragen, und Soul Blobs werden in der Stadt eingenetzt, sobald diese Funktion freigeschaltet ist.
      </p>

      <GuideImage
        imageId="moonlit-pines-vampster-map"
        contextAlt="Community-erstellte Karte mit 14 nummerierten Vampster-Fundorten in Moonlit Pines"
        caption="Eine von der Community erstellte Vampster-Fundortkarte für das Gebiet Moonlit Pines mit 14 erfassten Stellen. Behandle die genaue Nummerierung als Community-bericht statt als vom Entwickler bestätigt, aber sie ist ein nützlicher Ausgangspunkt, wenn du speziell in dieser Region nach Vampsters suchst."
      />

      <h2>Noch in Prüfung</h2>
      <ul>
        <li>Jede <strong>Angelstelle</strong> mit ihrem Fisch, Jahreszeit und Zeit.</li>
        <li><strong>Sammelgebiete</strong> und was dort erscheint.</li>
        <li><strong>Läden</strong> und was jeder verkauft.</li>
        <li><strong>Bewohner-Häuser</strong>, verlinkt mit den Romanze- und Geschenk-Seiten.</li>
      </ul>

      <h2>Häufige Fragen</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout">
        Verwandte Seiten: <a href="/nokturna">Nokturna-Kartenspiel</a>, <a href="/de/romance">Romanze &amp; Familien</a>,
        <a href="/de/beginner-guide">Einsteiger-Guide</a>.
      </div>
    </div>
  </article>

  <style>
    .maplegend { display: flex; gap: 8px; flex-wrap: wrap; margin: 6px 0 14px; }
    .lg { display: inline-flex; align-items: center; gap: 7px; font-size: 0.84rem; color: var(--mist); background: var(--surface); border: 1px solid var(--line); border-radius: 999px; padding: 6px 13px; cursor: pointer; }
    .lg-dot { width: 11px; height: 11px; border-radius: 50%; background: var(--mk); }
    .lg[aria-pressed="false"] { opacity: 0.4; text-decoration: line-through; }
    .mapwrap { position: relative; width: 100%; border: 1px solid var(--line); border-radius: 14px; overflow: hidden; background: #15101d; }
    .mapwrap svg { display: block; width: 100%; height: auto; }
    .mk { position: absolute; transform: translate(-50%, -50%); width: 22px; height: 22px; border-radius: 50%; background: var(--mk); border: 2px solid #15101d; box-shadow: 0 0 0 2px var(--mk), 0 2px 6px rgba(0,0,0,0.4); cursor: pointer; padding: 0; transition: transform .12s ease; }
    .mk:hover, .mk.is-sel { transform: translate(-50%, -50%) scale(1.35); z-index: 3; }
    .mk.is-sel { box-shadow: 0 0 0 3px #fff, 0 2px 8px rgba(0,0,0,0.5); }
    .mk.hide { display: none; }
    @media (max-width: 520px) { .mk { width: 26px; height: 26px; } }
    .mapinfo { margin-top: 14px; border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 14px 16px; min-height: 64px; }
    .mapinfo-empty { color: var(--faint); margin: 0; }
    .mapinfo h3 { font-family: var(--display); font-weight: 600; font-size: 1.1rem; margin: 0 0 4px; }
    .mapinfo .cat { font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--candle); }
    .mapinfo p.note { color: #ded3e6; margin: 6px 0 0; font-size: 0.92rem; }
  </style>

  <script>
    const legend = document.getElementById('maplegend');
    const info = document.getElementById('mapinfo');
    const off = new Set();
    const markerEls = Array.from(document.querySelectorAll('.mk'));

    const refresh = () => {
      markerEls.forEach((m) => {
        const cat = m.getAttribute('data-cat') || '';
        m.classList.toggle('hide', off.has(cat));
      });
    };

    if (legend) {
      legend.addEventListener('click', (e) => {
        const btn = e.target.closest('.lg');
        if (!btn) return;
        const cat = btn.getAttribute('data-cat') || '';
        if (off.has(cat)) { off.delete(cat); btn.setAttribute('aria-pressed', 'true'); }
        else { off.add(cat); btn.setAttribute('aria-pressed', 'false'); }
        refresh();
      });
    }

    markerEls.forEach((m) => {
      m.addEventListener('click', () => {
        markerEls.forEach((x) => x.classList.remove('is-sel'));
        m.classList.add('is-sel');
        if (info) {
          const name = m.getAttribute('data-name') || '';
          const label = m.getAttribute('data-label') || '';
          const note = m.getAttribute('data-note') || '';
          info.innerHTML = '<span class="cat"></span><h3></h3>' + (note ? '<p class="note"></p>' : '');
          info.querySelector('.cat').textContent = label;
          info.querySelector('h3').textContent = name;
          if (note) info.querySelector('p.note').textContent = note;
        }
      });
    });
  </script>
</Base>
