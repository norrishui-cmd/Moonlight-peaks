---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const faq = [
  { q: 'Wie viele Vampsters gibt es in Moonlight Peaks?', a: 'Bestätigt über das offizielle Wiki: 53 Vampsters insgesamt, verteilt über die Außenbereiche des Spiels.' },
  { q: 'Wohin bringt man Vampsters in Moonlight Peaks?', a: 'Bestätigt: zurück zu ihrem Zuhause, einer Höhle in Misty Shores (freigeschaltet über die Quest "A Bridge Too Far").' },
  { q: 'Kann man mehrere Vampsters gleichzeitig tragen?', a: 'Nein — du kannst nur einen Vampster auf einmal tragen. Ein Gespräch mit jemandem oder eine ausgelöste Cutscene lässt dich den getragenen Vampster fallen lassen.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Sammlung', item: `${SITE.url}/de/collections` },
    { '@type': 'ListItem', position: 3, name: 'Vampsters', item: `${SITE.url}/de/collections/vampsters` },
  ] },
];
---
<Base
  title="Moonlight Peaks Vampsters: Alle 53 & wie man sie sammelt"
  description="Moonlight Peaks Vampster-Guide: was sie sind, die bestätigte Gesamtzahl von 53, wie man sie trägt, und wo ihr Zuhause ist — aus dem offiziellen Wiki."
  path="/de/collections/vampsters"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Sammlung', href: '/de/collections' }, { label: 'Vampsters' }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Sammlung · Vampsters</p>
      <h1>Moonlight Peaks <em>Vampsters</em></h1>
      <p class="intro">
        Vampsters sind kleine, schelmische Kreaturen, die sich überall in Moonlight Peaks verstecken
        und Unfug treiben, aber traurig werden, wenn sie zu lange allein bleiben. Bestätigt über das
        offizielle Wiki: Es gibt 53 davon, und du sammelst jeden einzeln ein und trägst ihn nach Hause.
      </p>

      <div class="callout">
        <strong>Kurzantwort:</strong> Vampsters sind verlorene Kreaturen, die du draußen findest und
        — jeweils einzeln — zurück zu ihrem Zuhause in einer Höhle in Misty Shores trägst.
        Bestätigte Gesamtzahl: 53.
      </div>

      <h2>Wie die Vampster-Quest beginnt</h2>
      <p>
        Community-berichtet: Bei einem Ausflug zur Cave of Echoes zum Kupferabbau in deiner ersten
        Woche flitzt ein Vampster am Eingang davon. Drinnen triffst du
        <a href="/characters/alina">Alina</a>, die erklärt, dass die Vampsters verloren sind und
        um Hilfe bittet, sie alle nach Hause zu bringen.
      </p>

      <h2>Wo man sie findet</h2>
      <p>
        Bestätigt über das offizielle Wiki: Vampsters sind über ganz Moonlight Peaks verteilt und
        verstecken sich stets an den ungewöhnlichsten Orten. Zwei bestätigte Beispielorte: einer in
        Lunas Haus in Moonlit Pines, ihre Wendeltreppe hoch bei ihrem Bett mit einer Kerze auf dem
        Kopf, und ein weiterer im Moonlit Tower in Misty Shores, versteckt hinter einem
        beigefarbenen Blattsessel.
      </p>

      <h2>Wie man sie trägt und zurückbringt</h2>
      <ul>
        <li><strong>Nur einer auf einmal:</strong> bestätigt — du kannst keine mehreren Vampsters stapeln; du trägst genau einen, bis du ihn absetzt.</li>
        <li><strong>Ihr Zuhause:</strong> bestätigt — eine Höhle in Misty Shores (freigeschaltet über <a href="/quests/story/a-bridge-too-far">A Bridge Too Far</a>).</li>
        <li><strong>Vorsicht bei Unterbrechungen:</strong> Community-berichtet — ein Gespräch mit einem Bewohner oder jede ausgelöste Cutscene lässt dich den getragenen Vampster fallen lassen, also räume dialoglastige Bereiche vorher.</li>
      </ul>

      <h2>Häufige Probleme</h2>
      <ul>
        <li><strong>Vampster nach Cutscene verloren:</strong> erwartet — Cutscenes lassen dich den getragenen Vampster fallen; er bleibt dort liegen, wo du ihn fallen gelassen hast.</li>
        <li><strong>Findet keine weiteren Vampsters:</strong> versuche, mit deiner Sense überwuchertes Gras und Büsche in noch nicht komplett geräumten Bereichen zu entfernen.</li>
      </ul>

      <h2>Häufige Fragen</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Aus dem offiziellen Moonlight Peaks Wiki (moonlightpeaks.wiki.gg). Verwandte Seiten:
        <a href="/de/collections">Sammlungs-Hub</a>, <a href="/locations/mines">Cave of Echoes</a>,
        <a href="/achievements">Erfolge</a>, <a href="/characters/alina">Alina</a>.
      </div>
    </div>
  </article>
</Base>
