---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';

const entries = [
  { group: 'Angeln', title: 'Fische', desc: 'Rund 22 Fischarten, wie man seine erste Angelrute von Noel bekommt, und was beeinflusst, welche Fische man fängt.', href: '/de/collections/fish' },
  { group: 'Wirtschaft', title: 'Jobs', desc: "Albertus' Jobbrett — kurze Aufträge für Gold, Geschenke und Beziehungspunkte.", href: '/de/collections/jobs' },
  { group: 'Kreaturen', title: 'Kleintiere', desc: 'Fangbare Insekten, die sich mit Jahreszeit und Wetter ändern und auch als Wohndeko dienen.', href: '/de/collections/critters' },
  { group: 'Kreaturen', title: 'Vampsters', desc: 'Alle 53 bestätigten Vampsters, wo man sie findet, und wie man sie nach Hause trägt.', href: '/de/collections/vampsters' },
  { group: 'Kreaturen', title: 'Soul Blobs', desc: 'Alle 100 Soul Blobs und die Belohnung der Antiken Uhr fürs Sammeln aller.', href: '/de/collections/soul-blobs' },
];

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Sammlung', item: `${SITE.url}/de/collections` },
  ],
};
---
<Base
  title="Moonlight Peaks Sammlung — Fische, Jobs, Kleintiere, Vampsters & Soul Blobs"
  description="Der Moonlight Peaks Sammel-Bereich auf Deutsch: Fische, Albertus' Jobbrett, Kleintiere, Vampsters und Soul Blobs — aus dem offiziellen Wiki und abgeglichenen Launch-Week-Berichten."
  path="/de/collections"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Sammlung' }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Hub · Sammlung</p>
      <h1>{GAME.title} <em>Sammlung</em></h1>
      <p class="intro">
        Alles rund um die Sammel- und Fangsysteme des Spiels — was man fängt, was man abgibt, und
        was es wert ist. Die meisten Inhalte stammen direkt aus dem offiziellen Moonlight Peaks Wiki.
      </p>

      <div class="itg">
        {entries.map((e) => (
          <a class="itcard" href={e.href}>
            <span class="itgroup">{e.group}</span>
            <h3>{e.title}</h3>
            <p>{e.desc}</p>
          </a>
        ))}
      </div>

      <div class="callout wip">
        Verwandte Seiten: <a href="/de/farm">Hof</a>, <a href="/de/items">Gegenstände</a>,
        <a href="/de/activities">Aktivitäten</a>, <a href="/achievements">Erfolge</a>.
      </div>
    </div>
  </article>

  <style>
    .itg { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 6px 0 18px; }
    @media (min-width: 640px) { .itg { grid-template-columns: 1fr 1fr; } }
    @media (min-width: 980px) { .itg { grid-template-columns: 1fr 1fr 1fr; } }
    .itcard {
      display: block; border: 1px solid var(--line); border-radius: 14px;
      background: var(--surface); padding: 14px; color: inherit; text-decoration: none;
      transition: border-color .15s ease, transform .15s ease;
    }
    .itcard:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); transform: translateY(-2px); }
    .itgroup { font-family: var(--mono); color: var(--faint); text-transform: uppercase; letter-spacing: 0.04em; font-size: 0.62rem; }
    .itcard h3 { font-family: var(--display); font-weight: 600; font-size: 1rem; margin: 4px 0 6px; }
    .itcard p { color: #ded3e6; font-size: 0.84rem; margin: 0 0 10px; }
  </style>
</Base>
