---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { critterDetailPages } from '../../../data/collectionDetailPages';

const faq = [
  { q: 'Was kann man in Moonlight Peaks mit Kleintieren machen?', a: 'Bestätigt: Jedes gefangene Kleintier (oder Fisch) kann in deinem Haus als Deko ausgestellt werden — es lohnt sich, etwas Seltenes oder Niedliches zu behalten statt es zu verkaufen.' },
  { q: 'Ändern sich Kleintiere in Moonlight Peaks je nach Jahreszeit?', a: 'Ja, bestätigt: Wie beim Angeln bringen unterschiedliche Jahreszeiten und Wetter unterschiedliche Insekten und Kleintiere hervor.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Sammlung', item: `${SITE.url}/de/collections` },
    { '@type': 'ListItem', position: 3, name: 'Kleintiere', item: `${SITE.url}/de/collections/critters` },
  ] },
];
---
<Base
  title="Moonlight Peaks Kleintiere — Fangen, Jahreszeiten & Wohndeko"
  description="Bestätigt: Kleintiere und Insekten in Moonlight Peaks ändern sich mit Jahreszeit und Wetter, und jedes gefangene kann in deinem Haus als Deko ausgestellt werden."
  path="/de/collections/critters"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Sammlung', href: '/de/collections' }, { label: 'Kleintiere' }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Sammlung · Kleintiere</p>
      <h1>Moonlight Peaks <em>Kleintiere</em></h1>
      <p class="intro">
        Bestätigt über einen First-Week-Guide: Insekten und Kleintiere, die du fängst, sind nicht
        nur zum Verkaufen oder Kochen da — jedes gefangene kann in deinem Haus als Deko
        ausgestellt werden.
      </p>

      <h2>Kleintiere fangen</h2>
      <p>
        Bestätigt: Insektenfang ist schnell erlernt, aber leicht zu verpatzen, da sich Kleintiere
        schnell bewegen und ein verpasster Schlag Energie kostet. Wie beim Angeln bringen
        unterschiedliche Jahreszeiten und Wetter unterschiedliche Insekten hervor, sodass ein
        Kleintier, das du in einer Nacht nicht findest, möglicherweise nur auf die richtigen
        Bedingungen wartet.
      </p>

      <h2>Als Deko ausstellen</h2>
      <p>
        Bestätigt: Es lohnt sich, etwas Seltenes oder Niedliches zu behalten statt zu verkaufen, da
        jede gefangene Kreatur — Fisch oder Insekt — als Deko-Stück im Haus platziert werden kann.
        Siehe <a href="/de/farm/house">dein Haus</a> für mehr zum Dekorieren.
      </p>

      <h2>Kreaturen-Verzeichnis</h2>
      <p>Klicke auf einen Eintrag für die Detailseite mit Jahreszeit, Fundort, Art und Verkaufspreis. Felder mit "-" sind noch unbestätigt.</p>
      <ul class="fish-link-list">
        {critterDetailPages.map((c) => (
          <li><a href={`/de/collections/critters/${c.slug}`}>{c.name}</a></li>
        ))}
      </ul>

      <h2>Noch in Prüfung</h2>
      <ul>
        <li>Fundort, Jahreszeit und Wetter, wo die Detailseiten noch "-" zeigen.</li>
        <li>Ob Kleintiere verschenkt oder verkauft werden können, über die Ausstellung hinaus.</li>
      </ul>

      <h2>Häufige Fragen</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Verwandte Seiten: <a href="/de/collections">Sammlungs-Hub</a>, <a href="/environment">Umgebung</a>,
        <a href="/map">Karte</a>, <a href="/de/activities">Aktivitäten</a>.
      </div>
    </div>
  </article>

  <style>
    .fish-link-list {
      list-style: none; padding: 0; margin: 12px 0 24px;
      display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 8px;
    }
    .fish-link-list a {
      display: block; border: 1px solid var(--line); border-radius: 10px; padding: 8px 12px;
      background: var(--surface); color: var(--candle); text-decoration: none; font-size: 0.88rem;
    }
    .fish-link-list a:hover { border-color: color-mix(in srgb, var(--candle) 54%, var(--line)); }
  </style>
</Base>
