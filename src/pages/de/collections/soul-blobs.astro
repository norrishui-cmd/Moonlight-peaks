---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const faq = [
  { q: 'Wie viele Soul Blobs gibt es in Moonlight Peaks?', a: 'Bestätigt zum Release: 100 Soul Blobs, verteilt über die Spielwelt.' },
  { q: 'Wie fängt man Soul Blobs in Moonlight Peaks?', a: 'Bestätigt: mit dem Netz, demselben Werkzeug, das zum Insektenfang genutzt wird — nicht von Hand.' },
  { q: 'Was bekommt man fürs Sammeln aller Soul Blobs?', a: 'Bestätigt: die Antike Uhr, die die Nacht von standardmäßig 15 Minuten auf 25 Minuten verlängert.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Sammlung', item: `${SITE.url}/de/collections` },
    { '@type': 'ListItem', position: 3, name: 'Soul Blobs', item: `${SITE.url}/de/collections/soul-blobs` },
  ] },
];
---
<Base
  title="Moonlight Peaks Soul Blobs: Alle 100 & die Belohnung der Antiken Uhr"
  description="Bestätigt: 100 Soul Blobs sind über Moonlight Peaks verteilt, gefangen mit dem Netz. Alle zu sammeln belohnt die Antike Uhr, die die Nacht auf 25 Minuten verlängert."
  path="/de/collections/soul-blobs"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Sammlung', href: '/de/collections' }, { label: 'Soul Blobs' }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Sammlung · Soul Blobs</p>
      <h1>Moonlight Peaks <em>Soul Blobs</em></h1>
      <p class="intro">
        Soul Blobs sind kleine, umherwandernde Schädel-Seelen, verteilt über die Spielwelt —
        bestätigt zum Release: 100 davon insgesamt, mit einer wirklich nützlichen Belohnung für
        Komplettierer.
      </p>

      <div class="callout">
        <strong>Kurzantwort:</strong> Death stellt dir Soul Blobs nach eurem zweiten Treffen in der
        Stadt vor und bittet dich, sie mit dem Netz einzufangen. Es gibt 100 insgesamt; alle zu
        sammeln belohnt die Antike Uhr.
      </div>

      <h2>Wie Soul Blobs eingeführt werden</h2>
      <p>
        Bestätigt: <a href="/characters/death">Death</a> stellt dir Soul Blobs nach eurem zweiten
        Treffen in der Stadt vor und bittet dich, sie mit dem Netz einzufangen — demselben Werkzeug,
        das zum Insektenfang genutzt wird, nicht etwas Separates.
      </p>

      <h2>Was sie von anderen Sammelobjekten unterscheidet</h2>
      <p>
        Community-berichtet: Soul Blobs sind die erzählerischere der beiden
        Kreatur-Sammelaufgaben des Spiels (die andere sind
        <a href="/de/collections/vampsters">Vampsters</a>). Wenn du einen Soul Blob fängst, erzählt
        dir das Spiel eine kleine Vignette darüber, wie diese Seele gestorben ist — eine kleine
        erzählerische Belohnung für jeden Fund statt nur ein Häkchen auf der Liste.
      </p>

      <h2>Die Belohnung fürs Komplettieren</h2>
      <p>
        Bestätigt: Alle 100 Soul Blobs zu sammeln belohnt die <strong>Antike Uhr</strong>, die die
        Länge der Nacht von standardmäßig 15 Minuten auf 25 Minuten verlängert — eine wirklich
        nützliche, dauerhafte Komfort-Belohnung statt einer rein kosmetischen.
      </p>

      <h2>Häufige Fragen</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Verwandte Seiten: <a href="/de/collections">Sammlungs-Hub</a>, <a href="/de/collections/vampsters">Vampsters</a>,
        <a href="/characters/death">Death</a>, <a href="/de/activities">Angeln &amp; Insektenfang</a>.
      </div>
    </div>
  </article>
</Base>
