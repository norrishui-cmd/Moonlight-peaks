---
import TopicPage from '../../../components/TopicPage.astro';
import { locationsSection, locations } from '../../../data/locations';
import { locationsDe } from '../../../i18n/locations-de';

export function getStaticPaths() {
  const translated = locations.filter((it) => locationsDe[it.slug]);
  return translated.map((it, i) => {
    const tr = locationsDe[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...translated[(i - 1 + translated.length) % translated.length], ...locationsDe[translated[(i - 1 + translated.length) % translated.length].slug] },
        next: { ...translated[(i + 1) % translated.length], ...locationsDe[translated[(i + 1) % translated.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const deSection = { ...locationsSection, base: '/de/locations', label: 'Orte', eyebrow: 'Welt' };
---
<TopicPage section={deSection} item={item} prev={prev} next={next} lang="de" basePath="/de/locations" />
