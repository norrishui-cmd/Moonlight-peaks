---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { characters, typeLabels } from '../../../data/characters';

const typeLabelsDe: Record<string, string> = {
  vampire: 'Vampir', werewolf: 'Werwolf', witch: 'Hexe', mermaid: 'Meerjungfrau',
  seer: 'Seherin', ghost: 'Geist', human: 'Mensch', other: 'Sonstiges',
};
const statusLabelsDe: Record<string, string> = { confirmed: 'Bestätigt', reported: 'Gemeldet', datamined: 'Datamined', unconfirmed: 'Unbestätigt' };

const candidates = characters
  .filter((c) => c.status !== 'unconfirmed' && c.romanceable !== false)
  .map((c) => ({
    id: c.id,
    name: c.name,
    family: c.family && c.family !== 'Unknown' ? c.family : null,
    type: typeLabelsDe[c.type] || typeLabels[c.type],
    status: statusLabelsDe[c.status] || c.status,
    href: `/characters/${c.id}`,
  }));

const prepTasks = [
  { id: 'read-profile', t: 'Lies die Profile und bekannten Infos deiner engeren Auswahl' },
  { id: 'check-home', t: 'Notiere bekannte Wohnorte für deine Auswahl (siehe "Bekannte Infos" im Profil)' },
  { id: 'check-family', t: 'Prüfe, zu welcher Familie sie gehören und gemeldete Familienspannungen' },
  { id: 'check-status', t: 'Bestätige ihre aktuelle Genauigkeitsstufe (bestätigt / gemeldet / datamined)' },
  { id: 'try-quiz', t: 'Mach das Romanze-Match-Quiz für eine zweite Meinung' },
  { id: 'plan-day-one', t: 'Entscheide, mit wem du am ersten Tag zuerst sprechen willst' },
  { id: 'bookmark-page', t: 'Setze ein Lesezeichen für diese Seite — deine Auswahl und Notizen werden auf diesem Gerät gespeichert' },
];

const faq = [
  { q: 'Nutzt dieses Werkzeug echte Geschenk- oder Zuneigungsdaten?', a: 'Nein. Es sind noch keine Geschenk-, Zuneigungs- oder Event-Daten bestätigt, daher wird hier nichts davon gezeigt. Dieses Werkzeug verfolgt nur deine eigene Auswahl, Notizen und Vorbereitungs-Checkliste — alles privat in deinem Browser gespeichert, nicht auf unserem Server.' },
  { q: 'Bleibt meine Auswahl nach dem Release erhalten?', a: 'Ja, solange du denselben Browser und dasselbe Gerät nutzt und deine Seitendaten nicht löschst. Sobald echte Romanze-Daten bestätigt sind, erweitern wir dieses Werkzeug, um sie zu nutzen.' },
  { q: 'Werden meine Daten irgendwohin gesendet?', a: 'Nein. Alles wird nur im lokalen Speicher deines Browsers gespeichert. Wir sehen es nicht, speichern es nicht auf einem Server und nutzen es für nichts.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Werkzeuge', item: `${SITE.url}/de/tools` },
    { '@type': 'ListItem', position: 3, name: 'Romanze-Planer', item: new URL('/de/tools/romance-planner', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'Moonlight Peaks Romanze-Planer',
    applicationCategory: 'GameApplication', operatingSystem: 'Web',
    url: new URL('/de/tools/romance-planner', SITE.url).href,
    description: 'Eine Vor-Release-Romanze-Auswahlliste und Vorbereitungs-Tracker für Moonlight Peaks, lokal in deinem Browser gespeichert.' },
];
---
<Base
  title="Moonlight Peaks Romanze-Planer — Auswahlliste & Fortschritts-Tracker"
  description="Wähle deine Moonlight-Peaks-Romanze-Favoriten aus, füge persönliche Notizen hinzu und verfolge deinen Fortschritt mit jedem — privat in deinem Browser gespeichert, keine erfundenen Geschenkdaten."
  path="/de/tools/romance-planner"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Werkzeuge', href: '/de/tools' }, { label: 'Romanze-Planer' }]}
  lang="de"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Werkzeug · Romanze</p>
      <h1>Romanze-<em>Planer</em></h1>
      <p class="intro">
        Wähle aus, wen du dir von den 23 bestätigten Romanze-Optionen genauer ansehen möchtest, mache
        eigene Notizen und verfolge deinen Fortschritt mit jedem. Alles hier wird privat in deinem
        Browser gespeichert — kein Konto, kein Server, und keine erfundenen Geschenk- oder
        Zuneigungsdaten.
      </p>

      <h2>Deine Auswahlliste</h2>
      <p class="rp-sub">Tippe auf einen Charakter, um ihn zu deiner Auswahlliste hinzuzufügen oder zu entfernen.</p>
      <div id="rp-candidates" class="rp-candidates">
        {candidates.map((c) => (
          <button type="button" class="rp-candidate" data-rp-id={c.id} data-rp-href={c.href} data-rp-name={c.name}>
            <span class="rp-star" aria-hidden="true">☆</span>
            <span class="rp-name">{c.name}</span>
            <span class="rp-meta">{c.family ? `${c.family} · ` : ''}{c.status}</span>
          </button>
        ))}
      </div>

      <h2>Deine Notizen</h2>
      <div id="rp-shortlist-empty" class="callout wip">Deine Auswahlliste ist leer — tippe oben auf einen Charakter, um einen hinzuzufügen.</div>
      <div id="rp-notes-list" class="rp-notes-list"></div>

      <h2>Release-Tag-Vorbereitungs-Checkliste</h2>
      <ul id="rp-prep-list" class="rp-prep-list">
        {prepTasks.map((task) => (
          <li>
            <label>
              <input type="checkbox" data-rp-task={task.id} />
              <span>{task.t}</span>
            </label>
          </li>
        ))}
      </ul>

      <div class="rp-actions">
        <button type="button" id="rp-clear" class="rq-btn">Meine Auswahlliste &amp; Notizen löschen</button>
      </div>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Verwandt: <a href="/romance">Romanze & Heirat</a>, <a href="/tools/romance-match-quiz">Romanze-Match-Quiz</a>,
        <a href="/tools/romance-gift-finder">Romanze-Geschenkfinder</a>, <a href="/characters">Alle Charaktere</a>.
      </div>
    </div>
  </article>

  <style>
    .rp-sub { color: var(--faint); font-size: 0.8rem; margin: -6px 0 12px; }
    .rp-candidates { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin: 0 0 24px; }
    @media (min-width: 640px) { .rp-candidates { grid-template-columns: repeat(3, 1fr); } }
    .rp-candidate {
      display: flex; flex-direction: column; align-items: flex-start; gap: 2px; text-align: left;
      border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 10px 12px;
      cursor: pointer; transition: border-color .15s ease;
    }
    .rp-candidate:hover { border-color: color-mix(in srgb, var(--candle) 45%, var(--line)); }
    .rp-candidate.is-picked { border-color: var(--candle); background: color-mix(in srgb, var(--candle) 10%, var(--surface)); }
    .rp-candidate .rp-star { font-size: 0.9rem; color: var(--faint); }
    .rp-candidate.is-picked .rp-star { color: var(--candle); }
    .rp-candidate .rp-name { font-family: var(--display); font-weight: 600; font-size: 0.88rem; color: var(--mist); }
    .rp-candidate .rp-meta { font-family: var(--mono); font-size: 0.66rem; color: var(--faint); }
    .rp-notes-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
    .rp-note-card { border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 12px 14px; }
    .rp-note-card .rp-note-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
    .rp-note-card strong { font-family: var(--display); font-size: 0.94rem; }
    .rp-note-card a { font-family: var(--mono); font-size: 0.7rem; color: var(--candle); }
    .rp-note-card textarea {
      width: 100%; min-height: 64px; background: var(--ink-2); border: 1px solid var(--line); border-radius: 8px;
      color: var(--mist); font-family: inherit; font-size: 0.84rem; padding: 8px 10px; resize: vertical;
    }
    .rp-prep-list { list-style: none; margin: 0 0 20px; padding: 0; display: flex; flex-direction: column; gap: 6px; }
    .rp-prep-list label { display: flex; align-items: center; gap: 10px; font-size: 0.86rem; color: var(--muted); cursor: pointer; }
    .rp-prep-list input { accent-color: var(--candle); }
    .rp-actions { margin: 0 0 24px; }
  </style>

  <script>
    (function () {
      var KEY_SHORTLIST = 'mp-romance-shortlist';
      var KEY_NOTES = 'mp-romance-notes';
      var KEY_PREP = 'mp-romance-prep';

      function readJSON(key, fallback) {
        try {
          var raw = localStorage.getItem(key);
          return raw ? JSON.parse(raw) : fallback;
        } catch (e) { return fallback; }
      }
      function writeJSON(key, val) {
        try { localStorage.setItem(key, JSON.stringify(val)); } catch (e) {}
      }

      var shortlist = readJSON(KEY_SHORTLIST, []);
      var notes = readJSON(KEY_NOTES, {});
      var prep = readJSON(KEY_PREP, {});

      var candidateEls = document.querySelectorAll('.rp-candidate');
      var notesList = document.getElementById('rp-notes-list');
      var emptyMsg = document.getElementById('rp-shortlist-empty');

      function renderCandidates() {
        candidateEls.forEach(function (el) {
          var id = el.getAttribute('data-rp-id');
          el.classList.toggle('is-picked', shortlist.indexOf(id) > -1);
          var star = el.querySelector('.rp-star');
          if (star) star.textContent = shortlist.indexOf(id) > -1 ? '★' : '☆';
        });
      }

      function renderNotes() {
        notesList.innerHTML = '';
        if (shortlist.length === 0) { emptyMsg.hidden = false; return; }
        emptyMsg.hidden = true;
        shortlist.forEach(function (id) {
          var el = document.querySelector('.rp-candidate[data-rp-id="' + id + '"]');
          if (!el) return;
          var name = el.getAttribute('data-rp-name');
          var href = el.getAttribute('data-rp-href');
          var card = document.createElement('div');
          card.className = 'rp-note-card';
          var head = document.createElement('div');
          head.className = 'rp-note-head';
          var strong = document.createElement('strong');
          strong.textContent = name;
          var link = document.createElement('a');
          link.href = href;
          link.textContent = 'Profil ansehen';
          head.appendChild(strong);
          head.appendChild(link);
          var textarea = document.createElement('textarea');
          textarea.placeholder = 'Notizen zu ' + name + '…';
          textarea.value = notes[id] || '';
          textarea.addEventListener('input', function () {
            notes[id] = textarea.value;
            writeJSON(KEY_NOTES, notes);
          });
          card.appendChild(head);
          card.appendChild(textarea);
          notesList.appendChild(card);
        });
      }

      candidateEls.forEach(function (el) {
        el.addEventListener('click', function () {
          var id = el.getAttribute('data-rp-id');
          var idx = shortlist.indexOf(id);
          if (idx > -1) { shortlist.splice(idx, 1); }
          else { shortlist.push(id); }
          writeJSON(KEY_SHORTLIST, shortlist);
          renderCandidates();
          renderNotes();
        });
      });

      document.querySelectorAll('[data-rp-task]').forEach(function (box) {
        var id = box.getAttribute('data-rp-task');
        box.checked = !!prep[id];
        box.addEventListener('change', function () {
          prep[id] = box.checked;
          writeJSON(KEY_PREP, prep);
        });
      });

      var clearBtn = document.getElementById('rp-clear');
      if (clearBtn) {
        clearBtn.addEventListener('click', function () {
          if (!window.confirm('Deine Auswahlliste, Notizen und Checkliste löschen? Dies kann nicht rückgängig gemacht werden.')) return;
          shortlist = []; notes = {}; prep = {};
          writeJSON(KEY_SHORTLIST, shortlist);
          writeJSON(KEY_NOTES, notes);
          writeJSON(KEY_PREP, prep);
          renderCandidates();
          renderNotes();
          document.querySelectorAll('[data-rp-task]').forEach(function (box) { box.checked = false; });
        });
      }

      renderCandidates();
      renderNotes();
    })();
  </script>
</Base>
