---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
      { '@type': 'ListItem', position: 2, name: 'Werkzeuge', item: `${SITE.url}/de/tools` },
      { '@type': 'ListItem', position: 3, name: 'Landwirtschafts-Gewinnplaner', item: new URL('/de/tools/farming-profit-planner', SITE.url).href },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Moonlight Peaks Landwirtschafts-Gewinnplaner',
    applicationCategory: 'GameApplication',
    operatingSystem: 'Web',
    url: new URL('/de/tools/farming-profit-planner', SITE.url).href,
    description: 'Ein Moonlight-Peaks-Erntegewinnrechner für Saatgutpreis, Verkaufspreis, Wachstumstage, wiederholte Ernten und Düngerplanung.',
  },
];
---
<Base
  title="Moonlight Peaks Landwirtschafts-Gewinnplaner - Ernterechner & beste Feldfrüchte"
  description="Plane Moonlight-Peaks-Erntegewinne mit einem einsatzbereiten Landwirtschaftsrechner. Vergleiche Saatgutpreis, Verkaufspreis, Wachstumstage, Erntezahl und Düngerannahmen."
  path="/de/tools/farming-profit-planner"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Werkzeuge', href: '/de/tools' }, { label: 'Gewinnplaner' }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Werkzeug / Landwirtschaftsplaner</p>
      <h1>Moonlight Peaks <em>Landwirtschafts-Gewinnplaner</em></h1>
      <p class="intro">
        Vergleiche Feldfrüchte nach Gewinn pro Nacht, sobald echte {GAME.title}-Preise bekannt sind.
        Bis Launch-Daten verifiziert sind, nutze die untenstehenden manuellen Felder, um Szenarien
        zu testen, ohne unbekannte Erntewerte als endgültig auszugeben.
      </p>

      <section class="profit-tool" data-profit-tool>
        <form class="profit-form">
          <label><span>Name der Feldfrucht</span><input data-crop value="Zu bestätigende Feldfrucht" /></label>
          <label><span>Saatgutpreis</span><input data-seed type="number" min="0" value="0" /></label>
          <label><span>Verkaufspreis pro Ernte</span><input data-sell type="number" min="0" value="0" /></label>
          <label><span>Wachstumstage</span><input data-days type="number" min="1" value="1" /></label>
          <label><span>Anzahl Ernten</span><input data-harvests type="number" min="1" value="1" /></label>
          <label><span>Zusatzkosten</span><input data-extra type="number" min="0" value="0" /></label>
          <button type="button" class="btn btn-primary" data-add>Vergleich hinzufügen</button>
        </form>

        <aside class="profit-result">
          <span class="result-kicker">Aktuelle Schätzung</span>
          <h2 data-profit>0</h2>
          <p data-profit-copy>Gib nach dem Release Preise ein, um den Gesamtgewinn und den Gewinn pro Tag zu berechnen.</p>
        </aside>
      </section>

      <h2>Feldfrucht-Vergleiche</h2>
      <div class="profit-table-wrap">
        <table class="profit-table">
          <thead>
            <tr>
              <th>Feldfrucht</th>
              <th>Saatgut</th>
              <th>Verkauf</th>
              <th>Tage</th>
              <th>Ernten</th>
              <th>Gesamtgewinn</th>
              <th>Gewinn/Tag</th>
            </tr>
          </thead>
          <tbody data-rows>
            <tr><td colspan="7">Füge Feldfrüchte hinzu, sobald Launch-Daten verfügbar sind.</td></tr>
          </tbody>
        </table>
      </div>

      <div class="callout">
        Sichere Datenregel: Namen von Feldfrüchten, Saatgutpreise, Verkaufswerte, Wachstumszeit,
        Düngereffekte und Nachwuchsregeln sollten anhand des echten Spiels oder offizieller
        Materialien verifiziert werden, bevor sie als Guide-Inhalt behandelt werden.
      </div>
    </div>
  </article>

  <script>
    const root = document.querySelector('[data-profit-tool]');
    const rowsEl = document.querySelector('[data-rows]');
    if (root && rowsEl) {
      const els = {
        crop: root.querySelector('[data-crop]'),
        seed: root.querySelector('[data-seed]'),
        sell: root.querySelector('[data-sell]'),
        days: root.querySelector('[data-days]'),
        harvests: root.querySelector('[data-harvests]'),
        extra: root.querySelector('[data-extra]'),
        add: root.querySelector('[data-add]'),
        profit: root.querySelector('[data-profit]'),
        copy: root.querySelector('[data-profit-copy]'),
      };
      const key = 'moonlight-farming-planner-v1';
      let rows = JSON.parse(localStorage.getItem(key) || '[]');
      const num = (el) => Math.max(0, Number(el.value || 0));
      const calc = () => {
        const seed = num(els.seed);
        const sell = num(els.sell);
        const days = Math.max(1, num(els.days));
        const harvests = Math.max(1, num(els.harvests));
        const extra = num(els.extra);
        const totalRevenue = sell * harvests;
        const totalProfit = totalRevenue - seed - extra;
        const perDay = totalProfit / days;
        els.profit.textContent = Math.round(totalProfit).toString();
        els.copy.textContent = `${perDay.toFixed(2)} Gewinn pro Tag über ${days} Tag(e).`;
        return { crop: els.crop.value || 'Zu bestätigende Feldfrucht', seed, sell, days, harvests, totalProfit, perDay };
      };
      const renderRows = () => {
        rowsEl.innerHTML = rows.length ? rows.map((r) => `
          <tr>
            <td>${r.crop}</td>
            <td>${r.seed}</td>
            <td>${r.sell}</td>
            <td>${r.days}</td>
            <td>${r.harvests}</td>
            <td>${Math.round(r.totalProfit)}</td>
            <td>${Number(r.perDay).toFixed(2)}</td>
          </tr>
        `).join('') : '<tr><td colspan="7">Füge Feldfrüchte hinzu, sobald Launch-Daten verfügbar sind.</td></tr>';
      };
      const save = () => localStorage.setItem(key, JSON.stringify(rows.slice(-12)));
      root.addEventListener('input', calc);
      els.add.addEventListener('click', () => {
        rows.push(calc());
        save();
        renderRows();
      });
      calc();
      renderRows();
    }
  </script>

  <style>
    .profit-tool { display: grid; grid-template-columns: minmax(0, 1fr) 300px; gap: 18px; margin: 28px 0; }
    @media (max-width: 820px) { .profit-tool { grid-template-columns: 1fr; } }
    .profit-form, .profit-result {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--surface);
      padding: 18px;
    }
    .profit-form { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
    @media (max-width: 640px) { .profit-form { grid-template-columns: 1fr; } }
    .profit-form label span { display: block; margin-bottom: 6px; color: var(--mist); font-weight: 600; }
    .profit-form input {
      width: 100%;
      min-height: 44px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--ink);
      color: var(--mist);
      padding: 0 12px;
      font: inherit;
    }
    .profit-form button { grid-column: 1 / -1; justify-content: center; }
    .result-kicker { font-family: var(--mono); color: var(--candle); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; }
    .profit-result h2 { font-size: 3rem; margin: 8px 0; }
    .profit-result p { color: var(--muted); }
    .profit-table-wrap { overflow-x: auto; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); }
    .profit-table { width: 100%; min-width: 720px; border-collapse: collapse; }
    .profit-table th, .profit-table td { border-bottom: 1px solid var(--line); padding: 10px 12px; text-align: left; }
    .profit-table th { color: var(--candle); font-family: var(--mono); font-size: 0.68rem; text-transform: uppercase; }
    .profit-table tr:last-child td { border-bottom: 0; }
  </style>
</Base>
