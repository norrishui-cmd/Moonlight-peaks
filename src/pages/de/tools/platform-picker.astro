---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
      { '@type': 'ListItem', position: 2, name: 'Werkzeuge', item: `${SITE.url}/de/tools` },
      { '@type': 'ListItem', position: 3, name: 'Plattform-Auswahlhilfe', item: new URL('/de/tools/platform-picker', SITE.url).href },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Moonlight Peaks Plattform-Auswahlhilfe',
    applicationCategory: 'GameApplication',
    operatingSystem: 'Web',
    url: new URL('/de/tools/platform-picker', SITE.url).href,
    description: 'Eine Moonlight-Peaks-Plattform-Auswahlhilfe für Steam, Steam Deck, Nintendo Switch, Switch 2 und Android.',
  },
];
---
<Base
  title="Moonlight Peaks Plattform-Auswahlhilfe - Steam, Switch 2, Steam Deck oder Android?"
  description="Nutze diese Moonlight-Peaks-Plattform-Auswahlhilfe, um zu entscheiden, ob Steam, Steam Deck, Nintendo Switch, Switch 2 oder Android die beste Option für dich ist."
  path="/de/tools/platform-picker"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Werkzeuge', href: '/de/tools' }, { label: 'Plattform-Auswahlhilfe' }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Werkzeug / Plattform-Auswahlhilfe</p>
      <h1>Moonlight Peaks <em>Plattform-Auswahlhilfe</em></h1>
      <p class="intro">
        Nicht sicher, wo du {GAME.title} spielen sollst? Wähle aus, was dir wichtig ist, und dieses
        Werkzeug empfiehlt dir eine Plattform anhand bestätigter Plattformdaten, Demo-Verfügbarkeit
        und vorsichtiger Annahmen.
      </p>

      <section class="picker-shell" data-platform-picker>
        <div class="picker-panel">
          <h2>Deine Prioritäten</h2>
          <label>
            <span>Hauptsächliche Spielweise</span>
            <select data-field="playstyle">
              <option value="desk">Am Schreibtisch oder Laptop</option>
              <option value="handheld">Meist mobil/tragbar</option>
              <option value="tv">Am Fernseher oder Sofa</option>
              <option value="mobile">Auf Smartphone oder Mobilgerät</option>
            </select>
          </label>
          <fieldset>
            <legend>Was ist dir am wichtigsten?</legend>
            <label><input type="checkbox" value="demo" checked /> Ich möchte den einfachsten Demo-Zugang</label>
            <label><input type="checkbox" value="performance" /> Mir sind Performance und Patches wichtig</label>
            <label><input type="checkbox" value="portable" /> Ich möchte mobil spielen</label>
            <label><input type="checkbox" value="lowest-price" /> Ich möchte den niedrigsten wahrscheinlichen Preis</label>
            <label><input type="checkbox" value="controller" /> Ich bevorzuge Controller-/Sofa-Steuerung</label>
          </fieldset>
        </div>

        <div class="picker-result" aria-live="polite">
          <span class="result-kicker">Empfehlung</span>
          <h2 data-result-title>Steam</h2>
          <p data-result-copy>Steam ist die sicherste Standardwahl, wenn du schnelle Updates, PC/Mac-Zugang und den breitesten Demo-Zugang vor dem Release willst.</p>
          <div class="score-list" data-score-list></div>
          <a class="btn btn-primary" data-result-link href="/platforms">Plattform-Guide öffnen</a>
        </div>
      </section>

      <h2>Von dieser Auswahlhilfe verwendete Plattform-Fakten</h2>
      <table class="facts">
        <tr><th>Release-Datum</th><td>{GAME.releaseLabel}</td></tr>
        <tr><th>Bestätigte Plattformen</th><td>{GAME.platforms.join(', ')}</td></tr>
        <tr><th>Demo</th><td>{GAME.demo}</td></tr>
        <tr><th>Preis</th><td>{GAME.price}; die Switch-2-Edition dürfte höher liegen.</td></tr>
      </table>

      <div class="callout">
        Dies ist ein Planungswerkzeug, kein Performance-Benchmark. Endgültige Steam-Deck-Verifizierung,
        Android-Anforderungen und Switch-Performance sollten beim Release erneut geprüft werden.
      </div>
    </div>
  </article>

  <script>
    const tools = document.querySelector('[data-platform-picker]');
    if (tools) {
      const platforms = [
        {
          id: 'steam',
          title: 'Steam',
          href: '/platforms',
          copy: 'Steam ist die sicherste Standardwahl, wenn du schnelle Updates, PC/Mac-Zugang und den breitesten Demo-Zugang vor dem Release willst.',
          weights: { desk: 5, handheld: 1, tv: 1, mobile: 0, demo: 3, performance: 3, portable: 0, 'lowest-price': 2, controller: 1 },
        },
        {
          id: 'steam-deck',
          title: 'Steam Deck',
          href: '/platforms/steam-deck',
          copy: 'Steam Deck passt am besten, wenn du mobil spielen und trotzdem im Steam-Ökosystem bleiben willst.',
          weights: { desk: 1, handheld: 5, tv: 1, mobile: 0, demo: 2, performance: 2, portable: 4, 'lowest-price': 1, controller: 2 },
        },
        {
          id: 'switch-2',
          title: 'Nintendo Switch 2',
          href: '/platforms/switch-2',
          copy: 'Switch 2 ist die beste Konsolen-Wahl, wenn du eine native, neuere Nintendo-Version und sofafreundliches Spielen willst.',
          weights: { desk: 0, handheld: 4, tv: 5, mobile: 0, demo: 2, performance: 3, portable: 4, 'lowest-price': 0, controller: 4 },
        },
        {
          id: 'switch',
          title: 'Nintendo Switch',
          href: '/platforms',
          copy: 'Nintendo Switch passt gut, wenn du die Konsole bereits besitzt und mobil oder am Fernseher spielen willst, ohne einen PC zu nutzen.',
          weights: { desk: 0, handheld: 4, tv: 4, mobile: 0, demo: 2, performance: 0, portable: 4, 'lowest-price': 1, controller: 4 },
        },
        {
          id: 'android',
          title: 'Android / Google Play',
          href: '/platforms/android',
          copy: 'Android ist die Wahl für mobile Spieler, aber Geräteanforderungen und Steuerung sollten beim Release bestätigt werden.',
          weights: { desk: 0, handheld: 2, tv: 0, mobile: 5, demo: 0, performance: 0, portable: 4, 'lowest-price': 1, controller: 0 },
        },
      ];

      const playstyle = tools.querySelector('[data-field="playstyle"]');
      const checks = [...tools.querySelectorAll('input[type="checkbox"]')];
      const resultTitle = tools.querySelector('[data-result-title]');
      const resultCopy = tools.querySelector('[data-result-copy]');
      const resultLink = tools.querySelector('[data-result-link]');
      const scoreList = tools.querySelector('[data-score-list]');

      const render = () => {
        const selected = [playstyle.value, ...checks.filter((item) => item.checked).map((item) => item.value)];
        const scored = platforms
          .map((platform) => ({
            ...platform,
            score: selected.reduce((sum, key) => sum + (platform.weights[key] || 0), 0),
          }))
          .sort((a, b) => b.score - a.score);
        const best = scored[0];
        resultTitle.textContent = best.title;
        resultCopy.textContent = best.copy;
        resultLink.href = best.href;
        scoreList.innerHTML = scored
          .map((item) => `<div><span>${item.title}</span><strong>${item.score}</strong></div>`)
          .join('');
      };

      playstyle.addEventListener('change', render);
      checks.forEach((item) => item.addEventListener('change', render));
      render();
    }
  </script>

  <style>
    .picker-shell { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 0.9fr); gap: 18px; margin-top: 28px; align-items: stretch; }
    @media (max-width: 820px) { .picker-shell { grid-template-columns: 1fr; } }
    .picker-panel, .picker-result { border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); padding: 18px; }
    .picker-panel h2, .picker-result h2 { margin-top: 0; }
    .picker-panel label span, .picker-panel legend { display: block; color: var(--mist); font-weight: 600; margin-bottom: 8px; }
    .picker-panel select {
      width: 100%;
      min-height: 44px;
      color: var(--mist);
      background: var(--ink);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 0 12px;
      font: inherit;
    }
    .picker-panel fieldset { border: 0; padding: 0; margin: 22px 0 0; display: grid; gap: 10px; }
    .picker-panel fieldset label { display: flex; gap: 10px; align-items: flex-start; color: var(--muted); }
    .picker-panel input { accent-color: var(--candle); margin-top: 5px; }
    .result-kicker { font-family: var(--mono); font-size: 0.7rem; color: var(--candle); text-transform: uppercase; letter-spacing: 0.12em; }
    .score-list { display: grid; gap: 8px; margin: 18px 0; }
    .score-list div { display: flex; justify-content: space-between; gap: 12px; border-bottom: 1px solid var(--line); padding-bottom: 7px; color: var(--muted); }
    .score-list strong { color: var(--candle); font-family: var(--mono); }
  </style>
</Base>
