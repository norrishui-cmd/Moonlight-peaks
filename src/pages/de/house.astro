---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';

const faq = [
  { q: 'Kann man sein Häuschen in Moonlight Peaks dekorieren?', a: 'Ja — berichtet: Du kannst dein Häuschen-Interieur und dein Hofgelände anpassen, Möbel platzieren und drehen, und Deko wie Wege und Feenlichter herstellen.' },
  { q: 'Gibt es ein Gewächshaus in Moonlight Peaks?', a: 'Ja, bestätigt: Das Bauen eines Gewächshauses ist mit einer eigenen Errungenschaft verbunden, "Perpetual Bloom." Siehe unsere <a href="/farm/greenhouse">Gewächshaus-Seite</a> für das bisher Bekannte zu Baukosten und Nutzen.' },
  { q: 'Kann man sein Haus aufrüsten?', a: 'Bestätigt: "Dracula Estate" ist die Errungenschaft fürs vollständige Aufrüsten deines Hauses, es gibt also einen echten Upgrade-Pfad über kosmetisches Dekorieren hinaus — genaue Stufen und Kosten sind noch nicht bequellt. Der Barn (4.000 Gold, von Ridge) und der Brunnen (1.500 Gold) sind ebenfalls bestätigte Gebäudekäufe.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Haus & Dekoration', item: `${SITE.url}/de/house` },
  ] },
];
---
<Base
  title="Moonlight Peaks Haus, Dekoration & Gewächshaus"
  description="Dein Häuschen in Moonlight Peaks dekorieren: bisher bestätigte Möbel, Wege und Feenlichter, plus was zu Gewächshaus und Hausupgrades noch unbestätigt ist."
  path="/de/house"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Haus & Dekoration' }]}
  lang="de"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Eintrag · Zuhause</p>
      <h1>Moonlight Peaks <em>Haus</em> & Dekoration</h1>
      <p class="intro">
        Dein Häuschen und Hofgelände jenseits der Landwirtschaft — was zum Dekorieren bestätigt ist,
        getrennt von dem, was noch unbestätigt ist. Zuletzt aktualisiert: {SITE.updated}.
      </p>

      <h2>Dein Häuschen dekorieren</h2>
      <p>
        Berichtet: Dekorieren in Moonlight Peaks umfasst das Platzieren und Drehen von Möbeln, das
        Anpassen deines Häuschen-Interieurs und das Herstellen von Deko für das Hofgelände —
        darunter Wege und Feenlichter.
      </p>

      <h2>Gewächshaus — bestätigt zu existieren</h2>
      <p>
        Bestätigt: Das Bauen eines Gewächshauses ist mit einer eigenen Steam-Errungenschaft
        verbunden, "Perpetual Bloom." Community-berichtet: Eines zu haben soll auch bei mehreren
        anderen landwirtschaftlichen Zielen helfen, es lohnt sich also, es zu priorisieren. Siehe
        unsere <a href="/farm/greenhouse">Gewächshaus-Seite</a> für Baukosten- und Platzdetails,
        sobald sie bestätigt sind.
      </p>

      <h2>Bisher bestätigte Gebäude-Upgrades</h2>
      <p>
        Bestätigt: "Dracula Estate" ist die Errungenschaft fürs vollständige Aufrüsten deines
        Hauses, es gibt also einen echten Upgrade-Pfad über kosmetisches Dekorieren hinaus — genaue
        Stufen und Kosten sind noch nicht bequellt. Zwei weitere bestätigte Gebäudekäufe: der
        <strong>Barn</strong> (4.000 Gold + Materialien, von Ridge, erforderlich vor dem Kauf von
        Vieh) und der <strong>Brunnen</strong> (berichtet mit 1.500 Gold, hilft beim Gießen).
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Verwandt: <a href="/de/farming">Landwirtschaft</a>, <a href="/de/character-creator">Charaktereditor</a>,
        <a href="/de/beginner-guide">Einsteiger-Guide</a>.
      </div>
    </div>
  </article>
</Base>
