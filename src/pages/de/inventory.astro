---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const faq = [
  { q: 'Wie funktioniert das Inventar in Moonlight Peaks?', a: 'Bestätigt zum Release: Das Spiel nutzt ein universelles Hauslagersystem — Crafting-Stationen (wie Küche und Kessel) ziehen Zutaten und Materialien automatisch direkt aus deinem Hauslager, statt dass du alles in einem persönlichen Inventar mit dir tragen musst.' },
  { q: 'Kann man seinen Inventarplatz erhöhen?', a: 'Noch nicht bestätigt. Angesichts des universellen Lagerdesigns betreffen Kapazitäts-Upgrades (falls es welche gibt) eher das Hauslager als ein traditionelles Slot-Inventar.' },
  { q: 'Wie verkauft man Gegenstände?', a: 'Wirf Waren in Chester, die lebende Aufbewahrungstruhe, die dir Brook bei der Registrierung am Rathaus schenkt — Gegenstände verkaufen sich über Nacht, während du schläfst.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Inventar', item: `${SITE.url}/de/inventory` },
  ] },
];
---
<Base
  title="Moonlight Peaks Inventar — Universelles Lagersystem erklärt"
  description="Wie das Inventar in Moonlight Peaks funktioniert: das universelle Hauslagersystem, das deine Crafting-Stationen automatisch versorgt, und wie der Verkauf über Chester funktioniert."
  path="/de/inventory"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Inventar' }]}
  lang="de"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Eintrag · Inventar</p>
      <h1>Moonlight Peaks <em>Inventar</em> & Lagerung</h1>
      <p class="intro">
        {GAME.title} handhabt das Inventar anders als ein typisches Slot-System. Hier ist, was
        bestätigt ist. Zuletzt aktualisiert: {SITE.updated}.
      </p>

      <h2>Universelles Hauslager</h2>
      <p>
        Bestätigt zum Release: Statt ein persönliches Inventar fürs Crafting zu jonglieren, nutzt
        Moonlight Peaks ein universelles Hauslager — wirf Materialien ins Lager zu Hause, und
        Crafting-Stationen (die Küche, der Kessel und andere) ziehen sich automatisch, was sie
        brauchen. Frühe Spieler beschreiben dies als eines der bequemeren
        Lebensqualität-Systeme im Spiel.
      </p>

      <h2>Verkaufen über Chester</h2>
      <p>
        Bestätigt: Du verkaufst Waren, indem du sie in <a href="/characters/chester">Chester</a>
        wirfst, die lebende Aufbewahrungstruhe, die dir Brook bei deiner Registrierung am Rathaus
        schenkt. Gegenstände verkaufen sich über Nacht, während du schläfst, es gibt also keinen
        separaten Laden-Besuch-Schritt für einfache Verkäufe.
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Verwandt: <a href="/de/farming">Landwirtschaft</a>, <a href="/de/items">Gegenstände</a>,
        <a href="/characters/chester">Chester</a>, <a href="/de/beginner-guide">Einsteiger-Guide</a>.
      </div>
    </div>
  </article>
</Base>
