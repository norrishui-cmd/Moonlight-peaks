---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const entries = [
  { title: 'Einsteiger-Guide', desc: 'Was in der ersten Woche wirklich zählt — bestätigt aus dem laufenden Spiel.', href: '/de/beginner-guide', img: '/card-guide.webp' },
  { title: 'Release & Plattformen', desc: 'Seit dem 7. Juli erhältlich — Preis, Plattformen und PS5/Xbox-Status.', href: '/de/release-date', img: '/card-release.webp' },
  { title: 'Charaktere', desc: 'Bewohner, Familien und wen du romantisch verfolgen kannst.', href: '/de/characters', img: '/count-dracula.webp' },
  { title: 'Romanze', desc: '23 bestätigte Romanze-Optionen, Herzstufen und Heirat.', href: '/de/romance', img: '/card-romance.webp' },
  { title: 'Magie', desc: 'Der zerbrochene Zauberstab, Moon Fruit und Mana-Fortschritt.', href: '/de/magic', img: '/card-guide.webp' },
  { title: 'Orte', desc: 'Die Stadt, deine Farm, Howling Marshes und mehr.', href: '/de/locations', img: '/hero-loc-town.webp' },
  { title: 'Cave of Echoes', desc: 'Freischaltung, Erz und die Minen im Detail.', href: '/de/locations/mines', img: '/hero-loc-mines.webp' },
  { title: 'Bekannte Probleme', desc: 'Abstürze, Controller-Probleme und bestätigte Workarounds.', href: '/de/known-issues', img: '/card-guide.webp' },
];

const explore = [
  { k: 'Romanze-System', d: 'Herzstufen, Verabredungen und Ehe', href: '/de/romance', img: '/card-romance.webp' },
  { k: 'Familien', d: 'Die sieben übernatürlichen Familien der Stadt', href: '/de/families', img: '/hero-fam-vampires.webp' },
  { k: 'Farm & Anbau', d: 'Feldfrüchte, Scheune, magisches Vieh', href: '/de/farm', img: '/card-crops.webp' },
  { k: 'Quest-Guide', d: 'Hauptgeschichte Kapitel für Kapitel, plus Nebenquests', href: '/de/quests', img: '/hero-first-five-minutes.webp' },
  { k: 'Sammlung', d: 'Fische, Kreaturen, Vampster und Soul Blobs', href: '/de/collections', img: null, c1: '#3a4a2f', c2: '#8ab06a' },
  { k: 'Items', d: 'Werkzeuge, Tränke, Dekoration und mehr', href: '/de/items', img: '/card-guide.webp' },
];

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'WebSite', name: 'Moonlight Peaks Wiki (Deutsch)',
  url: `${SITE.url}/de`, inLanguage: 'de',
  description: 'Deutscher Fan-Guide zu Moonlight Peaks, dem gemütlichen Vampir-Life-Sim: Release, Einsteiger-Tipps, Romanze und mehr.',
};
---
<Base
  title="Moonlight Peaks Wiki auf Deutsch — Release, Guides & Tipps"
  description="Der deutsche Fan-Guide zu Moonlight Peaks: Release-Infos, Einsteiger-Guide, Romanze, Charaktere und bekannte Probleme — seit dem 7. Juli 2026 verfügbar."
  path="/de"
  jsonLd={jsonLd}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Der Feldkalender eines Vampir-Farmers</p>
      <h1><em>Moonlight Peaks</em> ist jetzt erhältlich.</h1>
      <p class="intro">
        Der gemütlich-gotische Guide zu {GAME.developer}s Vampir-Life-Sim. {GAME.title} ist seit dem
        7. Juli 2026 auf Steam, Nintendo Switch, Switch 2 und Android verfügbar. Diese deutsche
        Version deckt die wichtigsten Seiten ab.
      </p>
      <p class="callout wip">
        Diese deutschsprachige Version umfasst aktuell {entries.length} zentrale Seiten. Weitere
        Inhalte (Charakterprofile, FAQ, Aktivitäten) gibt es bisher nur auf Englisch — Links dorthin
        sind entsprechend gekennzeichnet.
      </p>

      <h2>Fang hier an</h2>
      <div class="es-grid">
        {entries.map((e) => (
          <a class="es-card" href={e.href}>
            <img src={e.img} alt="" loading="lazy" width="64" height="64" />
            <span>
              <strong>{e.title}</strong>
              <em>{e.desc}</em>
            </span>
          </a>
        ))}
      </div>

      <h2>Die Welt erkunden</h2>
      <div class="es-grid">
        {explore.map((x) => (
          <a class="es-card" href={x.href}>
            <span class="es-thumb" style={!x.img ? `background: linear-gradient(135deg, ${x.c1}, ${x.c2})` : undefined}>
              {x.img ? <img src={x.img} alt="" loading="lazy" width="64" height="64" /> : <span class="es-thumb-letter">{x.k[0]}</span>}
            </span>
            <span>
              <strong>{x.k}</strong>
              <em>{x.d}</em>
            </span>
          </a>
        ))}
      </div>

      <h2>Womit die meisten gerade feststecken</h2>
      <p class="trending-note">Was gerade am häufigsten gesucht wird</p>
      <ul class="trending-list">
        <li><a href="/de/magic">Den kaputten Zauberstab reparieren</a></li>
        <li><a href="/de/locations/mines">Die Höhle des Echos freischalten</a></li>
        <li><a href="/de/quests/side/ui-softlock-after-shop">UI eingefroren nach Ladenbesuch</a></li>
        <li><a href="/de/quests/side/lost-save-data">Speicherdaten verloren — was tun?</a></li>
        <li><a href="/de/quests/side/npc-stuck-cant-interact">Ein NPC reagiert nicht</a></li>
        <li><a href="/de/quests/story/a-bridge-too-far">A Bridge Too Far Quest-Guide</a></li>
      </ul>
    </div>
  </article>

  <style>
    .page { padding: 32px 0 60px; }
    .eyebrow { font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--faint); }
    h1 { font-family: var(--display); font-size: 2rem; margin: 6px 0 14px; }
    h1 em { color: var(--candle); font-style: normal; }
    .intro { color: var(--muted); font-size: 1rem; line-height: 1.6; max-width: 640px; margin-bottom: 16px; }
    .callout.wip { border-left: 2px solid var(--candle); background: var(--ink-2); padding: 12px 16px; border-radius: 0 10px 10px 0; color: var(--muted); font-size: 0.88rem; margin: 0 0 32px; }
    h2 { font-family: var(--display); font-size: 1.3rem; margin: 28px 0 12px; }
    .es-grid { display: grid; grid-template-columns: 1fr; gap: 10px; }
    @media (min-width: 640px) { .es-grid { grid-template-columns: 1fr 1fr; } }
    .es-card { display: flex; align-items: center; gap: 12px; border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 12px; transition: border-color .15s ease; }
    .es-card:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); }
    .es-card img { border-radius: 10px; object-fit: cover; width: 64px; height: 64px; flex: 0 0 auto; }
    .es-card span:not(.es-thumb) { display: flex; flex-direction: column; min-width: 0; }
    .es-card strong { font-family: var(--display); font-weight: 600; font-size: 0.96rem; color: var(--mist); }
    .es-card em { font-style: normal; font-size: 0.8rem; color: var(--faint); margin-top: 2px; }
    .es-thumb { flex: 0 0 auto; width: 64px; height: 64px; border-radius: 10px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--line); }
    .es-thumb-letter { font-family: var(--display); font-weight: 700; font-size: 1.4rem; color: rgba(255,255,255,0.9); }
    .trending-note { font-size: 0.82rem; color: var(--faint); margin: 4px 0 0; }
    .trending-list { list-style: none; margin: 12px 0 0; padding: 0; display: grid; grid-template-columns: 1fr; gap: 8px; }
    @media (min-width: 640px) { .trending-list { grid-template-columns: 1fr 1fr; } }
    .trending-list a {
      display: block; padding: 10px 14px; border: 1px solid var(--line); border-radius: 10px;
      color: var(--mist); text-decoration: none; font-size: 0.9rem; background: var(--surface);
      transition: border-color .15s ease;
    }
    .trending-list a:hover { border-color: color-mix(in srgb, var(--candle) 45%, var(--line)); color: var(--candle); }
  </style>
</Base>
