---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';

const faq = [
  { q: 'Überträgt sich der Spielstand der Demo auf das Hauptspiel?', a: 'Nein — es wurde keine Übertragung bestätigt. Das Hauptspiel beginnt unabhängig vom Demo-Fortschritt neu.' },
  { q: 'Wo gibt es die kostenlose Demo?', a: 'Auf Steam (PC/Mac) und im Nintendo eShop (auch auf Switch 2 spielbar).' },
  { q: 'Was ist in der Demo enthalten?', a: 'Charaktererstellung, Angeln, Blumenbinden, Sticken und erste Begegnungen mit Bewohnern.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Demo', item: `${SITE.url}/de/demo` },
  ] },
];
---
<Base
  title="Moonlight Peaks Demo — Download & Infos (Deutsch)"
  description="Die kostenlose Moonlight Peaks Demo auf Steam und im Nintendo eShop: Inhalt, Download und ob der Spielstand übertragen wird — auf Deutsch."
  path="/de/demo"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Demo' }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Eintrag / Demo</p>
      <h1>Moonlight Peaks <em>Demo</em></h1>
      <p class="intro">
        Die kostenlose Moonlight Peaks Demo ist weiterhin eine gute Möglichkeit, das gemütliche
        Vampir-Life-Sim auszuprobieren, bevor du das seit dem 7. Juli 2026 erhältliche Hauptspiel
        kaufst.
      </p>

      <div class="callout">
        <strong>Kurzantwort:</strong> Keine Übertragung des Spielstands wurde bestätigt — das
        Hauptspiel beginnt unabhängig von deinem Demo-Fortschritt neu. Die Demo eignet sich am
        besten, um Steuerung, Tonalität und frühe Aktivitäten zu testen.
      </div>

      <h2>Wo gibt es die Demo?</h2>
      <p>
        Kostenlos auf Steam (PC/Mac) und im Nintendo eShop verfügbar; die Switch-Demo ist auch auf
        Switch 2 spielbar.
      </p>

      <h2>Was ist enthalten?</h2>
      <p>
        Charaktererstellung, Angeln, Blumenbinden, Sticken und erste Begegnungen mit Bewohnern der
        Stadt.
      </p>

      <h2>Häufige Fragen</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Weiterführend: <a href="/de/release-date">Release-Datum</a>,
        <a href="/de/platforms">Plattformen</a>, <a href="/de/beginner-guide">Einsteiger-Guide</a>.
      </div>
    </div>
  </article>
</Base>
