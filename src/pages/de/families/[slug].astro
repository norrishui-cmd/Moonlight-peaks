---
import TopicPage from '../../../components/TopicPage.astro';
import { familiesSection, families } from '../../../data/families';
import { familiesDe } from '../../../i18n/families-de';

export function getStaticPaths() {
  return families.filter((it) => familiesDe[it.slug]).map((it, i, arr) => {
    const tr = familiesDe[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...arr[(i - 1 + arr.length) % arr.length], ...familiesDe[arr[(i - 1 + arr.length) % arr.length].slug] },
        next: { ...arr[(i + 1) % arr.length], ...familiesDe[arr[(i + 1) % arr.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const deSection = { ...familiesSection, base: '/de/families', label: 'Familien', eyebrow: 'Welt' };
---
<TopicPage section={deSection} item={item} prev={prev} next={next} lang="de" basePath="/de/families" />
