---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';

const tools = [
  { href: '/de/tools/platform-picker', tag: 'Entscheidung', title: 'Platform Picker', text: 'Wähle sicher zwischen Steam, Steam Deck, Switch, Switch 2 und Android.', status: 'Live' },
  { href: '/de/tools/romance-gift-finder', tag: 'Romanze', title: 'Romance Gift Finder', text: 'Bewohner, Romanze-Status, Familienhinweise und bestätigte Geschenkinfos auf einen Blick.', status: 'Live' },
  { href: '/de/tools/romance-match-quiz', tag: 'Quiz', title: 'Romance Match Quiz', text: 'Finde mit ein paar einfachen Fragen mögliche Romanze-Optionen für dich.', status: 'Live' },
  { href: '/de/tools/romance-planner', tag: 'Planer', title: 'Romance Planner', text: 'Speichere Favoriten, Notizen und deinen Romanze-Fortschritt im Browser.', status: 'Live' },
  { href: '/de/tools/families-explorer', tag: 'Familien', title: 'Families Explorer', text: 'Durchsuche alle 23 Romanze-Optionen, gruppiert nach ihrer echten Familie.', status: 'Live' },
  { href: '/de/tools/item-tracker', tag: 'Sammlung', title: 'Item Tracker', text: 'Verfolge deinen Sammelfortschritt bei Fischen, Insekten, Rezepten, Tränken und Dekoration.', status: 'Live' },
  { href: '/de/tools/gift-tracker', tag: 'Persönliches Log', title: 'Gift Tracker', text: 'Protokolliere deine eigenen Geschenk-Tests pro Bewohner, privat in deinem Browser gespeichert.', status: 'Live' },
  { href: '/de/tools/fish-finder', tag: 'Referenz', title: 'Fish Finder', text: 'Filtere alle 22 bestätigten Fischarten nach Fundort oder Seltenheit.', status: 'Live' },
  { href: '/de/tools/farming-profit-planner', tag: 'Landwirtschaft', title: 'Farming Profit Planner', text: 'Vergleiche Feldfrucht-Gewinne, sobald Preise und Wachstumstage bestätigt sind.', status: 'Live' },
  { href: '/de/tools/nokturna-tracker', tag: 'Karten', title: 'Nokturna Tracker', text: 'Protokolliere deine eigene Nokturna-Kartensammlung, sobald einzelne Karten bestätigt werden.', status: 'Live' },
  { href: '/de/tools/submit-data', tag: 'Community', title: 'Data Submitter', text: 'Speichere Launch-Week-Entdeckungen als lokalen Entwurf zur späteren Überprüfung.', status: 'Live' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Werkzeuge', item: new URL('/de/tools', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'CollectionPage', name: 'Moonlight Peaks Werkzeuge', url: new URL('/de/tools', SITE.url).href },
];
---
<Base
  title="Moonlight Peaks Werkzeuge - Plattform, Romanze, Sammlung"
  description="Deutscher Werkzeug-Hub für Moonlight Peaks. Plattformwahl, Romanze, Geschenke, Item-Tracking, Landwirtschaftsgewinn und Community-Daten."
  path="/de/tools"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Werkzeuge' }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Werkzeuge / Spielerhilfe</p>
      <h1>Moonlight Peaks <em>Werkzeuge</em></h1>
      <p class="intro">
        Praktische Werkzeuge für Plattformwahl, Romanze-Vorbereitung, Geschenke-Recherche,
        Gegenstandssammlung und Landwirtschaftsberechnungen — alle nützlich vor und nach dem Release.
      </p>

      <section class="tool-grid" aria-label="Moonlight Peaks tools">
        {tools.map((tool) => (
          <a class="tool-card" href={tool.href}>
            <span class="tool-status">{tool.status}</span>
            <span class="tool-tag">{tool.tag}</span>
            <strong>{tool.title}</strong>
            <span>{tool.text}</span>
            <em>Werkzeug öffnen -&gt;</em>
          </a>
        ))}
      </section>

      <h2>Unser Ansatz für diese Werkzeuge</h2>
      <p>
        Wir vermeiden es, unbestätigte Daten als sicher darzustellen. Unbestätigte Punkte werden
        als offen markiert, und sobald verlässliche Informationen bestätigt sind, aktualisieren
        wir dieselbe URL.
      </p>
    </div>
  </article>

  <style>
    .tool-grid { display: grid; grid-template-columns: 1fr; gap: 14px; margin: 24px 0; }
    @media (min-width: 760px) { .tool-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @media (min-width: 1080px) { .tool-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    .tool-card { min-height: 190px; display: flex; flex-direction: column; gap: 10px; border: 1px solid var(--line); border-radius: 12px; background: linear-gradient(135deg, rgba(244,202,104,.12), var(--surface)); padding: 16px; text-decoration: none; }
    .tool-card strong { font-family: var(--display); font-size: 1.25rem; color: var(--mist); }
    .tool-card span { color: var(--muted); }
    .tool-status, .tool-tag, .tool-card em { font-family: var(--mono); color: var(--candle); font-style: normal; }
    .tool-card em { margin-top: auto; }
  </style>
</Base>
