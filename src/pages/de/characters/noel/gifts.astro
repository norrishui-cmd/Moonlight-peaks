---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Was schenkt man Noel am liebsten?',
    acceptedAnswer: { '@type': 'Answer', text: 'Noel liebt Golden Egg über alles.' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Charaktere', item: `${SITE.url}/de/characters` },
    { '@type': 'ListItem', position: 3, name: 'Noel', item: `${SITE.url}/de/characters/noel` },
  ] },
];
---
<Base
  title="Noels Lieblingsgeschenke | Moonlight Peaks Charakterguide"
  description="Bestätigte Geschenkvorlieben von Noel in Moonlight Peaks — was er liebt, mag und ablehnt."
  path="/de/characters/noel/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Charaktere', href: '/de/characters' }, { label: 'Noel', href: '/de/characters/noel' }, { label: 'Geschenke' }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Charaktere · Geschenke</p>
      <h1>Noels Lieblings<em>geschenke</em></h1>
      <p class="intro">
        Bestätigte Geschenkdaten für Noel, basierend auf Launch-Week-Tests internationaler Medien
        (TheGamer, veröffentlicht am 7. Juli 2026).
      </p>

      <h2>Liebt er besonders</h2>
      <p>Bestätigt liebt Noel: Golden Egg. Die effektivste Wahl, um die Beziehung schnell zu vertiefen.</p>

      <h2>Mag er</h2>
      <p>Darüber hinaus mag Noel auch: Blood Grape, Blood Grape Juice, Erdbeersaft und Glibby Fish.</p>

      <h2>Mag er nicht</h2>
      <p>Vermeide bei Noel: Purple Tulip und Pink Azalea — bei den meisten anderen Charakteren beliebte Blumen, aber bei ihm bestätigt unerwünscht.</p>

      <div class="callout wip">
        Verwandte Seiten: <a href="/de/characters/noel">Noels Profil</a>,
        <a href="/de/characters">Charakterübersicht</a>, <a href="/characters/noel/gifts">ausführliche Version auf Englisch</a>.
      </div>
    </div>
  </article>
</Base>
