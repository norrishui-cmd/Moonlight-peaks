---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Was schenkt man Fiona am liebsten?',
    acceptedAnswer: { '@type': 'Answer', text: 'Fiona liebt Erdbeeren (Strawberries) über alles.' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Charaktere', item: `${SITE.url}/de/characters` },
    { '@type': 'ListItem', position: 3, name: 'Fiona', item: `${SITE.url}/de/characters/fiona` },
  ] },
];
---
<Base
  title="Fionas Lieblingsgeschenke | Moonlight Peaks Charakterguide"
  description="Bestätigte Geschenkvorlieben von Fiona in Moonlight Peaks — was sie liebt, mag und ablehnt."
  path="/de/characters/fiona/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Charaktere', href: '/de/characters' }, { label: 'Fiona', href: '/de/characters/fiona' }, { label: 'Geschenke' }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Charaktere · Geschenke</p>
      <h1>Fionas Lieblings<em>geschenke</em></h1>
      <p class="intro">
        Bestätigte Geschenkdaten für Fiona, basierend auf Launch-Week-Tests internationaler Medien
        (TheGamer, veröffentlicht am 7. Juli 2026).
      </p>

      <h2>Liebt sie besonders</h2>
      <p>Bestätigt liebt Fiona: Erdbeeren (Strawberries).</p>

      <h2>Mag sie</h2>
      <p>Darüber hinaus mag Fiona auch: Purple Tulip, Purple Azalea, Purple Lavender, Ei (Egg) und Moon Juice.</p>

      <h2>Mag sie nicht</h2>
      <p>Vermeide bei Fiona: Onion Seeds. Bestätigt senkt dies die Zuneigung.</p>

      <div class="callout wip">
        Verwandte Seiten: <a href="/de/characters/fiona">Fionas Profil</a>,
        <a href="/de/characters">Charakterübersicht</a>, <a href="/characters/fiona/gifts">ausführliche Version auf Englisch</a>.
      </div>
    </div>
  </article>
</Base>
