---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Was schenkt man Orlock am liebsten?',
    acceptedAnswer: { '@type': 'Answer', text: 'Orlock liebt Weißwein und Rotwein.' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Charaktere', item: `${SITE.url}/de/characters` },
    { '@type': 'ListItem', position: 3, name: 'Orlock', item: `${SITE.url}/de/characters/orlock` },
  ] },
];
---
<Base
  title="Orlocks Lieblingsgeschenke | Moonlight Peaks Charakterguide"
  description="Bestätigte Geschenkvorlieben von Orlock in Moonlight Peaks — was er liebt, mag und ablehnt."
  path="/de/characters/orlock/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Charaktere', href: '/de/characters' }, { label: 'Orlock', href: '/de/characters/orlock' }, { label: 'Geschenke' }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Charaktere · Geschenke</p>
      <h1>Orlocks Lieblings<em>geschenke</em></h1>
      <p class="intro">
        Bestätigte Geschenkdaten für Orlock, basierend auf Launch-Week-Tests internationaler Medien
        (TheGamer, veröffentlicht am 7. Juli 2026).
      </p>

      <h2>Liebt er besonders</h2>
      <p>Bestätigt liebt Orlock: Weißwein (White Wine) und Rotwein (Red Wine).</p>

      <h2>Mag er</h2>
      <p>Darüber hinaus mag Orlock auch: Purple Tulip und Pink Azalea.</p>

      <h2>Mag er nicht</h2>
      <p>Vermeide bei Orlock: Holz (Wood) und Onion Seeds. Bestätigt senken diese die Zuneigung.</p>

      <div class="callout wip">
        Verwandte Seiten: <a href="/de/characters/orlock">Orlocks Profil</a>,
        <a href="/de/characters">Charakterübersicht</a>, <a href="/characters/orlock/gifts">ausführliche Version auf Englisch</a>.
      </div>
    </div>
  </article>
</Base>
