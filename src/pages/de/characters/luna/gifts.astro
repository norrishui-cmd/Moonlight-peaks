---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Was schenkt man Luna am liebsten?',
    acceptedAnswer: { '@type': 'Answer', text: 'Luna liebt Purple Tulip, Purple Azalea und White Rose.' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Charaktere', item: `${SITE.url}/de/characters` },
    { '@type': 'ListItem', position: 3, name: 'Luna', item: `${SITE.url}/de/characters/luna` },
  ] },
];
---
<Base
  title="Lunas Lieblingsgeschenke | Moonlight Peaks Charakterguide"
  description="Bestätigte Geschenkvorlieben von Luna in Moonlight Peaks — was sie liebt, mag und ablehnt."
  path="/de/characters/luna/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Charaktere', href: '/de/characters' }, { label: 'Luna', href: '/de/characters/luna' }, { label: 'Geschenke' }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Charaktere · Geschenke</p>
      <h1>Lunas Lieblings<em>geschenke</em></h1>
      <p class="intro">
        Bestätigte Geschenkdaten für Luna, basierend auf Launch-Week-Tests internationaler Medien
        (TheGamer, veröffentlicht am 7. Juli 2026).
      </p>

      <h2>Liebt sie besonders</h2>
      <p>Bestätigt liebt Luna: Purple Tulip, Purple Azalea und White Rose.</p>

      <h2>Mag sie</h2>
      <p>Darüber hinaus mag Luna auch: Blood Grape.</p>

      <h2>Mag sie nicht</h2>
      <p>Vermeide bei Luna: Rusty Bean Can. Bestätigt senkt dies die Zuneigung.</p>

      <div class="callout wip">
        Verwandte Seiten: <a href="/de/characters/luna">Lunas Profil</a>,
        <a href="/de/characters">Charakterübersicht</a>, <a href="/characters/luna/gifts">ausführliche Version auf Englisch</a>.
      </div>
    </div>
  </article>
</Base>
