---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';
import GuideImage from '../../components/GuideImage.astro';

const minigames = [
  { name: 'Zaubern', how: 'Zeichne ein Kreis-und-Punkt-Muster mit ausgerüsteter Zauberstab, dem D-Pad-Hinweis folgend.', where: 'Überall, sobald Magie freigeschaltet ist' },
  { name: 'Date-Minispiele', how: 'Variiert je nach Date — Beispiele sind das Binden eines Blumenstraußes in gewünschten Farben oder das Rösten eines Marshmallows auf den bevorzugten Röstgrad.', where: 'Bei Dates mit einem Bewohner ab Herzlevel 4' },
  { name: 'Angeln', how: 'Wirf in Richtung von Schatten im Wasser, dann kurble mit einem zeitbasierten Minispiel ein.', where: 'Wasserbereiche, sobald die Angelrute freigeschaltet ist' },
  { name: 'Angelwettbewerb gegen Noel', how: 'Fang 3 verschiedene Fische vor Noel, mit einer Wette von 250 Gold, um die Angelrute zu gewinnen.', where: 'Frühes Spiel, verbunden mit Noel' },
];

const faq = [
  { q: 'Welche Minispiele gibt es in Moonlight Peaks?', a: 'Bisher bestätigt: Zaubern (ein Kreis-und-Punkt-Muster), Date-Aktivitäten wie Blumenstrauß-Binden und Marshmallow-Rösten, sowie ein zeitbasiertes Angel-Minispiel — plus der Noel-Angelwettbewerb, der deine Rute freischaltet.' },
  { q: 'Ist Angeln in Moonlight Peaks schwierig?', a: 'Rezensenten beschreiben es als bewusst stressfrei statt frustrierend, näher an einem entspannten Animal-Crossing-Stil-Werfen-und-Einholen als an einer geschicklichkeitsfordernden Herausforderung.' },
  { q: 'Beeinflussen Minispiele Beziehungen?', a: 'Ja, speziell bei Dates — zu spät zu kommen oder ein Date-Minispiel zu vermasseln kostet bestätigt Beziehungspunkte, statt die Dinge sofort zu beenden.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Minispiele', item: new URL('/de/mini-games', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Minispiele — Dates, Angeln & Zaubern"
  description="Jedes bestätigte Minispiel in Moonlight Peaks: Date-Aktivitäten wie Blumenstrauß-Binden, das Angel-Werfen-und-Einholen-System, und wie Zaubern funktioniert."
  path="/de/mini-games"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Minispiele' }]}
  lang="de"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Eintrag · Minispiele</p>
      <h1>Moonlight Peaks <em>Minispiele</em></h1>
      <p class="intro">
        {GAME.title} integriert mehrere Minispiele in seine Systeme, statt sie als separate
        Arcade-Modi zu behandeln. Hier ist, was bisher bestätigt ist. Aktualisiert {SITE.updated}.
      </p>

      <GuideImage imageId="minigame" priority />

      <table class="facts">
        <tr><th>Minispiel</th><th>Wie es funktioniert</th><th>Wo es vorkommt</th></tr>
        {minigames.map((m) => (
          <tr>
            <td>{m.name}</td>
            <td>{m.how}</td>
            <td>{m.where}</td>
          </tr>
        ))}
      </table>

      <div class="callout">
        Weitere Minispiele (Nokturna, Kochen, Trankbrauen) haben möglicherweise eigene, dedizierte
        Mechaniken — siehe die verlinkten Guides unten, statt sie hier zu duplizieren.
      </div>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Verwandt: <a href="/de/fishing">Angeln</a>, <a href="/de/magic">Magie</a>, <a href="/de/romance">Romanze</a>,
        <a href="/de/nokturna">Nokturna</a>.
      </div>
    </div>
  </article>
</Base>
