---
import TopicPage from '../../../components/TopicPage.astro';
import { activitiesSection, activities } from '../../../data/activities';
import { activitiesDe } from '../../../i18n/activities-de';

export function getStaticPaths() {
  const translated = activities.filter((it) => activitiesDe[it.slug]);
  return translated.map((it, i) => {
    const tr = activitiesDe[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...translated[(i - 1 + translated.length) % translated.length], ...activitiesDe[translated[(i - 1 + translated.length) % translated.length].slug] },
        next: { ...translated[(i + 1) % translated.length], ...activitiesDe[translated[(i + 1) % translated.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const deSection = { ...activitiesSection, base: '/de/activities', label: 'Aktivitäten', eyebrow: 'Gameplay' };
---
<TopicPage section={deSection} item={item} prev={prev} next={next} lang="de" basePath="/de/activities" />
