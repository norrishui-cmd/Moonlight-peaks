---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { itemCategories } from '../../../data/items';
import { itemsDe } from '../../../i18n/items-de';
import type { ItemCategory } from '../../../data/items';

export function getStaticPaths() {
  return itemCategories.map((item, index) => ({
    params: { slug: item.slug },
    props: { item, prev: itemCategories[(index - 1 + itemCategories.length) % itemCategories.length], next: itemCategories[(index + 1) % itemCategories.length] },
  }));
}

const { item } = Astro.props as { item: ItemCategory };
const tr = itemsDe[item.slug];
const url = new URL(`/de/items/${item.slug}`, SITE.url).href;

const statusLabelDe: Record<string, string> = {
  confirmed: 'Bestätigt', datamined: 'Datamining', expected: 'Erwartet',
};

const faq = [
  { q: `Was ist ${tr.name} in Moonlight Peaks?`, a: `${tr.name} ist eine Gegenstandskategorie in Moonlight Peaks. ${tr.summary}` },
  { q: `Sind die Informationen zu ${tr.name} bestätigt?`, a: item.status === 'confirmed'
      ? `Das System für ${tr.name} ist bestätigt, aber einzelne Gegenstandsnamen und Effekte werden weiterhin im Live-Spiel überprüft.`
      : `Die Kategorie ${tr.name} ist noch nicht unabhängig im Live-Spiel bestätigt. Wir raten nicht und aktualisieren diese Seite, sobald etwas bestätigt ist.` },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Gegenstände', item: `${SITE.url}/de/items` },
    { '@type': 'ListItem', position: 3, name: tr.name, item: url },
  ] },
];
---
<Base
  title={`${tr.name} | Moonlight Peaks Gegenstandsguide`}
  description={tr.dek}
  path={`/de/items/${item.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: 'Gegenstände', href: '/de/items' }, { label: tr.name }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Gegenstände · {statusLabelDe[item.status] ?? item.status}</p>
      <h1><em>{tr.name}</em></h1>
      <p class="intro">{tr.dek}</p>

      <h2>Details</h2>
      <p>{tr.summary}</p>

      <h2>Beispiele</h2>
      <ul>{tr.examples.map((e) => (<li>{e}</li>))}</ul>

      <h2>Häufige Fragen</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Verwandt: <a href="/de/items">Alle Gegenstände</a>, <a href={`/items/${item.slug}`}>ausführliche Version auf Englisch</a>.
      </div>
    </div>
  </article>
</Base>
