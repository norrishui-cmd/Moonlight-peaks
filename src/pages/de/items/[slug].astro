---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { itemCategories, getItemFramework } from '../../../data/items';
import { itemsDe } from '../../../i18n/items-de';
import type { ItemCategory } from '../../../data/items';

export function getStaticPaths() {
  return itemCategories.filter((item) => itemsDe[item.slug]).map((item, index, arr) => ({
    params: { slug: item.slug },
    props: { item, prev: arr[(index - 1 + arr.length) % arr.length], next: arr[(index + 1) % arr.length] },
  }));
}

const { item } = Astro.props as { item: ItemCategory };
const tr = itemsDe[item.slug];
const url = new URL(`/de/items/${item.slug}`, SITE.url).href;
const framework = getItemFramework(item.slug);
const hasRealData = item.slug === 'foraging' || item.slug === 'cooking';
const parseImageCell = (cell: string) => {
  const [src, alt = ''] = cell.slice('image:'.length).split('|');
  return { src, alt };
};

const statusLabelDe: Record<string, string> = {
  confirmed: 'Bestätigt', datamined: 'Datamining', expected: 'Erwartet',
};

const faq = [
  { q: `Was ist ${tr.name} in Moonlight Peaks?`, a: `${tr.name} ist eine Gegenstandskategorie in Moonlight Peaks. ${tr.summary}` },
  { q: `Sind die Informationen zu ${tr.name} bestätigt?`, a: item.status === 'confirmed'
      ? `Das System für ${tr.name} ist bestätigt, aber einzelne Gegenstandsnamen und Effekte werden weiterhin im Live-Spiel überprüft.`
      : `Die Kategorie ${tr.name} ist noch nicht unabhängig im Live-Spiel bestätigt. Wir raten nicht und aktualisieren diese Seite, sobald etwas bestätigt ist.` },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Gegenstände', item: `${SITE.url}/de/items` },
    { '@type': 'ListItem', position: 3, name: tr.name, item: url },
  ] },
];
---
<Base
  title={`${tr.name} | Moonlight Peaks Gegenstandsguide`}
  description={tr.dek}
  path={`/de/items/${item.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: 'Gegenstände', href: '/de/items' }, { label: tr.name }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Gegenstände · {statusLabelDe[item.status] ?? item.status}</p>
      <h1><em>{tr.name}</em></h1>
      <p class="intro">{tr.dek}</p>

      <h2>Details</h2>
      <p>{tr.summary}</p>

      <h2>Beispiele</h2>
      <ul>{tr.examples.map((e) => (<li>{e}</li>))}</ul>

      {hasRealData && (
        <>
          <h2>Vollständige Datentabelle</h2>
          <div class="de-item-table-wrap">
            <table class="de-item-table">
              <thead>
                <tr>{framework.columns.map((col) => <th>{col}</th>)}</tr>
              </thead>
              <tbody>
                {framework.rows.map((row) => (
                  <tr>
                    {row.map((cell) => {
                      const image = cell.startsWith('image:') ? parseImageCell(cell) : null;
                      return (
                        <td>
                          {image ? (
                            <img class="de-item-table-icon" src={image.src} alt={image.alt} loading="lazy" decoding="async" />
                          ) : cell}
                        </td>
                      );
                    })}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="de-source-note">{framework.sourceNote}</p>
        </>
      )}

      <h2>Häufige Fragen</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Verwandt: <a href="/de/items">Alle Gegenstände</a>, <a href={`/items/${item.slug}`}>ausführliche Version auf Englisch</a>.
      </div>
    </div>
  </article>

  <style>
    .de-item-table-wrap { overflow-x: auto; border: 1px solid var(--line); border-radius: 14px; background: var(--surface); margin: 12px 0; }
    .de-item-table { width: 100%; min-width: 700px; border-collapse: collapse; font-size: 0.84rem; }
    .de-item-table th, .de-item-table td { border-bottom: 1px solid var(--line); padding: 10px 12px; text-align: left; vertical-align: top; }
    .de-item-table th { color: var(--candle); font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.05em; text-transform: uppercase; background: rgba(21, 16, 29, 0.58); white-space: nowrap; }
    .de-item-table-icon { display: block; width: 68px; height: 68px; object-fit: contain; }
    .de-item-table tr:last-child td { border-bottom: 0; }
    .de-source-note { border-left: 3px solid var(--candle-dim); color: #ded3e6; padding-left: 12px; font-size: 0.88rem; }
  </style>
</Base>
