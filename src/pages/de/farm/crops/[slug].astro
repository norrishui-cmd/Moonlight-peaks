---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';
import { cropDetailsDe } from '../../../../data/farm-crop-details-de';

export function getStaticPaths() {
  return Object.entries(cropDetailsDe).map(([slug, data]) => ({ params: { slug }, props: { slug, data } }));
}

const { slug, data } = Astro.props as { slug: string; data: (typeof cropDetailsDe)[string] };

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: data.faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Hof', item: `${SITE.url}/de/farm` },
    { '@type': 'ListItem', position: 3, name: 'Feldfrüchte', item: `${SITE.url}/de/farm/crops` },
    { '@type': 'ListItem', position: 4, name: data.name, item: `${SITE.url}/de/farm/crops/${slug}` },
  ] },
];
---
<Base
  title={`${data.name} — Moonlight Peaks Feldfrucht-Guide`}
  description={data.dek}
  path={`/de/farm/crops/${slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: 'Hof', href: '/de/farm' }, { label: 'Feldfrüchte', href: '/de/farm/crops' }, { label: data.name }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Hof · {data.category}</p>
      <h1><em>{data.name}</em></h1>
      <p class="intro">{data.dek}</p>

      {data.body.map((p) => (<p>{p}</p>))}

      <h2>Häufige Fragen</h2>
      <div class="faq">
        {data.faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Aus dem offiziellen Moonlight Peaks Wiki. Verwandte Seiten:
        <a href="/de/farm/crops">Alle Feldfrüchte</a>, <a href="/de/farm">Hof-Hub</a>,
        <a href="/de/farm/farm-helpers">Hofhelfer</a>.
      </div>
    </div>
  </article>
</Base>
