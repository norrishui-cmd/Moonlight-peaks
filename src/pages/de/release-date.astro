---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const faq = [
  { q: 'Wann erscheint Moonlight Peaks?', a: 'Moonlight Peaks ist am 7. Juli 2026 auf Steam, Nintendo Switch, Switch 2 und Android erschienen und jetzt erhältlich.' },
  { q: 'Ist Moonlight Peaks auf PS5 oder Xbox erhältlich?', a: 'Nein — keine PlayStation- oder Xbox-Version wurde angekündigt. Bestätigte Plattformen: Steam, Steam Deck, Switch, Switch 2, Android.' },
  { q: 'Gibt es eine kostenlose Demo?', a: 'Ja. Eine kostenlose Demo ist auf Steam (PC/Mac) und im Nintendo eShop verfügbar, inklusive Charaktererstellung, Angeln, Blumenbinden und Sticken.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Startseite', item: `${SITE.url}/de` },
    { '@type': 'ListItem', position: 2, name: 'Release-Datum', item: `${SITE.url}/de/release-date` },
  ] },
];
---
<Base
  title="Moonlight Peaks Release-Datum & Plattformen (Deutsch)"
  description="Moonlight Peaks ist seit dem 7. Juli 2026 auf Steam, Switch, Switch 2 und Android erhältlich — nicht auf PS5 oder Xbox. Preis, Demo und Release-Infos auf Deutsch."
  path="/de/release-date"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Release-Datum' }]}
  lang="de"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Eintrag / Release</p>
      <h1>Moonlight Peaks <em>Release-Datum</em></h1>
      <p class="intro">
        Alles Bestätigte zum Release von {GAME.title} — Datum, Plattformen, Preis und die
        kostenlose Demo.
      </p>

      <div class="callout">
        <strong>Kurzantwort:</strong> Moonlight Peaks ist am 7. Juli 2026 erschienen und jetzt auf
        Steam (PC/Mac), Steam Deck, Nintendo Switch, Nintendo Switch 2 und Android erhältlich. Es
        ist nicht auf PS5 oder Xbox — keine solche Version wurde angekündigt.
      </div>

      <h2>Preis</h2>
      <p>{GAME.price} auf Steam, Switch und Android, 39,99 $ auf Switch 2.</p>

      <h2>Häufige Fragen</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Weiterführend: <a href="/de/platforms">Plattformen</a>, <a href="/de/demo">Demo</a>,
        <a href="/de/beginner-guide">Einsteiger-Guide</a>.
      </div>
    </div>
  </article>
</Base>
