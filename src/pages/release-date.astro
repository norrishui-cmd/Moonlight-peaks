---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';
import YouTube from '../components/YouTube.astro';
import PriorityLinks from '../components/PriorityLinks.astro';
import { previews } from '../data/previews';
import { releasePriorityLinks } from '../data/priorityLinks';

const faq = [
  { q: 'When does Moonlight Peaks release?', a: `Moonlight Peaks launches around ${GAME.releaseLabel} on Steam, Nintendo Switch, Nintendo Switch 2, and Android via Google Play. ${GAME.releaseNote}` },
  { q: 'What time does Moonlight Peaks unlock?', a: `No official hour-by-hour unlock time has been published for ${GAME.title}. Steam and eShop unlocks typically land at a fixed UTC time (commonly midnight UTC, which is late evening the day before on the US West Coast), but the exact minute varies by storefront and region. Check the countdown timer directly on the game's Steam page for the most accurate local unlock time.` },
  { q: 'How much does Moonlight Peaks cost?', a: `It is ${GAME.price} on Steam (PC/Mac), Switch, and Android, and $39.99 on Switch 2, with ${GAME.launchDiscount}.` },
  { q: 'Is there a Moonlight Peaks demo?', a: 'Yes. A free demo is available on Steam (PC/Mac) and the Nintendo Switch eShop (also playable on Switch 2). It includes character creation, fishing, flower arranging, and embroidery.' },
  { q: 'Is Moonlight Peaks on console?', a: 'Yes — it launches on Nintendo Switch and Switch 2 alongside PC and Android, with a physical Switch/Switch 2 release also confirmed for Japan with English-language support. The Switch demo is playable on Switch 2.' },
  { q: 'Is Moonlight Peaks multiplayer?', a: 'Moonlight Peaks is a single-player cozy life sim focused on farming, relationships, and town mysteries. There is no announced co-op mode.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Release date', item: new URL('/release-date', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Release Date - Steam, Switch, PC & Android"
  description="Moonlight Peaks release date guide for Steam, Switch, Switch 2, Android, demo access, price, system requirements, languages, and launch timing."
  path="/release-date"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Release date' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entry · Release</p>
      <h1>Moonlight Peaks <em>release date</em> — Switch, Switch 2 &amp; PC</h1>
      <p class="intro">
        Everything confirmed about the {GAME.title} launch — the date, where to play, the price,
        and the free demo you can try right now. Last updated {SITE.updated}.
      </p>

      <YouTube id="VL_15TiRRAM" title="Moonlight Peaks release date trailer" />

      <h2>The facts</h2>
      <table class="facts">
        <tr><th>Release date</th><td>{GAME.releaseLabel}</td></tr>
        <tr><th>Platforms</th><td>{GAME.platforms.join(' · ')}</td></tr>
        <tr><th>Price</th><td>{GAME.price} (Switch 2: $39.99) · {GAME.launchDiscount}</td></tr>
        <tr><th>Demo</th><td>{GAME.demo}</td></tr>
        <tr><th>Developer</th><td>{GAME.developer}</td></tr>
        <tr><th>Publisher</th><td>{GAME.publisher} (Americas) · Marvelous Europe (Europe)</td></tr>
        <tr><th>Players</th><td>Single-player cozy life sim</td></tr>
      </table>

      <PriorityLinks
        title="Release searches to check next"
        note="platform intent"
        links={releasePriorityLinks}
      />

      <h2>What is Moonlight Peaks?</h2>
      <p>
        Moonlight Peaks is a cozy-gothic life sim where you play a vampire — Count Dracula's child —
        settling into your family's abandoned homestead in a town full of werewolves, witches,
        mermaids, and other creatures of the night. You grow mystical crops, raise magical livestock,
        learn spell-casting and potion-making, and befriend — or romance — the locals, all while
        proving to your skeptical father that a kinder, undead life is possible.
      </p>

      <h2>Try the demo before launch</h2>
      <p>
        The free demo is the best way to decide if {GAME.title} is for you. It lets you test
        character creation and a handful of cozy activities — fishing, flower arranging, and
        embroidery among them — plus early interactions with townsfolk. Demo progress does not
        carry into the full game, but it is a faithful taste of the daily loop.
      </p>



      <h2>Launch checks before you buy</h2>
      <p>
        The most useful pre-purchase checks are platform, system requirements, language support,
        and whether the demo feels comfortable on your device. These pages stay conservative and
        point back to official storefront data instead of inventing launch details.
      </p>
      <ul>
        <li><a href="/system-requirements">System requirements</a> for PC, Mac, and Steam Deck checks.</li>
        <li><a href="/languages">Languages</a> for English, German, Japanese, Korean, Simplified Chinese, and Traditional Chinese support.</li>
        <li><a href="/platforms">Platforms</a> for Steam, Switch, Switch 2, Steam Deck, and Android.</li>
      </ul>

      <h2>Demo impressions & player feedback</h2>
      <p>
        Want to know how the demo actually lands before you download it? We rounded up what players
        and press are saying — the praise, the gripes, and whether it is worth your time.
      </p>
      <ul class="prev-list">
        {previews.map((p) => (
          <li>
            <a href={`/previews/${p.slug}`}>
              <img class="pl-thumb" src={p.image} alt={`${p.title} — Moonlight Peaks`} width="160" height="84" loading="lazy" />
              <span class="pl-body">
                <span class="pl-tag">{p.tag}</span>
                <span class="pl-title">{p.title}</span>
                <span class="pl-dek">{p.dek}</span>
                <span class="pl-meta">{p.readTime} · {p.date}</span>
              </span>
            </a>
          </li>
        ))}
      </ul>

      <div class="callout">
        Bookmark this page. The moment {GAME.title} goes live around {GAME.releaseLabel}, we publish the
        day-one cheat list, crop and fishing data, and the full Nokturna card guide.
      </div>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </article>

  <style>
    .prev-list { list-style: none; padding: 0; margin: 8px 0 0; display: grid; gap: 10px; }
    .prev-list a { display: flex; gap: 14px; align-items: stretch; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); padding: 12px; transition: border-color .15s ease, transform .15s ease; }
    .prev-list a:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); transform: translateY(-2px); }
    .pl-thumb { flex: 0 0 auto; width: 160px; height: 84px; object-fit: cover; border-radius: 10px; border: 1px solid var(--line); }
    .pl-body { min-width: 0; display: block; }
    .pl-tag { display: block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--faint); }
    .pl-title { display: block; font-family: var(--display); font-weight: 600; font-size: 1.1rem; color: var(--mist); margin: 3px 0 2px; }
    .pl-dek { display: block; color: var(--muted); font-size: 0.88rem; }
    .pl-meta { display: block; font-family: var(--mono); font-size: 0.68rem; color: var(--faint); margin-top: 6px; }
    @media (max-width: 560px) {
      .prev-list a { flex-direction: column; }
      .pl-thumb { width: 100%; height: auto; aspect-ratio: 1200 / 630; }
    }
  </style>
</Base>
