---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Search', item: new URL('/search', SITE.url).href },
  ],
};
---
<Base
  title="Search Moonlight Peaks Wiki & Guide"
  description="Search every Moonlight Peaks guide, character, FAQ, and article on this site."
  path="/search"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Search' }]}
  noindex
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Search</p>
      <h1>Search <em>{GAME.title}</em> Wiki &amp; Guide</h1>
      <p class="intro">Search characters, guides, FAQ, items, and articles — results update as you type.</p>

      <div class="search-input-row search-page-input-row">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input type="text" id="search-page-input" placeholder="Search characters, guides, FAQ, items…" autocomplete="off" spellcheck="false" aria-label="Search query" />
      </div>

      <ul id="search-page-results" class="search-results search-page-results" role="listbox"></ul>
      <p id="search-page-empty" class="search-empty" hidden>No matches — try a shorter or different term.</p>
      <p id="search-page-hint" class="search-hint">Start typing above, or try the search icon in the top navigation from anywhere on the site.</p>
    </div>
  </article>

  <style>
    .search-page-input-row {
      border: 1px solid var(--line); border-radius: 12px; padding: 12px 14px; margin: 8px 0 18px;
      background: var(--surface); color: var(--muted);
    }
    .search-page-input-row input {
      width: 100%; background: transparent; border: none; outline: none; color: var(--mist);
      font-size: 1rem; font-family: inherit;
    }
    .search-page-input-row input::placeholder { color: var(--faint); }
    .search-page-results { list-style: none; margin: 0; padding: 0; }
    .search-page-results .search-result a {
      display: grid; grid-template-columns: auto 1fr; grid-template-areas: 'kind title' 'kind desc';
      gap: 0 10px; padding: 12px; border-radius: 10px; text-decoration: none; align-items: center;
      border: 1px solid var(--line); margin-bottom: 8px;
    }
    .search-page-results .search-result a:hover { background: color-mix(in srgb, var(--surface) 80%, transparent); }
  </style>

  <script>
    (function () {
      var input = document.getElementById('search-page-input');
      var results = document.getElementById('search-page-results');
      var empty = document.getElementById('search-page-empty');
      var hint = document.getElementById('search-page-hint');
      if (!input || !results || !empty) return;

      var index = null;

      function norm(s) { return (s || '').toLowerCase(); }

      function subseq(needle, hay) {
        var i = 0, j = 0;
        while (i < needle.length && j < hay.length) {
          if (needle[i] === hay[j]) i++;
          j++;
        }
        return i === needle.length;
      }

      function score(q, doc) {
        var t = norm(doc.t), d = norm(doc.d), k = norm(doc.k);
        if (t === q) return 100;
        if (t.indexOf(q) === 0) return 90;
        if (t.indexOf(q) > -1) return 75;
        if (k.indexOf(q) > -1) return 60;
        if (d.indexOf(q) > -1) return 45;
        if (subseq(q, t)) return 30;
        if (subseq(q, d)) return 15;
        return 0;
      }

      function render(list) {
        results.innerHTML = '';
        if (list.length === 0) { empty.hidden = false; return; }
        empty.hidden = true;
        list.forEach(function (item) {
          var doc = item.doc;
          var li = document.createElement('li');
          li.className = 'search-result';
          var a = document.createElement('a');
          a.href = doc.u;
          a.innerHTML =
            '<span class="sr-kind">' + doc.k + '</span>' +
            '<span class="sr-title"></span>' +
            '<span class="sr-desc"></span>';
          a.querySelector('.sr-title').textContent = doc.t;
          a.querySelector('.sr-desc').textContent = doc.d;
          li.appendChild(a);
          results.appendChild(li);
        });
      }

      function run(raw) {
        var q = norm(raw).trim();
        if (!q) { results.innerHTML = ''; empty.hidden = true; hint.hidden = false; return; }
        hint.hidden = true;
        if (!index) return;
        var scored = [];
        for (var i = 0; i < index.length; i++) {
          var s = score(q, index[i]);
          if (s > 0) scored.push({ s: s, doc: index[i] });
        }
        scored.sort(function (a, b) { return b.s - a.s; });
        render(scored.slice(0, 20));
      }

      fetch('/search-index.json')
        .then(function (r) { return r.json(); })
        .then(function (data) {
          index = data;
          var params = new URLSearchParams(window.location.search);
          var q = params.get('q') || '';
          if (q) { input.value = q; run(q); }
        })
        .catch(function () {});

      input.addEventListener('input', function () {
        run(input.value);
        var url = new URL(window.location.href);
        if (input.value) { url.searchParams.set('q', input.value); }
        else { url.searchParams.delete('q'); }
        window.history.replaceState({}, '', url);
      });
    })();
  </script>
</Base>
