---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';

// Confirmed named achievements, sourced from Exophase's Steam achievement listing (launch week).
// 59 total achievements are confirmed to exist; only some names have been sourced so far.
const achievements = [
  { name: 'Discover all locations', desc: 'Find every location in Moonlight Peaks.' },
  { name: 'A Farming Monopoly', desc: 'Earn 1,000,000 coins.' },
  { name: 'Skulls in a Net', desc: 'Collect all Soul Blobs.' },
  { name: 'Back to the Den', desc: 'Return all Vampsters to their den.' },
  { name: 'Making Mina Proud', desc: 'Cook 25 different recipes.' },
  { name: "Albertus' Helper", desc: 'Complete 25 jobs from the job board.' },
  { name: 'Magic at Max Capacity', desc: 'Reach maximum Mana.' },
  { name: 'Fully Energized', desc: 'Reach maximum Energy.' },
  { name: 'Moonlit Stretching', desc: 'Attend your first Yoga session.' },
  { name: 'Back in Place', desc: 'Return all plastic chairs.' },
  { name: 'Tree Hugger', desc: 'Fall in love with a tree.' },
  { name: 'The Pumpking', desc: 'Meet a peculiar pumpkin.' },
  { name: 'Raiders of the Lost Art', desc: "Complete Elvira's treasure hunt." },
  { name: 'A Childhood Dream', desc: 'Build a treehouse with Ridge.' },
  { name: 'Nokturna Master', desc: 'Collect every Nokturna card.' },
  { name: 'Awooooo!', desc: 'Talk to a werewolf character during a full moon (community-reported).' },
  { name: 'AFKitten', desc: 'Pet your Hellkitten for 5 consecutive minutes (community-reported).' },
  { name: 'Cartographer', desc: 'Discover every location in Moonlight Peaks, including areas only reachable after unlocking a shapeshifting form (community-reported).' },
  { name: 'Rightful Ritualist', desc: 'Activate every Witches\u2019 Circle in town (community-reported).' },
  { name: 'Call of the Current', desc: 'Unlock the Mermaid/Aqua form \u2014 confirmed to unlock later in the game, though the exact unlock condition for this third form is still unconfirmed.' },
  { name: 'Perpetual Bloom', desc: 'Build a Greenhouse.' },
  { name: 'Dracula Estate', desc: 'Fully upgrade your house.' },
  { name: 'Vampire with a Wand', desc: 'Unlock magic and cast any spell once.' },
  { name: 'Master of Witchcraft', desc: 'Fully upgrade every spell.' },
  { name: 'A Magical Toolbelt', desc: 'Upgrade any tool into its Enchanted version.' },
  { name: 'A Magical Cocktail', desc: 'Have every potion effect active at the same time.' },
  { name: 'New Beginnings', desc: 'Plant your first crop \u2014 usually your very first in-game action.' },
  { name: 'Purrgatory', desc: 'Unlock the Hellkitten form.' },
  { name: 'Wings of the Night', desc: 'Unlock the Bat form.' },
  { name: 'Out of the Mist', desc: 'Lift the curse from Misty Shores through the main quest line.' },
  { name: 'To the Depths', desc: 'Open the entrance to the Catacombs.' },
  { name: 'Happy New Year!', desc: 'Complete one full in-game year across all four seasons.' },
  { name: 'A Generous Donor', desc: 'Give 299 total gifts.' },
  { name: 'Serial Gifter', desc: 'Give 25 loved gifts in a single night.' },
  { name: 'Social Butterfly', desc: 'Reach 4 hearts with every character.' },
  { name: 'Tied the Knot', desc: 'Max out a romance and propose.' },
  { name: 'Buddies for Afterlife', desc: 'Build friendship with Death, the same way you would with any other resident.' },
];

const faq = [
  { q: 'How many achievements does Moonlight Peaks have?', a: 'Confirmed at launch: around 59-60 Steam achievements total (sources report both figures). 37 named achievements have been sourced publicly so far \u2014 see the table above for what\u2019s confirmed.' },
  { q: 'Does Moonlight Peaks have Steam Trading Cards?', a: 'Yes — the Steam store page lists Steam Achievements, Steam Trading Cards, Steam Cloud saves, and full controller support.' },
  { q: 'What is the hardest or most obscure achievement?', a: 'Several confirmed names suggest quirky, easy-to-miss achievements rather than pure grinds — "Tree Hugger" (fall in love with a tree) and "The Pumpking" (meet a peculiar pumpkin) both sound tied to specific one-off interactions rather than repeated actions.' },
  { q: 'Are there achievements for romance or relationships?', a: 'Yes, confirmed: "Social Butterfly" (reach 4 hearts with every character), "Tied the Knot" (max out a romance and propose), "A Generous Donor" (give 299 total gifts), "Serial Gifter" (give 25 loved gifts in one night), and "Buddies for Afterlife" (build friendship with Death) are all romance/relationship-tagged. "A Childhood Dream" (building a treehouse with Ridge) and "Raiders of the Lost Art" (Elvira\u2019s treasure hunt) are also tied to specific named residents.' },
  { q: 'Is there an achievement for building a Greenhouse?', a: 'Yes, confirmed: "Perpetual Bloom" is awarded for building a Greenhouse.' },
  { q: 'What achievements are tied to shapeshifting forms?', a: 'Confirmed: "Purrgatory" (Hellkitten form), "Wings of the Night" (Bat form), and "Call of the Current" (Mermaid/Aqua form, unlocked later in the game).' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Achievements', item: new URL('/achievements', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Achievements — Full Trophy & Steam Achievement Guide"
  description="Moonlight Peaks has 59 confirmed achievements. See the named achievements sourced so far, from collecting Soul Blobs to earning 1,000,000 coins."
  path="/achievements"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Achievements' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entry · Achievements</p>
      <h1>Moonlight Peaks <em>achievements</em></h1>
      <p class="intro">
        Confirmed at launch: {GAME.title} has <strong>59 Steam achievements</strong>, alongside Steam
        Trading Cards, Cloud saves, and full controller support. Only some achievement names are
        public so far — this page lists exactly what's sourced, and grows as more are confirmed.
        Updated {SITE.updated}.
      </p>

      <h2>Confirmed achievements ({achievements.length} of 59)</h2>
      <table class="facts">
        <tr><th>Achievement</th><th>How to unlock</th></tr>
        {achievements.map((a) => (
          <tr>
            <td>{a.name}</td>
            <td>{a.desc}</td>
          </tr>
        ))}
      </table>

      <div class="callout">
        45 achievements are still unnamed here — we only list what's been sourced from real Steam
        achievement data, not guessed at. Check back as more are confirmed.
      </div>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Related: <a href="/items">items</a>, <a href="/farming">farming</a>,
        <a href="/characters/albertus">Albertus (job board)</a>, <a href="/characters/ridge">Ridge</a>,
        <a href="/characters/elvira">Elvira</a>, <a href="/nokturna">Nokturna card game</a>.
      </div>
    </div>
  </article>
</Base>
