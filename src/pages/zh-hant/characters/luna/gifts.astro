---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Luna 最喜歡什麼禮物?',
    acceptedAnswer: { '@type': 'Answer', text: 'Luna 最愛紫色鬱金香、紫色杜鵑花和白玫瑰。' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh-hant` },
    { '@type': 'ListItem', position: 2, name: '角色', item: `${SITE.url}/zh-hant/characters` },
    { '@type': 'ListItem', position: 3, name: 'Luna', item: `${SITE.url}/zh-hant/characters/luna` },
  ] },
];
---
<Base
  title="Luna 喜歡的禮物 | Moonlight Peaks 角色指南"
  description="Moonlight Peaks 中 Luna 已確認的禮物偏好——最愛、喜歡和要避開的禮物。"
  path="/zh-hant/characters/luna/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: '角色', href: '/zh-hant/characters' }, { label: 'Luna', href: '/zh-hant/characters/luna' }, { label: '禮物' }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">角色 · 禮物</p>
      <h1>Luna 喜歡的<em>禮物</em></h1>
      <p class="intro">基於首發周測試確認的 Luna 禮物數據。</p>

      <h2>最愛</h2>
      <p>已確認 Luna 最愛:紫色鬱金香、紫色杜鵑花和白玫瑰。</p>

      <h2>喜歡</h2>
      <p>除了最愛的禮物之外,Luna 也喜歡:Blood Grape。</p>

      <h2>不喜歡</h2>
      <p>要避開的:生鏽的豆罐頭。已確認會降低好感度。</p>

      <div class="callout wip">
        相關頁面:<a href="/zh-hant/characters/luna">Luna 資料</a>,
        <a href="/zh-hant/characters">所有角色</a>,<a href="/characters/luna/gifts">完整英文版</a>。
      </div>
    </div>
  </article>
</Base>
