---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Noel 最喜歡什麼禮物?',
    acceptedAnswer: { '@type': 'Answer', text: 'Noel 最愛的是黃金蛋(Golden Egg)。' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh-hant` },
    { '@type': 'ListItem', position: 2, name: '角色', item: `${SITE.url}/zh-hant/characters` },
    { '@type': 'ListItem', position: 3, name: 'Noel', item: `${SITE.url}/zh-hant/characters/noel` },
  ] },
];
---
<Base
  title="Noel 喜歡的禮物 | Moonlight Peaks 角色指南"
  description="Moonlight Peaks 中 Noel 已確認的禮物偏好——最愛、喜歡和要避開的禮物。"
  path="/zh-hant/characters/noel/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: '角色', href: '/zh-hant/characters' }, { label: 'Noel', href: '/zh-hant/characters/noel' }, { label: '禮物' }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">角色 · 禮物</p>
      <h1>Noel 喜歡的<em>禮物</em></h1>
      <p class="intro">基於首發周測試確認的 Noel 禮物數據。</p>

      <h2>最愛</h2>
      <p>已確認 Noel 最愛:黃金蛋(Golden Egg)。是快速拉近關係最有效的選擇。</p>

      <h2>喜歡</h2>
      <p>除了最愛的禮物之外,Noel 也喜歡:Blood Grape、Blood Grape 果汁、草莓汁和 Glibby 魚。</p>

      <h2>不喜歡</h2>
      <p>要避開的:紫色鬱金香和粉色杜鵑花——這兩種花對大多數其他角色都很受歡迎,但已確認是他不喜歡的禮物。</p>

      <div class="callout wip">
        相關頁面:<a href="/zh-hant/characters/noel">Noel 資料</a>,
        <a href="/zh-hant/characters">所有角色</a>,<a href="/characters/noel/gifts">完整英文版</a>。
      </div>
    </div>
  </article>
</Base>
