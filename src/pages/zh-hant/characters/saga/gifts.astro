---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Saga 最喜歡什麼禮物?',
    acceptedAnswer: { '@type': 'Answer', text: 'Saga 最愛的是白葡萄酒(White Wine)。' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh-hant` },
    { '@type': 'ListItem', position: 2, name: '角色', item: `${SITE.url}/zh-hant/characters` },
    { '@type': 'ListItem', position: 3, name: 'Saga', item: `${SITE.url}/zh-hant/characters/saga` },
  ] },
];
---
<Base
  title="Saga 喜歡的禮物 | Moonlight Peaks 角色指南"
  description="Moonlight Peaks 中 Saga 已確認的禮物偏好——最愛、喜歡和要避開的禮物。"
  path="/zh-hant/characters/saga/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: '角色', href: '/zh-hant/characters' }, { label: 'Saga', href: '/zh-hant/characters/saga' }, { label: '禮物' }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">角色 · 禮物</p>
      <h1>Saga 喜歡的<em>禮物</em></h1>
      <p class="intro">
        基於國際媒體首發周測試(TheGamer,2026 年 7 月 7 日發佈)確認的 Saga 禮物數據。
      </p>

      <h2>最愛</h2>
      <p>已確認 Saga 最愛:白葡萄酒(White Wine)。是快速拉近關係最有效的選擇。</p>

      <h2>喜歡</h2>
      <p>除了最愛的禮物之外,Saga 也喜歡:紅葡萄酒(Red Wine)、啤酒、單支的花(不是花束)、紫色鬱金香、粉色杜鵑花、Blood Grape、草莓汁和西班牙冷湯。</p>

      <h2>不喜歡</h2>
      <p>要避開的:花束(多支花捆在一起)和銅條。已確認會降低好感度。</p>

      <div class="callout wip">
        相關頁面:<a href="/zh-hant/characters/saga">Saga 資料</a>,
        <a href="/zh-hant/characters">所有角色</a>,<a href="/characters/saga/gifts">完整英文版</a>。
      </div>
    </div>
  </article>
</Base>
