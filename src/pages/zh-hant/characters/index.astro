---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';
import News from '../../../components/News.astro';
import { characters, type CharType } from '../../../data/characters';
import { charTranslations } from '../../../i18n/characters-data';

const zhHantTranslations = charTranslations['zh-hant'];
const translatedSlugs = new Set(Object.keys(zhHantTranslations));

const typeLabelsZh: Record<CharType, string> = {
  vampire: '吸血鬼', werewolf: '狼人', witch: '女巫', mermaid: '人魚',
  seer: '預言者', ghost: '幽靈', human: '人類', other: '其他',
};
const familyLabelZh = (family: string): string => {
  if (family.includes('Vampire')) return '吸血鬼家族 (Ambrosia)';
  if (family.includes('Werewolf')) return '狼人家族 (Logan)';
  if (family.includes('Witch')) return '女巫家族 (Webb)';
  if (family.includes('Mermaid')) return '人魚家族 (Hosu)';
  if (family.includes('Seer')) return '預言者家族 (Khazan)';
  if (family.includes('Human')) return '人類家族 (Henderson)';
  return '無家族';
};

const isMainCast = (c: (typeof characters)[number]) => c.romanceable === true || c.id === 'count-dracula';
const translated = characters.filter((c) => translatedSlugs.has(c.id));
const untranslated = characters.filter((c) => !translatedSlugs.has(c.id));
const mainCast = translated.filter(isMainCast);
const npcs = translated.filter((c) => !isMainCast(c));

function displayName(c: (typeof characters)[number]): string {
  return translatedSlugs.has(c.id) ? zhHantTranslations[c.id].name : c.name;
}

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '角色', item: `${SITE.url}/zh-hant/characters` },
  ],
};
---
<Base
  title="Moonlight Peaks 角色(完整居民名單) - 吸血鬼的哥特生活"
  description="Moonlight Peaks確認的完整居民中文件案:23位可攻略物件及其餘NPC。"
  path="/zh-hant/characters"
  jsonLd={jsonLd}
  crumbs={[{ label: '角色' }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">入門 / 角色</p>
      <h1>{GAME.title} <em>角色</em>(完整居民名單)</h1>
      <p class="intro">
        已確認的全部居民,按可攻略物件和其他NPC分類整理。目前已有{translated.length}位角色的檔案翻譯為中文。
      </p>

      <h2>可攻略物件及主要角色 ({mainCast.length})</h2>
      <div class="cx-grid">
        {mainCast.map((c) => (
          <a class="cx-card" href={`/zh-hant/characters/${c.id}`}>
            <span class="cx-thumb">
              {c.img ? <img src={c.img} alt="" loading="lazy" width="72" height="72" /> : <span class="cx-letter" style={`background: linear-gradient(135deg, ${c.c1}, ${c.c2})`}>{displayName(c).charAt(0)}</span>}
            </span>
            <span>
              <strong>{displayName(c)}</strong>
              <em>{familyLabelZh(c.family)} · {typeLabelsZh[c.type]}</em>
            </span>
          </a>
        ))}
      </div>

      <h2>其他NPC ({npcs.length})</h2>
      <div class="cx-grid">
        {npcs.map((c) => (
          <a class="cx-card" href={`/zh-hant/characters/${c.id}`}>
            <span class="cx-thumb">
              {c.img ? <img src={c.img} alt="" loading="lazy" width="72" height="72" /> : <span class="cx-letter" style={`background: linear-gradient(135deg, ${c.c1}, ${c.c2})`}>{displayName(c).charAt(0)}</span>}
            </span>
            <span>
              <strong>{displayName(c)}</strong>
              <em>{familyLabelZh(c.family)} · {typeLabelsZh[c.type]}</em>
            </span>
          </a>
        ))}
      </div>

      <h2>最新角色相關更新</h2>
      <News category="characters" limit={5} />

      {untranslated.length > 0 && (
        <div class="callout wip">
          目前{translated.length}位角色檔案已翻譯為中文。其餘{untranslated.length}位角色點選後會跳轉到
          <a href="/characters">英文版角色頁面</a>,那裡有最詳細的已確認資訊(包括Kai、Celine這類尚無實際內容的未確認佔位角色)。
        </div>
      )}
    </div>
  </article>

  <style>
    .cx-grid { display: grid; grid-template-columns: 1fr; gap: 10px; margin: 8px 0 24px; }
    @media (min-width: 640px) { .cx-grid { grid-template-columns: 1fr 1fr; } }
    .cx-card { display: flex; align-items: center; gap: 12px; border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 12px; transition: border-color .15s ease; }
    .cx-card:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); }
    .cx-thumb { flex: 0 0 auto; width: 72px; height: 72px; border-radius: 10px; overflow: hidden; display: flex; align-items: center; justify-content: center; }
    .cx-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .cx-letter { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-family: var(--display); font-weight: 700; font-size: 1.6rem; color: rgba(255,255,255,0.9); }
    .cx-card span:not(.cx-thumb) { display: flex; flex-direction: column; }
    .cx-card strong { font-family: var(--display); font-weight: 600; font-size: 0.96rem; color: var(--mist); }
    .cx-card em { font-style: normal; font-size: 0.78rem; color: var(--faint); margin-top: 2px; }
  </style>
</Base>
