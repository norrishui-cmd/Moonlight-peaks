---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Fiona 最喜歡什麼禮物?',
    acceptedAnswer: { '@type': 'Answer', text: 'Fiona 最愛的是草莓(Strawberries)。' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh-hant` },
    { '@type': 'ListItem', position: 2, name: '角色', item: `${SITE.url}/zh-hant/characters` },
    { '@type': 'ListItem', position: 3, name: 'Fiona', item: `${SITE.url}/zh-hant/characters/fiona` },
  ] },
];
---
<Base
  title="Fiona 喜歡的禮物 | Moonlight Peaks 角色指南"
  description="Moonlight Peaks 中 Fiona 已確認的禮物偏好——最愛、喜歡和要避開的禮物。"
  path="/zh-hant/characters/fiona/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: '角色', href: '/zh-hant/characters' }, { label: 'Fiona', href: '/zh-hant/characters/fiona' }, { label: '禮物' }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">角色 · 禮物</p>
      <h1>Fiona 喜歡的<em>禮物</em></h1>
      <p class="intro">基於首發周測試確認的 Fiona 禮物數據。</p>

      <h2>最愛</h2>
      <p>已確認 Fiona 最愛:草莓(Strawberries)。</p>

      <h2>喜歡</h2>
      <p>除了最愛的禮物之外,Fiona 也喜歡:紫色鬱金香、紫色杜鵑花、紫色薰衣草、雞蛋和月光果汁。</p>

      <h2>不喜歡</h2>
      <p>要避開的:洋蔥種子。已確認會降低好感度。</p>

      <div class="callout wip">
        相關頁面:<a href="/zh-hant/characters/fiona">Fiona 資料</a>,
        <a href="/zh-hant/characters">所有角色</a>,<a href="/characters/fiona/gifts">完整英文版</a>。
      </div>
    </div>
  </article>
</Base>
