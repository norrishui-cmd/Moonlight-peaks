---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { characters } from '../../../data/characters';
import { charTranslations } from '../../../i18n/characters-data';

export function getStaticPaths() {
  return Object.keys(charTranslations['zh-hant']).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const base = characters.find((c) => c.id === slug)!;
const tr = charTranslations['zh-hant'][slug as keyof typeof charTranslations['zh-hant']];

const url = new URL(`/zh-hant/characters/${slug}`, SITE.url).href;
const imgAbs = base.img ? new URL(base.img, SITE.url).href : undefined;
const statusLabel =
  base.status === 'confirmed' ? '已確認'
  : base.status === 'reported' ? '報道資訊'
  : base.status === 'datamined' ? '資料探勘'
  : '未確認';
const romanceText = base.romanceable === true ? tr.romanceYes : base.romanceable === false ? tr.romanceNo : tr.romanceTbc;

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh-hant` },
    { '@type': 'ListItem', position: 2, name: '角色', item: `${SITE.url}/zh-hant/characters` },
    { '@type': 'ListItem', position: 3, name: tr.name, item: url },
  ] },
  { '@context': 'https://schema.org', '@type': 'Person', name: tr.name, description: tr.desc, ...(imgAbs ? { image: imgAbs } : {}) },
];
---
<Base
  title={`${tr.name} - Moonlight Peaks 角色攻略`}
  description={`Moonlight Peaks 裡的${tr.name}: ${tr.desc} 所屬家族、戀愛狀態和目前已知資訊。`}
  path={`/zh-hant/characters/${slug}`}
  jsonLd={jsonLd}
  ogImage={base.img}
  crumbs={[{ label: '角色', href: '/zh-hant/characters' }, { label: tr.name }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">角色 · {tr.typeLabel}</p>

      <div class="chead">
        <div class="cavatar">
          {base.img ? (
            <img src={base.img} alt={`${tr.name} portrait`} width="160" height="160" />
          ) : (
            <span class="fallback-avatar" style={`background: linear-gradient(135deg, ${base.c1}, ${base.c2})`}>{tr.name.charAt(0)}</span>
          )}
        </div>
        <div class="cmeta">
          <h1>{tr.name}</h1>
          <div class="ctags">
            <span class={`cbadge ${base.status === 'confirmed' ? 'is-conf' : base.status === 'reported' ? 'is-rep' : base.status === 'datamined' ? 'is-dm' : 'is-unc'}`}>{statusLabel}</span>
            <span class="ctag fam">{tr.familyLabel}</span>
            {base.romanceable === true && <span class="ctag heart">可戀愛</span>}
            {base.romanceable === false && <span class="ctag">不可戀愛</span>}
            {base.romanceable === null && <span class="ctag">戀愛狀態待確認</span>}
          </div>
          <p class="cdesc">{tr.desc}</p>
        </div>
      </div>

      <h2>目前已知資訊</h2>
      <ul>{tr.knownInfo.map((k) => (<li>{k}</li>))}</ul>

      <h2>戀愛情況</h2>
      <p>{romanceText}</p>

      <div class="callout">
        相關頁面: <a href="/zh-hant/characters">中文角色列表</a>、<a href="/romance">戀愛攻略</a>、
        <a href="/families">家族</a>、<a href="/characters">英文完整角色資料</a>。
      </div>
    </div>
  </article>
</Base>
