---
import Base from '../../../../layouts/Base.astro';
import { SITE } from '../../../../consts';

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: 'Sabrina 最喜歡什麼禮物?',
    acceptedAnswer: { '@type': 'Answer', text: 'Sabrina 最愛紫色鬱金香和紫色雞蛋花。' },
  }] },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh-hant` },
    { '@type': 'ListItem', position: 2, name: '角色', item: `${SITE.url}/zh-hant/characters` },
    { '@type': 'ListItem', position: 3, name: 'Sabrina', item: `${SITE.url}/zh-hant/characters/sabrina` },
  ] },
];
---
<Base
  title="Sabrina 喜歡的禮物 | Moonlight Peaks 角色指南"
  description="Moonlight Peaks 中 Sabrina 已確認的禮物偏好——最愛、喜歡和要避開的禮物。"
  path="/zh-hant/characters/sabrina/gifts"
  jsonLd={jsonLd}
  crumbs={[{ label: '角色', href: '/zh-hant/characters' }, { label: 'Sabrina', href: '/zh-hant/characters/sabrina' }, { label: '禮物' }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">角色 · 禮物</p>
      <h1>Sabrina 喜歡的<em>禮物</em></h1>
      <p class="intro">基於首發周測試確認的 Sabrina 禮物數據。</p>

      <h2>最愛</h2>
      <p>已確認 Sabrina 最愛:紫色鬱金香和紫色雞蛋花。</p>

      <h2>喜歡</h2>
      <p>除了最愛的禮物之外,Sabrina 也喜歡:Blood Grape 和 Blood Grape 果汁。</p>

      <h2>不喜歡</h2>
      <p>要避開的:洋蔥種子和粉色海螺殼。已確認會降低好感度。</p>

      <div class="callout wip">
        相關頁面:<a href="/zh-hant/characters/sabrina">Sabrina 資料</a>,
        <a href="/zh-hant/characters">所有角色</a>,<a href="/characters/sabrina/gifts">完整英文版</a>。
      </div>
    </div>
  </article>
</Base>
