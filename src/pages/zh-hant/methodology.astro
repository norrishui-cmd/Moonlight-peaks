---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const tiers = [
  { label: '已確認', desc: '直接對照實際遊戲、官方補丁說明或開發者直接聲明驗證過(Steam 社區帖子、官方 wiki、媒體資料包)。這是我們唯一當作既定事實處理的級別。' },
  { label: '據報道', desc: '在媒體試玩報道、評測者報告或我們認爲可信的社區測試(Reddit、Steam 社區討論、YouTube 實況)中出現,但我們還沒有在當前版本里親自獨立復現過。' },
  { label: '數據挖掘', desc: '在發售前的遊戲文件中發現,儘可能與其他發售前資料交叉覈對。數據挖掘內容是真實數據,但可能在發售前後發生變化,所以我們不會當作已確認呈現。' },
  { label: '預期 / 未確認', desc: '基於遊戲現有規律做出的合理推測(比如已有的商店名稱暗示營業時間),明確標註爲我們自己的推測,而不是有證據支持的事實。' },
];

const stats = [
  { n: '52+', label: '帶署名並附鏈接來源的 FAQ 回答' },
  { n: '70+', label: '帶署名並附鏈接來源的新聞條目' },
  { n: '49', label: '單獨標註狀態的角色資料' },
  { n: '4', label: '每個使用它們的頁面上都會顯示的確認等級' },
];

const faq = [
  { q: 'Moonlight Peaks Wiki & Guide 如何覈實信息?', a: '本站上的每一條事實都標註了四個確認等級之一——已確認、據報道、數據挖掘或預期——這樣讀者一眼就能看出某個說法的可信程度,而不是把每個細節都用同樣的確定性呈現。' },
  { q: '本站會編造未經確認的禮物表、數值或配方嗎?', a: '不會。數據尚不可用的地方,頁面會明確說明,而不是用看似合理的內容填補空白。我們寧願展示空白,也不猜測。' },
  { q: '記者或其他網站可以引用本站的數據嗎?', a: `可以——這正是本站存在的意義。請註明 ${SITE.brand} 並鏈接回你引用的具體頁面(而不只是首頁),這樣讀者可以自己覈實來源和確認等級。` },
  { q: '本站多久更新一次?', a: '在搶先體驗期間和發售後都持續更新——補丁說明、新的社區報告和官方確認一出現就會被收錄進來,已有條目會重新標註(而不是刪除),以反映確認等級的變化。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh-hant` },
    { '@type': 'ListItem', position: 2, name: '方法論與準確性標準', item: `${SITE.url}/zh-hant/methodology` },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
];
---
<Base
  title="方法論與準確性標準 | Moonlight Peaks Wiki & Guide"
  description="我們如何覈實 Moonlight Peaks 的信息:四級確認體系(已確認、據報道、數據挖掘、預期)、來源標準,以及如何引用本站。"
  path="/zh-hant/methodology"
  jsonLd={jsonLd}
  crumbs={[{ label: '方法論與準確性標準' }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">關於 · 方法論</p>
      <h1>方法論與<em>準確性標準</em></h1>
      <p class="intro">
        {SITE.brand} 建立在一條規則之上:絕不把推測用和已覈實事實一樣的確定性呈現出來。這個頁面
        準確說明我們如何標註、註明來源並更新關於 {GAME.title} 的信息,以及其他網站或記者可以
        如何引用我們的工作。
      </p>

      <h2>我們的四級確認體系</h2>
      <p>每個包含事實性說法的角色資料、FAQ 回答和攻略條目都會標註下列四個等級之一,直接顯示在頁面上,而不是藏在腳註裏:</p>
      <table class="facts">
        <tr><th>等級</th><th>含義</th></tr>
        {tiers.map((t) => (<tr><th>{t.label}</th><td>{t.desc}</td></tr>))}
      </table>

      <h2>數字一覽</h2>
      <div class="stat-grid">
        {stats.map((s) => (
          <div class="stat-card"><strong>{s.n}</strong><span>{s.label}</span></div>
        ))}
      </div>

      <h2>我們的資料來源</h2>
      <ul>
        <li><strong>官方渠道:</strong>Steam 補丁說明、開發者自己在 Steam 社區發佈的帖子、官方 wiki,以及各平臺的商店頁面。</li>
        <li><strong>媒體報道:</strong>我們明確署名的媒體(IGN、GameRant、TheGamer、Nintendo Everything 等)的評測和試玩報道,而不是不具名地引用"有評測者說"。</li>
        <li><strong>社區測試:</strong>Reddit、Steam 社區討論和 YouTube 實況,在我們能驗證之前都歸爲"據報道"而非"已確認"。</li>
        <li><strong>發售前數據挖掘:</strong>儘可能與其他發售前資料交叉覈對,並明確標註爲數據挖掘而非已確認,因爲文件在正式發售前可能會變化。</li>
      </ul>

      <h2>我們不會做的事</h2>
      <p>
        我們不會爲了填補空白而編造禮物表、數值、掉落率或配方。我們不會把"據報道"的內容升級爲
        "已確認",只是爲了讓頁面看起來更完整。當某個事實的確認等級發生變化時——比如某個數據挖掘
        得到的名字後來在正式遊戲中被確認——我們會更新標註,而不是悄悄改寫歷史。
      </p>

      <h2>引用本站</h2>
      <p>
        如果你是記者、YouTuber,或其他攻略的共同作者,並且引用了我們的數據,請直接鏈接到你引用
        的具體頁面(角色資料、FAQ 回答或地點攻略),而不只是首頁,這樣你的讀者可以自己查看來源
        和確認等級。類似"<em>經由 {SITE.brand}</em>"這樣一句話加上鍊接正是我們所希望的——不需要
        正式許可。
      </p>
      <p>
        發現了錯誤,或者有真實來源的更正信息?請通過 {SITE.contact} 聯繫我們,我們會覈實並更新
        相關頁面。
      </p>

      <h2>常見問題</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        相關鏈接:<a href="/zh-hant/about">關於本站</a>、<a href="/zh-hant/faq">FAQ 樞紐</a>。
      </div>
    </div>
  </article>

  <style>
    .stat-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin: 14px 0 22px; }
    @media (min-width: 640px) { .stat-grid { grid-template-columns: repeat(4, 1fr); } }
    .stat-card { border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 16px 14px; text-align: center; }
    .stat-card strong { display: block; font-family: var(--display); font-size: 1.8rem; color: var(--candle); }
    .stat-card span { color: var(--muted); font-size: 0.82rem; }
  </style>
</Base>
