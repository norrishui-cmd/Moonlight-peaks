---
import TopicPage from '../../../components/TopicPage.astro';
import { familiesSection, families } from '../../../data/families';
import { familiesZhHant } from '../../../i18n/families-zh-hant';

export function getStaticPaths() {
  return families.filter((it) => familiesZhHant[it.slug]).map((it, i, arr) => {
    const tr = familiesZhHant[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...arr[(i - 1 + arr.length) % arr.length], ...familiesZhHant[arr[(i - 1 + arr.length) % arr.length].slug] },
        next: { ...arr[(i + 1) % arr.length], ...familiesZhHant[arr[(i + 1) % arr.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const zhSection = { ...familiesSection, base: '/zh-hant/families', label: '家族', eyebrow: '世界觀' };
---
<TopicPage section={zhSection} item={item} prev={prev} next={next} lang="zh-hant" basePath="/zh-hant/families" />
