---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';
import { faqs } from '../../../data/faq';
import { faqZhHant } from '../../../i18n/faq-zh-hant';

const catLabelZh: Record<string, string> = {
  platforms: '平臺、價格 & 試玩版', romance: '戀愛與結婚', characters: '角色',
  world: '世界與玩法', farming: '農耕與經濟', general: '通用',
};
const cats = ['platforms', 'romance', 'characters', 'world', 'farming', 'general'] as const;
const translated = faqs.filter((f) => faqZhHant[f.slug]);
const plain = (slug: string) => {
  const tr = faqZhHant[slug];
  return [tr.a, ...(tr.more || [])].join(' ');
};

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh-hant` },
    { '@type': 'ListItem', position: 2, name: '常見問題', item: `${SITE.url}/zh-hant/faq` },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: translated.map((f) => ({
    '@type': 'Question', name: faqZhHant[f.slug].q, acceptedAnswer: { '@type': 'Answer', text: plain(f.slug) },
  })) },
];
---
<Base
  title="Moonlight Peaks 常見問題 — 發售、戀愛、試玩版 & 更多"
  description="關於 Moonlight Peaks 最常見問題的解答:發售日期、價格、平臺、多人模式、戰鬥、結婚、戀愛選項、試玩版和玩法。"
  path="/zh-hant/faq"
  jsonLd={jsonLd}
  crumbs={[{ label: '常見問題' }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">樞紐 · 常見問題</p>
      <h1>{GAME.title} <em>常見問題</em></h1>
      <p class="intro">
        自 2026 年 7 月 7 日發售以來,玩家們關於 {GAME.title} 最常問的問題,這裏提供快速且有
        來源支持的答案。每個問題都有自己的頁面。我們只回答已確認或據報道的內容,尚不清楚的
        內容會明確標註,而不是靠猜測填補。最近更新:{SITE.updated}。
      </p>

      <h2>怎麼使用這份常見問題</h2>
      <p>
        需要快速答案時用這個頁面,然後打開鏈接的攻略瞭解更多細節。平臺和試玩版相關問題通常
        指向發售頁面,戀愛和角色相關問題則指向禮物、日程、好感度事件和家族頁面。
      </p>

      {cats.map((cat) => {
        const items = translated.filter((f) => f.cat === cat);
        if (items.length === 0) return null;
        return (
          <section class="grp">
            <div class="grp-head"><h2>{catLabelZh[cat]}</h2><span class="note">{items.length} 個問題</span></div>
            <ul class="q-list">
              {items.map((f) => (
                <li><a href={`/zh-hant/faq/${f.slug}`}>{faqZhHant[f.slug].q}</a></li>
              ))}
            </ul>
          </section>
        );
      })}

      <div class="callout wip">
        目前已有 {translated.length} 條常見問題被翻譯爲中文。英文版提供全部 {faqs.length} 條——
        <a href="/faq">英文常見問題頁面</a>。
      </div>
    </div>
  </article>

  <style>
    .grp { margin: 28px 0; }
    .grp-head { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; border-bottom: 1px solid var(--line); padding-bottom: 6px; margin-bottom: 10px; }
    .grp-head h2 { margin: 0; }
    .note { font-family: var(--mono); font-size: 0.72rem; color: var(--faint); white-space: nowrap; }
    .q-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; }
    .q-list a { display: block; padding: 8px 0; color: var(--mist); text-decoration: none; border-bottom: 1px dashed var(--line); }
    .q-list a:hover { color: var(--candle); }
  </style>
</Base>
