---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';
import { faqs, faqCatLabels } from '../../../data/faq';
import { faqZhHant } from '../../../i18n/faq-zh-hant';

export function getStaticPaths() {
  const translated = faqs.filter((f) => faqZhHant[f.slug]);
  return translated.map((f, i) => ({
    params: { slug: f.slug },
    props: { f, tr: faqZhHant[f.slug], prev: translated[(i - 1 + translated.length) % translated.length], next: translated[(i + 1) % translated.length] },
  }));
}

const { f, tr, prev, next } = Astro.props as {
  f: (typeof faqs)[number]; tr: { q: string; a: string; more?: string[] };
  prev: (typeof faqs)[number]; next: (typeof faqs)[number];
};
const url = new URL(`/zh-hant/faq/${f.slug}`, SITE.url).href;
const plain = [tr.a, ...(tr.more || [])].join(' ');

const catLabelZh: Record<string, string> = {
  platforms: '平臺、價格 & 試玩版', romance: '戀愛與結婚', characters: '角色',
  world: '世界與玩法', farming: '農耕與經濟', general: '通用',
};

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh-hant` },
    { '@type': 'ListItem', position: 2, name: '常見問題', item: `${SITE.url}/zh-hant/faq` },
    { '@type': 'ListItem', position: 3, name: tr.q, item: url },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [{
    '@type': 'Question', name: tr.q, acceptedAnswer: { '@type': 'Answer', text: plain },
  }] },
];
---
<Base
  title={`${tr.q} · Moonlight Peaks`}
  description={plain.length > 155 ? plain.slice(0, 152) + '…' : plain}
  path={`/zh-hant/faq/${f.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: '常見問題', href: '/zh-hant/faq' }, { label: tr.q }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">常見問題 · {catLabelZh[f.cat] ?? faqCatLabels[f.cat]}</p>
      <h1>{tr.q}</h1>
      <p class="intro">{tr.a}</p>
      {tr.more && tr.more.map((m) => (<p>{m}</p>))}

      {f.related && f.related.length > 0 && (
        <div class="callout">
          <strong>相關:</strong>{' '}
          {f.related.map((r, i) => (<>{i > 0 ? ' · ' : ''}<a href={r.href}>{r.label}</a></>))}
        </div>
      )}

      <p class="cnote">我們只回答關於 {GAME.title} 已確認或據報道的內容;尚不清楚的內容會標註出來並持續更新。</p>

      <nav class="prevnext" aria-label="常見問題導航">
        <a href={`/zh-hant/faq/${prev.slug}`}>← 上一個</a>
        <a href="/zh-hant/faq">所有常見問題</a>
        <a href={`/zh-hant/faq/${next.slug}`}>下一個 →</a>
      </nav>
    </div>
  </article>

  <style>
    .cnote { font-size: 0.74rem; color: var(--faint); margin: 14px 0 0; }
    .prevnext { display: flex; justify-content: space-between; gap: 10px; margin: 18px 0 0; font-family: var(--mono); font-size: 0.8rem; }
    .prevnext a { color: var(--candle); }
  </style>
</Base>
