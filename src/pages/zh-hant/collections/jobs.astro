---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const faq = [
  { q: '月光峰的Albertus工作是什麼?', a: '確認:由貓頭鷹Albertus經營的佈告欄，玩家可以在上面檢視可接的工作——完成短小的委託能獲得金幣，有時還有道具禮物，以及與委託人的好感度。' },
  { q: '月光峰的工作佈告欄在哪裡?', a: '確認:在鎮公所，由Albertus經營。這是新居民登記時最早被介紹的系統之一。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '收藏', item: `${SITE.url}/zh-hant/collections` },
    { '@type': 'ListItem', position: 3, name: '工作', item: `${SITE.url}/zh-hant/collections/jobs` },
  ] },
];
---
<Base
  title="月光峰Albertus的工作 — 佈告欄系統詳解"
  description="確認:Albertus的工作佈告欄上，完成短小委託能獲得金幣、道具禮物，以及與委託人的好感度。"
  path="/zh-hant/collections/jobs"
  jsonLd={jsonLd}
  crumbs={[{ label: '收藏', href: '/zh-hant/collections' }, { label: '工作' }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">收藏 · 工作</p>
      <h1>Albertus的<em>工作</em></h1>
      <p class="intro">
        確認:Albertus的工作是貓頭鷹<a href="/characters/albertus">Albertus</a>在鎮公所經營的
        佈告欄——這是新居民登記時最早被介紹的系統之一。
      </p>

      <h2>工作的運作方式</h2>
      <p>
        確認:工作是貼在佈告欄上的短小委託。完成一項工作能獲得金幣，有時還有道具禮物，以及
        與委託人的好感度提升——對早期收入和被動建立友好關係都很有幫助。
      </p>

      <h2>地點</h2>
      <p>
        確認:佈告欄在鎮公所，位於Brook鎮長登記櫃檯旁邊——是新居民在小鎮上最早被介紹的東西之一。
      </p>

      <h2>目前仍在核實的資訊</h2>
      <ul>
        <li>具體的工作池和重新整理頻率。</li>
        <li>難度和獎勵會不會隨時間變化。</li>
        <li>哪些居民會發布委託的完整名單。</li>
      </ul>

      <h2>常見問題</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        相關頁面: <a href="/zh-hant/collections">收藏中心</a>、<a href="/characters/albertus">Albertus</a>、
        <a href="/locations/town-hall">鎮公所</a>、<a href="/zh-hant/characters/brook">Brook</a>。
      </div>
    </div>
  </article>
</Base>
