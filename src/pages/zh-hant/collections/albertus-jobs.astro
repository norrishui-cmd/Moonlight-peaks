---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const faq = [
  { q: 'Moonlight Peaks 裏 Albertus 打工板是什麼?', a: '已確認:一塊由貓頭鷹 Albertus 管理的告示板,玩家可以在上面查看可接的委託——完成這些短小的任務能獲得金幣、偶爾還有物品,以及和委託人的好感度。' },
  { q: 'Moonlight Peaks 裏打工板在哪找?', a: '已確認:在市政廳,由 Albertus 管理。這是新居民最早會接觸到的系統之一。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh-hant` },
    { '@type': 'ListItem', position: 2, name: '收藏', item: `${SITE.url}/zh-hant/collections` },
    { '@type': 'ListItem', position: 3, name: '打工板', item: `${SITE.url}/zh-hant/collections/albertus-jobs` },
  ] },
];
---
<Base
  title="Moonlight Peaks Albertus 打工板 — 玩法詳解"
  description="已確認:Albertus 打工板是 Moonlight Peaks 的告示板,完成短小委託能獲得金幣、物品和與委託人的好感度。"
  path="/zh-hant/collections/albertus-jobs"
  jsonLd={jsonLd}
  crumbs={[{ label: '收藏', href: '/zh-hant/collections' }, { label: '打工板' }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">收藏 · 打工板</p>
      <h1>Albertus <em>打工板</em></h1>
      <p class="intro">
        已確認:Albertus 打工板是小鎮的告示板,由貓頭鷹
        <a href="/characters/albertus">Albertus</a> 在市政廳管理——這是新居民最早會接觸到的
        系統之一。
      </p>

      <h2>打工怎麼運作</h2>
      <p>
        已確認:打工是貼在告示板上的短小委託。完成一份委託能獲得金幣,有時還有物品,外加與
        委託人的好感度提升——這對早期賺錢和被動積累好感度都很有用。
      </p>

      <h2>在哪找</h2>
      <p>
        已確認:告示板位於市政廳內,就在鎮長 Brook 的登記櫃檯旁邊——這是新居民在小鎮上最早
        會接觸到的東西之一。
      </p>

      <h2>仍在確認中</h2>
      <ul>
        <li>具體的委託池以及多久刷新一次。</li>
        <li>難度或獎勵是否會隨時間提升。</li>
        <li>哪些居民的委託可能出現的完整列表。</li>
      </ul>

      <h2>常見問題</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        相關頁面:<a href="/zh-hant/collections">收藏樞紐</a>、<a href="/characters/albertus">Albertus</a>、
        <a href="/locations/town-hall">市政廳</a>、<a href="/zh-hant/characters/brook">Brook</a>。
      </div>
    </div>
  </article>
</Base>
