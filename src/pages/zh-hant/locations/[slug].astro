---
import TopicPage from '../../../components/TopicPage.astro';
import { locationsSection, locations } from '../../../data/locations';
import { locationsZhHant } from '../../../i18n/locations-zh-hant';

export function getStaticPaths() {
  return locations.filter((it) => locationsZhHant[it.slug]).map((it, i, arr) => {
    const tr = locationsZhHant[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...arr[(i - 1 + arr.length) % arr.length], ...locationsZhHant[arr[(i - 1 + arr.length) % arr.length].slug] },
        next: { ...arr[(i + 1) % arr.length], ...locationsZhHant[arr[(i + 1) % arr.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const zhSection = { ...locationsSection, base: '/zh-hant/locations', label: '地點', eyebrow: '地點' };
---
<TopicPage section={zhSection} item={item} prev={prev} next={next} lang="zh-hant" basePath="/zh-hant/locations" />
