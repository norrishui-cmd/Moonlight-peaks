---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const coverage = [
  ['發售與平臺', '發售日期、Demo、Steam、Steam Deck、Switch、Switch 2、Android 和購買前檢查。'],
  ['玩家攻略', '新手、種田、魔法、活動、物品、地圖、對比頁面和開局建議。'],
  ['角色與戀愛', '居民、家族、戀愛候選人、禮物、結婚，以及發售後需要驗證的資料。'],
  ['工具與 FAQ', 'Platform Picker、戀愛工具、Item Tracker、種田計算、FAQ 和持續更新頁面。'],
];

const principles = [
  '區分已確認資訊、Demo 觀察、預覽內容和待驗證資料。',
  '先回答玩家真正的問題，而不是堆關鍵詞。',
  '保持頁面在手機端快速、清晰、好閱讀。',
  '可靠資料出現後，在同一個 URL 上繼續更新。'
];

const faq = [
  { q: 'Moonlight Peaks Wiki & Guide 是官網嗎？', a: `不是。${SITE.brand} 是玩家制作的獨立攻略站，與 ${GAME.developer} 或 ${GAME.publisher} 沒有官方從屬或背書關係。` },
  { q: '這個網站覆蓋哪些內容？', a: '覆蓋發售日期、Demo、平臺、角色、家族、戀愛、禮物、種田、魔法、物品、工具、FAQ 和對比頁面。' },
  { q: '未確認資訊會怎麼處理？', a: '會標明為待確認或需要驗證，不把推測內容寫成最終資料。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'AboutPage', name: `關於 ${SITE.brand}`, url: new URL('/zh-hant/about', SITE.url).href },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh-hant` },
    { '@type': 'ListItem', position: 2, name: '關於本站', item: new URL('/zh-hant/about', SITE.url).href },
  ] },
];
---
<Base
  title={`關於 ${SITE.brand} - Moonlight Peaks 獨立攻略站`}
  description={`${SITE.brand} 是 Moonlight Peaks 獨立攻略站，覆蓋發售日期、Demo、平臺、戀愛、角色、種田、魔法、工具、FAQ 和更新。`}
  path="/zh-hant/about"
  jsonLd={jsonLd}
  crumbs={[{ label: '關於本站' }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">獨立玩家攻略</p>
      <h1>關於 <em>{SITE.brand}</em></h1>
      <p class="intro">
        {SITE.brand} 是為 {GAME.title} 玩家制作的獨立攻略站，幫助玩家快速瞭解發售日期、
        Demo、平臺、戀愛、角色、禮物、種田、魔法、工具和發售前準備。
      </p>

      <h2>我們覆蓋什麼</h2>
      <div class="info-grid">
        {coverage.map((item) => <section><h3>{item[0]}</h3><p>{item[1]}</p></section>)}
      </div>

      <h2>編輯原則</h2>
      <ul>
        {principles.map((item) => <li>{item}</li>)}
      </ul>

      <h2>獨立宣告</h2>
      <p>
        本站不是官方網站，也沒有與 {GAME.developer} 或 {GAME.publisher} 建立官方合作、授權或背書關係。
        Moonlight Peaks 相關名稱和素材歸各自權利方所有。
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => <details><summary>{f.q}</summary><p>{f.a}</p></details>)}
      </div>
    </div>
  </article>

  <style>
    .info-grid { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 16px 0 24px; }
    @media (min-width: 760px) { .info-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    .info-grid section { border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 16px; }
    .info-grid h3 { margin-top: 0; }
  </style>
</Base>
