---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const faq = [
  { q: 'Moonlight Peaks裡友情和戀愛不一樣嗎?', a: '是的——每位居民(不論是否可攻略)都有一份可以透過對話和送禮來培養的關係,記錄在關係選單裡。戀愛和結婚是一條可選的、更深入的路線,只對23位已確認的可攻略角色開放;其他所有人依然可以成為朋友。' },
  { q: '培養友情能得到什麼?', a: '發售時確認:關係會解鎖特殊圖紙和製作材料,以及角色個人故事——所以跟全鎮居民打好關係,即使不走戀愛路線也很有回報。' },
  { q: '可以跟朋友一起玩Nokturna嗎?', a: '可以——和居民的Nokturna對戰會和對話、禮物一起記錄在他們的友情選單裡,所以這也是培養關係的一種方式。' },
  { q: '友情和戀愛的禮物機制一樣嗎?', a: '機制是一樣的——送禮提升關係等級——不過喜歡/一般/不喜歡的反應可能因人而異,和你是否在追求戀愛無關。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '友情', item: new URL('/zh-hant/friendship', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks 友情 — 關係選單與獎勵"
  description="Moonlight Peaks裡友情(區別於戀愛)是怎麼運作的:關係選單、禮物反應,以及培養友情能解鎖什麼。"
  path="/zh-hant/friendship"
  jsonLd={jsonLd}
  crumbs={[{ label: '友情' }]}
  lang="zh-hant"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">入門 · 友情</p>
      <h1>Moonlight Peaks <em>友情</em></h1>
      <p class="intro">
        不是每位居民都能戀愛,但每個人都有一份可以培養的關係。本頁講的是純友情的一面,
        區別於<a href="/romance">戀愛攻略</a>。最後更新:{SITE.updated}。
      </p>

      <h2>友情是怎麼運作的</h2>
      <p>
        發售時確認:和居民對話、送禮會提升關係等級,記錄在關係選單裡,能看到最近的禮物以及
        每份禮物的反應。這適用於每一位有名字的居民——不論是23位戀愛選項,還是更廣泛的NPC群體。
      </p>

      <h2>友情能解鎖什麼</h2>
      <p>
        確認:更深的關係會解鎖圖紙和製作材料,以及角色個人故事,不論你是否在追求這個人的戀愛線。
        和居民玩Nokturna也會記錄在他們的友情選單裡。
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        相關:<a href="/romance">戀愛</a>、<a href="/characters">角色</a>、
        <a href="/tools/gift-tracker">送禮記錄工具</a>、<a href="/nokturna">Nokturna</a>。
      </div>
    </div>
  </article>
</Base>
