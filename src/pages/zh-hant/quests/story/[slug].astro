---
import Base from '../../../../layouts/Base.astro';
import { SITE, GAME } from '../../../../consts';
import { storyQuests, storyQuestBySlug } from '../../../../data/quests-story';
import { storyQuestsZhHant, storyChaptersZhHant } from '../../../../i18n/quests-story-zh-hant';

export function getStaticPaths() {
  return storyQuests.filter((q) => storyQuestsZhHant[q.slug]).map((q) => ({ params: { slug: q.slug }, props: { q } }));
}

const { q } = Astro.props as { q: (typeof storyQuests)[number] };
const tr = storyQuestsZhHant[q.slug];
const chapter = storyChaptersZhHant.find((c) => c.number === q.chapter)!;
const prev = storyQuests[storyQuests.indexOf(q) - 1];
const next = q.leadsTo ? storyQuestBySlug.get(q.leadsTo) : undefined;
const statusLabel = q.status === 'confirmed' ? '已確認' : '據報告';

const faq = [
  { q: `如何解鎖"${tr.title}"?`, a: tr.unlock || '這個任務是上一個劇情節點的直接延續——請參見下方的上一任務連結。' },
  { q: `"${tr.title}"的獎勵是什麼?`, a: tr.reward || '目前還沒有確認這個任務有直接的道具獎勵。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh-hant` },
    { '@type': 'ListItem', position: 2, name: '任務攻略', item: `${SITE.url}/zh-hant/quests` },
    { '@type': 'ListItem', position: 3, name: '主線任務', item: `${SITE.url}/zh-hant/quests/story` },
    { '@type': 'ListItem', position: 4, name: tr.title, item: `${SITE.url}/zh-hant/quests/story/${q.slug}` },
  ] },
];
---
<Base
  title={`${tr.title} — 月光峰任務攻略`}
  description={`月光峰任務"${tr.title}": ${tr.summary.slice(0, 100)}`}
  path={`/zh-hant/quests/story/${q.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: '任務攻略', href: '/zh-hant/quests' }, { label: '主線任務', href: '/zh-hant/quests/story' }, { label: tr.title }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">主線任務 · 第{q.chapter}章:{chapter.title} · <span class="tag-community">{statusLabel}</span></p>
      <h1>{tr.title}</h1>

      {tr.unlock && (
        <div class="callout">
          <strong>解鎖方式:</strong> {tr.unlock}
        </div>
      )}

      <h2>任務內容</h2>
      <p>{tr.summary}</p>

      {tr.reward && (
        <>
          <h2>獎勵</h2>
          <p>{tr.reward}</p>
        </>
      )}

      {tr.troubleshooting && tr.troubleshooting.length > 0 && (
        <>
          <h2>卡關了?檢查這些</h2>
          <div class="faq">
            {tr.troubleshooting.map((t) => (
              <details open>
                <summary>{t.q}</summary>
                <p>{t.a}</p>
              </details>
            ))}
          </div>
        </>
      )}

      <h2>常見問題</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <nav class="prevnext" aria-label="任務導航">
        {prev && storyQuestsZhHant[prev.slug] ? <a href={`/zh-hant/quests/story/${prev.slug}`}>← {storyQuestsZhHant[prev.slug].title}</a> : <span />}
        <a href="/zh-hant/quests/story">所有章節</a>
        {next && storyQuestsZhHant[next.slug] ? <a href={`/zh-hant/quests/story/${next.slug}`}>{storyQuestsZhHant[next.slug].title} →</a> : <span />}
      </nav>

      <div class="callout wip">
        相關: <a href="/zh-hant/quests">任務中心</a>, <a href="/zh-hant/quests/side">支線任務</a>,
        <a href="/zh/beginner-guide">新手指南</a>。
      </div>
    </div>
  </article>

  <style>
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 7px;
      vertical-align: middle;
    }
    .prevnext { display: flex; justify-content: space-between; gap: 10px; margin: 22px 0; font-family: var(--mono); font-size: 0.82rem; }
    .prevnext a { color: var(--candle); }
  </style>
</Base>
