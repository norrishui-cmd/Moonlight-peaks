---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const faq = [
  { q: 'Moonlight Peaks 中 A Bridge Too Far 怎麼開始?', a: '已確認:這個任務緊接在"Orlock 的釀酒計劃"之後——向 Orlock 道歉,替他還清 Samael 的 350 金債務,然後回去彙報。' },
  { q: 'A Bridge Too Far 解鎖了什麼?', a: '已確認:Ambrosia 莊園以及整個 Misty Shores 區域,包括回聲洞穴(銅礦石)。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh-hant` },
    { '@type': 'ListItem', position: 2, name: '任務', item: `${SITE.url}/zh-hant/quests/a-bridge-too-far` },
  ] },
];
---
<Base
  title="Moonlight Peaks:A Bridge Too Far 任務攻略(簡體中文)"
  description="Moonlight Peaks A Bridge Too Far 中文攻略:如何開始這個任務、Orlock 與 Fiona 的糾紛,以及它解鎖了什麼(Misty Shores、回聲洞穴)。"
  path="/zh-hant/quests/a-bridge-too-far"
  jsonLd={jsonLd}
  crumbs={[{ label: '任務' }, { label: 'A Bridge Too Far' }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">任務攻略</p>
      <h1>Moonlight Peaks:<em>A Bridge Too Far</em></h1>

      <div class="callout">
        <strong>快速回答:</strong>A Bridge Too Far 在完成"Orlock 的釀酒計劃"後解鎖。找小鎮上懂
        魔法的人聊聊,然後回到 Ambrosia 莊園旁邊的橋上。完成後會開放 Misty Shores 和回聲洞穴。
      </div>

      <h2>如何開始這個任務</h2>
      <p>
        已確認:這個任務緊接在<strong>Orlock 的釀酒計劃</strong>之後,你需要在那個任務裏爲
        Orlock 釀造血酒。向 Orlock 道歉、並在破燈酒館替他還清 350 金債務之後,下次進城時任務
        會自動觸發。
      </p>

      <h2>橋爲什麼被封了</h2>
      <p>
        <span class="tag-community">社區報告</span> Orlock 認爲是 Fiona 詛咒了這座橋。實際上
        根本沒有真正的詛咒——兩人只是吵了一架,Orlock 說話不太客氣。
      </p>

      <h2>這個任務解鎖了什麼</h2>
      <p>
        已確認:完成後會開放 Ambrosia 莊園以及整個 Misty Shores 區域,包括回聲洞穴。
      </p>

      <h2>常見問題</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        延伸閱讀:<a href="/locations/mines">回聲洞穴</a>、
        <a href="/quests/a-bridge-too-far">完整攻略(英文)</a>。
      </div>
    </div>
  </article>
  <style>
    .tag-community {
      display: inline-block; font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.02em;
      color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 2px 8px;
      margin-right: 6px; vertical-align: middle;
    }
  </style>
</Base>
