---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const facts = [
  ['發售日期', GAME.releaseLabel],
  ['價格', `${GAME.price}(Nintendo Switch 2 版:$39.99)`],
  ['平臺', GAME.platforms.join(', ')],
  ['免費試玩版', GAME.demo],
  ['配置需求', '具體的 PC/Mac 官方配置要求請以 Steam 頁面為準;想實際感受表現,建議先玩試玩版'],
  ['語言支援', GAME.languages.join(', ')],
  ['PS5 / Xbox / iOS', '未公佈'],
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh-hant` },
    { '@type': 'ListItem', position: 2, name: '平臺攻略', item: `${SITE.url}/zh-hant/platforms` },
  ] },
];
---
<Base
  title="Moonlight Peaks 平臺攻略 —— Switch、Switch 2、Steam 與價格"
  description="Moonlight Peaks 能在哪玩:Switch、Switch 2、Steam(PC 與 Mac)、Steam Deck 與 Android——價格、免費試玩版,以及 PS5/Xbox/iOS 的現狀。"
  path="/zh-hant/platforms"
  jsonLd={jsonLd}
  crumbs={[{ label: '平臺攻略' }]}
  lang="zh-hant"
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">詞條 · 平臺</p>
      <h1>Moonlight Peaks 的<em>平臺</em>與價格</h1>
      <p class="intro">
        Moonlight Peaks 將在 {GAME.releaseLabel} 發售。這裡彙總了能在哪玩、多少錢,
        以及免費試玩版是怎麼運作的。
      </p>

      <h2>一覽表</h2>
      <table class="facts">
        {facts.map((f) => (<tr><th>{f[0]}</th><td>{f[1]}</td></tr>))}
      </table>

      <h2>能在哪玩</h2>
      <p>
        Moonlight Peaks 確認會登陸 Steam(PC 與 Mac)、Steam Deck、Nintendo Switch、
        Nintendo Switch 2,以及透過 Google Play 上線的 Android 版。每個平臺都有各自的詳細攻略——
        目前只有英文版——裡面有關於效能表現、操作方式和價格的具體說明。
      </p>

      <h2>Moonlight Peaks 會上 PlayStation、Xbox 或 iOS 嗎?</h2>
      <p>
        目前沒有公佈 PlayStation、Xbox 或 iOS 版本。已確認的平臺是 Steam(PC 與 Mac)、
        Steam Deck、Nintendo Switch、Nintendo Switch 2,以及透過 Google Play 上線的 Android 版。
        如果情況有變,我們會更新這個頁面。
      </p>

      <div class="callout wip">
        相關內容:<a href="/release-date">發售日期</a>、<a href="/demo">試玩版</a>、
        <a href="/system-requirements">配置需求</a>、<a href="/languages">語言支援</a>、
        <a href="/compare">和其它溫馨模擬遊戲對比</a>、<a href="/faq">完整版 FAQ</a>(英文)·
        <a href="/zh-hant/faq">中文版 FAQ</a>。
      </div>
    </div>
  </article>
</Base>
