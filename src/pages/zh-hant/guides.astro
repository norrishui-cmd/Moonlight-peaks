---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const rows = [
  ['從這裡開始', '新手指南、Demo、發售日期和平臺資訊。'],
  ['核心系統', '種田、釣魚、魔法、活動、物品、地圖和 Nokturna。'],
  ['關係玩法', '角色、家族、戀愛、禮物、結婚和好感路線。'],
  ['收集玩法', '魚類、蟲類、食譜、藥劑、神器、裝飾和素材。'],
  ['購買前查詢', 'Steam Deck、Switch、Android、價格、Demo 和對比頁面。'],
];

const links = [
  { href: '/zh/beginner-guide', label: '新手指南' },
  { href: '/zh/release-date', label: '發售日期' },
  { href: '/zh/demo', label: 'Demo' },
  { href: '/zh/platforms', label: '平臺資訊' },
  { href: '/zh/characters', label: '角色' },
  { href: '/zh/romance', label: '戀愛' },
  { href: '/zh/farming', label: '種田' },
  { href: '/zh/magic', label: '魔法' },
  { href: '/zh/items', label: '物品' },
  { href: '/tools', label: '工具' },
];

const faq = [
  { q: '應該先看哪篇 Moonlight Peaks 攻略？', a: '建議先看新手指南，然後根據需求檢視 Demo、發售日期、平臺、角色或戀愛頁面。' },
  { q: '站內的攻略資料都是最終確認的嗎？', a: '不完全是。頁面會區分已確認資訊、玩家實測反饋和仍在核實中的內容，不會把猜測當成事實。' },
  { q: '禮物、魚類和作物表會放在哪裡？', a: '確認可靠資料後，會補充到戀愛、角色、物品、種田和活動等頁面。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '攻略', item: new URL('/zh/guides', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
];
---
<Base
  title="Moonlight Peaks 攻略 - 新手、種田與戀愛"
  description="Moonlight Peaks 中文攻略中心，整理新手、Demo、發售日期、平臺、種田、魔法、角色、戀愛和物品等入口。"
  path="/zh-hant/guides"
  jsonLd={jsonLd}
  crumbs={[{ label: '攻略' }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">中心 / 攻略</p>
      <h1>Moonlight Peaks <em>攻略</em></h1>
      <p class="intro">
        這是 {GAME.title} 的中文攻略入口，用來整理玩家最常查詢的發售、平臺、Demo、
        新手、種田、魔法、角色和戀愛內容。
      </p>

      <h2>攻略地圖</h2>
      <table class="facts">
        {rows.map((row) => (<tr><th>{row[0]}</th><td>{row[1]}</td></tr>))}
      </table>

      <h2>主要頁面</h2>
      <div class="link-grid">
        {links.map((link) => <a href={link.href}>{link.label}</a>)}
      </div>

      <h2>推薦閱讀順序</h2>
      <ol class="steps">
        <li>先確認發售日期、Demo 和平臺。</li>
        <li>開始第一夜之前閱讀新手指南。</li>
        <li>從種田、魔法、戀愛、收集或探索中選擇第一個目標。</li>
        <li>需要具體答案時，再進入對應專題頁。</li>
      </ol>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => <details><summary>{f.q}</summary><p>{f.a}</p></details>)}
      </div>
    </div>
  </article>

  <style>
    .link-grid { display: grid; grid-template-columns: 1fr; gap: 10px; margin: 12px 0 24px; }
    @media (min-width: 720px) { .link-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    .link-grid a { border: 1px solid var(--line); border-radius: 10px; background: var(--surface); color: var(--mist); padding: 12px 14px; text-decoration: none; }
  </style>
</Base>
