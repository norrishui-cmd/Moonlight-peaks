---
import Base from '../../../layouts/Base.astro';
import { SITE, GAME } from '../../../consts';

const entries = [
  { group: '資料庫', title: '作物', desc: '完整的作物資料庫——30多種田地作物、草藥園作物和樹木作物，標註季節與是否為魔法作物。', href: '/zh-hant/farm/crops' },
  { group: '住宅', title: '房屋', desc: '房屋如何透過Howling Hammer升級4次，由"修屋頂"任務解鎖。', href: '/zh-hant/farm/house' },
  { group: '建築', title: '穀倉', desc: '穀倉的花費、大小與解鎖方式——4000金，佔地10x6，可養4只動物。', href: '/zh-hant/farm/barn' },
  { group: '建築', title: '溫室', desc: '目前已確認的溫室擴建相關資訊。', href: '/zh-hant/farm/greenhouse' },
  { group: '生物', title: '動物', desc: '已確認的動物名單、領養方式、餵養方法，以及它們的產出。', href: '/zh-hant/farm/animals' },
  { group: '機器', title: '農場助手', desc: '全部16臺已確認的加工機器——熔爐、酒桶、精煉機、蜂箱等，附配方。', href: '/zh-hant/farm/farm-helpers' },
];

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '農場', item: `${SITE.url}/zh-hant/farm` },
  ],
};
---
<Base
  title="月光峰農場 — 作物、房屋、穀倉、溫室與動物"
  description="月光峰農場中心:作物、房屋升級、穀倉、溫室、家畜與加工機器——全部來自官方wiki。"
  path="/zh-hant/farm"
  jsonLd={jsonLd}
  crumbs={[{ label: '農場' }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">中心 · 農場</p>
      <h1>你的<em>農場</em></h1>
      <p class="intro">
        關於如何搭建你的家園——種什麼、房屋和穀倉如何擴建、以及維持農場運作所需的動物和機器。
        以下內容大多直接來自月光峰官方wiki。
      </p>

      <div class="itg">
        {entries.map((e) => (
          <a class="itcard" href={e.href}>
            <span class="itgroup">{e.group}</span>
            <h3>{e.title}</h3>
            <p>{e.desc}</p>
          </a>
        ))}
      </div>

      <div class="callout wip">
        每個板塊的詳細頁面也已提供。相關:
        <a href="/zh-hant/farming">種田指南</a>, <a href="/zh/locations">地點</a>, <a href="/zh/items">物品</a>。
      </div>
    </div>
  </article>

  <style>
    .itg { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 6px 0 18px; }
    @media (min-width: 640px) { .itg { grid-template-columns: 1fr 1fr; } }
    @media (min-width: 980px) { .itg { grid-template-columns: 1fr 1fr 1fr; } }
    .itcard {
      display: block;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--surface);
      padding: 14px;
      color: inherit;
      text-decoration: none;
      transition: border-color .15s ease, transform .15s ease;
    }
    .itcard:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); transform: translateY(-2px); }
    .itgroup { font-family: var(--mono); color: var(--faint); text-transform: uppercase; letter-spacing: 0.04em; font-size: 0.62rem; }
    .itcard h3 { font-family: var(--display); font-weight: 600; font-size: 1rem; margin: 4px 0 6px; }
    .itcard p { color: #ded3e6; font-size: 0.84rem; margin: 0 0 10px; }
  </style>
</Base>
