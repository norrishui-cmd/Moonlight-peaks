---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';

const faq = [
  { q: '月光峰的溫室有什麼作用?', a: '社群報告:它能增加受保護的種植空間，當戶外地塊用滿或需要額外空間種植魔法作物時會很有用。具體建造花費、解鎖條件，以及是否會改變作物生長規則，目前還沒有獨立確認。' },
  { q: '建造溫室有成就嗎?', a: '有，確認:建造溫室會獲得"永恆盛開"成就。社群報告:除了成就本身，擁有溫室據說也有助於完成其他幾個與種田相關的目標，所以值得優先建造，而不是留到遊戲後期。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '農場', item: `${SITE.url}/zh-hant/farm` },
    { '@type': 'ListItem', position: 3, name: '溫室', item: `${SITE.url}/zh-hant/farm/greenhouse` },
  ] },
];
---
<Base
  title="月光峰溫室 — 目前已確認的資訊"
  description="月光峰溫室目前已確認的內容:提供額外受保護的種植空間，尚未驗證的部分會誠實標註，不做猜測。"
  path="/zh-hant/farm/greenhouse"
  jsonLd={jsonLd}
  crumbs={[{ label: '農場', href: '/zh-hant/farm' }, { label: '溫室' }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">農場 · 溫室</p>
      <h1><em>溫室</em></h1>
      <p class="intro">
        社群報告:溫室是一項農場擴建，能增加額外受保護的種植空間，當現有地塊用滿時會很有用。
        除此之外，我們目前還沒有獨立確認的建造花費、解鎖條件，或者它究竟如何改變種田玩法的
        具體細節——所以這個頁面保持簡短，而不是隨意猜測。
      </p>

      <h2>目前仍在核實的內容</h2>
      <ul>
        <li>建造花費和所需材料。</li>
        <li>哪個任務或劇情節點(如果有的話)會解鎖它。</li>
        <li>是否會改變種植季節或提供天氣防護。</li>
        <li>實際能增加多少種植空間。</li>
      </ul>

      <h2>常見問題</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        一旦確認了真實的溫室資料，本頁會繼續擴充。相關:
        <a href="/zh-hant/farm">農場中心</a>, <a href="/zh-hant/farm/crops">作物</a>, <a href="/zh-hant/farm/house">房屋</a>。
      </div>
    </div>
  </article>
</Base>
