---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../consts';
import { farmHelpers } from '../../../data/farm-helpers';
import { farmHelperDescZhHant } from '../../../data/farm-helpers-zh-hant';

const faq = [
  { q: '月光峰的農場助手機器是什麼?', a: `經官方wiki確認:農場助手是能自動化種田或加工農產品的機器。目前已確認${farmHelpers.length}臺，包括熔爐、酒桶、精煉機、草藥園、草藥烘乾架、研缽、蜂箱、織布機、乳酪壓榨機、魔力提取器、磨坊、果醬機、螢火蟲保育箱、螢火蟲傳粉器、巧克力工坊，以及種子分選機。` },
  { q: '月光峰的精煉機怎麼解鎖?', a: '確認:在工作臺用20木材+20石頭建造。它能把木材、石頭、纖維、暗木等原材料加工成木板、精煉石、飼料和硬木板。' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE.url}/zh` },
    { '@type': 'ListItem', position: 2, name: '農場', item: `${SITE.url}/zh-hant/farm` },
    { '@type': 'ListItem', position: 3, name: '農場助手', item: `${SITE.url}/zh-hant/farm/farm-helpers` },
  ] },
];
---
<Base
  title="月光峰農場助手 — 全部16臺機器與配方"
  description="月光峰全部已確認的農場助手機器:熔爐、酒桶、精煉機、蜂箱、磨坊、果醬機等，附建造配方與產出，資料來自官方wiki。"
  path="/zh-hant/farm/farm-helpers"
  jsonLd={jsonLd}
  crumbs={[{ label: '農場', href: '/zh-hant/farm' }, { label: '農場助手' }]}
  lang="zh-hant"
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">農場 · 機器</p>
      <h1>農場<em>助手</em></h1>
      <p class="intro">
        經月光峰官方wiki確認:農場助手是能自動化種田或加工農產品的機器。目前已確認{farmHelpers.length}臺。
      </p>

      {farmHelpers.map((h) => (
        <>
          <h2>{h.name}</h2>
          <p>
            {farmHelperDescZhHant[h.name] || h.desc}
            {h.buildRecipe && <> <strong>建造:</strong> {h.buildRecipe}{h.buildSource ? `(來自${h.buildSource})` : ''}。</>}
          </p>
          {h.outputs && h.outputs.length > 0 && (
            <ul>
              {h.outputs.map((o) => (<li><strong>{o.name}:</strong> {o.recipe}</li>))}
            </ul>
          )}
        </>
      ))}

      <h2>常見問題</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        資料來源:月光峰官方wiki(moonlightpeaks.wiki.gg)。相關:
        <a href="/zh-hant/farm">農場中心</a>, <a href="/zh-hant/farm/crops">作物</a>, <a href="/items/mineables">礦物</a>,
        <a href="/items/cooking">烹飪</a>。
      </div>
    </div>
  </article>
</Base>
