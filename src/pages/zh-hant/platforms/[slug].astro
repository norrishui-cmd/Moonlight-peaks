---
import TopicPage from '../../../components/TopicPage.astro';
import { platformsSection, platforms } from '../../../data/platforms';
import { platformsZhHant } from '../../../i18n/platforms-zh-hant';

export function getStaticPaths() {
  return platforms.filter((it) => platformsZhHant[it.slug]).map((it, i, arr) => {
    const tr = platformsZhHant[it.slug];
    const merged = { ...it, ...tr };
    return {
      params: { slug: it.slug },
      props: {
        item: merged,
        prev: { ...arr[(i - 1 + arr.length) % arr.length], ...platformsZhHant[arr[(i - 1 + arr.length) % arr.length].slug] },
        next: { ...arr[(i + 1) % arr.length], ...platformsZhHant[arr[(i + 1) % arr.length].slug] },
      },
    };
  });
}
const { item, prev, next } = Astro.props;
const zhSection = { ...platformsSection, base: '/zh-hant/platforms', label: '平臺', eyebrow: '平臺' };
---
<TopicPage section={zhSection} item={item} prev={prev} next={next} lang="zh-hant" basePath="/zh-hant/platforms" />
