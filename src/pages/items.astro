---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';
import { itemCategories, itemLaunchNote } from '../data/items';
import News from '../components/News.astro';

const collectionSlugs = new Set(['fish', 'critters', 'vampster', 'soul-blobs']);
const itemHubCategories = itemCategories.filter((cat) => !collectionSlugs.has(cat.slug));

const faq = [
  { q: 'What items are in Moonlight Peaks?', a: 'Pre-launch structure lists item categories including tools, fertilizer, clothing, fish, critters, Vampster, Soul Blobs, cooking, crafting, artifacts, farm helpers, potions, mineables, and decorations. Specific names, effects, prices, and sources still need launch verification.' },
  { q: 'Are there potions in Moonlight Peaks?', a: 'Yes. Potion-making is a confirmed activity, and the Alter Ego Elixir, which changes your appearance, is a confirmed example. The full potion list will be verified after launch.' },
  { q: 'Will each Moonlight Peaks item category get its own page?', a: 'Yes. Each category now has a landing page so item data can expand cleanly after launch without changing URLs.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Items', item: new URL('/items', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'ItemList', name: 'Moonlight Peaks item categories', itemListElement: itemHubCategories.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    url: new URL(`/items/${item.slug}`, SITE.url).href,
  })) },
];
---
<Base
  title="Moonlight Peaks Items - Tools, Potions, Fish & Categories"
  description="Moonlight Peaks item guide: tools, potions, fish, cooking, crafting and more — confirmed prices and mechanics, updated daily post-launch."
  path="/items"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Items' }]}
>
  <article class="page items-page">
    <div class="wrap">
      <p class="eyebrow">Hub / Items</p>
      <h1>Moonlight Peaks <em>items</em></h1>
      <p class="intro">
        A launch-ready index for the items you will collect, craft, cook, mine, decorate with, and use around
        your vampire farm in {GAME.title}. The category structure below is treated carefully: some systems are
        confirmed, while exact item names and effects still need live-game verification.
      </p>

      <div class="item-note">
        <strong>Accuracy note:</strong> {itemLaunchNote} These pages are built so the item guide can expand
        without changing URLs after launch.
      </div>

      <div class="item-note collection-move">
        <strong>Collections moved:</strong> Fish, Critters, Vampsters, and Soul Blobs now live under
        <a href="/collections">World / Collections</a>. The old item URLs remain available for compatibility,
        but the new collection pages are the main place for sourced tables and launch tracking.
      </div>

      <h2>Item categories</h2>
      <div class="itg">
        {itemHubCategories.map((cat) => (
          <a class="itcard" href={`/items/${cat.slug}`}>
            <span class="itgroup">{cat.group}</span>
            <h3>{cat.name}</h3>
            <p>{cat.dek}</p>
            <span class={`itbadge is-${cat.status}`}>{cat.status}</span>
          </a>
        ))}
      </div>

      <h2>How these pages will grow</h2>
      <p>
        Each category page is structured for the details players usually need from a wiki: where to find an
        item, how to craft or buy it, what it does, whether it is used in cooking, gifts, quests, upgrades, or
        decorating, and which related guides explain the surrounding system.
      </p>

      <h2>Latest item updates</h2>
      <News topic="items" limit={5} />

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Related:
        <a href="/farming">farming</a>, <a href="/magic">magic and potions</a>,
        <a href="/activities">activities</a>, <a href="/locations">locations</a>,
        <a href="/tools">site tools</a>.
        More FAQ: <a href="/faq/what-is-the-starting-tool-set-in-moonlight-peaks">Starting tools</a>,
        <a href="/faq/can-ridge-upgrade-the-magic-wand">Can Ridge upgrade the wand?</a>,
        <a href="/faq">full FAQ hub</a>.
      </div>
    </div>
  </article>

  <style>
    .item-note {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--surface);
      padding: 12px 14px;
      color: #ded3e6;
      font-size: 0.9rem;
      margin: 12px 0 22px;
    }
    .collection-move a { color: var(--candle); font-weight: 700; }
    .itg { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 6px 0 18px; }
    @media (min-width: 640px) { .itg { grid-template-columns: 1fr 1fr; } }
    @media (min-width: 980px) { .itg { grid-template-columns: 1fr 1fr 1fr; } }
    .itcard {
      display: block;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--surface);
      padding: 14px;
      color: inherit;
      text-decoration: none;
      transition: border-color .15s ease, transform .15s ease;
    }
    .itcard:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); transform: translateY(-2px); }
    .itgroup { font-family: var(--mono); color: var(--faint); text-transform: uppercase; letter-spacing: 0.04em; font-size: 0.62rem; }
    .itcard h3 { font-family: var(--display); font-weight: 600; font-size: 1rem; margin: 4px 0 6px; }
    .itcard p { color: #ded3e6; font-size: 0.84rem; margin: 0 0 10px; }
    .itbadge { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.04em; text-transform: uppercase; border-radius: 5px; padding: 2px 6px; }
    .itbadge.is-confirmed { color: #9be6b4; border: 1px solid #2f6a45; }
    .itbadge.is-expected { color: var(--candle); border: 1px solid var(--candle-dim); }
    .itbadge.is-datamined { color: #9ac6e0; border: 1px solid #2f5a70; }
  </style>
</Base>
