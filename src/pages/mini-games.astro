---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';

const minigames = [
  { name: 'Spell casting', how: 'Draw a circle-and-dot pattern with your wand equipped, following the D-pad prompt.', where: 'Anywhere, once magic is unlocked' },
  { name: 'Date minigames', how: 'Varies by date — examples include assembling a flower bouquet in requested colors, or roasting a marshmallow to a preferred doneness.', where: 'On dates with a resident at Heart Level 4+' },
  { name: 'Fishing', how: 'Cast toward shadows in the water, then reel in with a timing-based minigame.', where: 'Water areas, once the fishing rod is unlocked' },
  { name: 'Fishing contest vs. Noel', how: 'Catch 3 different fish before Noel does, betting 250 gold, to win the fishing rod.', where: 'Early-game, tied to Noel' },
];

const faq = [
  { q: 'What mini-games are in Moonlight Peaks?', a: 'Confirmed so far: spell casting (a circle-and-dot pattern), date activities like bouquet-assembly and marshmallow-roasting, and a timing-based fishing minigame — plus the Noel fishing contest that unlocks your rod.' },
  { q: 'Is fishing difficult in Moonlight Peaks?', a: 'Reviewers describe it as deliberately low-stress rather than frustrating, closer to a relaxed Animal Crossing-style cast-and-reel than a skill-testing challenge.' },
  { q: 'Do minigames affect relationships?', a: 'Yes for dates specifically — showing up late or fumbling a date minigame is confirmed to cost relationship points rather than ending things outright.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Mini-games', item: new URL('/mini-games', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Mini-games — Dates, Fishing & Spellcasting"
  description="Every confirmed mini-game in Moonlight Peaks: date activities like bouquet-making, the fishing cast-and-reel system, and how spellcasting works."
  path="/mini-games"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Mini-games' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entry · Mini-games</p>
      <h1>Moonlight Peaks <em>mini-games</em></h1>
      <p class="intro">
        {GAME.title} folds several mini-games into its systems rather than treating them as separate
        arcade modes. Here's what's confirmed so far. Updated {SITE.updated}.
      </p>

      <table class="facts">
        <tr><th>Mini-game</th><th>How it works</th><th>Where it shows up</th></tr>
        {minigames.map((m) => (
          <tr>
            <td>{m.name}</td>
            <td>{m.how}</td>
            <td>{m.where}</td>
          </tr>
        ))}
      </table>

      <div class="callout">
        More mini-games (Nokturna, cooking, potion-brewing) may have their own dedicated mechanics —
        see the linked guides below rather than duplicating them here.
      </div>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Related: <a href="/fishing">fishing</a>, <a href="/magic">magic</a>, <a href="/romance">romance</a>,
        <a href="/nokturna">Nokturna</a>.
      </div>
    </div>
  </article>
</Base>
