---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';

const faq = [
  { q: 'How much does the Barn cost in Moonlight Peaks?', a: 'Confirmed via the official wiki: 4,000 coins from Ridge at the Howling Hammer, after being introduced to farm animals by Luna.' },
  { q: 'How big is the Barn in Moonlight Peaks?', a: 'Confirmed: the Barn requires a 10x6 space and takes one night to build. It holds 4 animals.' },
  { q: 'Can you build more than one Barn in Moonlight Peaks?', a: 'Yes, confirmed: you can build multiple Barns, each holding 4 animals, as long as you have the required 10x6 space free for each one.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Farm', item: new URL('/farm', SITE.url).href },
    { '@type': 'ListItem', position: 3, name: 'Barn', item: new URL('/farm/barn', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Barn — Cost, Size & How to Unlock"
  description="Confirmed: the Moonlight Peaks Barn costs 4,000 coins from Ridge, needs a 10x6 space, takes one night to build, and holds 4 animals. How to unlock it via Luna and Ridge."
  path="/farm/barn"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Farm', href: '/farm' }, { label: 'Barn' }]}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Farm · Barn</p>
      <h1>The <em>Barn</em></h1>
      <p class="intro">
        Confirmed via the official wiki and cross-checked against launch-week coverage: the Barn
        can be purchased at the Howling Hammer for <strong>4,000 coins</strong>, once you've been
        introduced to farm animals by Luna.
      </p>

      <h2>How to unlock it</h2>
      <p>
        Confirmed: early in Spring of year one, Ridge appears outside your door commenting on your
        roof, and you separately get a note from Luna about a "Farm Animals for Sale" quest —
        visiting Luna at her farm shows you the first available animal (a Cheeken). Once your roof
        is fixed, Ridge can be found at the Howling Hammer (open 6 PM–midnight); select Shop, then
        the second tab, to find the Barn for purchase.
      </p>

      <h2>Size, cost, and capacity</h2>
      <table class="facts">
        <tr><th>Cost</th><td>4,000 coins</td></tr>
        <tr><th>Space required</th><td>10x6</td></tr>
        <tr><th>Build time</th><td>1 night</td></tr>
        <tr><th>Animal capacity</th><td>4 per Barn</td></tr>
        <tr><th>Multiple Barns?</th><td>Yes — build more to house more than 4 animals</td></tr>
      </table>

      <h2>After it's built</h2>
      <p>
        Confirmed: once the Barn is built, return to Luna's farm to adopt your first animal.
        Available animals rotate daily in a small paddock next to her house, and you'll need to
        name each one yourself — the game doesn't suggest a name.
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Sourced from the official Moonlight Peaks Wiki (moonlightpeaks.wiki.gg), cross-checked
        against Bonus Action and Prima Games launch-week coverage. Related:
        <a href="/farm">Farm hub</a>, <a href="/farm/animals">animals</a>,
        <a href="/characters/ridge">Ridge</a>, <a href="/characters/luna">Luna</a>.
      </div>
    </div>
  </article>
</Base>
