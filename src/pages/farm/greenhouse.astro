---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';

const faq = [
  { q: 'What does the Greenhouse do in Moonlight Peaks?', a: 'Community-reported: it adds more protected farming space, useful once your outdoor plots are full or you want extra room for magical crops. Exact build cost, unlock requirements, and whether it changes crop growth rules are not yet independently confirmed here.' },
  { q: 'Is there an achievement for building a Greenhouse?', a: 'Yes, confirmed: "Perpetual Bloom" is awarded for building a Greenhouse. Community-reported: beyond the achievement itself, having a Greenhouse is also said to help toward several other farming-related goals, so it\u2019s worth prioritizing rather than leaving for late-game.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Farm', item: new URL('/farm', SITE.url).href },
    { '@type': 'ListItem', position: 3, name: 'Greenhouse', item: new URL('/farm/greenhouse', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Greenhouse — What's Confirmed So Far"
  description="What's confirmed about the Moonlight Peaks Greenhouse: extra protected farming space, kept honest about what's still unverified rather than guessed at."
  path="/farm/greenhouse"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Farm', href: '/farm' }, { label: 'Greenhouse' }]}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Farm · Greenhouse</p>
      <h1>The <em>Greenhouse</em></h1>
      <p class="intro">
        Community-reported: the Greenhouse is a farm expansion that adds extra protected farming
        space, useful once your existing plots are full. Beyond that, we don't yet have independently
        confirmed detail on its build cost, unlock requirements, or exactly how it changes farming —
        so this page stays short rather than guessing.
      </p>

      <h2>What's still being verified</h2>
      <ul>
        <li>Build cost and materials required.</li>
        <li>Which quest or story beat (if any) unlocks it.</li>
        <li>Whether it changes growing seasons or protects against weather.</li>
        <li>How much farmland space it actually adds.</li>
      </ul>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        This page will expand as real Greenhouse data is confirmed. Related:
        <a href="/farm">Farm hub</a>, <a href="/farm/crops">crops</a>, <a href="/farm/house">house</a>.
      </div>
    </div>
  </article>
</Base>
