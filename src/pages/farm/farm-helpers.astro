---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';
import { farmHelpers } from '../../data/farm-helpers';

const faq = [
  { q: 'What are Farm Helpers in Moonlight Peaks?', a: `Confirmed via the official wiki: Farm Helpers are machines that automate farming or process farm produce. There are ${farmHelpers.length} confirmed so far, including the Furnace, Keg, Refiner, Herb Garden, Herb Drying Rack, Mortar, Bee House, Loom, Cheese Press, Mana Extractor, Mill, Jam Maker, Firefly Sanctuary, Firefly Pollinator, Chocolatier, and Seed Sequencer.` },
  { q: 'How do you unlock the Refiner in Moonlight Peaks?', a: 'Confirmed: built at the Workbench for 20 Wood + 20 Stone. It turns raw materials like Wood, Stone, Fiber, and Dark Wood into Planks, Refined Stone, Fodder, and Hardwood Planks.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Farm', item: new URL('/farm', SITE.url).href },
    { '@type': 'ListItem', position: 3, name: 'Farm Helpers', item: new URL('/farm/farm-helpers', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Farm Helpers — All 16 Machines & Recipes"
  description="Every confirmed Moonlight Peaks Farm Helper machine: Furnace, Keg, Refiner, Bee House, Mill, Jam Maker and more, with build recipes and outputs, sourced from the official wiki."
  path="/farm/farm-helpers"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Farm', href: '/farm' }, { label: 'Farm Helpers' }]}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Farm · Machines</p>
      <h1>Farm <em>Helpers</em></h1>
      <p class="intro">
        Confirmed via the official Moonlight Peaks Wiki: Farm Helpers are machines that automate
        farming or process farm produce. {farmHelpers.length} are confirmed so far.
      </p>

      {farmHelpers.map((h) => (
        <>
          <h2>{h.name}</h2>
          <p>
            {h.desc}
            {h.buildRecipe && <> <strong>Build:</strong> {h.buildRecipe}{h.buildSource ? ` (from ${h.buildSource})` : ''}.</>}
          </p>
          {h.outputs && h.outputs.length > 0 && (
            <ul>
              {h.outputs.map((o) => (<li><strong>{o.name}:</strong> {o.recipe}</li>))}
            </ul>
          )}
        </>
      ))}

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Sourced from the official Moonlight Peaks Wiki (moonlightpeaks.wiki.gg). Related:
        <a href="/farm">Farm hub</a>, <a href="/farm/crops">crops</a>, <a href="/items/mineables">mineables</a>,
        <a href="/items/cooking">cooking</a>.
      </div>
    </div>
  </article>
</Base>
