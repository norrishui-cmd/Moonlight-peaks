---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';

const faq = [
  { q: 'How do you sell items in Moonlight Peaks?', a: 'Confirmed at launch: drop goods into Chester, the living storage chest gifted by Brook during your Town Hall registration. Items sell overnight while you sleep — there\u2019s no separate shop-counter step.' },
  { q: 'Is selling raw crops worth it?', a: 'Reported: rarely. Early players found processing (turning Blood Grapes into Blood Wine via a keg, milling crops into flour, crafting artisan goods) far more valuable than selling raw harvests.' },
  { q: 'What is the best way to make money early on?', a: 'Reported: build kegs and other processing stations early, since the economy is built around finished goods rather than raw sales. Keep a small food-crop rotation too, since cooking restores both energy and mana.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Shipping & Selling', item: new URL('/shipping', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Shipping & Selling — How Chester Works"
  description="How to sell goods in Moonlight Peaks: Chester the living storage chest, why processing beats raw selling, and the confirmed early-game money loop."
  path="/shipping"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Shipping & Selling' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entry · Economy</p>
      <h1>Moonlight Peaks <em>shipping</em> & selling</h1>
      <p class="intro">
        How money actually moves in {GAME.title} — confirmed mechanics only. Updated {SITE.updated}.
      </p>

      <h2>Chester is your shipping bin</h2>
      <p>
        Confirmed at launch: <a href="/characters/chester">Chester</a>, a living storage chest, is
        gifted to you by Mayor Brook during your first Town Hall visit. Drop finished goods into
        Chester before bed, and the sale money is waiting when you wake up — there's no manual
        shop-counter interaction needed.
      </p>

      <h2>Processing beats raw selling</h2>
      <p>
        Reported by early players: selling raw crops is rarely worth it. The real money is in
        processing — Blood Grapes into Blood Wine via a keg, milling crops into flour, and crafting
        artisan goods. Building multiple kegs early is a repeated tip, since processing is described
        as the backbone of the in-game economy.
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Related: <a href="/farming">farming</a>, <a href="/characters/chester">Chester</a>,
        <a href="/inventory">inventory</a>, <a href="/items">items</a>.
      </div>
    </div>
  </article>
</Base>
