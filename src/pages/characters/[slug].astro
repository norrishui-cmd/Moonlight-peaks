---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';
import { characters, typeLabels, typeIcons } from '../../data/characters';
import { seoPages } from '../../data/seoGraph';

const profiled = characters;

export function getStaticPaths() {
  const list = characters;
  return list.map((c, i) => ({
    params: { slug: c.id },
    props: { c, prev: list[(i - 1 + list.length) % list.length], next: list[(i + 1) % list.length] },
  }));
}

const { c, prev, next } = Astro.props;
const publishedPaths = new Set(seoPages.map((p) => p.path));
const giftsPath = `/characters/${c.id}/gifts`;
const romanceStatusPath = `/characters/${c.id}/romance-status`;
const hasGiftPage = publishedPaths.has(giftsPath);
const hasRomanceStatusPage = publishedPaths.has(romanceStatusPath);

const sameType = profiled.filter((x) => x.id !== c.id && x.type === c.type);
const fill = profiled.filter((x) => x.id !== c.id && x.type !== c.type);
const related = [...sameType, ...fill].slice(0, 3);

const url = new URL(`/characters/${c.id}`, SITE.url).href;
const imgAbs = c.img ? new URL(c.img, SITE.url).href : undefined;
const statusLabel =
  c.status === 'confirmed'
    ? 'Developer-confirmed'
    : c.status === 'reported'
      ? 'Reported from previews or coverage; independent verification ongoing'
      : c.status === 'datamined'
        ? 'Datamined - name verified via pre-launch game files, role still unconfirmed'
        : 'Unconfirmed - portrait shown, name and role still not independently verified';

const familyMap: Record<string, string> = { vampire: '/families/vampires', werewolf: '/families/werewolves', witch: '/families/witches', other: '/families' };
const familyHref = familyMap[c.type] || '/families';
const familyLabel = c.type === 'other' ? 'the seven families' : `${typeLabels[c.type].toLowerCase()} family`;

// Death-specific FAQ, built only for his page from real, sourced facts — not a generic
// per-character FAQ pattern, so this doesn't get duplicated across other profiles.
const deathFaq = c.id === 'death' ? [
  { q: 'Where do you find Death in Moonlight Peaks?', a: 'Confirmed: Death lives at "Death\u2019s Shack," in the Ambrosia Graveyard within the Misty Shores area.' },
  { q: 'Why is Death not appearing for me?', a: 'Confirmed: Misty Shores and the Ambrosia Graveyard are locked until you finish the "A Bridge Too Far" quest. If Death isn\u2019t showing up, the most likely reason is that this quest — not a missed dialogue or wrong time of night — isn\u2019t finished yet.' },
  { q: 'Does Death appear immediately once Misty Shores unlocks?', a: 'Confirmed: you meet him twice as part of an unlock sequence, before he gives you the bug net — so a single visit right after unlocking the area may not be the full interaction. Exact timing or triggers for each of the two meetings are not detailed in our current sources.' },
  { q: 'Can you romance Death?', a: 'Yes, confirmed — Death is a romance option, no longer just pre-launch rumor as it once was.' },
] : [];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Characters', item: new URL('/characters', SITE.url).href },
    { '@type': 'ListItem', position: 3, name: c.name, item: url },
  ] },
  { '@context': 'https://schema.org', '@type': 'Person', name: c.name, description: c.desc, ...(imgAbs ? { image: imgAbs } : {}) },
  ...(deathFaq.length > 0 ? [{ '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: deathFaq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) }] : []),
];
---
<Base
  title={`${c.name} - Moonlight Peaks Character Guide`}
  description={`${c.name} in Moonlight Peaks: ${c.desc} Family, romance status, and what we know so far.`}
  path={`/characters/${c.id}`}
  jsonLd={jsonLd}
  ogImage={c.img}
  crumbs={[{ label: 'Characters', href: '/characters' }, { label: c.name }]}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Character - {typeLabels[c.type]}</p>

      <div class="chead">
        <div class="cavatar">
          {c.img ? (
            <img src={c.img} alt={`${c.name} - Moonlight Peaks character portrait`} width="160" height="160" />
          ) : (
            <svg viewBox="0 0 160 160" width="160" height="160" aria-hidden="true">
              <defs><linearGradient id={`g-${c.id}`} x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color={c.c1} /><stop offset="1" stop-color={c.c2} /></linearGradient></defs>
              <rect width="160" height="160" fill={`url(#g-${c.id})`} />
              {typeIcons[c.type] ? (
                <g transform="translate(24,24) scale(1.12)" fill="rgba(255,255,255,0.92)" stroke="rgba(255,255,255,0.92)" set:html={typeIcons[c.type]} />
              ) : (
                <text x="80" y="104" text-anchor="middle" font-family="Fraunces, serif" font-size="68" fill="rgba(255,255,255,0.9)">{c.name.charAt(0)}</text>
              )}
            </svg>
          )}
        </div>
        <div class="cmeta">
          <h1>{c.name}</h1>
          <div class="ctags">
            <span class={`cbadge ${c.status === 'confirmed' ? 'is-conf' : c.status === 'reported' ? 'is-rep' : c.status === 'datamined' ? 'is-dm' : 'is-unc'}`}>{c.status}</span>
            <a class="ctag fam" href={familyHref}>{typeLabels[c.type]}</a>
            {c.family !== 'Unknown' && c.family !== typeLabels[c.type] && <span class="ctag fam">{c.family}</span>}
            {c.romanceable === true && <span class="ctag heart">Heart: Romanceable</span>}
            {c.romanceable === false && <span class="ctag">Not romanceable</span>}
            {c.romanceable === null && <span class="ctag">Romance: TBC</span>}
          </div>
          <p class="cdesc">{c.desc}</p>
        </div>
      </div>

      <h2>What we know</h2>
      {c.knownInfo && c.knownInfo.length > 0 ? (
        <ul>{c.knownInfo.map((k) => (<li>{k}</li>))}</ul>
      ) : (
        <p>Details are still limited post-launch. We expand this profile as more is verified against the live game.</p>
      )}

      <h2>Romance</h2>
      <p>
        {c.romanceable === true && `${c.name} is a romance option.`}
        {c.romanceable === false && `${c.name} is not a romance option.`}
        {c.romanceable === null && `Whether ${c.name} can be romanced is currently unverified — we update this page as soon as it's confirmed.`}
        {c.romanceable === true && (c.lovedGifts?.length || c.likedGifts?.length) ? ` Confirmed gift data is available.` : (c.romanceable === true ? ` Gift preferences are added here once verified against the live game.` : '')}
      </p>
      {(hasGiftPage || hasRomanceStatusPage) && (
        <p class="cnote">
          {hasRomanceStatusPage && <a href={romanceStatusPath}>Full romance-status breakdown</a>}
          {hasRomanceStatusPage && hasGiftPage && ' · '}
          {hasGiftPage && <a href={giftsPath}>{c.name}'s gift guide</a>}
        </p>
      )}

      {c.id === 'death' && (
        <>
          <h2>Where to find Death</h2>
          <p>
            Confirmed: Death lives at "Death's Shack," located in the Ambrosia Graveyard within
            the Misty Shores area.
          </p>

          <h2>Why Death is not appearing</h2>
          <p>
            Confirmed: Misty Shores and the Ambrosia Graveyard are both locked areas until you
            finish the <a href="/quests/a-bridge-too-far">"A Bridge Too Far" quest</a>. If you've
            explored where you think his shack should be and found nothing, this quest — not a
            missed dialogue option or a specific time of night — is almost always the real reason.
          </p>

          <h2>How to unlock the relevant area</h2>
          <p>
            See the full <a href="/quests/a-bridge-too-far">A Bridge Too Far quest guide</a> for
            prerequisites and steps. Finishing it reopens the Ambrosia Estate and the wider Misty
            Shores area, including both the graveyard where Death is found and the
            <a href="/locations/mines">Cave of Echoes mine</a>.
          </p>

          <h2>How A Bridge Too Far relates to progression</h2>
          <p>
            Confirmed: this single quest is the shared gate behind Death, the Cave of Echoes, and
            the rest of Misty Shores — they all open together once it resolves, rather than
            unlocking separately or in a different order.
          </p>

          <h2>Does Death appear immediately?</h2>
          <p>
            Confirmed: you meet him twice as part of an unlock sequence before he gives you the bug
            net, so don't expect the full interaction on a single first visit right after Misty
            Shores opens. The exact trigger or timing for the second meeting isn't detailed in our
            current sources — if you've met him once and he's not reappearing, this is more likely
            expected pacing than a bug.
          </p>

          <h2>Common problems when looking for Death</h2>
          <ul>
            <li><strong>Can't find Misty Shores at all:</strong> confirm "A Bridge Too Far" is
              actually finished, not just started.</li>
            <li><strong>Found the graveyard but no Death:</strong> confirmed he's tied to a
              two-visit unlock sequence — try returning after progressing another night or two.</li>
            <li><strong>Got the bug net already but want to keep interacting with Death:</strong>
              not confirmed either way whether he has further content after that point.</li>
          </ul>

          <h2>Frequently asked questions</h2>
          <div class="faq">
            {deathFaq.map((f) => (
              <details>
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))}
          </div>
        </>
      )}

      {((c.lovedGifts?.length || c.likedGifts?.length || c.dislikedGifts?.length || c.birthday)) && (
        <>
          <h2>Gifts</h2>
          <p class="cnote">
            {c.giftStatus === 'confirmed' ? 'Verified in the live game.' : 'Reported / not yet fully verified - check back as we confirm.'}
          </p>
          {c.birthday && <p><strong>Birthday:</strong> {c.birthday}</p>}
          {c.lovedGifts && c.lovedGifts.length > 0 && (<p><strong>Loved:</strong> {c.lovedGifts.join(', ')}</p>)}
          {c.likedGifts && c.likedGifts.length > 0 && (<p><strong>Liked:</strong> {c.likedGifts.join(', ')}</p>)}
          {c.dislikedGifts && c.dislikedGifts.length > 0 && (<p><strong>Disliked:</strong> {c.dislikedGifts.join(', ')}</p>)}
        </>
      )}

      {c.traits.length > 0 && (
        <>
          <h2>Personality read</h2>
          <p class="cnote">Illustrative personality traits (not in-game combat stats) - Moonlight Peaks has no combat. Updated as confirmed detail becomes available.</p>
          <div class="ctraits">
            {c.traits.map((t) => (
              <div class="ctrait"><span class="ctrait-l">{t[0]}</span><span class="cbar"><i style={`width:${t[1]}%`}></i></span></div>
            ))}
          </div>
        </>
      )}

      <div class="callout">
        <strong>Accuracy:</strong> {statusLabel}. We mark what is developer-confirmed vs reported from previews, and never invent gift tables or stats. This page is updated as more is verified against the live game.
      </div>

      <h2>Related residents</h2>
      <ul class="rel-list">
        {related.map((r) => (
          <li>
            <a href={`/characters/${r.id}`}>
              {r.img && <img src={r.img} alt={`${r.name} - Moonlight Peaks`} width="48" height="48" loading="lazy" />}
              <span class="rel-body"><span class="rel-name">{r.name}</span><span class="rel-tag">{typeLabels[r.type]}</span></span>
            </a>
          </li>
        ))}
      </ul>

      <nav class="prevnext" aria-label="Character navigation">
        <a href={`/characters/${prev.id}`}>Prev: {prev.name}</a>
        <a href="/characters">All characters</a>
        <a href={`/characters/${next.id}`}>Next: {next.name}</a>
      </nav>

      <div class="callout">
        More: <a href={familyHref}>{familyLabel}</a> - <a href="/families">all families</a> -
        <a href="/romance">romance</a> - <a href="/characters">all characters</a> - <a href="/beginner-guide">beginner guide</a>.
      </div>
    </div>
  </article>

  <style>
    .chead { display: flex; gap: 18px; align-items: flex-start; flex-wrap: wrap; margin: 4px 0 8px; }
    .cavatar { flex: 0 0 auto; width: 160px; height: 160px; border-radius: 18px; overflow: hidden; border: 1px solid var(--line); }
    .cavatar img, .cavatar svg { width: 100%; height: 100%; object-fit: cover; display: block; }
    .cmeta { flex: 1; min-width: 240px; }
    .cmeta h1 { margin: 0 0 8px; }
    .ctags { display: flex; gap: 6px; flex-wrap: wrap; margin: 0 0 10px; }
    .cbadge { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.04em; text-transform: uppercase; border-radius: 5px; padding: 2px 6px; }
    .cbadge.is-conf { color: #9be6b4; border: 1px solid #2f6a45; }
    .cbadge.is-rep { color: var(--faint); border: 1px solid var(--line); }
    .cbadge.is-dm { color: #9ac6e0; border: 1px solid #2f5a70; }
    .cbadge.is-unc { color: #7c6e90; border: 1px dashed var(--line); }
    .ctag { font-family: var(--mono); font-size: 0.66rem; color: var(--candle); border: 1px solid var(--candle-dim); border-radius: 6px; padding: 2px 7px; }
    a.ctag.fam { color: #cbb4f0; border-color: #5a4a7a; text-decoration: none; }
    a.ctag.fam:hover { border-color: #cbb4f0; }
    .ctag.fam { color: #cbb4f0; border-color: #5a4a7a; }
    .ctag.heart { color: var(--wine); border-color: #7a2f45; }
    .cdesc { color: #ded3e6; margin: 0; }
    .cnote { font-size: 0.74rem; color: var(--faint); margin: 0 0 8px; }
    .ctraits { display: grid; gap: 6px; max-width: 420px; }
    .ctrait { display: grid; grid-template-columns: 90px 1fr; align-items: center; gap: 8px; font-size: 0.78rem; color: var(--muted); }
    .cbar { height: 7px; border-radius: 99px; background: var(--ink-2); overflow: hidden; }
    .cbar > i { display: block; height: 100%; border-radius: 99px; background: linear-gradient(90deg, var(--wine), var(--candle)); }
    .rel-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 8px; }
    @media (min-width: 560px) { .rel-list { grid-template-columns: 1fr 1fr 1fr; } }
    .rel-list a { display: flex; align-items: center; gap: 10px; border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 8px 10px; }
    .rel-list a:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); }
    .rel-list img { border-radius: 8px; }
    .rel-body { display: flex; flex-direction: column; }
    .rel-name { font-family: var(--display); font-weight: 600; color: var(--mist); font-size: 0.95rem; }
    .rel-tag { font-family: var(--mono); font-size: 0.62rem; color: var(--faint); text-transform: uppercase; }
    .prevnext { display: flex; justify-content: space-between; gap: 10px; margin: 18px 0 0; font-family: var(--mono); font-size: 0.8rem; }
    .prevnext a { color: var(--candle); }
  </style>
</Base>

