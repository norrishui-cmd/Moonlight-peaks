---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Tools', item: new URL('/tools', SITE.url).href },
      { '@type': 'ListItem', position: 3, name: 'Platform Picker', item: new URL('/tools/platform-picker', SITE.url).href },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Moonlight Peaks Platform Picker',
    applicationCategory: 'GameApplication',
    operatingSystem: 'Web',
    url: new URL('/tools/platform-picker', SITE.url).href,
    description: 'A Moonlight Peaks platform picker for Steam, Steam Deck, Nintendo Switch, Switch 2, and Android launch planning.',
  },
];
---
<Base
  title="Moonlight Peaks Platform Picker - Steam, Switch 2, Steam Deck or Android? | Moonlight Peaks Wiki & Guide"
  description="Use this Moonlight Peaks platform picker to decide whether Steam, Steam Deck, Nintendo Switch, Switch 2, or Android is the best launch option for you."
  path="/tools/platform-picker"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Tools', href: '/tools' }, { label: 'Platform Picker' }]}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Tool / Platform picker</p>
      <h1>Moonlight Peaks <em>platform picker</em></h1>
      <p class="intro">
        Not sure where to play {GAME.title}? Choose the things you care about and this tool will recommend a launch platform using confirmed platform data,
        demo availability, and conservative pre-launch assumptions.
      </p>

      <section class="picker-shell" data-platform-picker>
        <div class="picker-panel">
          <h2>Your priorities</h2>
          <label>
            <span>Main way you want to play</span>
            <select data-field="playstyle">
              <option value="desk">At a desk or laptop</option>
              <option value="handheld">Mostly handheld</option>
              <option value="tv">On a TV or couch</option>
              <option value="mobile">On a phone or mobile device</option>
            </select>
          </label>
          <fieldset>
            <legend>What matters most?</legend>
            <label><input type="checkbox" value="demo" checked /> I want the easiest demo access</label>
            <label><input type="checkbox" value="performance" /> I care about performance and patches</label>
            <label><input type="checkbox" value="portable" /> I want portable play</label>
            <label><input type="checkbox" value="lowest-price" /> I want the lowest likely launch price</label>
            <label><input type="checkbox" value="controller" /> I prefer controller / couch controls</label>
          </fieldset>
        </div>

        <div class="picker-result" aria-live="polite">
          <span class="result-kicker">Recommended</span>
          <h2 data-result-title>Steam</h2>
          <p data-result-copy>Steam is the safest default if you want fast updates, PC/Mac access, and the broadest demo path before launch.</p>
          <div class="score-list" data-score-list></div>
          <a class="btn btn-primary" data-result-link href="/platforms">Open platform guide</a>
        </div>
      </section>

      <h2>Platform facts used by this picker</h2>
      <table class="facts">
        <tr><th>Release date</th><td>{GAME.releaseLabel}</td></tr>
        <tr><th>Confirmed platforms</th><td>{GAME.platforms.join(', ')}</td></tr>
        <tr><th>Demo</th><td>{GAME.demo}</td></tr>
        <tr><th>Price</th><td>{GAME.price}; Switch 2 edition is expected to be higher.</td></tr>
      </table>

      <div class="callout">
        This is a planning tool, not a performance benchmark. Final Steam Deck verification, Android requirements, and Switch performance should be checked again at launch.
      </div>
    </div>
  </article>

  <script>
    const tools = document.querySelector('[data-platform-picker]');
    if (tools) {
      const platforms = [
        {
          id: 'steam',
          title: 'Steam',
          href: '/platforms',
          copy: 'Steam is the safest default if you want fast updates, PC/Mac access, and the broadest demo path before launch.',
          weights: { desk: 5, handheld: 1, tv: 1, mobile: 0, demo: 3, performance: 3, portable: 0, 'lowest-price': 2, controller: 1 },
        },
        {
          id: 'steam-deck',
          title: 'Steam Deck',
          href: '/platforms/steam-deck',
          copy: 'Steam Deck is the best fit if you want portable play while staying in the Steam ecosystem.',
          weights: { desk: 1, handheld: 5, tv: 1, mobile: 0, demo: 2, performance: 2, portable: 4, 'lowest-price': 1, controller: 2 },
        },
        {
          id: 'switch-2',
          title: 'Nintendo Switch 2',
          href: '/platforms/switch-2',
          copy: 'Switch 2 is the best console-style pick if you want a native newer Nintendo version and couch-friendly play.',
          weights: { desk: 0, handheld: 4, tv: 5, mobile: 0, demo: 2, performance: 3, portable: 4, 'lowest-price': 0, controller: 4 },
        },
        {
          id: 'switch',
          title: 'Nintendo Switch',
          href: '/platforms',
          copy: 'Nintendo Switch is a good fit if you already own the console and want portable or TV play without using a PC.',
          weights: { desk: 0, handheld: 4, tv: 4, mobile: 0, demo: 2, performance: 0, portable: 4, 'lowest-price': 1, controller: 4 },
        },
        {
          id: 'android',
          title: 'Android / Google Play',
          href: '/platforms/android',
          copy: 'Android is the pick for mobile-first players, but device requirements and controls should be confirmed at launch.',
          weights: { desk: 0, handheld: 2, tv: 0, mobile: 5, demo: 0, performance: 0, portable: 4, 'lowest-price': 1, controller: 0 },
        },
      ];

      const playstyle = tools.querySelector('[data-field="playstyle"]');
      const checks = [...tools.querySelectorAll('input[type="checkbox"]')];
      const resultTitle = tools.querySelector('[data-result-title]');
      const resultCopy = tools.querySelector('[data-result-copy]');
      const resultLink = tools.querySelector('[data-result-link]');
      const scoreList = tools.querySelector('[data-score-list]');

      const render = () => {
        const selected = [playstyle.value, ...checks.filter((item) => item.checked).map((item) => item.value)];
        const scored = platforms
          .map((platform) => ({
            ...platform,
            score: selected.reduce((sum, key) => sum + (platform.weights[key] || 0), 0),
          }))
          .sort((a, b) => b.score - a.score);
        const best = scored[0];
        resultTitle.textContent = best.title;
        resultCopy.textContent = best.copy;
        resultLink.href = best.href;
        scoreList.innerHTML = scored
          .map((item) => `<div><span>${item.title}</span><strong>${item.score}</strong></div>`)
          .join('');
      };

      playstyle.addEventListener('change', render);
      checks.forEach((item) => item.addEventListener('change', render));
      render();
    }
  </script>

  <style>
    .picker-shell { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 0.9fr); gap: 18px; margin-top: 28px; align-items: stretch; }
    @media (max-width: 820px) { .picker-shell { grid-template-columns: 1fr; } }
    .picker-panel, .picker-result { border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); padding: 18px; }
    .picker-panel h2, .picker-result h2 { margin-top: 0; }
    .picker-panel label span, .picker-panel legend { display: block; color: var(--mist); font-weight: 600; margin-bottom: 8px; }
    .picker-panel select {
      width: 100%;
      min-height: 44px;
      color: var(--mist);
      background: var(--ink);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 0 12px;
      font: inherit;
    }
    .picker-panel fieldset { border: 0; padding: 0; margin: 22px 0 0; display: grid; gap: 10px; }
    .picker-panel fieldset label { display: flex; gap: 10px; align-items: flex-start; color: var(--muted); }
    .picker-panel input { accent-color: var(--candle); margin-top: 5px; }
    .result-kicker { font-family: var(--mono); font-size: 0.7rem; color: var(--candle); text-transform: uppercase; letter-spacing: 0.12em; }
    .score-list { display: grid; gap: 8px; margin: 18px 0; }
    .score-list div { display: flex; justify-content: space-between; gap: 12px; border-bottom: 1px solid var(--line); padding-bottom: 7px; color: var(--muted); }
    .score-list strong { color: var(--candle); font-family: var(--mono); }
  </style>
</Base>
