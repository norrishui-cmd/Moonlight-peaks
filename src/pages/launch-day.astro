---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';

const rows = [
  ['Start here', 'Check release timing, demo access, platform choice, system requirements, and supported languages before installing.'],
  ['First session', 'Create your vampire, test controls, check readability, learn the night loop, and avoid rushing unverified money or gift routes.'],
  ['Data to verify', 'Crops, fish, gifts, schedules, shop prices, quests, saves, performance, and any launch bugs.'],
  ['Safe update policy', 'Only add values once they are visible in the live game, official notes, store pages, or reliable neutral coverage.'],
];

const checklist = [
  { label: 'Release date', href: '/release-date', note: 'Launch timing, price, platforms, and demo status.' },
  { label: 'Demo guide', href: '/demo', note: 'What to test before buying or starting fresh.' },
  { label: 'System requirements', href: '/system-requirements', note: 'PC, Mac, and Steam Deck checks.' },
  { label: 'Languages', href: '/languages', note: 'Japanese, Chinese, Korean, German, and English support.' },
  { label: 'Known issues', href: '/known-issues', note: 'Launch bug tracker and verification notes.' },
  { label: 'Best settings', href: '/best-settings', note: 'PC, Steam Deck, Switch, and Mac settings checklist.' },
  { label: 'Beginner guide', href: '/beginner-guide', note: 'First-night priorities and safe early goals.' },
  { label: 'Characters', href: '/characters', note: 'Residents, romance status, and launch verification.' },
];

const faq = [
  {
    q: 'What should I check first on Moonlight Peaks launch day?',
    a: 'Start with release timing, platform, system requirements, language support, known issues, and the beginner guide before chasing detailed item or gift tables.',
  },
  {
    q: 'Will launch-day data be complete immediately?',
    a: 'No. Exact values such as crops, gifts, schedules, shop prices, quests, and performance notes should be added only after the live game confirms them.',
  },
  {
    q: 'Should I still play the demo after launch?',
    a: 'Yes if you are unsure about controls, tone, readability, or performance on your device. The demo remains useful as a quick comfort check.',
  },
  {
    q: 'Where will bugs and performance notes go?',
    a: 'Use the known issues page for crashes, save problems, controller issues, Steam Deck notes, Switch performance, and other launch-week problems.',
  },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Launch day', item: new URL('/launch-day', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })) },
  { '@context': 'https://schema.org', '@type': 'ItemList', itemListElement: checklist.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    url: new URL(item.href, SITE.url).href,
  })) },
];
---
<Base
  title="Moonlight Peaks Launch Day Guide - What to Check First"
  description="Moonlight Peaks launch day hub for release timing, demo, system requirements, languages, known issues, best settings, beginner tips, and safe data updates."
  path="/launch-day"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Launch day' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Launch / Day one</p>
      <h1>Moonlight Peaks <em>launch day</em> guide</h1>
      <p class="intro">
        The day-one hub for {GAME.title}: what to check before installing, where verified data will
        land, and how to avoid thin or guessed launch information.
      </p>

      <div class="callout">
        <strong>Release timing:</strong> {GAME.releaseNote}
      </div>

      <h2>Launch-day map</h2>
      <table class="facts">
        {rows.map((row) => (<tr><th>{row[0]}</th><td>{row[1]}</td></tr>))}
      </table>

      <h2>Check these first</h2>
      <div class="link-grid">
        {checklist.map((item) => (
          <a href={item.href}>
            <strong>{item.label}</strong>
            <span>{item.note}</span>
          </a>
        ))}
      </div>

      <h2>What not to guess</h2>
      <p>
        Avoid publishing exact loved gifts, item prices, quest outcomes, crop profits, fish locations,
        Steam Deck ratings, or save paths until they are visible in the live game or official sources.
        Launch search traffic is valuable, but guessed tables are bad for players and risky for SEO.
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </article>

  <style>
    .link-grid { display: grid; grid-template-columns: 1fr; gap: 10px; margin-top: 10px; }
    @media (min-width: 680px) { .link-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    .link-grid a { display: flex; flex-direction: column; gap: 3px; border: 1px solid var(--line); border-radius: 10px; background: var(--surface); padding: 12px 14px; text-decoration: none; }
    .link-grid strong { color: var(--mist); font-family: var(--display); }
    .link-grid span { color: var(--muted); font-size: 0.84rem; }
    .link-grid a:hover { border-color: color-mix(in srgb, var(--candle) 55%, var(--line)); }
  </style>
</Base>
