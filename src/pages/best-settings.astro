---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';

const settingsRows = [
  ['PC', 'Confirmed accessibility/graphics options: vsync toggle, controller vibration toggle, on-screen interaction labels, text animation toggle, rebindable keys, framerate lock, and render scale. One real reported quirk: graphics settings (including resolution) save into your cloud save file, so switching between a Steam Deck and a desktop monitor means readjusting each time.'],
  ['Mac', 'Runs via the same Steam build as Windows; check current Steam system requirements for your specific Mac hardware.'],
  ['Steam Deck', 'Confirmed Verified on Steam with a Gold rating on ProtonDB. One in-depth review reported the game can struggle to hold 60FPS with TDP uncapped, and recommends locking the refresh rate to 50Hz for a smoother, more battery-friendly experience.'],
  ['Nintendo Switch / Switch 2', 'Full controller support out of the box; reviewers found the Switch 2 version ran exceptionally well in portable mode. See our Switch guide for edition-specific differences.'],
  ['Camera & UI comfort (any platform)', 'Real player-reported quirk: the default camera sits quite close/zoomed-in, which some PC players on a large monitor found uncomfortable (motion-sickness-adjacent) compared to Steam Deck or Switch, where the same zoom level feels natural on a smaller screen.'],
];

const testingSteps = [
  'Check your accessibility needs first: confirmed options are vibration, interaction labels, text animation, and rebindable keys \u2014 there is no confirmed colorblind mode.',
  'On Steam Deck, try locking the refresh rate to 50Hz if you\u2019re seeing framerate dips with TDP uncapped.',
  'If playing on a PC monitor and the default camera zoom feels too close, try windowed mode, which several players found more comfortable.',
  'Expect to redo your graphics settings after switching devices \u2014 they\u2019re saved in the cloud save file, not per-device.',
  'Test controller vs. keyboard+mouse early: multiple players reported the game leans controller-first, with mouse input underused in the default keyboard scheme.',
];

const faq = [
  {
    q: 'What are the best Moonlight Peaks settings?',
    a: 'On Steam Deck, try a locked 50Hz refresh rate if you see framerate dips. On a PC monitor, windowed mode can help if the default camera zoom feels too close. Note that graphics settings save into your cloud save, so expect to readjust after switching devices.',
  },
  {
    q: 'What are the best Steam Deck settings for Moonlight Peaks?',
    a: 'Confirmed: the game is Steam Deck Verified with a ProtonDB Gold rating and has full controller support out of the box. One in-depth review found it can struggle to hit 60FPS with TDP uncapped, and recommends a locked 50Hz refresh rate for smoother, more battery-friendly play.',
  },
  {
    q: 'Should I use controller or keyboard?',
    a: 'Controller is the more natural fit \u2014 multiple players reported the default keyboard+mouse scheme leaves the mouse mostly unused, requiring the keyboard hand to do most of the work. Full controller support works well on PC, Steam Deck, and Switch alike.',
  },
  {
    q: 'Does Moonlight Peaks have accessibility settings?',
    a: 'Some: confirmed options are vsync, controller vibration, on-screen interaction labels, text animation, rebindable keys, a framerate lock, and render scale. Not confirmed: no colorblind mode or dyslexia-friendly text option has been reported.',
  },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Best settings', item: new URL('/best-settings', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })) },
  {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to choose Moonlight Peaks settings safely at launch',
    description: 'A launch-safe settings checklist for Moonlight Peaks on PC, Mac, Steam Deck, Switch, and Switch 2.',
    step: testingSteps.map((text, index) => ({
      '@type': 'HowToStep',
      position: index + 1,
      text,
    })),
  },
];
---
<Base
  title="Moonlight Peaks Best Settings - PC, Steam Deck, Switch & Mac"
  description="Moonlight Peaks best settings guide for PC, Mac, Steam Deck, Switch, Switch 2, controller comfort, readability, demo testing, and launch updates."
  path="/best-settings"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Best settings' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Launch / Best settings</p>
      <h1>Moonlight Peaks <em>best settings</em></h1>
      <p class="intro">
        Real, confirmed settings and accessibility options for {GAME.title} across PC, Mac, Steam
        Deck, and Switch/Switch 2, plus a few platform quirks reported by players since launch.
      </p>

      <div class="callout">
        <strong>No fake benchmarks:</strong> exact FPS, graphics presets, battery life, and platform
        performance notes should be added only after launch testing or reliable source confirmation.
      </div>

      <h2>Platform checklist</h2>
      <table class="facts">
        {settingsRows.map((row) => (<tr><th>{row[0]}</th><td>{row[1]}</td></tr>))}
      </table>

      <h2>What to test first</h2>
      <ol>
        {testingSteps.map((step) => (<li>{step}</li>))}
      </ol>

      <h2>Related pages</h2>
      <div class="link-grid">
        <a href="/demo">Demo guide</a>
        <a href="/system-requirements">System requirements</a>
        <a href="/known-issues">Known issues</a>
        <a href="/platforms">Platforms</a>
        <a href="/platforms/steam-deck">Steam Deck</a>
        <a href="/launch-day">Launch day hub</a>
      </div>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </article>

  <style>
    .link-grid { display: grid; grid-template-columns: 1fr; gap: 10px; margin-top: 10px; }
    @media (min-width: 640px) { .link-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    .link-grid a { border: 1px solid var(--line); border-radius: 10px; background: var(--surface); color: var(--mist); padding: 12px 14px; text-decoration: none; }
    .link-grid a:hover { border-color: color-mix(in srgb, var(--candle) 55%, var(--line)); }
  </style>
</Base>
