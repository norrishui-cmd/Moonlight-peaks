---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';
import News from '../components/News.astro';

// Confirmed quest names sourced from launch-week walkthroughs (Neoseeker, Bonus Action, Into Indie
// Games). Full step lists live on those sites; here we map names, unlock conditions, and rewards.
const quests = [
  { name: 'Register at Town Hall', giver: 'Story (setup)', unlocks: 'Meeting Brook, receiving Chester', status: 'confirmed' },
  { name: 'Meet the Townsfolk', giver: 'Story (setup)', unlocks: 'Opens early town routes', status: 'confirmed' },
  { name: "Orlock's Wine Scheme (Blood Wine)", giver: 'Orlock', unlocks: 'Make Blood Wine; apologize to Orlock, pay a 350-gold debt to Samael; leads toward A Bridge Too Far', status: 'confirmed' },
  { name: 'A Bridge Too Far', giver: 'Story (Orlock/Fiona feud)', unlocks: 'Reopens Ambrosia Estate; unlocks Misty Shores & Cave of Echoes (copper)', status: 'confirmed' },
  { name: 'Tension in the Crest Garden', giver: 'Story', unlocks: 'Requires A Bridge Too Far + 1 day; leads to A Croak and a Crest', status: 'confirmed' },
  { name: 'A Croak and a Crest', giver: 'Story', unlocks: 'Part of the Hellkitten form chain', status: 'confirmed' },
  { name: 'The Dinner Party', giver: 'Story', unlocks: 'Reward: Cat (Hellkitten) form; Aquaflux spell route via Luna', status: 'confirmed' },
  { name: 'The Magic of Crops', giver: 'Story', unlocks: 'Leads into the mana questline', status: 'confirmed' },
  { name: 'A Mayor\u2019s Burden', giver: 'Story (Brook)', unlocks: 'Triggers on entering Town after The Magic of Crops', status: 'confirmed' },
  { name: 'The Quest for Mana', giver: 'Story (Sabrina\u2019s letter)', unlocks: 'Reward: Mana Essence + Mana Extractor blueprint', status: 'confirmed' },
  { name: 'Building a Mana Extractor', giver: 'Story', unlocks: 'Requires The Quest for Mana + 2 days', status: 'confirmed' },
  { name: 'The Mermaid\u2019s Wish', giver: 'Story (Hosu family)', unlocks: 'Part of the mermaid/wedding chain', status: 'confirmed' },
  { name: 'A Touch of Magic', giver: 'Story', unlocks: 'Required alongside The Mermaid\u2019s Wish before The Rehearsal Dinner triggers', status: 'confirmed' },
  { name: 'The Rehearsal Dinner', giver: 'Story (Hosu family)', unlocks: 'Requires The Mermaid\u2019s Wish + A Touch of Magic, then 1 day, then reading the dinner invitation', status: 'confirmed' },
  { name: 'Kim\u2019s Invite', giver: 'Story (Hosu family)', unlocks: 'Follows The Rehearsal Dinner', status: 'confirmed' },
  { name: 'Bride\u2019s Attendant Duty', giver: 'Story (Hosu family)', unlocks: 'Follows Kim\u2019s Invite', status: 'confirmed' },
  { name: 'Unfinished Business', giver: 'Story (Hosu family)', unlocks: 'Closes out the mermaid wedding chain', status: 'confirmed' },
  { name: 'Master of the Night', giver: 'Story', unlocks: 'Named in launch-week walkthroughs; exact trigger and reward not yet independently verified here', status: 'reported' },
  { name: 'A Key to the Deep', giver: 'Story', unlocks: 'Named in launch-week walkthroughs; exact trigger and reward not yet independently verified here', status: 'reported' },
  { name: 'Cosmic Preparations', giver: 'Story', unlocks: 'Named in launch-week walkthroughs; exact trigger and reward not yet independently verified here', status: 'reported' },
  { name: 'Elections by Moonlight', giver: 'Story', unlocks: 'Town governance storyline', status: 'confirmed' },
  { name: 'Darkness over Moonlight Peaks', giver: 'Story', unlocks: 'Main-story progression quest', status: 'confirmed' },
  { name: "Elvira's treasure hunt", giver: 'Elvira', unlocks: 'Five poetic clues (Samael\u2019s bar → graveyard → mine bell → Cave of Echoes → Khazan Temple); ties to "Raiders of the Lost Art"', status: 'confirmed' },
  { name: 'Building a treehouse with Ridge', giver: 'Ridge', unlocks: 'Tied to the "A Childhood Dream" achievement', status: 'reported' },
  { name: 'Vampster collection quest', giver: 'Alina', unlocks: 'Return 100 scattered Vampsters to their den in the Cave of Echoes, one at a time — see the full Vampsters guide', status: 'reported' },
];

const faq = [
  { q: 'How do quests work in Moonlight Peaks?', a: 'Confirmed at launch: quest markers appear on the map — an exclamation point means entering an area triggers a cutscene, and a sparkling aura around a building means going inside triggers one. The town bulletin board (Albertus\u2019 Jobs, run by an owl) also lists available jobs.' },
  { q: 'What happens if my quest log is empty?', a: 'Revisit key areas and talk to residents tied to recent story events, check the town bulletin board, and make sure you\u2019ve tried any newly unlocked spell or form — some quests gate on those rather than a visible marker.' },
  { q: 'Are there missable quests?', a: 'Not yet confirmed either way. Until verified, treat story-relevant conversations as worth revisiting rather than skipping.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Quests', item: new URL('/quests', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Quests — Named Quests & How Unlocks Work"
  description="Moonlight Peaks quest guide: confirmed named quests like A Bridge Too Far and The Dinner Party, how quest markers work, and the job board."
  path="/quests"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Quests' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entry · Quests</p>
      <h1>Moonlight Peaks <em>quests</em></h1>
      <p class="intro">
        A structured page for {GAME.title}'s quest system — filled with real confirmed quests as we
        verify them, not a guessed-at list. Updated {SITE.updated}.
      </p>

      <h2>How quests and unlocks work</h2>
      <p>
        Confirmed at launch: the map shows quest markers — an exclamation point triggers a cutscene
        when you enter that area, and a sparkling aura on a building triggers one when you go inside.
        The town's bulletin board, <a href="/characters/albertus">Albertus' Jobs</a> (run by an owl),
        lists available jobs separately from the main story quests.
      </p>

      <h2>Confirmed quests so far</h2>
      <table class="facts">
        <tr><th>Quest</th><th>Giver</th><th>Leads to</th><th>Status</th></tr>
        {quests.map((q) => (
          <tr>
            <td>{q.name}</td>
            <td>{q.giver}</td>
            <td>{q.unlocks}</td>
            <td>{q.status}</td>
          </tr>
        ))}
      </table>

      <div class="callout">
        This table grows as more quests are confirmed. We don't invent quest names, givers, or
        rewards — every row above traces to a real source.
      </div>

      <h2>Latest quest updates</h2>
      <News topic="quests" limit={5} />

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Related: <a href="/beginner-guide">beginner guide</a>, <a href="/shapeshifting">shapeshifting</a>,
        <a href="/magic">magic</a>, <a href="/characters/albertus">Albertus</a>, <a href="/achievements">achievements</a>.
        More FAQ: <a href="/faq/how-does-quest-for-mana-unlock">The Quest for Mana unlock</a>,
        <a href="/faq/how-many-townsfolk-must-you-meet-at-the-start">Meet the Townsfolk checklist</a>,
        <a href="/faq">full FAQ hub</a>.
      </div>
    </div>
  </article>
</Base>
