---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';

const faq = [
  { q: 'Can you decorate your cottage in Moonlight Peaks?', a: 'Yes — reported: you can customize your cottage interior and homestead grounds, placing and rotating furniture, and crafting decor like paths and fairy lights.' },
  { q: 'Is there a greenhouse in Moonlight Peaks?', a: 'Not yet confirmed. If a dedicated greenhouse building exists (common in the genre for off-season/weather-protected growing), we\u2019ll add it here once verified rather than assuming.' },
  { q: 'Can you upgrade your house?', a: 'Not yet fully confirmed beyond cosmetic decorating. Building upgrades like the Barn (4,000 gold, from Ridge) and the well (1,500 gold) are confirmed; a house-specific upgrade path is not yet sourced.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'House & Decorating', item: new URL('/house', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks House, Decorating & Greenhouse"
  description="Decorating your cottage in Moonlight Peaks: furniture, paths, and fairy lights confirmed so far, plus what's still unverified about a greenhouse or house upgrades."
  path="/house"
  jsonLd={jsonLd}
  crumbs={[{ label: 'House & Decorating' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entry · Home</p>
      <h1>Moonlight Peaks <em>house</em> & decorating</h1>
      <p class="intro">
        Your cottage and homestead grounds beyond farming — what's confirmed about decorating, kept
        separate from what's still unverified. Updated {SITE.updated}.
      </p>

      <h2>Decorating your cottage</h2>
      <p>
        Reported: decorating in Moonlight Peaks covers placing and rotating furniture, customizing
        your cottage interior, and crafting decor for the homestead grounds — including paths and
        fairy lights.
      </p>

      <h2>Greenhouse — not yet confirmed</h2>
      <p>
        We haven't sourced a dedicated greenhouse building yet. Many cozy sims include one for
        weather-protected or off-season growing; if Moonlight Peaks has one, we'll add it here once
        verified rather than assuming it exists.
      </p>

      <h2>Building upgrades confirmed so far</h2>
      <p>
        Two confirmed structure purchases: the <strong>Barn</strong> (4,000 gold + materials, from
        Ridge, required before buying livestock) and the <strong>well</strong> (reported at 1,500
        gold, helps with watering). A house-specific upgrade path beyond cosmetic decorating is not
        yet sourced.
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Related: <a href="/farming">farming</a>, <a href="/character-creator">character creator</a>,
        <a href="/beginner-guide">beginner guide</a>.
      </div>
    </div>
  </article>
</Base>
