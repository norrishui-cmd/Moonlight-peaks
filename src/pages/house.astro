---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';

const faq = [
  { q: 'Can you decorate your cottage in Moonlight Peaks?', a: 'Yes — reported: you can customize your cottage interior and homestead grounds, placing and rotating furniture, and crafting decor like paths and fairy lights.' },
  { q: 'Is there a greenhouse in Moonlight Peaks?', a: 'Yes, confirmed: building a Greenhouse is tied to its own achievement, "Perpetual Bloom." See our dedicated Greenhouse page for what\u2019s known so far about build cost and what it adds.' },
  { q: 'Can you upgrade your house?', a: 'Confirmed: "Dracula Estate" is the achievement for fully upgrading your house, so a house upgrade path exists beyond cosmetic decorating, though the exact tiers and costs aren\u2019t sourced yet. Building upgrades like the Barn (4,000 gold, from Ridge) and the well (1,500 gold) are also confirmed.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'House & Decorating', item: new URL('/house', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks House, Decorating & Greenhouse"
  description="Decorating your cottage in Moonlight Peaks: furniture, paths, and fairy lights confirmed so far, plus what's still unverified about a greenhouse or house upgrades."
  path="/house"
  jsonLd={jsonLd}
  crumbs={[{ label: 'House & Decorating' }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entry · Home</p>
      <h1>Moonlight Peaks <em>house</em> & decorating</h1>
      <p class="intro">
        Your cottage and homestead grounds beyond farming — what's confirmed about decorating, kept
        separate from what's still unverified. Updated {SITE.updated}.
      </p>

      <h2>Decorating your cottage</h2>
      <p>
        Reported: decorating in Moonlight Peaks covers placing and rotating furniture, customizing
        your cottage interior, and crafting decor for the homestead grounds — including paths and
        fairy lights.
      </p>

      <h2>Greenhouse — confirmed to exist</h2>
      <p>
        Confirmed: building a Greenhouse is tied to its own Steam achievement, "Perpetual Bloom."
        Community-reported: having one is also said to help toward several other farming-related
        goals, so it's worth prioritizing. See our <a href="/farm/greenhouse">Greenhouse page</a>
        for build cost and space details as they're confirmed.
      </p>

      <h2>Building upgrades confirmed so far</h2>
      <p>
        Confirmed: "Dracula Estate" is the achievement for fully upgrading your house, so a real
        upgrade path exists beyond cosmetic decorating — exact tiers and costs aren't sourced yet.
        Two other confirmed structure purchases: the <strong>Barn</strong> (4,000 gold + materials,
        from Ridge, required before buying livestock) and the <strong>well</strong> (reported at
        1,500 gold, helps with watering).
      </p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Related: <a href="/farming">farming</a>, <a href="/character-creator">character creator</a>,
        <a href="/beginner-guide">beginner guide</a>.
      </div>
    </div>
  </article>
</Base>
