---
import TopicPage from '../../components/TopicPage.astro';
import { demoSection, demo } from '../../data/demo';

export function getStaticPaths() {
  return demo.map((it, i) => ({
    params: { slug: it.slug },
    props: { item: it, prev: demo[(i - 1 + demo.length) % demo.length], next: demo[(i + 1) % demo.length] },
  }));
}
const { item, prev, next } = Astro.props;
---
<TopicPage section={demoSection} item={item} prev={prev} next={next} />
