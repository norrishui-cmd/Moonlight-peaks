---
import { SITE, GA_MEASUREMENT_ID, ADSENSE_CLIENT_ID } from '../consts';
import '../styles/global.css';
import SiteSearch from '../components/SiteSearch.astro';
import { t, type Locale } from '../i18n/nav';
import { isPathTranslated } from '../i18n/translated-paths';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
interface Crumb { label: string; href?: string; }
interface Props {
  title: string;
  description: string;
  path?: string;
  jsonLd?: object | object[];
  crumbs?: Crumb[];
  ogImage?: string;
  showExport?: boolean;
  noindex?: boolean;
  lang?: 'en' | 'es' | 'ja' | 'zh' | 'zh-hant' | 'de' | 'fr';
}
const { title, description, path = '/', jsonLd, crumbs = [], ogImage, showExport = false, noindex = false, lang = 'en' } = Astro.props;
const canonical = new URL(path, SITE.url).href;
const ogImageUrl = ogImage ? new URL(ogImage, SITE.url).href : undefined;

// hreflang alternates: strip any existing /es/ /ja/ /zh/ /zh-hant/ /de/ prefix to get the "bare"
// path, then only emit an alternate for a locale if that locale genuinely has a translation for
// this path — otherwise we'd be telling search engines a /de/... (or /es/.../ etc.) page exists
// when it doesn't. English (the source) and the current page's own locale are always included.
const barePath = path.replace(/^\/(es|ja|zh-hant|zh|de|fr)(\/|$)/, '/');
const localeUrl = (code: string) => new URL(code === 'en' ? barePath : `/${code}${barePath}`.replace(/\/$/, '') || `/${code}`, SITE.url).href;
// hreflang attribute values use proper BCP-47 casing (zh-Hant), even though the URL path segment
// itself stays lowercase (zh-hant) per usual URL convention.
const hreflangAttr: Record<string, string> = { 'zh-hant': 'zh-Hant' };
const hreflangs: { code: string; href: string }[] = [
  { code: 'en', href: localeUrl('en') },
  ...(['es', 'ja', 'zh', 'zh-hant', 'de', 'fr'] as const)
    .filter((code) => code === lang || isPathTranslated(code, barePath))
    .map((code) => ({ code: hreflangAttr[code] || code, href: localeUrl(code) })),
];
const peopleGroup = {
  label: t(lang, 'characters'),
  href: '/characters',
  children: [
    { href: '/characters', label: t(lang, 'characters') },
    { href: '/characters/customize', label: 'Customize' },
    { href: '/families', label: t(lang, 'families') },
  ],
};
const navPeople = [
  { href: '/romance', label: t(lang, 'romance') },
];
const navUtility = [
  { href: '/tools', label: t(lang, 'tools') },
  { href: '/faq', label: t(lang, 'faq') },
  { href: '/about', label: t(lang, 'about') },
];
const guideGroup = {
  label: t(lang, 'guides'),
  href: '/guides',
  children: [
    { href: '/guides', label: t(lang, 'allGuides') },
    { href: '/quests', label: t(lang, 'quests') },
    { href: '/release-date', label: t(lang, 'release') },
    { href: '/demo', label: t(lang, 'demo') },
    { href: '/platforms', label: t(lang, 'platforms') },
  ],
};
const worldGroup = {
  label: t(lang, 'world'),
  href: '/locations',
  children: [
    { href: '/locations', label: t(lang, 'locations') },
    { href: '/farm', label: t(lang, 'farm') },
    { href: '/activities', label: t(lang, 'activities') },
    { href: '/spellcasting', label: 'Spellcasting' },
    { href: '/collections', label: t(lang, 'collection') },
    { href: '/items', label: t(lang, 'items') },
    { href: '/map', label: t(lang, 'map') },
  ],
};
const here = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => here === href || (href !== '/' && here.startsWith(`${href}/`));
const isGuideGroupActive = guideGroup.children.some((c) => isActive(c.href));
const isPeopleGroupActive = peopleGroup.children.some((c) => isActive(c.href));
const isWorldGroupActive = worldGroup.children.some((c) => isActive(c.href));

// Only /  and /beginner-guide are translated so far. Every other nav target still only
// exists in English — linking to a non-existent /es/characters etc. would 404. As more
// pages get translated, add their bare English path here and links will follow automatically.
const localizedHref = (href: string): string => {
  if (lang === 'en') return href;
  if (isPathTranslated(lang as Locale, href)) return href === '/' ? `/${lang}` : `/${lang}${href}`;
  return href; // not translated yet — send to the English version rather than a 404
};
const rawLd = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const schemaAuthor = { '@type': 'Organization', name: SITE.brand, url: SITE.url };
const schemaDate = '2026-07-04';
let questionSchemaIndex = 0;

const enrichAnswer = (answer: Record<string, unknown>, index: number) => ({
  ...answer,
  author: answer.author ?? schemaAuthor,
  datePublished: answer.datePublished ?? schemaDate,
  upvoteCount: answer.upvoteCount ?? 0,
  url: answer.url ?? `${canonical}#answer-${index}`,
});

const enrichStructuredData = (value: unknown): unknown => {
  if (Array.isArray(value)) return value.map(enrichStructuredData);
  if (!value || typeof value !== 'object') return value;

  const source = value as Record<string, unknown>;
  const next = Object.fromEntries(
    Object.entries(source).map(([key, child]) => [key, enrichStructuredData(child)]),
  ) as Record<string, unknown>;

  if (next['@type'] === 'Question' && next.acceptedAnswer) {
    questionSchemaIndex += 1;
    const index = questionSchemaIndex;
    const acceptedAnswer = Array.isArray(next.acceptedAnswer)
      ? next.acceptedAnswer.map((answer) => enrichAnswer(answer as Record<string, unknown>, index))
      : enrichAnswer(next.acceptedAnswer as Record<string, unknown>, index);

    return {
      ...next,
      author: next.author ?? schemaAuthor,
      datePublished: next.datePublished ?? schemaDate,
      answerCount: next.answerCount ?? (Array.isArray(acceptedAnswer) ? acceptedAnswer.length : 1),
      url: next.url ?? `${canonical}#question-${index}`,
      acceptedAnswer,
    };
  }

  return next;
};

const ld = rawLd.map(enrichStructuredData);
---
<!doctype html>
<html lang={hreflangAttr[lang] || lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonical} />
    {hreflangs.map((h) => <link rel="alternate" hreflang={h.code} href={h.href} />)}
    <link rel="alternate" hreflang="x-default" href={hreflangs[0].href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Moonlight Peaks — Articles & Guides" href="/rss.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.brand} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500;700&display=swap"
    />
    {ld.map((obj) => <script type="application/ld+json" set:html={JSON.stringify(obj)} />)}
    {ADSENSE_CLIENT_ID && <meta name="google-adsense-account" content={ADSENSE_CLIENT_ID} />}
    {ADSENSE_CLIENT_ID && (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT_ID}`}
        crossorigin="anonymous"
      />
    )}
    {GA_MEASUREMENT_ID && (
      <>
        <script
          is:inline
          set:html={`
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('consent', 'default', {
              ad_storage: 'denied',
              analytics_storage: 'denied',
              ad_user_data: 'denied',
              ad_personalization: 'denied',
            });
            try {
              if (localStorage.getItem('mp-consent') === 'granted') {
                gtag('consent', 'update', { analytics_storage: 'granted' });
              }
            } catch (e) {}
            gtag('js', new Date());
            gtag('config', '${GA_MEASUREMENT_ID}', { anonymize_ip: true });
          `}
        />
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`} />
      </>
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="wrap bar">
        <a class="brand" href={localizedHref('/')} aria-label={`${SITE.brand} home`}>
          <span class="moon" aria-hidden="true"></span>
          <span class="mark">
            <span class="mark-title">Moonlight Peaks</span>
            <span class="mark-sub">Wiki &amp; Guide</span>
          </span>
        </a>
        <button type="button" class="nav-toggle" id="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="primary-nav">
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
        </button>
        <nav class="nav" id="primary-nav" aria-label="Primary">
          <details class="nav-dd" name="primary-nav">
            <summary aria-current={isGuideGroupActive ? 'page' : undefined}>{guideGroup.label}</summary>
            <div class="nav-dd-menu">
              {guideGroup.children.map((c) => (
                <a href={localizedHref(c.href)} aria-current={isActive(c.href) ? 'page' : undefined}>{c.label}</a>
              ))}
            </div>
          </details>
          <details class="nav-dd" name="primary-nav">
            <summary aria-current={isPeopleGroupActive ? 'page' : undefined}>{peopleGroup.label}</summary>
            <div class="nav-dd-menu">
              {peopleGroup.children.map((c) => (
                <a href={localizedHref(c.href)} aria-current={isActive(c.href) ? 'page' : undefined}>{c.label}</a>
              ))}
            </div>
          </details>
          {navPeople.map((n) => (
            <a href={localizedHref(n.href)} aria-current={isActive(n.href) ? 'page' : undefined}>{n.label}</a>
          ))}
          <details class="nav-dd" name="primary-nav">
            <summary aria-current={isWorldGroupActive ? 'page' : undefined}>{worldGroup.label}</summary>
            <div class="nav-dd-menu">
              {worldGroup.children.map((c) => (
                <a href={localizedHref(c.href)} aria-current={isActive(c.href) ? 'page' : undefined}>{c.label}</a>
              ))}
            </div>
          </details>
          {navUtility.map((n) => (
            <a href={localizedHref(n.href)} aria-current={isActive(n.href) ? 'page' : undefined}>{n.label}</a>
          ))}
        </nav>
        <LanguageSwitcher lang={lang} path={path} />
        <SiteSearch />
      </div>
    </header>
    {crumbs.length > 0 && (
      <div class="wrap">
        <nav class="crumb" aria-label="Breadcrumb">
          <a href={localizedHref('/')}>{t(lang, 'home')}</a>
          {crumbs.map((c) => (
            <span>{' / '}{c.href ? <a href={c.href}>{c.label}</a> : c.label}</span>
          ))}
        </nav>
      </div>
    )}
    {showExport && (
      <div class="wrap print-hide export-pdf-row">
        <button type="button" class="export-pdf-btn" onclick="window.print()">
          Export this page to PDF
        </button>
      </div>
    )}
    <div class="print-only print-header">
      <strong>{SITE.brand}</strong>
      <span>{canonical}</span>
      <span class="print-date" data-print-date></span>
    </div>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="wrap">
        <div class="row">
          <span>{SITE.brand}</span>
          <span class="links">
            <a href={localizedHref('/characters')}>{t(lang, 'characters')}</a>
            <a href={localizedHref('/locations')}>{t(lang, 'locations')}</a>
            <a href={localizedHref('/families')}>{t(lang, 'families')}</a>
            <a href={localizedHref('/activities')}>{t(lang, 'activities')}</a>
            <a href={localizedHref('/faq')}>{t(lang, 'faq')}</a>
            <a href={localizedHref('/guides')}>{t(lang, 'guides')}</a>
            <a href={localizedHref('/tools')}>{t(lang, 'tools')}</a>
            <a href={localizedHref('/platforms')}>{t(lang, 'platforms')}</a>
            <a href={localizedHref('/compare')}>Compare</a>
            <a href={localizedHref('/about')}>{t(lang, 'about')}</a>
            <a href={localizedHref('/privacy')}>Privacy</a>
            <span>Updated {SITE.updated}</span>
          </span>
        </div>
        <p class="disclaimer">
          {SITE.brand} is an independent, fan-made guide. It is not affiliated
          with, endorsed by, or connected to Little Chicken Game Company or XSEED Games. “Moonlight
          Peaks” and all related names and assets are trademarks of their respective owners.
        </p>
      </div>
    </footer>
    {GA_MEASUREMENT_ID && (
      <div id="cookie-consent" class="cookie-consent" hidden role="dialog" aria-label="Cookie consent">
        <p>
          We use privacy-friendly analytics (Google Analytics) to see which guides help most.
          Nothing is stored until you accept. See our <a href="/privacy">privacy page</a>.
        </p>
        <div class="cookie-consent-actions">
          <button type="button" id="cookie-decline" class="cc-btn cc-decline">Decline</button>
          <button type="button" id="cookie-accept" class="cc-btn cc-accept">Accept</button>
        </div>
      </div>
    )}
    <script>
      document.querySelectorAll('[data-print-date]').forEach((el) => {
        el.textContent = 'Exported ' + new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
      });
    </script>
    <script is:inline>
      (function () {
        var toggle = document.getElementById('nav-toggle');
        var nav = document.getElementById('primary-nav');
        if (!toggle || !nav) return;
        function closeMenu() {
          nav.classList.remove('nav-open');
          toggle.setAttribute('aria-expanded', 'false');
        }
        function openMenu() {
          nav.classList.add('nav-open');
          toggle.setAttribute('aria-expanded', 'true');
        }
        toggle.addEventListener('click', function () {
          if (nav.classList.contains('nav-open')) { closeMenu(); } else { openMenu(); }
        });
        // Close the mobile menu after navigating to a plain link (not a dropdown summary toggle).
        nav.querySelectorAll('a').forEach(function (a) {
          a.addEventListener('click', closeMenu);
        });
      })();
    </script>
    <script is:inline>
      (function () {
        // --header-height caps the open mobile nav panel's max-height (100vh - header-height) so
        // it never overflows the viewport. IMPORTANT: only measure while the nav is CLOSED —
        // .nav lives inside .site-header, so the header's own height grows once the nav panel
        // opens. Watching the header continuously (e.g. with ResizeObserver) would measure that
        // taller open state, feed a bigger --header-height back into the nav's own max-height
        // calc, which changes the nav's size, which changes the header's size again — an
        // infinite feedback loop that looks like the page jittering/shaking.
        var header = document.querySelector('.site-header');
        var nav = document.getElementById('primary-nav');
        if (!header) return;
        function setHeaderHeight() {
          if (nav && nav.classList.contains('nav-open')) return; // never measure while open
          document.documentElement.style.setProperty('--header-height', header.offsetHeight + 'px');
        }
        setHeaderHeight();
        window.addEventListener('resize', setHeaderHeight);
        window.addEventListener('orientationchange', setHeaderHeight);
      })();
    </script>
    {GA_MEASUREMENT_ID && (
      <script is:inline set:html={`
        (function () {
          var banner = document.getElementById('cookie-consent');
          if (!banner) return;
          var stored;
          try { stored = localStorage.getItem('mp-consent'); } catch (e) { stored = null; }
          if (stored !== 'granted' && stored !== 'denied') { banner.hidden = false; }
          function choose(v) {
            try { localStorage.setItem('mp-consent', v); } catch (e) {}
            if (v === 'granted' && typeof gtag === 'function') {
              gtag('consent', 'update', { analytics_storage: 'granted' });
            }
            banner.hidden = true;
          }
          var a = document.getElementById('cookie-accept');
          var d = document.getElementById('cookie-decline');
          if (a) a.addEventListener('click', function () { choose('granted'); });
          if (d) d.addEventListener('click', function () { choose('denied'); });
        })();
      `} />
    )}
  </body>
</html>
